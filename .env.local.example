# ============================================
# CONFIGURATION LOCALE - EXEMPLE
# ============================================
# Copiez ce fichier vers .env.local
# Puis remplacez les valeurs par les vraies clés API

###> symfony/mailer - SENDGRID ###
# Obtenir une clé sur: https://app.sendgrid.com/settings/api_keys
MAILER_DSN=sendgrid+api://YOUR_SENDGRID_API_KEY@default
###< symfony/mailer ###

###> openweathermap ###
# Obtenir une clé sur: https://home.openweathermap.org/api_keys
WEATHER_API_KEY=your_openweathermap_api_key_here
###< openweathermap ###

###> groq/api ###
# Obtenir une clé sur: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
###< groq/api ###

###> Hugging Face API ###
# Obtenir un token sur: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_token_here
HUGGINGFACE_MODEL=meta-llama/Llama-3.2-3B-Instruct
###< Hugging Face API ###
