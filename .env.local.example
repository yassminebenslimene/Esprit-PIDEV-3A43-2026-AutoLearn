# ============================================
# EXEMPLE DE CONFIGURATION LOCALE
# ============================================
# Copie ce fichier en .env.local et remplace par tes vraies clés
# .env.local n'est PAS commité sur Git (déjà dans .gitignore)

###> symfony/mailer - SENDGRID ###
# Ta vraie clé SendGrid
# Obtiens-la sur: https://app.sendgrid.com/ → Settings → API Keys
# Format: MAILER_DSN=sendgrid+api://SG.ta_cle_ici@default
MAILER_DSN=sendgrid+api://YOUR_REAL_SENDGRID_KEY@default
###< symfony/mailer ###

###> openweathermap ###
# Ta vraie clé OpenWeatherMap
# Obtiens-la sur: https://openweathermap.org/ → My API keys
WEATHER_API_KEY=YOUR_REAL_OPENWEATHERMAP_KEY
###< openweathermap ###
