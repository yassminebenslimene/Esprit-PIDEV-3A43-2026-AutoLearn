# ============================================
# EXEMPLE DE CONFIGURATION LOCALE
# ============================================
# ⚠️ IMPORTANT: Ce fichier est un TEMPLATE
# 
# ÉTAPES POUR CONFIGURER:
# 1. Copie ce fichier: copy .env.local.example .env.local
# 2. Obtiens tes propres clés API (voir guide ci-dessous)
# 3. Remplace les valeurs YOUR_REAL_xxx par tes vraies clés
# 4. Redémarre le serveur Symfony
#
# 📖 Guide complet: GUIDE_CONFIGURATION_API_EQUIPE.md
# ⚡ Guide rapide: SETUP_APIS.md
# ============================================

###> symfony/mailer - SENDGRID ###
# 📧 Clé API SendGrid pour envoi d'emails
# 
# Comment obtenir:
# 1. Crée compte gratuit: https://signup.sendgrid.com/
# 2. Va dans: Settings → API Keys → Create API Key
# 3. Copie la clé (commence par SG.)
# 4. Vérifie ton sender identity
#
# Format: sendgrid+api://SG.ta_cle_ici@default
# Exemple: sendgrid+api://SG.abc123xyz789.def456uvw012@default
#
MAILER_DSN=sendgrid+api://YOUR_REAL_SENDGRID_KEY@default
###< symfony/mailer ###

###> openweathermap ###
# 🌤️ Clé API OpenWeatherMap pour météo des événements
#
# Comment obtenir:
# 1. Crée compte gratuit: https://home.openweathermap.org/users/sign_up
# 2. Va dans: API keys (menu)
# 3. Copie la clé (32 caractères)
# 4. Attends 10-15 min pour activation
#
# Format: 32 caractères hexadécimaux
# Exemple: 5177b7da6160976397c624428cd12f3d
#
WEATHER_API_KEY=YOUR_REAL_OPENWEATHERMAP_KEY
###< openweathermap ###

# ============================================
# 🔐 SÉCURITÉ
# ============================================
# ❌ NE JAMAIS commiter .env.local sur Git
# ❌ NE JAMAIS partager tes clés API
# ✅ Chaque développeur a ses propres clés
# ✅ .env.local est dans .gitignore
# ============================================

###> huggingface ###
# Clé API Hugging Face pour l'analyse AI des feedbacks
# 1. Créer un compte sur https://huggingface.co/
# 2. Aller sur https://huggingface.co/settings/tokens
# 3. Créer un token avec permission "Read"
# 4. Copier le token ici (commence par hf_...)
HUGGINGFACE_API_KEY=hf_votre_cle_api_ici
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.2
###< huggingface ###
