
APP_ENV=dev
APP_SECRET=your_app_secret_here
DATABASE_URL="mysql://root:@127.0.0.1:3306/autolearn_db?serverVersion=10.4.32-MariaDB&charset=utf8mb4"

MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0

###> Brevo API ###
BREVO_API_KEY=your_brevo_api_key_here
MAIL_FROM_EMAIL=your_email@example.com
MAIL_FROM_NAME=AutoLearn
###< Brevo API ###

###> Brevo SMTP ###
MAILER_DSN=smtp://apikey:your_brevo_smtp_key_here@smtp-relay.brevo.com:587
###< Brevo SMTP ###

###> symfony/brevo-mailer ###
# MAILER_DSN=brevo+api://KEY@default
# MAILER_DSN=brevo+smtp://USERNAME:PASSWORD@default
###< symfony/brevo-mailer ###

###> OpenWeatherMap API ###
# Get your free API key at: https://openweathermap.org/api
WEATHER_API_KEY=your_openweathermap_api_key_here
###< OpenWeatherMap API ###

###> AI Assistant (Ollama - Legacy) ###
# Ollama is no longer used, replaced by Groq for better performance
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2:3b
###< AI Assistant ###

###> Groq API Configuration ###
# Get your free API key at: https://console.groq.com
# Groq provides ultra-fast AI responses (< 1 second)
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.3-70b-versatile
###< Groq API ###

###> Hugging Face API ###
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.2
###< Hugging Face API ###
