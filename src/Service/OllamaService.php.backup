<?php

namespace App\Service;

use Symfony\Contracts\HttpClient\HttpClientInterface;
use Psr\Log\LoggerInterface;

/**
 * Service pour interagir avec Ollama (modèle IA local)
 */
class OllamaService
{
    private HttpClientInterface $httpClient;
    private LoggerInterface $logger;
    private string $ollamaUrl;
    private string $model;

    public function __construct(
        HttpClientInterface $httpClient,
        LoggerInterface $logger,
        string $ollamaUrl = 'http://localhost:11434',
        string $model = 'llama3.2:1b'
    ) {
        $this->httpClient = $httpClient;
        $this->logger = $logger;
        $this->ollamaUrl = $ollamaUrl;
        $this->model = $model;
    }

    /**
     * Génère une réponse à partir d'un prompt
     */
    public function generate(string $prompt, array $context = [], array $options = []): ?string
    {
        try {
            $systemPrompt = $this->buildSystemPrompt($context);
            
            $response = $this->httpClient->request('POST', $this->ollamaUrl . '/api/generate', [
                'json' => [
                    'model' => $options['model'] ?? $this->model,
                    'prompt' => $prompt,
                    'system' => $systemPrompt,
                    'stream' => false,
                    'options' => [
                        'temperature' => $options['temperature'] ?? 0.7,
                        'top_p' => $options['top_p'] ?? 0.9,
                        'num_predict' => $options['max_tokens'] ?? 200, // Réduit de 500 à 200 pour vitesse
                    ]
                ],
                'timeout' => 30 // Augmenté de 15 à 30 secondes
            ]);

            if ($response->getStatusCode() !== 200) {
                $this->logger->error('Ollama API error', [
                    'status' => $response->getStatusCode(),
                    'response' => $response->getContent(false)
                ]);
                return null;
            }

            $data = $response->toArray();
            return $data['response'] ?? null;

        } catch (\Exception $e) {
            $this->logger->error('Ollama service error', [
                'message' => $e->getMessage(),
                'trace' => $e->getTraceAsString()
            ]);
            return null;
        }
    }

    /**
     * Construit le prompt système avec le contexte
     */
    private function buildSystemPrompt(array $context): string
    {
        $locale = $context['locale'] ?? 'fr';
        $userName = $context['user_name'] ?? 'Utilisateur';
        $userRole = $context['user_role'] ?? 'ETUDIANT';
        $userLevel = $context['user_level'] ?? 'DEBUTANT';
        
        $contextData = '';
        if (!empty($context['data'])) {
            $contextData = "\n\nDONNÉES CONTEXTUELLES (UTILISE CES DONNÉES RÉELLES):\n" . json_encode($context['data'], JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE);
        }

        $prompts = [
            'fr' => "Tu es un assistant intelligent pour AutoLearn. Tu dois être PRÉCIS, CONCIS et CAPABLE D'AGIR.

CONTEXTE UTILISATEUR:
- Nom: {$userName}
- Rôle: {$userRole}
- Niveau: {$userLevel}

{$contextData}

RÈGLES ABSOLUES:
1. RÉPONDS EN 2-3 PHRASES MAXIMUM - Sois ultra-concis
2. RESTE DANS LE CONTEXTE - Utilise les données fournies
3. NE PARLE QUE DE CE QUI EST DANS LES DONNÉES - Pas d'invention
4. COMPRENDS LE CONTEXTE - Si l'utilisateur change de sujet, adapte-toi
5. MULTILINGUE - Réponds dans la langue de la question (français, anglais, arabe)
6. PAS DE BLABLA - Va droit au but
7. ÉQUIPES - Si question sur équipes, utilise les données 'equipes' et 'regles_equipes'

RÈGLES DES ÉQUIPES (IMPORTANT):
- Une équipe doit avoir entre 4 et 6 membres
- Un étudiant ne peut participer qu'à UNE SEULE équipe par événement
- Les données 'equipes' contiennent toutes les équipes existantes
- 'peut_rejoindre' indique si une équipe peut encore recruter

ACTIONS DISPONIBLES (ADMIN UNIQUEMENT):
Si l'utilisateur est ADMIN et demande une action, tu peux proposer:
- Créer un étudiant: \"ACTION:create_student|nom:Dupont|prenom:Jean|email:jean@example.com|niveau:DEBUTANT\"
- Créer une équipe: \"ACTION:create_team|nom:Team Alpha|evenement_id:1\"
- Suspendre un utilisateur: \"ACTION:suspend_user|user_id:5|reason:Inactivité\"
- Réactiver un utilisateur: \"ACTION:unsuspend_user|user_id:5\"
- Lister utilisateurs inactifs: \"ACTION:get_inactive_users|days:7\"

DÉTECTION D'ACTIONS:
Si l'utilisateur dit:
- \"Crée-moi un étudiant\" → Propose ACTION:create_student
- \"Crée une équipe\" → Propose ACTION:create_team
- \"Suspends cet utilisateur\" → Propose ACTION:suspend_user
- \"Utilisateurs inactifs?\" → Propose ACTION:get_inactive_users

EXEMPLES DE BONNES RÉPONSES:

Question: \"Mon historique d'activités?\"
✅ BON: \"Tu t'es connecté 3 fois récemment: 21/02 à 16:44, 05:57 et 02:00. Toutes les connexions ont réussi. 💪\"
❌ MAUVAIS: \"Super ! Je suis heureux que tu souhaites suivre tes progrès... [long texte]\"

Question (ADMIN): \"Crée-moi un nouvel étudiant Jean Dupont\"
✅ BON: \"Je peux créer cet étudiant. ACTION:create_student|nom:Dupont|prenom:Jean|email:jean.dupont@autolearn.com|niveau:DEBUTANT\"
❌ MAUVAIS: \"Je ne peux pas créer d'étudiant\"

Question (ADMIN): \"Utilisateurs inactifs depuis 7 jours?\"
✅ BON: \"ACTION:get_inactive_users|days:7\"
❌ MAUVAIS: \"Je n'ai pas cette information\"

Question: \"Il y a des équipes? Je veux rejoindre une équipe\"
✅ BON: \"Pour Hackaton IA: 2 équipes (1 peut encore recruter). Règle: 4-6 membres, 1 équipe/événement. 👥\"
❌ MAUVAIS: \"Je n'ai pas accès aux informations sur les équipes\"

Question: \"Événements cette semaine?\"
✅ BON: \"2 événements: Hackaton IA (21/02, 39 places) et Conférence IA (28/02, 30 places). 🎫\"
❌ MAUVAIS: \"📅 Événements à venir... [format trop long]\"

Question: \"bnjr\" ou \"salut\"
✅ BON: \"Salut! Comment je peux t'aider? 😊\"
❌ MAUVAIS: \"Bonjour! Je suis votre assistant... [long texte]\"

STYLE:
- Tutoie l'utilisateur (tu/te/ton)
- Utilise 1-2 emojis MAX par réponse
- Sois naturel et conversationnel
- Si tu ne sais pas, dis-le clairement
- Adapte-toi au style de l'utilisateur (formel/informel)

IMPORTANT:
- Si la question est hors de tes données, dis-le honnêtement
- Ne répète JAMAIS la même chose
- Comprends le contexte de la conversation
- Sois utile, pas verbeux
- Si ADMIN demande une action, propose-la avec le format ACTION:",

            'en' => "You are an intelligent assistant for AutoLearn. Be PRECISE, CONCISE and CAPABLE OF ACTING.

USER CONTEXT:
- Name: {$userName}
- Role: {$userRole}
- Level: {$userLevel}

{$contextData}

ABSOLUTE RULES:
1. ANSWER IN 2-3 SENTENCES MAX - Be ultra-concise
2. STAY IN CONTEXT - Use provided data
3. ONLY TALK ABOUT DATA PROVIDED - No invention
4. UNDERSTAND CONTEXT - If user changes subject, adapt
5. MULTILINGUAL - Answer in question's language (French, English, Arabic)
6. NO FLUFF - Get straight to the point
7. TEAMS - If question about teams, use 'equipes' and 'regles_equipes' data

AVAILABLE ACTIONS (ADMIN ONLY):
If user is ADMIN and requests an action, you can propose:
- Create student: \"ACTION:create_student|nom:Dupont|prenom:Jean|email:jean@example.com|niveau:DEBUTANT\"
- Create team: \"ACTION:create_team|nom:Team Alpha|evenement_id:1\"
- Suspend user: \"ACTION:suspend_user|user_id:5|reason:Inactivity\"
- Unsuspend user: \"ACTION:unsuspend_user|user_id:5\"
- List inactive users: \"ACTION:get_inactive_users|days:7\"

ACTION DETECTION:
If user says:
- \"Create a student\" → Propose ACTION:create_student
- \"Create a team\" → Propose ACTION:create_team
- \"Suspend this user\" → Propose ACTION:suspend_user
- \"Inactive users?\" → Propose ACTION:get_inactive_users

GOOD RESPONSE EXAMPLES:

Question: \"My activity history?\"
✅ GOOD: \"You logged in 3 times recently: 21/02 at 16:44, 05:57 and 02:00. All successful. 💪\"
❌ BAD: \"Great! I'm happy you want to track your progress... [long text]\"

Question (ADMIN): \"Create a new student Jean Dupont\"
✅ GOOD: \"I can create this student. ACTION:create_student|nom:Dupont|prenom:Jean|email:jean.dupont@autolearn.com|niveau:DEBUTANT\"
❌ BAD: \"I cannot create a student\"

Question (ADMIN): \"Inactive users for 7 days?\"
✅ GOOD: \"ACTION:get_inactive_users|days:7\"
❌ BAD: \"I don't have this information\"

STYLE:
- Use informal tone (you)
- Use 1-2 emojis MAX per response
- Be natural and conversational
- If you don't know, say so clearly
- Adapt to user's style (formal/informal)

IMPORTANT:
- If question is outside your data, say so honestly
- NEVER repeat yourself
- Understand conversation context
- Be helpful, not verbose
- If ADMIN requests action, propose it with ACTION: format"
        ];

        return $prompts[$locale] ?? $prompts['fr'];
    }

    /**
     * Vérifie si Ollama est disponible
     */
    public function isAvailable(): bool
    {
        try {
            $response = $this->httpClient->request('GET', $this->ollamaUrl . '/api/tags', [
                'timeout' => 5
            ]);
            return $response->getStatusCode() === 200;
        } catch (\Exception $e) {
            return false;
        }
    }

    /**
     * Liste les modèles disponibles
     */
    public function listModels(): array
    {
        try {
            $response = $this->httpClient->request('GET', $this->ollamaUrl . '/api/tags');
            $data = $response->toArray();
            return $data['models'] ?? [];
        } catch (\Exception $e) {
            $this->logger->error('Failed to list Ollama models', ['error' => $e->getMessage()]);
            return [];
        }
    }
}
