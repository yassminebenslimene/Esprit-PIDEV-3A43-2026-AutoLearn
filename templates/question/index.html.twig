{% extends 'backoffice/base.html.twig' %}

{% block title %}Gestion des Questions{% endblock %}
{% block page_title %}Gestion des Questions{% endblock %}

{% block body %}
    <div class="glass-card table-card">
        <div class="card-header">
            <div>
                <h2 class="card-title">Liste des Questions</h2>
                <p class="card-subtitle">Gérez vos questions de quiz</p>
            </div>
            <div class="card-actions">
                <a href="{{ path('app_question_new') }}" class="card-btn" style="background: linear-gradient(135deg, var(--gold), var(--amber)); color: white; padding: 0.5rem 1rem; border-radius: 0.5rem; text-decoration: none;">
                    <svg style="width: 16px; height: 16px; display: inline-block; vertical-align: middle; margin-right: 0.25rem;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="12" y1="5" x2="12" y2="19"/>
                        <line x1="5" y1="12" x2="19" y2="12"/>
                    </svg>
                    Nouvelle Question
                </a>
            </div>
        </div>
        <div class="table-wrapper">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Question</th>
                        <th>Points</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for question in questions %}
                    <tr>
                        <td>{{ question.id }}</td>
                        <td><strong>{{ question.texteQuestion|length > 60 ? question.texteQuestion|slice(0, 60) ~ '...' : question.texteQuestion }}</strong></td>
                        <td>
                            <span class="status-badge completed">{{ question.point }} pts</span>
                        </td>
                        <td>
                            <a href="{{ path('app_question_show', {'id': question.id}) }}" class="card-btn" style="padding: 0.25rem 0.5rem; font-size: 0.875rem; margin-right: 0.25rem;">Voir</a>
                            <a href="{{ path('app_question_edit', {'id': question.id}) }}" class="card-btn" style="padding: 0.25rem 0.5rem; font-size: 0.875rem;">Modifier</a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" style="text-align: center; padding: 2rem; color: var(--text-secondary);">
                            Aucune question trouvée
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
