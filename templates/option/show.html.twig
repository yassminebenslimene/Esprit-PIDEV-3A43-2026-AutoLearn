{% extends 'backoffice/base.html.twig' %}

{% block title %}Détails de l'Option{% endblock %}
{% block page_title %}Détails de l'Option{% endblock %}

{% block body %}
    <div class="glass-card">
        <div class="card-header">
            <div>
                <h2 class="card-title">Option #{{ option.id }}</h2>
                <p class="card-subtitle">{{ option.estCorrecte ? 'Réponse correcte' : 'Réponse incorrecte' }}</p>
            </div>
            <div class="card-actions">
                <a href="{{ path('app_option_index') }}" class="card-btn">
                    <svg style="width: 16px; height: 16px; display: inline-block; vertical-align: middle; margin-right: 0.25rem;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="19" y1="12" x2="5" y2="12"/>
                        <polyline points="12 19 5 12 12 5"/>
                    </svg>
                    Retour
                </a>
                <a href="{{ path('app_option_edit', {'id': option.id}) }}" class="card-btn" style="background: linear-gradient(135deg, var(--coral), var(--gold)); color: white;">
                    <svg style="width: 16px; height: 16px; display: inline-block; vertical-align: middle; margin-right: 0.25rem;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                    </svg>
                    Modifier
                </a>
            </div>
        </div>
        <div style="padding: 1.5rem;">
            <div style="display: grid; gap: 1.5rem;">
                <div>
                    <label style="display: block; font-weight: 600; margin-bottom: 0.5rem; color: var(--text-primary);">Texte de l'option</label>
                    <p style="color: var(--text-secondary);">{{ option.texteOption }}</p>
                </div>
                <div>
                    <label style="display: block; font-weight: 600; margin-bottom: 0.5rem; color: var(--text-primary);">Correcte</label>
                    <span class="status-badge {{ option.estCorrecte ? 'completed' : 'pending' }}">
                        {{ option.estCorrecte ? '✓ Oui' : '✗ Non' }}
                    </span>
                </div>
            </div>
            <div style="margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid rgba(255, 255, 255, 0.1);">
                {{ include('option/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
{% endblock %}
