{% extends 'backoffice/base.html.twig' %}

{% block title %}Gestion des Options{% endblock %}
{% block page_title %}Gestion des Options{% endblock %}

{% block body %}
    <div class="glass-card table-card">
        <div class="card-header">
            <div>
                <h2 class="card-title">Liste des Options</h2>
                <p class="card-subtitle">Gérez les options de réponse</p>
            </div>
            <div class="card-actions">
                <a href="{{ path('app_option_new') }}" class="card-btn" style="background: linear-gradient(135deg, var(--coral), var(--gold)); color: white; padding: 0.5rem 1rem; border-radius: 0.5rem; text-decoration: none;">
                    <svg style="width: 16px; height: 16px; display: inline-block; vertical-align: middle; margin-right: 0.25rem;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="12" y1="5" x2="12" y2="19"/>
                        <line x1="5" y1="12" x2="19" y2="12"/>
                    </svg>
                    Nouvelle Option
                </a>
            </div>
        </div>
        <div class="table-wrapper">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Texte de l'option</th>
                        <th>Correcte</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for option in options %}
                    <tr>
                        <td>{{ option.id }}</td>
                        <td><strong>{{ option.texteOption|length > 60 ? option.texteOption|slice(0, 60) ~ '...' : option.texteOption }}</strong></td>
                        <td>
                            <span class="status-badge {{ option.estCorrecte ? 'completed' : 'pending' }}">
                                {{ option.estCorrecte ? '✓ Oui' : '✗ Non' }}
                            </span>
                        </td>
                        <td>
                            <a href="{{ path('app_option_show', {'id': option.id}) }}" class="card-btn" style="padding: 0.25rem 0.5rem; font-size: 0.875rem; margin-right: 0.25rem;">Voir</a>
                            <a href="{{ path('app_option_edit', {'id': option.id}) }}" class="card-btn" style="padding: 0.25rem 0.5rem; font-size: 0.875rem;">Modifier</a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" style="text-align: center; padding: 2rem; color: var(--text-secondary);">
                            Aucune option trouvée
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
