{# Widget Chat IA - À inclure dans base.html.twig #}
{% if app.user %}
<div id="ai-chat-widget" class="ai-chat-widget">
    <!-- Bulle de bienvenue animée -->
    <div id="ai-welcome-bubble" class="ai-welcome-bubble">
        <div class="ai-bubble-content">
            <div class="ai-bubble-avatar">🤖</div>
            <div class="ai-bubble-text">
                <strong>Bonjour {{ app.user.prenom }}!</strong>
                <p>Besoin d'aide? Je suis là pour vous! 💬</p>
            </div>
            <button class="ai-bubble-close" onclick="closeWelcomeBubble()">×</button>
        </div>
        <div class="ai-bubble-arrow"></div>
    </div>

    <!-- Bouton flottant -->
    <button id="ai-chat-toggle" class="ai-chat-toggle" title="Assistant IA">
        <div class="ai-toggle-icon">
            <svg class="ai-icon ai-icon-chat" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
            <svg class="ai-icon ai-icon-close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display: none;">
                <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
        </div>
        <span class="ai-pulse-ring"></span>
        <span class="ai-badge" id="ai-notification-badge" style="display: none;">1</span>
    </button>

    <!-- Fenêtre de chat -->
    <div id="ai-chat-window" class="ai-chat-window" style="display: none;">
        <!-- Header -->
        <div class="ai-chat-header">
            <div class="ai-chat-header-content">
                <div class="ai-avatar">🤖</div>
                <div class="ai-header-text">
                    <h3>Assistant AutoLearn</h3>
                    <p class="ai-status" id="ai-status">En ligne</p>
                </div>
            </div>
            <button id="ai-chat-close" class="ai-close-btn" title="Fermer">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
            </button>
        </div>

        <!-- Messages -->
        <div id="ai-chat-messages" class="ai-chat-messages">
            <!-- Message de bienvenue -->
            <div class="ai-message ai-message-bot">
                <div class="ai-message-avatar">🤖</div>
                <div class="ai-message-content">
                    {% if app.user.role == 'ADMIN' %}
                        {# Message pour Admin #}
                        <p>Bonjour {{ app.user.prenom }}! 👋</p>
                        <p>Je suis votre assistant administrateur. Je peux vous aider à:</p>
                        <ul>
                            <li>👥 Gérer les étudiants (créer, modifier, rechercher)</li>
                            <li>📊 Voir les statistiques de la plateforme</li>
                            <li>🔍 Filtrer et rechercher des utilisateurs</li>
                            <li>📚 Gérer le contenu (cours, exercices, événements)</li>
                            <li>📈 Analyser les données et générer des rapports</li>
                        </ul>
                        <p>Que souhaitez-vous faire?</p>
                    {% else %}
                        {# Message pour Étudiant #}
                        <p>Bonjour {{ app.user.prenom }}! 👋</p>
                        <p>Je suis votre assistant d'apprentissage. Je peux vous aider à:</p>
                        <ul>
                            <li>📚 Trouver des cours adaptés à votre niveau</li>
                            <li>💪 Découvrir des exercices et challenges</li>
                            <li>📅 Voir les événements et workshops à venir</li>
                            <li>👥 Rejoindre des communautés et équipes</li>
                            <li>📊 Suivre vos progrès et obtenir des feedbacks</li>
                        </ul>
                        <p>Posez-moi une question!</p>
                    {% endif %}
                </div>
            </div>

            <!-- Suggestions -->
            <div class="ai-suggestions" id="ai-suggestions">
                <p class="ai-suggestions-title">Suggestions:</p>
                <div class="ai-suggestions-buttons" id="ai-suggestions-buttons">
                    <!-- Chargées dynamiquement -->
                </div>
            </div>
        </div>

        <!-- Typing indicator -->
        <div id="ai-typing-indicator" class="ai-typing-indicator" style="display: none;">
            <div class="ai-message-avatar">🤖</div>
            <div class="ai-typing-dots">
                <span></span><span></span><span></span>
            </div>
        </div>

        <!-- Input -->
        <div class="ai-chat-input">
            <textarea 
                id="ai-chat-textarea" 
                class="ai-textarea" 
                placeholder="Posez votre question..."
                rows="1"
                maxlength="500"
            ></textarea>
            <button id="ai-chat-send" class="ai-send-btn" title="Envoyer">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
                </svg>
            </button>
        </div>

        <!-- Character counter -->
        <div class="ai-char-counter">
            <span id="ai-char-count">0</span>/500
        </div>
    </div>
</div>

<style>
/* Widget Chat IA - Design Moderne et Élégant */
.ai-chat-widget {
    position: fixed;
    bottom: 20px;
    right: 20px;
    z-index: 9999;
    font-family: 'Poppins', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
}

/* Bulle de bienvenue */
.ai-welcome-bubble {
    position: absolute;
    bottom: 90px;
    right: 0;
    width: 320px;
    background: white;
    border-radius: 16px;
    box-shadow: 0 8px 32px rgba(102, 126, 234, 0.25);
    padding: 20px;
    animation: bubbleSlideIn 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55);
    border: 2px solid rgba(102, 126, 234, 0.1);
}

@keyframes bubbleSlideIn {
    from {
        opacity: 0;
        transform: translateY(20px) scale(0.8);
    }
    to {
        opacity: 1;
        transform: translateY(0) scale(1);
    }
}

.ai-bubble-content {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    position: relative;
}

.ai-bubble-avatar {
    font-size: 32px;
    line-height: 1;
    animation: bounce 2s infinite;
}

@keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-5px); }
}

.ai-bubble-text {
    flex: 1;
}

.ai-bubble-text strong {
    display: block;
    color: #667eea;
    font-size: 16px;
    margin-bottom: 4px;
}

.ai-bubble-text p {
    margin: 0;
    color: #6b7280;
    font-size: 14px;
    line-height: 1.5;
}

.ai-bubble-close {
    position: absolute;
    top: -8px;
    right: -8px;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: #ef4444;
    color: white;
    border: none;
    cursor: pointer;
    font-size: 18px;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
}

.ai-bubble-close:hover {
    transform: scale(1.1);
    background: #dc2626;
}

.ai-bubble-arrow {
    position: absolute;
    bottom: -10px;
    right: 30px;
    width: 0;
    height: 0;
    border-left: 10px solid transparent;
    border-right: 10px solid transparent;
    border-top: 10px solid white;
}

.ai-bubble-arrow::before {
    content: '';
    position: absolute;
    bottom: 2px;
    left: -11px;
    width: 0;
    height: 0;
    border-left: 11px solid transparent;
    border-right: 11px solid transparent;
    border-top: 11px solid rgba(102, 126, 234, 0.1);
}

/* Bouton flottant amélioré */
.ai-chat-toggle {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border: none;
    box-shadow: 0 8px 24px rgba(102, 126, 234, 0.4);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
    position: relative;
    overflow: visible;
}

.ai-chat-toggle:hover {
    transform: scale(1.1) rotate(5deg);
    box-shadow: 0 12px 32px rgba(102, 126, 234, 0.6);
}

.ai-chat-toggle:active {
    transform: scale(0.95);
}

.ai-toggle-icon {
    position: relative;
    width: 32px;
    height: 32px;
}

.ai-icon {
    width: 32px;
    height: 32px;
    color: white;
    position: absolute;
    top: 0;
    left: 0;
    transition: all 0.3s;
}

.ai-icon-chat {
    opacity: 1;
    transform: rotate(0deg) scale(1);
}

.ai-icon-close {
    opacity: 0;
    transform: rotate(90deg) scale(0);
}

.ai-chat-toggle.active .ai-icon-chat {
    opacity: 0;
    transform: rotate(-90deg) scale(0);
}

.ai-chat-toggle.active .ai-icon-close {
    opacity: 1;
    transform: rotate(0deg) scale(1);
    display: block !important;
}

/* Animation de pulsation */
.ai-pulse-ring {
    position: absolute;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    border: 3px solid #667eea;
    animation: pulse 2s cubic-bezier(0.455, 0.03, 0.515, 0.955) infinite;
    opacity: 0;
}

@keyframes pulse {
    0% {
        transform: scale(1);
        opacity: 1;
    }
    100% {
        transform: scale(1.5);
        opacity: 0;
    }
}

.ai-badge {
    position: absolute;
    top: -5px;
    right: -5px;
    background: linear-gradient(135deg, #ef4444, #dc2626);
    color: white;
    border-radius: 50%;
    width: 26px;
    height: 26px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: bold;
    box-shadow: 0 4px 12px rgba(239, 68, 68, 0.4);
    animation: badgePop 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
}

@keyframes badgePop {
    0% { transform: scale(0); }
    50% { transform: scale(1.2); }
    100% { transform: scale(1); }
}

/* Fenêtre de chat améliorée */
.ai-chat-window {
    position: absolute;
    bottom: 90px;
    right: 0;
    width: 420px;
    max-width: calc(100vw - 40px);
    height: 650px;
    max-height: calc(100vh - 120px);
    background: white;
    border-radius: 20px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    animation: chatSlideUp 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
    border: 1px solid rgba(102, 126, 234, 0.1);
}

@keyframes chatSlideUp {
    from {
        opacity: 0;
        transform: translateY(30px) scale(0.9);
    }
    to {
        opacity: 1;
        transform: translateY(0) scale(1);
    }
}

/* Header */
.ai-chat-header {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 16px;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.ai-chat-header-content {
    display: flex;
    align-items: center;
    gap: 12px;
}

.ai-avatar {
    font-size: 32px;
    line-height: 1;
}

.ai-header-text h3 {
    margin: 0;
    font-size: 16px;
    font-weight: 600;
}

.ai-status {
    margin: 0;
    font-size: 12px;
    opacity: 0.9;
}

.ai-close-btn {
    background: none;
    border: none;
    color: white;
    cursor: pointer;
    padding: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.2s;
}

.ai-close-btn:hover {
    opacity: 0.8;
}

.ai-close-btn svg {
    width: 20px;
    height: 20px;
}

/* Messages */
.ai-chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
    background: #f8f9fa;
}

.ai-message {
    display: flex;
    gap: 12px;
    margin-bottom: 16px;
    animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
}

.ai-message-avatar {
    font-size: 24px;
    line-height: 1;
    flex-shrink: 0;
}

.ai-message-content {
    background: white;
    padding: 12px 16px;
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    max-width: 80%;
    color: #2d3748; /* Texte gris foncé pour bonne lisibilité */
}

.ai-message-user {
    flex-direction: row-reverse;
}

.ai-message-user .ai-message-content {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
}

.ai-message-content p {
    margin: 0 0 8px 0;
    color: inherit; /* Hérite de la couleur du parent */
}

.ai-message-content p:last-child {
    margin-bottom: 0;
}

.ai-message-content ul {
    margin: 8px 0 0 0;
    padding-left: 20px;
    color: inherit; /* Hérite de la couleur du parent */
}

.ai-message-content li {
    margin: 4px 0;
    color: inherit; /* Hérite de la couleur du parent */
}

.ai-link {
    color: #667eea;
    text-decoration: underline;
    font-weight: 500;
}

.ai-message-user .ai-link {
    color: white;
}

/* Suggestions */
.ai-suggestions {
    margin-top: 16px;
}

.ai-suggestions-title {
    font-size: 12px;
    color: #6b7280;
    margin-bottom: 8px;
    font-weight: 500;
}

.ai-suggestions-buttons {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.ai-suggestion-btn {
    background: white;
    border: 1px solid #e5e7eb;
    padding: 10px 14px;
    border-radius: 8px;
    text-align: left;
    cursor: pointer;
    transition: all 0.2s;
    font-size: 13px;
    color: #374151;
}

.ai-suggestion-btn:hover {
    background: #f3f4f6;
    border-color: #667eea;
    color: #667eea;
}

/* Typing indicator */
.ai-typing-indicator {
    display: flex;
    gap: 12px;
    padding: 0 16px 16px 16px;
    background: #f8f9fa;
}

.ai-typing-dots {
    background: white;
    padding: 12px 16px;
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    display: flex;
    gap: 4px;
}

.ai-typing-dots span {
    width: 8px;
    height: 8px;
    background: #667eea;
    border-radius: 50%;
    animation: typing 1.4s infinite;
}

.ai-typing-dots span:nth-child(2) {
    animation-delay: 0.2s;
}

.ai-typing-dots span:nth-child(3) {
    animation-delay: 0.4s;
}

@keyframes typing {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.7; }
    30% { transform: translateY(-10px); opacity: 1; }
}

/* Input */
.ai-chat-input {
    display: flex;
    gap: 8px;
    padding: 16px;
    background: white;
    border-top: 1px solid #e5e7eb;
}

.ai-textarea {
    flex: 1;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 10px 12px;
    font-family: inherit;
    font-size: 14px;
    resize: none;
    max-height: 100px;
    transition: border-color 0.2s;
}

.ai-textarea:focus {
    outline: none;
    border-color: #667eea;
}

.ai-send-btn {
    width: 40px;
    height: 40px;
    border-radius: 8px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border: none;
    color: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.2s;
    flex-shrink: 0;
}

.ai-send-btn:hover {
    opacity: 0.9;
}

.ai-send-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

.ai-send-btn svg {
    width: 20px;
    height: 20px;
}

.ai-char-counter {
    padding: 0 16px 12px 16px;
    text-align: right;
    font-size: 11px;
    color: #9ca3af;
    background: white;
}

/* Responsive */
@media (max-width: 768px) {
    .ai-chat-window {
        width: calc(100vw - 40px);
        height: calc(100vh - 120px);
    }
}
</style>

<script>
// AI Chat Widget JavaScript - Version Améliorée
(function() {
    const widget = document.getElementById('ai-chat-widget');
    const toggle = document.getElementById('ai-chat-toggle');
    const chatWindow = document.getElementById('ai-chat-window');
    const closeBtn = document.getElementById('ai-chat-close');
    const messages = document.getElementById('ai-chat-messages');
    const textarea = document.getElementById('ai-chat-textarea');
    const sendBtn = document.getElementById('ai-chat-send');
    const typingIndicator = document.getElementById('ai-typing-indicator');
    const charCount = document.getElementById('ai-char-count');
    const suggestionsContainer = document.getElementById('ai-suggestions-buttons');
    const welcomeBubble = document.getElementById('ai-welcome-bubble');

    let isOpen = false;

    // Afficher la bulle de bienvenue après 2 secondes
    setTimeout(() => {
        if (welcomeBubble && !isOpen) {
            welcomeBubble.style.display = 'block';
            // Auto-fermer après 10 secondes
            setTimeout(() => {
                if (welcomeBubble && !isOpen) {
                    welcomeBubble.style.animation = 'bubbleSlideOut 0.3s ease';
                    setTimeout(() => {
                        if (welcomeBubble) welcomeBubble.style.display = 'none';
                    }, 300);
                }
            }, 10000);
        }
    }, 2000);

    // Fermer la bulle de bienvenue
    window.closeWelcomeBubble = function() {
        if (welcomeBubble) {
            welcomeBubble.style.animation = 'bubbleSlideOut 0.3s ease';
            setTimeout(() => {
                welcomeBubble.style.display = 'none';
            }, 300);
        }
    };

    // Toggle chat window
    toggle.addEventListener('click', () => {
        isOpen = !isOpen;
        chatWindow.style.display = isOpen ? 'flex' : 'none';
        toggle.classList.toggle('active', isOpen);
        
        if (isOpen) {
            textarea.focus();
            loadSuggestions();
            // Cacher la bulle de bienvenue
            if (welcomeBubble) {
                welcomeBubble.style.display = 'none';
            }
        }
    });

    closeBtn.addEventListener('click', () => {
        isOpen = false;
        chatWindow.style.display = 'none';
        toggle.classList.remove('active');
    });

    // Auto-resize textarea
    textarea.addEventListener('input', () => {
        textarea.style.height = 'auto';
        textarea.style.height = Math.min(textarea.scrollHeight, 100) + 'px';
        charCount.textContent = textarea.value.length;
    });

    // Send message on Enter (Shift+Enter for new line)
    textarea.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            sendMessage();
        }
    });

    sendBtn.addEventListener('click', sendMessage);

    // Load suggestions
    function loadSuggestions() {
        fetch('/ai-assistant/suggestions', {
            headers: {
                'Accept': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(res => {
            if (!res.ok) throw new Error('Network response was not ok');
            return res.json();
        })
        .then(data => {
            if (data.success && suggestionsContainer) {
                suggestionsContainer.innerHTML = '';
                data.suggestions.forEach(suggestion => {
                    const btn = document.createElement('button');
                    btn.className = 'ai-suggestion-btn';
                    btn.textContent = suggestion;
                    btn.onclick = () => {
                        textarea.value = suggestion;
                        sendMessage();
                    };
                    suggestionsContainer.appendChild(btn);
                });
            }
        })
        .catch(err => {
            console.error('Error loading suggestions:', err);
        });
    }

    // Send message
    function sendMessage() {
        const question = textarea.value.trim();
        if (!question) return;

        // Disable input
        textarea.disabled = true;
        sendBtn.disabled = true;

        // Add user message
        addMessage(question, 'user');
        textarea.value = '';
        textarea.style.height = 'auto';
        charCount.textContent = '0';

        // Show typing indicator
        typingIndicator.style.display = 'flex';
        messages.scrollTop = messages.scrollHeight;

        // Send to API
        fetch('/ai-assistant/ask', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Accept': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify({ question })
        })
        .then(res => {
            // Vérifier si la réponse est du JSON
            const contentType = res.headers.get('content-type');
            if (!contentType || !contentType.includes('application/json')) {
                throw new Error('La réponse n\'est pas du JSON. Vérifiez que vous êtes connecté.');
            }
            if (!res.ok) {
                throw new Error(`HTTP error! status: ${res.status}`);
            }
            return res.json();
        })
        .then(data => {
            typingIndicator.style.display = 'none';
            textarea.disabled = false;
            sendBtn.disabled = false;
            textarea.focus();
            
            if (data.success) {
                addMessage(data.response, 'bot');
            } else {
                addMessage('Désolé, une erreur est survenue: ' + (data.error || 'Erreur inconnue'), 'bot');
            }
        })
        .catch(err => {
            console.error('Error:', err);
            typingIndicator.style.display = 'none';
            textarea.disabled = false;
            sendBtn.disabled = false;
            textarea.focus();
            
            let errorMsg = 'Erreur de connexion. ';
            if (err.message.includes('JSON')) {
                errorMsg += 'Veuillez vous reconnecter à la plateforme.';
            } else {
                errorMsg += 'Vérifiez votre connexion internet.';
            }
            addMessage(errorMsg, 'bot');
        });
    }

    // Add message to chat
    function addMessage(text, type) {
        const messageDiv = document.createElement('div');
        messageDiv.className = `ai-message ai-message-${type}`;
        
        const avatar = document.createElement('div');
        avatar.className = 'ai-message-avatar';
        avatar.textContent = type === 'bot' ? '🤖' : '👤';
        
        const content = document.createElement('div');
        content.className = 'ai-message-content';
        content.innerHTML = text.replace(/\n/g, '<br>');
        
        messageDiv.appendChild(avatar);
        messageDiv.appendChild(content);
        
        messages.appendChild(messageDiv);
        messages.scrollTop = messages.scrollHeight;
        
        // Animation d'apparition
        messageDiv.style.opacity = '0';
        messageDiv.style.transform = 'translateY(10px)';
        setTimeout(() => {
            messageDiv.style.transition = 'all 0.3s ease';
            messageDiv.style.opacity = '1';
            messageDiv.style.transform = 'translateY(0)';
        }, 10);
    }

    // Animation CSS pour la bulle
    const style = document.createElement('style');
    style.textContent = `
        @keyframes bubbleSlideOut {
            from {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
            to {
                opacity: 0;
                transform: translateY(20px) scale(0.8);
            }
        }
    `;
    document.head.appendChild(style);
})();
</script>
{% endif %}
