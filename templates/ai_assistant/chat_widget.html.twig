{# Widget Chat IA - À inclure dans base.html.twig #}
{% if app.user %}
<div id="ai-chat-widget" class="ai-chat-widget">
    <!-- Bouton flottant -->
    <button id="ai-chat-toggle" class="ai-chat-toggle" title="Assistant IA">
        <svg class="ai-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
        </svg>
        <span class="ai-badge" id="ai-notification-badge" style="display: none;">1</span>
    </button>

    <!-- Fenêtre de chat -->
    <div id="ai-chat-window" class="ai-chat-window" style="display: none;">
        <!-- Header -->
        <div class="ai-chat-header">
            <div class="ai-chat-header-content">
                <div class="ai-avatar">🤖</div>
                <div class="ai-header-text">
                    <h3>Assistant AutoLearn</h3>
                    <p class="ai-status" id="ai-status">En ligne</p>
                </div>
            </div>
            <button id="ai-chat-close" class="ai-close-btn" title="Fermer">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
            </button>
        </div>

        <!-- Messages -->
        <div id="ai-chat-messages" class="ai-chat-messages">
            <!-- Message de bienvenue -->
            <div class="ai-message ai-message-bot">
                <div class="ai-message-avatar">🤖</div>
                <div class="ai-message-content">
                    <p>Bonjour {{ app.user.prenom }}! 👋</p>
                    <p>Je suis votre assistant intelligent. Je peux vous aider à:</p>
                    <ul>
                        <li>🎓 Trouver des cours adaptés</li>
                        <li>📅 Découvrir les événements</li>
                        <li>📊 Suivre vos progrès</li>
                        <li>💡 Naviguer sur la plateforme</li>
                    </ul>
                    <p>Posez-moi une question!</p>
                </div>
            </div>

            <!-- Suggestions -->
            <div class="ai-suggestions" id="ai-suggestions">
                <p class="ai-suggestions-title">Suggestions:</p>
                <div class="ai-suggestions-buttons" id="ai-suggestions-buttons">
                    <!-- Chargées dynamiquement -->
                </div>
            </div>
        </div>

        <!-- Typing indicator -->
        <div id="ai-typing-indicator" class="ai-typing-indicator" style="display: none;">
            <div class="ai-message-avatar">🤖</div>
            <div class="ai-typing-dots">
                <span></span><span></span><span></span>
            </div>
        </div>

        <!-- Input -->
        <div class="ai-chat-input">
            <textarea 
                id="ai-chat-textarea" 
                class="ai-textarea" 
                placeholder="Posez votre question..."
                rows="1"
                maxlength="500"
            ></textarea>
            <button id="ai-chat-send" class="ai-send-btn" title="Envoyer">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
                </svg>
            </button>
        </div>

        <!-- Character counter -->
        <div class="ai-char-counter">
            <span id="ai-char-count">0</span>/500
        </div>
    </div>
</div>

<style>
/* Widget Chat IA */
.ai-chat-widget {
    position: fixed;
    bottom: 20px;
    right: 20px;
    z-index: 9999;
    font-family: 'Poppins', sans-serif;
}

/* Bouton flottant */
.ai-chat-toggle {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border: none;
    box-shadow: 0 4px 20px rgba(102, 126, 234, 0.4);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    position: relative;
}

.ai-chat-toggle:hover {
    transform: scale(1.1);
    box-shadow: 0 6px 30px rgba(102, 126, 234, 0.6);
}

.ai-chat-toggle .ai-icon {
    width: 28px;
    height: 28px;
    color: white;
}

.ai-badge {
    position: absolute;
    top: -5px;
    right: -5px;
    background: #ef4444;
    color: white;
    border-radius: 50%;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: bold;
}

/* Fenêtre de chat */
.ai-chat-window {
    position: absolute;
    bottom: 80px;
    right: 0;
    width: 400px;
    max-width: calc(100vw - 40px);
    height: 600px;
    max-height: calc(100vh - 120px);
    background: white;
    border-radius: 16px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    animation: slideUp 0.3s ease;
}

@keyframes slideUp {
    from {
        opacity: 0;
        transform: translateY(20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

/* Header */
.ai-chat-header {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 16px;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.ai-chat-header-content {
    display: flex;
    align-items: center;
    gap: 12px;
}

.ai-avatar {
    font-size: 32px;
    line-height: 1;
}

.ai-header-text h3 {
    margin: 0;
    font-size: 16px;
    font-weight: 600;
}

.ai-status {
    margin: 0;
    font-size: 12px;
    opacity: 0.9;
}

.ai-close-btn {
    background: none;
    border: none;
    color: white;
    cursor: pointer;
    padding: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.2s;
}

.ai-close-btn:hover {
    opacity: 0.8;
}

.ai-close-btn svg {
    width: 20px;
    height: 20px;
}

/* Messages */
.ai-chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
    background: #f8f9fa;
}

.ai-message {
    display: flex;
    gap: 12px;
    margin-bottom: 16px;
    animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
}

.ai-message-avatar {
    font-size: 24px;
    line-height: 1;
    flex-shrink: 0;
}

.ai-message-content {
    background: white;
    padding: 12px 16px;
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    max-width: 80%;
}

.ai-message-user {
    flex-direction: row-reverse;
}

.ai-message-user .ai-message-content {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
}

.ai-message-content p {
    margin: 0 0 8px 0;
}

.ai-message-content p:last-child {
    margin-bottom: 0;
}

.ai-message-content ul {
    margin: 8px 0 0 0;
    padding-left: 20px;
}

.ai-message-content li {
    margin: 4px 0;
}

.ai-link {
    color: #667eea;
    text-decoration: underline;
    font-weight: 500;
}

.ai-message-user .ai-link {
    color: white;
}

/* Suggestions */
.ai-suggestions {
    margin-top: 16px;
}

.ai-suggestions-title {
    font-size: 12px;
    color: #6b7280;
    margin-bottom: 8px;
    font-weight: 500;
}

.ai-suggestions-buttons {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.ai-suggestion-btn {
    background: white;
    border: 1px solid #e5e7eb;
    padding: 10px 14px;
    border-radius: 8px;
    text-align: left;
    cursor: pointer;
    transition: all 0.2s;
    font-size: 13px;
    color: #374151;
}

.ai-suggestion-btn:hover {
    background: #f3f4f6;
    border-color: #667eea;
    color: #667eea;
}

/* Typing indicator */
.ai-typing-indicator {
    display: flex;
    gap: 12px;
    padding: 0 16px 16px 16px;
    background: #f8f9fa;
}

.ai-typing-dots {
    background: white;
    padding: 12px 16px;
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    display: flex;
    gap: 4px;
}

.ai-typing-dots span {
    width: 8px;
    height: 8px;
    background: #667eea;
    border-radius: 50%;
    animation: typing 1.4s infinite;
}

.ai-typing-dots span:nth-child(2) {
    animation-delay: 0.2s;
}

.ai-typing-dots span:nth-child(3) {
    animation-delay: 0.4s;
}

@keyframes typing {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.7; }
    30% { transform: translateY(-10px); opacity: 1; }
}

/* Input */
.ai-chat-input {
    display: flex;
    gap: 8px;
    padding: 16px;
    background: white;
    border-top: 1px solid #e5e7eb;
}

.ai-textarea {
    flex: 1;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 10px 12px;
    font-family: inherit;
    font-size: 14px;
    resize: none;
    max-height: 100px;
    transition: border-color 0.2s;
}

.ai-textarea:focus {
    outline: none;
    border-color: #667eea;
}

.ai-send-btn {
    width: 40px;
    height: 40px;
    border-radius: 8px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border: none;
    color: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.2s;
    flex-shrink: 0;
}

.ai-send-btn:hover {
    opacity: 0.9;
}

.ai-send-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

.ai-send-btn svg {
    width: 20px;
    height: 20px;
}

.ai-char-counter {
    padding: 0 16px 12px 16px;
    text-align: right;
    font-size: 11px;
    color: #9ca3af;
    background: white;
}

/* Responsive */
@media (max-width: 768px) {
    .ai-chat-window {
        width: calc(100vw - 40px);
        height: calc(100vh - 120px);
    }
}
</style>

<script>
// AI Chat Widget JavaScript
(function() {
    const widget = document.getElementById('ai-chat-widget');
    const toggle = document.getElementById('ai-chat-toggle');
    const window = document.getElementById('ai-chat-window');
    const close = document.getElementById('ai-chat-close');
    const messages = document.getElementById('ai-chat-messages');
    const textarea = document.getElementById('ai-chat-textarea');
    const sendBtn = document.getElementById('ai-chat-send');
    const typingIndicator = document.getElementById('ai-typing-indicator');
    const charCount = document.getElementById('ai-char-count');
    const suggestionsContainer = document.getElementById('ai-suggestions-buttons');

    let isOpen = false;

    // Toggle chat window
    toggle.addEventListener('click', () => {
        isOpen = !isOpen;
        window.style.display = isOpen ? 'flex' : 'none';
        if (isOpen) {
            textarea.focus();
            loadSuggestions();
        }
    });

    close.addEventListener('click', () => {
        isOpen = false;
        window.style.display = 'none';
    });

    // Auto-resize textarea
    textarea.addEventListener('input', () => {
        textarea.style.height = 'auto';
        textarea.style.height = textarea.scrollHeight + 'px';
        charCount.textContent = textarea.value.length;
    });

    // Send message on Enter (Shift+Enter for new line)
    textarea.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            sendMessage();
        }
    });

    sendBtn.addEventListener('click', sendMessage);

    // Load suggestions
    function loadSuggestions() {
        fetch('/ai-assistant/suggestions')
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    suggestionsContainer.innerHTML = '';
                    data.suggestions.forEach(suggestion => {
                        const btn = document.createElement('button');
                        btn.className = 'ai-suggestion-btn';
                        btn.textContent = suggestion;
                        btn.onclick = () => {
                            textarea.value = suggestion;
                            sendMessage();
                        };
                        suggestionsContainer.appendChild(btn);
                    });
                }
            });
    }

    // Send message
    function sendMessage() {
        const question = textarea.value.trim();
        if (!question) return;

        // Add user message
        addMessage(question, 'user');
        textarea.value = '';
        textarea.style.height = 'auto';
        charCount.textContent = '0';

        // Show typing indicator
        typingIndicator.style.display = 'flex';
        messages.scrollTop = messages.scrollHeight;

        // Send to API
        fetch('/ai-assistant/ask', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({ question })
        })
        .then(res => res.json())
        .then(data => {
            typingIndicator.style.display = 'none';
            if (data.success) {
                addMessage(data.response, 'bot');
            } else {
                addMessage('Désolé, une erreur est survenue. Veuillez réessayer.', 'bot');
            }
        })
        .catch(err => {
            typingIndicator.style.display = 'none';
            addMessage('Erreur de connexion. Vérifiez votre connexion internet.', 'bot');
        });
    }

    // Add message to chat
    function addMessage(text, type) {
        const messageDiv = document.createElement('div');
        messageDiv.className = `ai-message ai-message-${type}`;
        
        const avatar = document.createElement('div');
        avatar.className = 'ai-message-avatar';
        avatar.textContent = type === 'bot' ? '🤖' : '👤';
        
        const content = document.createElement('div');
        content.className = 'ai-message-content';
        content.innerHTML = text.replace(/\n/g, '<br>');
        
        messageDiv.appendChild(avatar);
        messageDiv.appendChild(content);
        
        messages.appendChild(messageDiv);
        messages.scrollTop = messages.scrollHeight;
    }
})();
</script>
{% endif %}
