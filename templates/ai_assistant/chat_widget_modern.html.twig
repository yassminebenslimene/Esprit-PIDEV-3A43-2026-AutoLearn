{# Widget Chat IA Moderne #}
<div id="ai-chat-widget" class="ai-chat-widget">
    {# Bouton flottant #}
    <button id="ai-chat-toggle" class="ai-chat-toggle" aria-label="Ouvrir l'assistant IA">
        <svg class="ai-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
        </svg>
        <svg class="ai-close-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
    </button>

    {# Fenêtre de chat #}
    <div id="ai-chat-window" class="ai-chat-window">
        {# Header #}
        <div class="ai-chat-header">
            <div class="ai-chat-header-content">
                <div class="ai-avatar">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                    </svg>
                </div>
                <div>
                    <h3 class="ai-chat-title">Assistant IA</h3>
                    <p class="ai-chat-subtitle">
                        <span class="ai-status-dot"></span>
                        En ligne
                    </p>
                </div>
            </div>
            <button id="ai-chat-close" class="ai-chat-close-btn" aria-label="Fermer">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>

        {# Messages #}
        <div id="ai-chat-messages" class="ai-chat-messages">
            {# Message de bienvenue #}
            <div class="ai-message ai-message-bot">
                <div class="ai-message-avatar">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                    </svg>
                </div>
                <div class="ai-message-content">
                    <div class="ai-message-bubble">
                        👋 <strong>Bonjour!</strong><br><br>
                        Je suis votre assistant IA. Je parle <strong>français</strong> et <strong>anglais</strong>.<br><br>
                        Comment puis-je vous aider aujourd'hui?
                    </div>
                    <div class="ai-message-time">{{ "now"|date("H:i") }}</div>
                </div>
            </div>

            {# Suggestions #}
            <div class="ai-suggestions">
                <button class="ai-suggestion-btn" data-question="Quels cours me recommandes-tu?">
                    🎓 Recommande-moi des cours
                </button>
                <button class="ai-suggestion-btn" data-question="Quels sont les prochains événements?">
                    📅 Événements à venir
                </button>
                <button class="ai-suggestion-btn" data-question="Show me exercises">
                    💪 Exercices disponibles
                </button>
            </div>
        </div>

        {# Input #}
        <div class="ai-chat-input-container">
            <div class="ai-chat-input-wrapper">
                <textarea 
                    