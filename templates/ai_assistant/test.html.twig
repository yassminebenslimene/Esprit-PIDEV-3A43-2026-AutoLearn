<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Test Assistant IA - AutoLearn</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        .header {
            background: white;
            padding: 30px;
            border-radius: 16px;
            margin-bottom: 20px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
        }

        .header h1 {
            color: #667eea;
            margin-bottom: 10px;
        }

        .status-card {
            background: white;
            padding: 20px;
            border-radius: 12px;
            margin-bottom: 20px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        }

        .status-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            margin-top: 15px;
        }

        .status-item {
            padding: 15px;
            background: #f8f9fa;
            border-radius: 8px;
            border-left: 4px solid #667eea;
        }

        .status-item h3 {
            font-size: 14px;
            color: #6b7280;
            margin-bottom: 8px;
        }

        .status-item p {
            font-size: 20px;
            font-weight: bold;
            color: #1f2937;
        }

        .status-badge {
            display: inline-block;
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: bold;
            text-transform: uppercase;
        }

        .status-operational {
            background: #10b981;
            color: white;
        }

        .status-degraded {
            background: #f59e0b;
            color: white;
        }

        .test-section {
            background: white;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        }

        .test-section h2 {
            color: #1f2937;
            margin-bottom: 20px;
        }

        .test-form {
            margin-bottom: 30px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 500;
            color: #374151;
        }

        .form-group textarea {
            width: 100%;
            padding: 12px;
            border: 2px solid #e5e7eb;
            border-radius: 8px;
            font-family: inherit;
            font-size: 14px;
            resize: vertical;
            min-height: 100px;
        }

        .form-group textarea:focus {
            outline: none;
            border-color: #667eea;
        }

        .form-group select {
            width: 100%;
            padding: 12px;
            border: 2px solid #e5e7eb;
            border-radius: 8px;
            font-family: inherit;
            font-size: 14px;
        }

        .btn {
            padding: 12px 24px;
            border: none;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
        }

        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }

        .btn-primary:hover {
            opacity: 0.9;
            transform: translateY(-2px);
        }

        .btn-primary:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
        }

        .response-box {
            background: #f8f9fa;
            padding: 20px;
            border-radius: 8px;
            border-left: 4px solid #667eea;
            margin-top: 20px;
            display: none;
        }

        .response-box.show {
            display: block;
            animation: fadeIn 0.3s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .response-meta {
            display: flex;
            gap: 15px;
            margin-bottom: 15px;
            font-size: 12px;
            color: #6b7280;
        }

        .response-content {
            color: #1f2937;
            line-height: 1.6;
        }

        .loading {
            display: none;
            text-align: center;
            padding: 20px;
        }

        .loading.show {
            display: block;
        }

        .spinner {
            border: 3px solid #f3f4f6;
            border-top: 3px solid #667eea;
            border-radius: 50%;
            width: 40px;
            height: 40px;
            animation: spin 1s linear infinite;
            margin: 0 auto 10px;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .examples {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 10px;
            margin-top: 20px;
        }

        .example-btn {
            padding: 12px;
            background: #f3f4f6;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            text-align: left;
            cursor: pointer;
            transition: all 0.2s;
            font-size: 13px;
        }

        .example-btn:hover {
            background: #e5e7eb;
            border-color: #667eea;
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Header -->
        <div class="header">
            <h1>🤖 Test Assistant IA</h1>
            <p>Interface de test pour l'assistant intelligent AutoLearn</p>
        </div>

        <!-- Status -->
        <div class="status-card">
            <h2>📊 Statut du Service</h2>
            <div class="status-grid">
                <div class="status-item">
                    <h3>Ollama</h3>
                    <p>
                        <span class="status-badge status-{{ status.ollama_available ? 'operational' : 'degraded' }}">
                            {{ status.ollama_available ? 'Opérationnel' : 'Indisponible' }}
                        </span>
                    </p>
                </div>
                <div class="status-item">
                    <h3>Modèles Disponibles</h3>
                    <p>{{ status.models_count }}</p>
                </div>
                <div class="status-item">
                    <h3>RAG</h3>
                    <p>
                        <span class="status-badge status-operational">
                            {{ status.rag_enabled ? 'Activé' : 'Désactivé' }}
                        </span>
                    </p>
                </div>
                <div class="status-item">
                    <h3>Statut Global</h3>
                    <p>
                        <span class="status-badge status-{{ status.status == 'operational' ? 'operational' : 'degraded' }}">
                            {{ status.status|upper }}
                        </span>
                    </p>
                </div>
            </div>
            
            {% if status.models|length > 0 %}
            <div style="margin-top: 20px;">
                <h3 style="margin-bottom: 10px;">Modèles installés:</h3>
                <ul style="list-style: none; padding: 0;">
                    {% for model in status.models %}
                    <li style="padding: 8px; background: #f8f9fa; margin-bottom: 5px; border-radius: 6px;">
                        🤖 {{ model }}
                    </li>
                    {% endfor %}
                </ul>
            </div>
            {% endif %}
        </div>

        <!-- Test Form -->
        <div class="test-section">
            <h2>💬 Tester l'Assistant</h2>
            
            <div class="test-form">
                <div class="form-group">
                    <label for="question">Question:</label>
                    <textarea id="question" placeholder="Posez votre question..."></textarea>
                </div>

                <div class="form-group">
                    <label for="model">Modèle:</label>
                    <select id="model">
                        <option value="">Par défaut (llama3.2:3b)</option>
                        {% for model in status.models %}
                        <option value="{{ model }}">{{ model }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="form-group">
                    <label for="temperature">Température (0.0 - 1.0):</label>
                    <input type="range" id="temperature" min="0" max="1" step="0.1" value="0.7" style="width: 100%;">
                    <span id="temperature-value">0.7</span>
                </div>

                <button class="btn btn-primary" id="submit-btn" onclick="askQuestion()">
                    Envoyer la Question
                </button>
            </div>

            <!-- Examples -->
            <h3>Exemples de questions:</h3>
            <div class="examples">
                <button class="example-btn" onclick="setQuestion('Quels cours pour débuter en Python?')">
                    🎓 Cours Python débutant
                </button>
                <button class="example-btn" onclick="setQuestion('Événements cette semaine?')">
                    📅 Événements à venir
                </button>
                <button class="example-btn" onclick="setQuestion('Mon historique d\'activités?')">
                    📊 Mon historique
                </button>
                <button class="example-btn" onclick="setQuestion('Recommande-moi un cours')">
                    💡 Recommandation
                </button>
                <button class="example-btn" onclick="setQuestion('Combien d\'utilisateurs actifs?')">
                    👥 Stats utilisateurs
                </button>
                <button class="example-btn" onclick="setQuestion('Comment progresser rapidement?')">
                    🚀 Conseils progression
                </button>
            </div>

            <!-- Loading -->
            <div class="loading" id="loading">
                <div class="spinner"></div>
                <p>L'assistant réfléchit...</p>
            </div>

            <!-- Response -->
            <div class="response-box" id="response-box">
                <div class="response-meta" id="response-meta"></div>
                <div class="response-content" id="response-content"></div>
            </div>
        </div>
    </div>

    <script>
        // Update temperature display
        document.getElementById('temperature').addEventListener('input', (e) => {
            document.getElementById('temperature-value').textContent = e.target.value;
        });

        // Set example question
        function setQuestion(text) {
            document.getElementById('question').value = text;
        }

        // Ask question
        async function askQuestion() {
            const question = document.getElementById('question').value.trim();
            if (!question) {
                alert('Veuillez entrer une question');
                return;
            }

            const model = document.getElementById('model').value;
            const temperature = parseFloat(document.getElementById('temperature').value);

            // Show loading
            document.getElementById('loading').classList.add('show');
            document.getElementById('response-box').classList.remove('show');
            document.getElementById('submit-btn').disabled = true;

            try {
                const response = await fetch('/ai-assistant/ask', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        question,
                        model: model || undefined,
                        temperature
                    })
                });

                const data = await response.json();

                // Hide loading
                document.getElementById('loading').classList.remove('show');
                document.getElementById('submit-btn').disabled = false;

                // Show response
                if (data.success) {
                    const meta = document.getElementById('response-meta');
                    meta.innerHTML = `
                        <span>✅ Succès</span>
                        <span>⏱️ ${data.duration_ms}ms</span>
                        <span>🤖 ${data.model}</span>
                        <span>📊 Contexte: ${data.context_used ? 'Oui' : 'Non'}</span>
                    `;

                    const content = document.getElementById('response-content');
                    content.innerHTML = data.response.replace(/\n/g, '<br>');

                    document.getElementById('response-box').classList.add('show');
                } else {
                    alert('Erreur: ' + (data.error || 'Erreur inconnue'));
                }
            } catch (error) {
                document.getElementById('loading').classList.remove('show');
                document.getElementById('submit-btn').disabled = false;
                alert('Erreur de connexion: ' + error.message);
            }
        }

        // Enter to submit
        document.getElementById('question').addEventListener('keydown', (e) => {
            if (e.key === 'Enter' && e.ctrlKey) {
                askQuestion();
            }
        });
    </script>
</body>
</html>
