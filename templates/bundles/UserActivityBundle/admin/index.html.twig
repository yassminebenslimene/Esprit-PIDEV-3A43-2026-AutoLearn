{% extends 'backoffice/base.html.twig' %}

{% block title %}User Activity Log{% endblock %}

{% block page_title %}User Activity Log{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">Recent User Activities</h3>
                    <p class="text-muted">Last 100 activities across all users</p>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Date/Time</th>
                                    <th>User</th>
                                    <th>Action</th>
                                    <th>IP Address</th>
                                    <th>Location</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for activity in activities %}
                                <tr>
                                    <td>{{ activity.createdAt|date('Y-m-d H:i:s') }}</td>
                                    <td>
                                        <a href="{{ path('admin_user_activity_show', {id: activity.user.id}) }}">
                                            {{ activity.user.prenom }} {{ activity.user.nom }}
                                        </a>
                                    </td>
                                    <td>
                                        <span class="badge bg-info">{{ activity.action }}</span>
                                    </td>
                                    <td>{{ activity.ipAddress ?? 'N/A' }}</td>
                                    <td>{{ activity.location ?? 'N/A' }}</td>
                                    <td>
                                        {% if activity.success %}
                                            <span class="badge bg-success">Success</span>
                                        {% else %}
                                            <span class="badge bg-danger">Failed</span>
                                        {% endif %}
                                    </td>
                                </tr>
                                {% else %}
                                <tr>
                                    <td colspan="6" class="text-center">No activities recorded yet</td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
