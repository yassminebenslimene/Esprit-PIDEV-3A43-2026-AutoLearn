{% extends 'backoffice/base.html.twig' %}

{% block title %}User Activity Log{% endblock %}

{% block page_title %}User Activity Log{% endblock %}

{% block body %}
<style>
    .activity-stats {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }
    
    .stat-card {
        background: linear-gradient(135deg, rgba(255,255,255,0.1), rgba(255,255,255,0.05));
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,0.2);
        border-radius: 15px;
        padding: 20px;
        display: flex;
        align-items: center;
        gap: 15px;
    }
    
    .stat-icon {
        width: 60px;
        height: 60px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
    }
    
    .stat-icon.success { background: linear-gradient(135deg, #10b981, #059669); }
    .stat-icon.warning { background: linear-gradient(135deg, #f59e0b, #d97706); }
    .stat-icon.danger { background: linear-gradient(135deg, #ef4444, #dc2626); }
    .stat-icon.info { background: linear-gradient(135deg, #6366f1, #4f46e5); }
    
    .stat-content h3 {
        margin: 0;
        font-size: 32px;
        font-weight: bold;
        color: white;
    }
    
    .stat-content p {
        margin: 5px 0 0 0;
        color: rgba(255,255,255,0.8);
        font-size: 14px;
    }
    
    .activity-table {
        background: linear-gradient(135deg, rgba(255,255,255,0.1), rgba(255,255,255,0.05));
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,0.2);
        border-radius: 15px;
        padding: 25px;
    }
    
    .activity-table h3 {
        margin: 0 0 10px 0;
        color: white;
        font-size: 24px;
    }
    
    .activity-table .subtitle {
        color: rgba(255,255,255,0.7);
        margin-bottom: 20px;
    }
    
    .data-table {
        width: 100%;
        border-collapse: collapse;
    }
    
    .data-table thead tr {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: white;
    }
    
    .data-table th {
        padding: 15px;
        text-align: left;
        font-weight: 600;
        border-bottom: 2px solid rgba(255,255,255,0.2);
    }
    
    .data-table td {
        padding: 15px;
        border-bottom: 1px solid rgba(255,255,255,0.1);
        color: rgba(255,255,255,0.9);
    }
    
    .data-table tbody tr:hover {
        background: rgba(255,255,255,0.05);
    }
    
    .action-badge {
        padding: 6px 12px;
        border-radius: 12px;
        font-size: 12px;
        font-weight: bold;
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }
    
    .action-badge.login { background: linear-gradient(135deg, #10b981, #059669); color: white; }
    .action-badge.suspend { background: linear-gradient(135deg, #f59e0b, #d97706); color: white; }
    .action-badge.reactivate { background: linear-gradient(135deg, #22c55e, #16a34a); color: white; }
    .action-badge.create { background: linear-gradient(135deg, #3b82f6, #2563eb); color: white; }
    .action-badge.update { background: linear-gradient(135deg, #8b5cf6, #7c3aed); color: white; }
    .action-badge.delete { background: linear-gradient(135deg, #ef4444, #dc2626); color: white; }
    .action-badge.view { background: linear-gradient(135deg, #6366f1, #4f46e5); color: white; }
    .action-badge.default { background: linear-gradient(135deg, #6b7280, #4b5563); color: white; }
    
    .status-badge {
        padding: 4px 10px;
        border-radius: 10px;
        font-size: 11px;
        font-weight: bold;
    }
    
    .status-badge.success { background: #10b981; color: white; }
    .status-badge.failed { background: #ef4444; color: white; }
    
    .user-link {
        color: #60a5fa;
        text-decoration: none;
        font-weight: 500;
    }
    
    .user-link:hover {
        color: #93c5fd;
        text-decoration: underline;
    }
    
    .filter-bar {
        display: flex;
        gap: 15px;
        margin-bottom: 20px;
        flex-wrap: wrap;
    }
    
    .filter-input {
        padding: 10px 15px;
        border: 2px solid rgba(255,255,255,0.2);
        background: rgba(255,255,255,0.1);
        border-radius: 8px;
        color: white;
        font-size: 14px;
        flex: 1;
        min-width: 200px;
    }
    
    .filter-input option {
        background: white;
        color: black;
    }
    
    .filter-input::placeholder {
        color: rgba(255,255,255,0.5);
    }
    
    .filter-btn {
        padding: 10px 20px;
        border: none;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        color: white;
        border-radius: 8px;
        cursor: pointer;
        font-weight: bold;
        font-size: 14px;
    }
    
    .filter-btn:hover {
        background: linear-gradient(135deg, #4f46e5, #7c3aed);
    }
</style>

<div style="padding: 30px;">
    <!-- Statistics Cards -->
    <div class="activity-stats">
        <div class="stat-card">
            <div class="stat-icon success">🔐</div>
            <div class="stat-content">
                <h3>{{ activities|filter(a => a.action == 'user.login')|length }}</h3>
                <p>Successful Logins</p>
            </div>
        </div>
        
        <div class="stat-card">
            <div class="stat-icon warning">⛔</div>
            <div class="stat-content">
                <h3>{{ activities|filter(a => a.action == 'user.suspended')|length }}</h3>
                <p>Suspensions</p>
            </div>
        </div>
        
        <div class="stat-card">
            <div class="stat-icon info">➕</div>
            <div class="stat-content">
                <h3>{{ activities|filter(a => a.action == 'user.created')|length }}</h3>
                <p>New Users Created</p>
            </div>
        </div>
        
        <div class="stat-card">
            <div class="stat-icon danger">❌</div>
            <div class="stat-content">
                <h3>{{ activities|filter(a => not a.success)|length }}</h3>
                <p>Failed Actions</p>
            </div>
        </div>
    </div>
    
    <!-- Activity Table -->
    <div class="activity-table">
        <h3>👨‍🎓 Student Activities Dashboard</h3>
        <p class="subtitle">Last 100 activities - includes both student actions (login, logout) and admin actions on students (suspend, create, update)</p>
        <p class="subtitle" style="font-size: 12px; color: rgba(96, 165, 250, 0.8); margin-top: -10px;">
            ℹ️ For admin-only actions audit trail, visit <a href="{{ path('backoffice_audit_index') }}" style="color: #60a5fa; text-decoration: underline;">Audit Trail</a>
        </p>
        
        <!-- Filter Bar -->
        <div class="filter-bar">
            <input type="text" class="filter-input" id="searchInput" placeholder="Search by user, action, or IP...">
            <select class="filter-input" id="actionFilter" style="flex: 0 0 200px;">
                <option value="">All Actions</option>
                <optgroup label="👨‍🎓 Student Actions">
                    <option value="login">Login</option>
                    <option value="logout">Logout</option>
                    <option value="view">View Profile</option>
                </optgroup>
                <optgroup label="👨‍💼 Admin Actions on Students">
                    <option value="suspend">Suspend</option>
                    <option value="reactivate">Reactivate</option>
                    <option value="create">Create</option>
                    <option value="update">Update</option>
                </optgroup>
            </select>
            <select class="filter-input" id="statusFilter" style="flex: 0 0 150px;">
                <option value="">All Status</option>
                <option value="success">Success</option>
                <option value="failed">Failed</option>
            </select>
            <button class="filter-btn" onclick="clearFilters()">Clear Filters</button>
        </div>
        
        <div style="overflow-x: auto;">
            <table class="data-table" id="activityTable">
                <thead>
                    <tr>
                        <th>Date/Time</th>
                        <th>User</th>
                        <th>Action</th>
                        <th>IP Address</th>
                        <th>Location</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    {% for activity in activities %}
                    <tr data-user="{{ activity.user.prenom }} {{ activity.user.nom }}" 
                        data-action="{{ activity.action }}" 
                        data-ip="{{ activity.ipAddress ?? '' }}"
                        data-status="{{ activity.success ? 'success' : 'failed' }}">
                        <td>{{ activity.createdAt|date('Y-m-d H:i:s') }}</td>
                        <td>
                            <a href="{{ path('admin_user_activity_show', {id: activity.user.id}) }}" class="user-link">
                                {{ activity.user.prenom }} {{ activity.user.nom }}
                            </a>
                        </td>
                        <td>
                            {% set actionType = 'default' %}
                            {% set actionIcon = '📋' %}
                            {% if 'login' in activity.action %}
                                {% set actionType = 'login' %}
                                {% set actionIcon = '🔐' %}
                            {% elseif 'suspend' in activity.action %}
                                {% set actionType = 'suspend' %}
                                {% set actionIcon = '⛔' %}
                            {% elseif 'reactivat' in activity.action %}
                                {% set actionType = 'reactivate' %}
                                {% set actionIcon = '✅' %}
                            {% elseif 'created' in activity.action %}
                                {% set actionType = 'create' %}
                                {% set actionIcon = '➕' %}
                            {% elseif 'updated' in activity.action %}
                                {% set actionType = 'update' %}
                                {% set actionIcon = '✏️' %}
                            {% elseif 'deleted' in activity.action %}
                                {% set actionType = 'delete' %}
                                {% set actionIcon = '🗑️' %}
                            {% elseif 'viewed' in activity.action %}
                                {% set actionType = 'view' %}
                                {% set actionIcon = '👁️' %}
                            {% endif %}
                            <span class="action-badge {{ actionType }}">{{ actionIcon }} {{ activity.action }}</span>
                        </td>
                        <td style="font-family: monospace; font-size: 13px;">{{ activity.ipAddress ?? 'N/A' }}</td>
                        <td>{{ activity.location ?? 'N/A' }}</td>
                        <td>
                            {% if activity.success %}
                                <span class="status-badge success">✓ Success</span>
                            {% else %}
                                <span class="status-badge failed">✗ Failed</span>
                            {% endif %}
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="6" style="text-align: center; padding: 40px; color: rgba(255,255,255,0.5);">
                            No activities recorded yet
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
// Filter functionality
const searchInput = document.getElementById('searchInput');
const actionFilter = document.getElementById('actionFilter');
const statusFilter = document.getElementById('statusFilter');
const table = document.getElementById('activityTable');
const rows = table.querySelectorAll('tbody tr');

function filterTable() {
    const searchTerm = searchInput.value.toLowerCase();
    const actionValue = actionFilter.value.toLowerCase();
    const statusValue = statusFilter.value.toLowerCase();
    
    rows.forEach(row => {
        if (!row.dataset.user) return; // Skip empty state row
        
        const user = row.dataset.user.toLowerCase();
        const action = row.dataset.action.toLowerCase();
        const ip = row.dataset.ip.toLowerCase();
        const status = row.dataset.status.toLowerCase();
        
        const matchesSearch = !searchTerm || user.includes(searchTerm) || action.includes(searchTerm) || ip.includes(searchTerm);
        const matchesAction = !actionValue || action.includes(actionValue);
        const matchesStatus = !statusValue || status === statusValue;
        
        if (matchesSearch && matchesAction && matchesStatus) {
            row.style.display = '';
        } else {
            row.style.display = 'none';
        }
    });
}

function clearFilters() {
    searchInput.value = '';
    actionFilter.value = '';
    statusFilter.value = '';
    filterTable();
}

searchInput.addEventListener('input', filterTable);
actionFilter.addEventListener('change', filterTable);
statusFilter.addEventListener('change', filterTable);
</script>
{% endblock %}
