<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>
    <title>{{ chapitre.titre }}</title>
    <style>
        @page {
            margin: 100px 50px 80px 50px;
        }
        
        body {
            font-family: 'DejaVu Sans', Arial, sans-serif;
            font-size: 12pt;
            line-height: 1.6;
            color: #333;
        }
        
        /* Header fixe */
        header {
            position: fixed;
            top: -80px;
            left: 0;
            right: 0;
            height: 80px;
            text-align: center;
            border-bottom: 3px solid #4A90E2;
            padding-bottom: 10px;
        }
        
        header h1 {
            color: #4A90E2;
            font-size: 24pt;
            margin: 10px 0 5px 0;
        }
        
        header .logo {
            font-size: 18pt;
            font-weight: bold;
            color: #7a6ad8;
            margin-bottom: 5px;
        }
        
        /* Footer fixe */
        footer {
            position: fixed;
            bottom: -60px;
            left: 0;
            right: 0;
            height: 50px;
            text-align: center;
            border-top: 2px solid #4A90E2;
            padding-top: 10px;
            font-size: 10pt;
            color: #666;
        }
        
        footer .page-number:before {
            content: "Page " counter(page);
        }
        
        /* Contenu principal */
        .content {
            margin-top: 20px;
        }
        
        .chapter-meta {
            background: #f8f9fa;
            border-left: 4px solid #4A90E2;
            padding: 15px;
            margin-bottom: 30px;
            border-radius: 5px;
        }
        
        .chapter-meta p {
            margin: 5px 0;
            font-size: 11pt;
        }
        
        .chapter-meta strong {
            color: #4A90E2;
        }
        
        h2 {
            color: #4A90E2;
            font-size: 18pt;
            margin-top: 25px;
            margin-bottom: 15px;
            border-bottom: 2px solid #e0e0e0;
            padding-bottom: 5px;
        }
        
        h3 {
            color: #666;
            font-size: 14pt;
            margin-top: 20px;
            margin-bottom: 10px;
        }
        
        p {
            text-align: justify;
            margin-bottom: 12px;
        }
        
        ul, ol {
            margin-left: 20px;
            margin-bottom: 15px;
        }
        
        li {
            margin-bottom: 8px;
        }
        
        pre, code {
            background: #f5f5f5;
            border: 1px solid #4A90E2;
            border-radius: 4px;
            padding: 10px;
            font-family: 'Courier New', monospace;
            font-size: 10pt;
            overflow-x: auto;
            margin: 15px 0;
        }
        
        code {
            padding: 2px 6px;
            display: inline;
        }
        
        pre {
            display: block;
            white-space: pre-wrap;
        }
        
        .branding {
            text-align: center;
            margin-top: 40px;
            padding: 20px;
            background: linear-gradient(135deg, #7a6ad8 0%, #4e3b9c 100%);
            color: white;
            border-radius: 10px;
        }
        
        .branding h2 {
            color: white;
            border: none;
            margin: 0;
            font-size: 20pt;
        }
        
        .branding p {
            margin: 10px 0 0 0;
            font-size: 12pt;
        }
        
        a {
            color: #4A90E2;
            text-decoration: none;
        }
        
        table {
            width: 100%;
            border-collapse: collapse;
            margin: 15px 0;
        }
        
        table th, table td {
            border: 1px solid #ddd;
            padding: 8px;
            text-align: left;
        }
        
        table th {
            background: #4A90E2;
            color: white;
        }
    </style>
</head>
<body>
    <!-- Header -->
    <header>
        <div class="logo">🎓 AUTOLEARN</div>
        <h1>{{ chapitre.titre }}</h1>
    </header>
    
    <!-- Footer -->
    <footer>
        <div>Autolearn - Plateforme d'apprentissage</div>
        <div class="page-number"></div>
    </footer>
    
    <!-- Contenu -->
    <div class="content">
        <!-- Métadonnées du chapitre -->
        <div class="chapter-meta">
            <p><strong>Chapitre:</strong> {{ chapitre.ordre }}</p>
            <p><strong>Cours:</strong> {{ chapitre.cours.titre }}</p>
            <p><strong>Matière:</strong> {{ chapitre.cours.matiere }}</p>
            <p><strong>Niveau:</strong> {{ chapitre.cours.niveau }}</p>
            <p><strong>Date de génération:</strong> {{ "now"|date("d/m/Y à H:i") }}</p>
        </div>
        
        <!-- Contenu du chapitre -->
        {{ chapitre.contenu|raw }}
        
        <!-- Branding Autolearn -->
        <div class="branding">
            <h2>🎓 Autolearn</h2>
            <p>Votre plateforme d'apprentissage en ligne</p>
        </div>
    </div>
</body>
</html>
