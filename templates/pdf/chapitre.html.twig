<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>
    <title>{{ chapitre.titre }}</title>
    <style>
        @page {
            margin: 100px 50px 80px 50px;
        }
        
        body {
            font-family: 'DejaVu Sans', Arial, sans-serif;
            font-size: 12pt;
            line-height: 1.6;
            color: #333;
            margin: 0;
            padding: 0;
        }
        
        .header {
            position: fixed;
            top: -100px;
            left: 0;
            right: 0;
            height: 80px;
            text-align: center;
            border-bottom: 3px solid #4A90E2;
            padding: 10px 0;
            background: white;
        }
        
        .header img {
            height: 50px;
            margin-bottom: 5px;
        }
        
        .header .logo-text {
            font-size: 20pt;
            font-weight: bold;
            color: #4A90E2;
            margin: 0;
            padding: 5px 0;
        }
        
        .header .chapter-title {
            font-size: 14pt;
            color: #4A90E2;
            margin: 5px 0 0 0;
            font-weight: normal;
        }
        
        .footer {
            position: fixed;
            bottom: -80px;
            left: 0;
            right: 0;
            height: 50px;
            text-align: center;
            border-top: 2px solid #4A90E2;
            padding-top: 10px;
            font-size: 10pt;
            color: #666;
            background: white;
        }
        
        .footer .page-number:before {
            content: "Page " counter(page);
        }
        
        .chapter-meta {
            background: #f8f9fa;
            padding: 15px;
            border-left: 4px solid #4A90E2;
            margin-bottom: 20px;
            border-radius: 4px;
        }
        
        .chapter-meta p {
            margin: 5px 0;
            font-size: 11pt;
        }
        
        .chapter-meta strong {
            color: #4A90E2;
        }
        
        .content {
            margin-top: 20px;
        }
        
        .content h2 {
            color: #4A90E2;
            font-size: 16pt;
            margin-top: 25px;
            margin-bottom: 15px;
            border-bottom: 2px solid #e0e0e0;
            padding-bottom: 5px;
        }
        
        .content h3 {
            color: #333;
            font-size: 14pt;
            margin-top: 20px;
            margin-bottom: 10px;
        }
        
        .content p {
            text-align: justify;
            margin-bottom: 12px;
        }
        
        .content ul, .content ol {
            margin-left: 20px;
            margin-bottom: 15px;
        }
        
        .content li {
            margin-bottom: 8px;
        }
        
        .content pre {
            background: #f5f5f5;
            border: 1px solid #ddd;
            border-left: 4px solid #4A90E2;
            padding: 15px;
            margin: 15px 0;
            overflow-x: auto;
            border-radius: 4px;
        }
        
        .content code {
            font-family: 'Courier New', monospace;
            font-size: 10pt;
            background: #f5f5f5;
            padding: 2px 6px;
            border-radius: 3px;
        }
        
        .content pre code {
            background: transparent;
            padding: 0;
        }
        
        .content a {
            color: #4A90E2;
            text-decoration: none;
        }
        
        .content strong {
            color: #000;
            font-weight: bold;
        }
        
        .branding {
            text-align: center;
            margin-top: 30px;
            padding: 20px;
            background: #f8f9fa;
            border-radius: 8px;
        }
        
        .branding h3 {
            color: #4A90E2;
            margin-bottom: 10px;
        }
        
        .branding p {
            font-size: 10pt;
            color: #666;
        }
    </style>
</head>
<body>
    <!-- Header fixe -->
    <div class="header">
        {# Logo texte - Fonctionne sans GD #}
        <div class="logo-text">🎓 AUTOLEARN</div>
        
        {# Logo image - Décommenter après avoir activé GD dans php.ini #}
        {# <img src="{{ absolute_url(asset('public/frontoffice/images/auto.png')) }}" alt="Autolearn Logo"> #}
        
        <div class="chapter-title">{{ chapitre.titre }}</div>
    </div>
    
    <!-- Footer fixe -->
    <div class="footer">
        <div>
            <strong>Autolearn</strong> - Plateforme d'apprentissage en ligne
        </div>
        <div class="page-number"></div>
    </div>
    
    <!-- Métadonnées du chapitre -->
    <div class="chapter-meta">
        <p><strong>Chapitre:</strong> {{ chapitre.ordre }}</p>
        {% if chapitre.cours %}
            <p><strong>Cours:</strong> {{ chapitre.cours.titre }}</p>
            <p><strong>Matière:</strong> {{ chapitre.cours.matiere }}</p>
            <p><strong>Niveau:</strong> {{ chapitre.cours.niveau }}</p>
        {% endif %}
        <p><strong>Date de génération:</strong> {{ "now"|date("d/m/Y à H:i") }}</p>
    </div>
    
    <!-- Contenu du chapitre -->
    <div class="content">
        {{ chapitre.contenu|raw }}
    </div>
    
    <!-- Branding Autolearn -->
    <div class="branding">
        <h3>🎓 Autolearn</h3>
        <p>Votre plateforme d'apprentissage en ligne</p>
        <p>Ce document a été généré automatiquement depuis votre cours.</p>
    </div>
</body>
</html>
