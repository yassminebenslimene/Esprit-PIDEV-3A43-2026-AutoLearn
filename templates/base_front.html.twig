<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

    <title>{% block title %}Scholar{% endblock %}</title>

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@100;200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">

    {% block stylesheets %}
        <!-- Bootstrap -->
        <link rel="stylesheet" href="{{ asset('frontoffice/vendor/bootstrap/css/bootstrap.min.css') }}">

        <!-- Scholar CSS -->
        <link rel="stylesheet" href="{{ asset('frontoffice/css/animate.css') }}">
        <link rel="stylesheet" href="{{ asset('frontoffice/css/flex-slider.css') }}">
        <link rel="stylesheet" href="{{ asset('frontoffice/css/fontawesome.css') }}">
        <link rel="stylesheet" href="{{ asset('frontoffice/css/owl.css') }}">
        <link rel="stylesheet" href="{{ asset('frontoffice/css/templatemo-scholar.css') }}">

        <!-- Swiper -->
        <link rel="stylesheet" href="https://unpkg.com/swiper@7/swiper-bundle.min.css"/>

        <style>
            /* Bloc étudiant connecté : nom de compte + déconnexion */
            .nav-user-name { display: flex; align-items: center; gap: 6px; padding: 0 15px; color: #4a69bd; }
            .nav-account-label { font-size: 0.9em; color: #666; }
            .nav-user-name strong { white-space: nowrap; }
            .nav-logout-btn { display: inline-flex; align-items: center; gap: 6px; padding: 8px 14px; background: rgba(244, 67, 54, 0.12); color: #c62828; border-radius: 8px; font-weight: 500; }
            .nav-logout-btn:hover { background: rgba(244, 67, 54, 0.2); color: #b71c1c; }
            
            /* Language dropdown and profile button - BLACK COLOR */
            .main-nav .nav .profile-dropdown-btn {
                color: #1e1e1e !important;
            }
            
            .main-nav .nav .profile-dropdown-btn:hover {
                color: #000 !important;
            }
            
            /* Language dropdown styles */
            .main-nav .nav li {
                position: relative;
            }
            
            .main-nav .nav .profile-dropdown-menu {
                display: none;
                position: absolute !important;
                top: 100% !important;
                right: 0 !important;
                z-index: 999999 !important;
                min-width: 180px !important;
                background: white !important;
                border-radius: 8px !important;
                box-shadow: 0 5px 25px rgba(0,0,0,0.15) !important;
                padding: 10px 0 !important;
                margin-top: 5px !important;
                list-style: none !important;
            }
            
            .main-nav .nav .profile-dropdown-menu.show {
                display: block !important;
            }
            
            .main-nav .nav .profile-dropdown-menu li {
                width: 100% !important;
                margin: 0 !important;
                padding: 0 !important;
                display: block !important;
            }
            
            .main-nav .nav .profile-dropdown-menu a {
                display: block !important;
                padding: 12px 20px !important;
                color: #333 !important;
                text-decoration: none !important;
                font-size: 15px !important;
                transition: all 0.2s !important;
            }
            
            .main-nav .nav .profile-dropdown-menu a:hover {
                background: linear-gradient(105deg, #7a6ad8 0%, #4e3b9c 100%) !important;
                color: white !important;
            }
        </style>
    {% endblock %}
</head>

<body>

<!-- ***** Preloader Start ***** -->
<div id="js-preloader" class="js-preloader">
    <div class="preloader-inner">
        <span class="dot"></span>
        <div class="dots">
            <span></span>
            <span></span>
            <span></span>
        </div>
    </div>
</div>
<!-- ***** Preloader End ***** -->

<!-- ***** Header Area Start ***** -->
<header class="header-area header-sticky">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <nav class="main-nav">
                    <!-- ***** Logo Start ***** -->
                    <a href="{{ path('app_frontoffice') }}" class="logo">
                        <h1>Scholar</h1>
                    </a>
                    <!-- ***** Logo End ***** -->
                    <!-- ***** Search Start ***** -->
                    <div class="search-input">
                        <form id="search" action="#">
                            <input type="text" placeholder="Type Something" id='searchText' name="searchKeyword" />
                            <i class="fa fa-search"></i>
                        </form>
                    </div>
                    <!-- ***** Search End ***** -->
                    <!-- ***** Menu Start ***** -->
                    <ul class="nav">

                        <li class="scroll-to-section"><a href="{{ path('app_frontoffice') }}#top">{{ 'nav.home'|trans }}</a></li>
                        <li class="scroll-to-section"><a href="{{ path('app_frontoffice') }}#cours">{{ 'nav.courses'|trans }}</a></li>
                        <li class="scroll-to-section"><a href="{{ path('app_frontoffice') }}#events">{{ 'nav.events'|trans }}</a></li>
                        <li class="scroll-to-section"><a href="{{ path('app_frontoffice') }}#challenge">{{ 'nav.challenges'|trans }}</a></li>
                        <li class="scroll-to-section"><a href="{{ path('app_frontoffice') }}#contact">{{ 'nav.contact'|trans }}</a></li>
                        <li><a href="{{ path('app_communaute_index') }}">{{ 'nav.community'|trans }}</a></li>
                        
                        {# Sélecteur de langue #}
                        <li class="profile-dropdown-container" style="position: relative;">
                            <a href="javascript:void(0);" onclick="toggleLanguageDropdown(event)" class="profile-dropdown-btn" style="display: flex; align-items: center; gap: 5px; cursor: pointer;">
                                <i class="fa fa-globe"></i>
                                {% if app.request.locale == 'fr' %}
                                    FR
                                {% elseif app.request.locale == 'en' %}
                                    EN
                                {% elseif app.request.locale == 'es' %}
                                    ES
                                {% elseif app.request.locale == 'ar' %}
                                    AR
                                {% else %}
                                    FR
                                {% endif %}
                                <i class="fa fa-chevron-down" style="font-size: 10px;"></i>
                            </a>
                            <ul class="profile-dropdown-menu" id="languageDropdown">
                                <li>
                                    <a href="{{ path('app_change_language', {'locale': 'fr'}) }}">
                                        🇫🇷 {{ 'language.french'|trans }}
                                    </a>
                                </li>
                                <li>
                                    <a href="{{ path('app_change_language', {'locale': 'en'}) }}">
                                        🇬🇧 {{ 'language.english'|trans }}
                                    </a>
                                </li>
                                <li>
                                    <a href="{{ path('app_change_language', {'locale': 'es'}) }}">
                                        🇪🇸 {{ 'language.spanish'|trans }}
                                    </a>
                                </li>
                                <li>
                                    <a href="{{ path('app_change_language', {'locale': 'ar'}) }}">
                                        🇸🇦 {{ 'language.arabic'|trans }}
                                    </a>
                                </li>
                            </ul>
                        </li>
                        
                        {% if app.user %}
                            <li><a href="{{ path('app_mes_participations') }}">{{ 'nav.my_participations'|trans }}</a></li>
                            
                            <li class="profile-dropdown-container" style="position: relative;">
                                <a href="javascript:void(0);" onclick="toggleProfileDropdown(event)" class="profile-dropdown-btn" style="display: flex; align-items: center; gap: 5px; cursor: pointer;">
                                    <i class="fa fa-user-circle"></i>
                                    {{ app.user.prenom }} {{ app.user.nom }}
                                    <i class="fa fa-chevron-down" style="font-size: 12px; margin-left: 5px;"></i>
                                </a>
                                <ul class="profile-dropdown-menu" id="profileDropdown">
                                    <li>
                                        <a href="{{ path('app_profile') }}">
                                            <i class="fa fa-id-card"></i> {{ 'nav.profile'|trans }}
                                        </a>
                                    </li>
                                    <li class="profile-dropdown-divider" style="height: 1px; background: #eeeeee; margin: 8px 0;"></li>
                                    <li>
                                        <a href="{{ path('backoffice_logout') }}">
                                            <i class="fa fa-sign-out"></i> {{ 'nav.logout'|trans }}
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        {% else %}
                            <li><a href="{{ path('backoffice_login') }}">{{ 'nav.login'|trans }}</a></li>
                            <li><a href="{{ path('backoffice_register') }}">{{ 'nav.register'|trans }}</a></li>
                        {% endif %}
                    </ul>
                    <a class='menu-trigger'>
                        <span>Menu</span>
                    </a>
                    <!-- ***** Menu End ***** -->
                </nav>
            </div>
        </div>
    </div>
</header>
<!-- ***** Header Area End ***** -->

    <main>
        {% block body %}{% endblock %}
    </main>

    <!-- ***** Footer Start ***** -->
