<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

    <title>{% block title %}Scholar{% endblock %}</title>

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@100;200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">

    {% block stylesheets %}
        <!-- Bootstrap -->
        <link rel="stylesheet" href="{{ asset('frontoffice/vendor/bootstrap/css/bootstrap.min.css') }}">

        <!-- Scholar CSS -->
        <link rel="stylesheet" href="{{ asset('frontoffice/css/animate.css') }}">
        <link rel="stylesheet" href="{{ asset('frontoffice/css/flex-slider.css') }}">
        <link rel="stylesheet" href="{{ asset('frontoffice/css/fontawesome.css') }}">
        <link rel="stylesheet" href="{{ asset('frontoffice/css/owl.css') }}">
        <link rel="stylesheet" href="{{ asset('frontoffice/css/templatemo-scholar.css') }}">

        <!-- Swiper -->
        <link rel="stylesheet" href="https://unpkg.com/swiper@7/swiper-bundle.min.css"/>

        <style>
            /* Bloc étudiant connecté : nom de compte + déconnexion */
            .nav-user-name { display: flex; align-items: center; gap: 6px; padding: 0 15px; color: #4a69bd; }
            .nav-account-label { font-size: 0.9em; color: #666; }
            .nav-user-name strong { white-space: nowrap; }
            .nav-logout-btn { display: inline-flex; align-items: center; gap: 6px; padding: 8px 14px; background: rgba(244, 67, 54, 0.12); color: #c62828; border-radius: 8px; font-weight: 500; }
            .nav-logout-btn:hover { background: rgba(244, 67, 54, 0.2); color: #b71c1c; }
        </style>
    {% endblock %}
</head>

<body>

<!-- ***** Preloader Start ***** -->
<div id="js-preloader" class="js-preloader">
    <div class="preloader-inner">
        <span class="dot"></span>
        <div class="dots">
            <span></span>
            <span></span>
            <span></span>
        </div>
    </div>
</div>
<!-- ***** Preloader End ***** -->

<!-- ***** Header Area Start ***** -->
<header class="header-area header-sticky">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <nav class="main-nav">
                    <!-- ***** Logo Start ***** -->
                    <a href="{{ path('app_frontoffice') }}" class="logo">
                        <h1>Scholar</h1>
                    </a>
                    <!-- ***** Logo End ***** -->
                    <!-- ***** Search Start ***** -->
                    <div class="search-input">
                        <form id="search" action="#">
                            <input type="text" placeholder="Type Something" id='searchText' name="searchKeyword" />
                            <i class="fa fa-search"></i>
                        </form>
                    </div>
                    <!-- ***** Search End ***** -->
                    <!-- ***** Menu Start ***** -->
                    <ul class="nav">

                        <li class="scroll-to-section"><a href="{{ path('app_frontoffice') }}">Home</a></li>
                        <li class="scroll-to-section"><a href="{{ path('app_frontoffice') }}#services">Cours</a></li>
                        <li class="scroll-to-section"><a href="{{ path('app_frontoffice') }}#courses">Courses</a></li>
                        <li class="scroll-to-section"><a href="{{ path('app_frontoffice') }}#team">Team</a></li>
                        <li class="scroll-to-section"><a href="{{ path('app_frontoffice') }}#events">Events</a></li>
                        <li class="scroll-to-section"><a href="{{ path('app_frontoffice') }}#challenge">Challenge</a></li>
                        <li class="scroll-to-section"><a href="{{ path('app_communaute_index') }}">Communauté</a></li>
                        {% if app.user %}
                            <li class="scroll-to-section nav-user-name">
                                <span class="nav-account-label">Mon compte :</span>
                                <strong>{{ app.user.prenom }} {{ app.user.nom }}</strong>
                            </li>
                            <li class="scroll-to-section"><a href="{{ path('app_profile') }}">Mon profil</a></li>
                            <li class="scroll-to-section">
                                <a href="{{ path('backoffice_logout') }}" class="nav-logout-btn">
                                    <i class="fa fa-sign-out-alt"></i> Déconnexion
                                </a>
                            </li>
                        {% else %}
                            <li class="scroll-to-section"><a href="{{ path('backoffice_login') }}">Login</a></li>
                            <li class="scroll-to-section"><a href="{{ path('backoffice_register') }}">Register</a></li>
                        {% endif %}
                    </ul>
                    <a class='menu-trigger'>
                        <span>Menu</span>
                    </a>
                    <!-- ***** Menu End ***** -->
                </nav>
            </div>
        </div>
    </div>
</header>
<!-- ***** Header Area End ***** -->

    <main>
        {% block body %}{% endblock %}
    </main>

    {% block javascripts %}
        <script src="{{ asset('frontoffice/vendor/jquery/jquery.min.js') }}"></script>
        <script src="{{ asset('frontoffice/vendor/bootstrap/js/bootstrap.bundle.min.js') }}"></script>

        <script src="{{ asset('frontoffice/js/isotope.min.js') }}"></script>
        <script src="{{ asset('frontoffice/js/owl-carousel.js') }}"></script>
        <script src="{{ asset('frontoffice/js/counter.js') }}"></script>
        <script src="{{ asset('frontoffice/js/custom.js') }}"></script>
    {% endblock %}

</body>

</html>