                            <li style="margin-bottom: 12px;">
                                <a href="{{ path('app_frontoffice') }}#cours" style="color: rgba(255,255,255,0.8); text-decoration: none; transition: color 0.3s; display: block;" onmouseover="this.style.color='white'" onmouseout="this.style.color='rgba(255,255,255,0.8)'">
                                    <i class="fa fa-angle-right" style="margin-right: 8px;"></i> Cours
                                </a>
                            </li>
                            <li style="margin-bottom: 12px;">
                                <a href="{{ path('app_frontoffice') }}#events" style="color: rgba(255,255,255,0.8); text-decoration: none; transition: color 0.3s; display: block;" onmouseover="this.style.color='white'" onmouseout="this.style.color='rgba(255,255,255,0.8)'">
                                    <i class="fa fa-angle-right" style="margin-right: 8px;"></i> Événements
                                </a>
                            </li>
                            <li style="margin-bottom: 12px;">
                                <a href="{{ path('app_frontoffice') }}#challenge" style="color: rgba(255,255,255,0.8); text-decoration: none; transition: color 0.3s; display: block;" onmouseover="this.style.color='white'" onmouseout="this.style.color='rgba(255,255,255,0.8)'">
                                    <i class="fa fa-angle-right" style="margin-right: 8px;"></i> Challenges
