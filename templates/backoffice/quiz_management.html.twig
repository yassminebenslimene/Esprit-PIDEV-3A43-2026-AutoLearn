{% extends 'backoffice/base.html.twig' %}

{% block title %}Gestion des Quiz{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="text-white mb-2">Gestion des Quiz</h1>
        </div>
    </div>

    <!-- Liste des Quiz avec affichage hiérarchique -->
    <div class="row">
        <div class="col-12">
            <div class="glass-card">
                <div class="card-header d-flex justify-content-between align-items-center mb-3">
                    <div>
                        <h2 class="card-title mb-1">📋 Liste des Quiz</h2>
                        <p class="card-subtitle mb-0">Cliquez sur "Sélectionner" pour afficher les questions</p>
                    </div>
                    <a href="{{ path('app_quiz_new') }}" class="card-btn">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="12" y1="5" x2="12" y2="19"></line>
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                        </svg>
                        Nouveau Quiz
                    </a>
                </div>

                <div id="quiz-list">
                    {% for quiz in quizzes %}
                    <div class="quiz-item mb-3" data-quiz-id="{{ quiz.id }}">
                        <!-- Ligne du Quiz -->
                        <div class="quiz-row glass-sub-card">
                            <div class="quiz-info">
                                <div class="quiz-header">
                                    <span class="quiz-id">#{{ quiz.id }}</span>
                                    <h3 class="quiz-title">{{ quiz.titre }}</h3>
                                    <span class="status-badge 
                                        {% if quiz.etat == 'actif' %}completed
                                        {% elseif quiz.etat == 'brouillon' %}processing
                                        {% else %}pending{% endif %}">
                                        {{ quiz.etat|capitalize }}
                                    </span>
                                </div>
                                <p class="quiz-description">{{ quiz.description|slice(0, 100) }}...</p>
                            </div>
                            <div class="quiz-actions">
                                <button class="card-btn btn-sm toggle-questions-btn" data-quiz-id="{{ quiz.id }}" data-quiz-titre="{{ quiz.titre }}">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <polyline points="6 9 12 15 18 9"></polyline>
                                    </svg>
                                    Sélectionner
                                </button>
                                <a href="{{ path('app_quiz_show', {'id': quiz.id}) }}" class="card-btn btn-sm btn-info">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <circle cx="12" cy="12" r="10"></circle>
                                        <line x1="12" y1="16" x2="12" y2="12"></line>
                                        <line x1="12" y1="8" x2="12.01" y2="8"></line>
                                    </svg>
                                    Voir
                                </a>
                                <a href="{{ path('app_quiz_edit', {'id': quiz.id}) }}" class="card-btn btn-sm btn-secondary">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                                    </svg>
                                    Modifier
                                </a>
                                <form method="post" action="{{ path('app_quiz_delete', {'id': quiz.id}) }}" style="display: inline;" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce quiz ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ quiz.id) }}">
                                    <button type="submit" class="card-btn btn-sm btn-danger">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <polyline points="3 6 5 6 21 6"></polyline>
                                            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                        </svg>
                                        Supprimer
                                    </button>
                                </form>
                            </div>
                        </div>

                        <!-- Container des Questions (caché par défaut) -->
                        <div class="questions-container" id="questions-{{ quiz.id }}" style="display: none;">
                            <div class="questions-header mb-2">
                                <a href="{{ path('app_question_new') }}?quiz={{ quiz.id }}" class="card-btn btn-sm">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <line x1="12" y1="5" x2="12" y2="19"></line>
                                        <line x1="5" y1="12" x2="19" y2="12"></line>
                                    </svg>
                                    Nouvelle Question
                                </a>
                            </div>
                            <div class="loading-spinner text-center py-3">
                                <div class="spinner-border text-light" role="status">
                                    <span class="visually-hidden">Chargement...</span>
                                </div>
                            </div>
                            <div class="questions-list" style="display: none;">
                                <!-- Les questions seront insérées ici dynamiquement -->
                            </div>
                        </div>
                    </div>
                    {% else %}
                    <div class="text-center text-white-50 py-4">
                        <p>Aucun quiz disponible</p>
                    </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.glass-card {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 24px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
}

.glass-sub-card {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(8px);
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 16px;
    transition: all 0.3s ease;
}

.glass-sub-card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(99, 102, 241, 0.3);
}

.card-header {
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    padding-bottom: 16px;
}

.card-title {
    font-size: 1.5rem;
    font-weight: 600;
    color: #fff;
    margin: 0;
}

.card-subtitle {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.6);
}

.quiz-item {
    margin-bottom: 16px;
}

.quiz-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
}

.quiz-info {
    flex: 1;
}

.quiz-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 8px;
    flex-wrap: wrap;
}

.quiz-id {
    background: rgba(99, 102, 241, 0.2);
    color: #818cf8;
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 600;
}

.quiz-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: #fff;
    margin: 0;
}

.quiz-description {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.875rem;
    margin: 0;
}

.quiz-actions {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
    flex-wrap: wrap;
}

.questions-container {
    margin-top: 16px;
    margin-left: 32px;
    padding-left: 24px;
    border-left: 2px solid rgba(99, 102, 241, 0.3);
}

.questions-header {
    display: flex;
    justify-content: flex-start;
    margin-bottom: 12px;
}

.question-item {
    margin-bottom: 12px;
}

.question-row {
    background: rgba(168, 85, 247, 0.05);
    border: 1px solid rgba(168, 85, 247, 0.2);
    border-radius: 10px;
    padding: 12px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    transition: all 0.3s ease;
}

.question-row:hover {
    background: rgba(168, 85, 247, 0.1);
    border-color: rgba(168, 85, 247, 0.4);
}

.question-info {
    flex: 1;
}

.question-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 4px;
    flex-wrap: wrap;
}

.question-id {
    background: rgba(168, 85, 247, 0.2);
    color: #c084fc;
    padding: 3px 8px;
    border-radius: 5px;
    font-size: 0.7rem;
    font-weight: 600;
}

.question-text {
    color: #fff;
    font-size: 0.95rem;
    font-weight: 500;
    margin: 0;
}

.question-meta {
    display: flex;
    gap: 12px;
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.6);
}

.question-actions {
    display: flex;
    gap: 6px;
    flex-shrink: 0;
    flex-wrap: wrap;
}

.options-container {
    margin-top: 12px;
    margin-left: 32px;
    padding-left: 20px;
    border-left: 2px solid rgba(168, 85, 247, 0.3);
}

.options-header {
    display: flex;
    justify-content: flex-start;
    margin-bottom: 8px;
}

.option-item {
    background: rgba(34, 197, 94, 0.05);
    border: 1px solid rgba(34, 197, 94, 0.2);
    border-radius: 8px;
    padding: 10px 14px;
    margin-bottom: 8px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: all 0.3s ease;
}

.option-item:hover {
    background: rgba(34, 197, 94, 0.1);
}

.option-item.incorrect {
    background: rgba(239, 68, 68, 0.05);
    border-color: rgba(239, 68, 68, 0.2);
}

.option-item.incorrect:hover {
    background: rgba(239, 68, 68, 0.1);
}

.option-info {
    display: flex;
    align-items: center;
    gap: 10px;
    flex: 1;
}

.option-id {
    background: rgba(34, 197, 94, 0.2);
    color: #4ade80;
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 0.7rem;
    font-weight: 600;
}

.option-item.incorrect .option-id {
    background: rgba(239, 68, 68, 0.2);
    color: #f87171;
}

.option-text {
    color: #fff;
    font-size: 0.875rem;
}

.option-actions {
    display: flex;
    gap: 4px;
    flex-shrink: 0;
}

.card-btn {
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.2), rgba(168, 85, 247, 0.2));
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: #fff;
    padding: 8px 16px;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
}

.card-btn:hover {
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.3), rgba(168, 85, 247, 0.3));
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
    color: #fff;
}

.btn-sm {
    padding: 6px 12px;
    font-size: 0.8rem;
}

.btn-secondary {
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.05));
}

.btn-secondary:hover {
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.15), rgba(255, 255, 255, 0.1));
}

.btn-info {
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.2), rgba(37, 99, 235, 0.2));
}

.btn-info:hover {
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.3), rgba(37, 99, 235, 0.3));
}

.btn-danger {
    background: linear-gradient(135deg, rgba(239, 68, 68, 0.2), rgba(220, 38, 38, 0.2));
}

.btn-danger:hover {
    background: linear-gradient(135deg, rgba(239, 68, 68, 0.3), rgba(220, 38, 38, 0.3));
}

.status-badge {
    padding: 4px 12px;
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: 500;
}

.status-badge.completed {
    background: rgba(34, 197, 94, 0.2);
    color: #4ade80;
}

.status-badge.processing {
    background: rgba(251, 191, 36, 0.2);
    color: #fbbf24;
}

.status-badge.pending {
    background: rgba(239, 68, 68, 0.2);
    color: #f87171;
}

.spinner-border {
    width: 2rem;
    height: 2rem;
    border-width: 0.25em;
}

.toggle-questions-btn.active svg,
.toggle-options-btn.active svg {
    transform: rotate(180deg);
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Gestion du clic sur "Sélectionner" pour afficher/masquer les questions
    document.querySelectorAll('.toggle-questions-btn').forEach(btn => {
        btn.addEventListener('click', function() {
            const quizId = this.dataset.quizId;
            const questionsContainer = document.getElementById(`questions-${quizId}`);
            const questionsList = questionsContainer.querySelector('.questions-list');
            const loadingSpinner = questionsContainer.querySelector('.loading-spinner');
            
            // Si déjà ouvert, fermer
            if (questionsContainer.style.display === 'block') {
                questionsContainer.style.display = 'none';
                this.classList.remove('active');
                return;
            }
            
            // Ouvrir et charger les questions
            questionsContainer.style.display = 'block';
            this.classList.add('active');
            
            // Si déjà chargé, ne pas recharger
            if (questionsList.dataset.loaded === 'true') {
                loadingSpinner.style.display = 'none';
                questionsList.style.display = 'block';
                return;
            }
            
            // Charger les questions via AJAX
            loadingSpinner.style.display = 'block';
            questionsList.style.display = 'none';
            
            fetch(`/quiz/api/${quizId}/questions`)
                .then(response => response.json())
                .then(questions => {
                    questionsList.innerHTML = '';
                    
                    if (questions.length === 0) {
                        questionsList.innerHTML = '<p class="text-white-50 text-center py-3">Aucune question pour ce quiz</p>';
                    } else {
                        questions.forEach(question => {
                            const questionDiv = createQuestionElement(question);
                            questionsList.appendChild(questionDiv);
                        });
                        
                        // Ajouter les événements pour les boutons "Sélectionner" des questions
                        questionsList.querySelectorAll('.toggle-options-btn').forEach(optBtn => {
                            optBtn.addEventListener('click', function() {
                                toggleOptions(this);
                            });
                        });
                    }
                    
                    questionsList.dataset.loaded = 'true';
                    loadingSpinner.style.display = 'none';
                    questionsList.style.display = 'block';
                })
                .catch(error => {
                    console.error('Erreur:', error);
                    questionsList.innerHTML = '<p class="text-danger text-center py-3">Erreur de chargement</p>';
                    loadingSpinner.style.display = 'none';
                    questionsList.style.display = 'block';
                });
        });
    });
    
    function toggleOptions(btn) {
        const questionId = btn.dataset.questionId;
        const optionsContainer = document.getElementById(`options-${questionId}`);
        const optionsList = optionsContainer.querySelector('.options-list');
        const loadingSpinner = optionsContainer.querySelector('.loading-spinner');
        
        // Si déjà ouvert, fermer
        if (optionsContainer.style.display === 'block') {
            optionsContainer.style.display = 'none';
            btn.classList.remove('active');
            return;
        }
        
        // Ouvrir et charger les options
        optionsContainer.style.display = 'block';
        btn.classList.add('active');
        
        // Si déjà chargé, ne pas recharger
        if (optionsList.dataset.loaded === 'true') {
            loadingSpinner.style.display = 'none';
            optionsList.style.display = 'block';
            return;
        }
        
        // Charger les options via AJAX
        loadingSpinner.style.display = 'block';
        optionsList.style.display = 'none';
        
        fetch(`/question/api/${questionId}/options`)
            .then(response => response.json())
            .then(options => {
                optionsList.innerHTML = '';
                
                if (options.length === 0) {
                    optionsList.innerHTML = '<p class="text-white-50 text-center py-2">Aucune option pour cette question</p>';
                } else {
                    options.forEach(option => {
                        const optionDiv = createOptionElement(option);
                        optionsList.appendChild(optionDiv);
                    });
                }
                
                optionsList.dataset.loaded = 'true';
                loadingSpinner.style.display = 'none';
                optionsList.style.display = 'block';
            })
            .catch(error => {
                console.error('Erreur:', error);
                optionsList.innerHTML = '<p class="text-danger text-center py-2">Erreur de chargement</p>';
                loadingSpinner.style.display = 'none';
                optionsList.style.display = 'block';
            });
    }
    
    function createQuestionElement(question) {
        const questionItem = document.createElement('div');
        questionItem.className = 'question-item';
        
        questionItem.innerHTML = `
            <div class="question-row">
                <div class="question-info">
                    <div class="question-header">
                        <span class="question-id">#${question.id}</span>
                        <p class="question-text">${question.texte}</p>
                    </div>
                    <div class="question-meta">
                        <span>📊 Type: ${question.type}</span>
                        <span>⭐ ${question.points} points</span>
                    </div>
                </div>
                <div class="question-actions">
                    <button class="card-btn btn-sm toggle-options-btn" data-question-id="${question.id}">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="6 9 12 15 18 9"></polyline>
                        </svg>
                        Sélectionner
                    </button>
                    <a href="/question/${question.id}" class="card-btn btn-sm btn-info">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" y1="16" x2="12" y2="12"></line>
                            <line x1="12" y1="8" x2="12.01" y2="8"></line>
                        </svg>
                        Voir
                    </a>
                    <a href="/question/${question.id}/edit" class="card-btn btn-sm btn-secondary">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                        </svg>
                        Modifier
                    </a>
                    <button class="card-btn btn-sm btn-danger delete-question-btn" data-question-id="${question.id}">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="3 6 5 6 21 6"></polyline>
                            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                        </svg>
                        Supprimer
                    </button>
                </div>
            </div>
            <div class="options-container" id="options-${question.id}" style="display: none;">
                <div class="options-header">
                    <a href="/option/new?question=${question.id}" class="card-btn btn-sm">
                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="12" y1="5" x2="12" y2="19"></line>
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                        </svg>
                        Nouvelle Option
                    </a>
                </div>
                <div class="loading-spinner text-center py-2">
                    <div class="spinner-border text-light" role="status" style="width: 1.5rem; height: 1.5rem;">
                        <span class="visually-hidden">Chargement...</span>
                    </div>
                </div>
                <div class="options-list" style="display: none;">
                    <!-- Les options seront insérées ici -->
                </div>
            </div>
        `;
        
        // Ajouter l'événement de suppression
        const deleteBtn = questionItem.querySelector('.delete-question-btn');
        deleteBtn.addEventListener('click', function() {
            if (confirm('Êtes-vous sûr de vouloir supprimer cette question ?')) {
                deleteQuestion(question.id);
            }
        });
        
        return questionItem;
    }
    
    function createOptionElement(option) {
        const optionDiv = document.createElement('div');
        optionDiv.className = `option-item ${option.estCorrecte ? 'correct' : 'incorrect'}`;
        optionDiv.dataset.optionId = option.id;
        
        optionDiv.innerHTML = `
            <div class="option-info">
                <span class="option-id">#${option.id}</span>
                <span class="option-text">${option.texte}</span>
            </div>
            <div class="option-actions">
                <span class="status-badge ${option.estCorrecte ? 'completed' : 'pending'}">
                    ${option.estCorrecte ? '✓ Correcte' : '✗ Incorrecte'}
                </span>
                <a href="/option/${option.id}/edit" class="card-btn btn-sm btn-secondary">
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                    </svg>
                    Modifier
                </a>
                <button class="card-btn btn-sm btn-danger delete-option-btn" data-option-id="${option.id}">
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="3 6 5 6 21 6"></polyline>
                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                    </svg>
                    Supprimer
                </button>
            </div>
        `;
        
        // Ajouter l'événement de suppression
        const deleteBtn = optionDiv.querySelector('.delete-option-btn');
        deleteBtn.addEventListener('click', function() {
            if (confirm('Êtes-vous sûr de vouloir supprimer cette option ?')) {
                deleteOption(option.id);
            }
        });
        
        return optionDiv;
    }
    
    function deleteQuestion(questionId) {
        fetch(`/question/${questionId}`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: `_token=${getCsrfToken('delete' + questionId)}`
        })
        .then(response => {
            if (response.ok) {
                location.reload();
            } else {
                alert('Erreur lors de la suppression');
            }
        })
        .catch(error => {
            console.error('Erreur:', error);
            alert('Erreur lors de la suppression');
        });
    }
    
    function deleteOption(optionId) {
        fetch(`/option/${optionId}`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: `_token=${getCsrfToken('delete' + optionId)}`
        })
        .then(response => {
            if (response.ok) {
                const optionElement = document.querySelector(`[data-option-id="${optionId}"]`);
                if (optionElement) {
                    optionElement.remove();
                }
            } else {
                alert('Erreur lors de la suppression');
            }
        })
        .catch(error => {
            console.error('Erreur:', error);
            alert('Erreur lors de la suppression');
        });
    }
    
