{% extends 'backoffice/base.html.twig' %}

{% block title %}Modifier le Quiz{% endblock %}
{% block page_title %}Modifier le Quiz{% endblock %}

{% block body %}
    <div class="glass-card">
        <div class="card-header">
            <div>
                <h2 class="card-title">Modifier le Quiz</h2>
                <p class="card-subtitle">Mettez à jour les informations</p>
            </div>
            <div class="card-actions">
                <a href="{{ path('app_quiz_index') }}" class="card-btn">
                    <svg style="width: 16px; height: 16px; display: inline-block; vertical-align: middle; margin-right: 0.25rem;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="19" y1="12" x2="5" y2="12"/>
                        <polyline points="12 19 5 12 12 5"/>
                    </svg>
                    Retour
                </a>
            </div>
        </div>
        <div style="padding: 1.5rem;">
            {{ include('quiz/_form.html.twig', {'button_label': 'Mettre à jour'}) }}
            <div style="margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid rgba(255, 255, 255, 0.1);">
                {{ include('quiz/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
{% endblock %}
