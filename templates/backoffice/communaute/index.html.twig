{% extends 'backoffice/base.html.twig' %}

{% block title %}Communautés{% endblock %}

{% block page_title %}
Communautés
{% endblock %}

{% block body %}

<style>
    .badge {
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        display: inline-block;
    }
    .badge-info { background: linear-gradient(135deg, var(--cyan), var(--emerald-light)); color: white; }
    .badge-primary { background: linear-gradient(135deg, var(--purple), var(--magenta)); color: white; }
    .action-buttons { display: flex; gap: 5px; flex-wrap: wrap; }
    .small-btn {
        font-size: 12px !important;
        padding: 6px 10px !important;
        min-width: 70px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }
    .small-btn svg { margin-right: 4px; }
    .danger { background: var(--danger) !important; color: white !important; }
</style>

<section class="stats-grid">
    <div class="glass-card glass-card-3d stat-card">
        <div class="stat-card-inner">
            <div class="stat-info">
                <h3>Total Communautés</h3>
                <div class="stat-value">{{ communautes|length }}</div>
            </div>
            <div class="stat-icon cyan">
                <svg viewBox="0 0 24 24" fill="none" stroke="var(--emerald-light)" stroke-width="2">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
                </svg>
            </div>
        </div>
    </div>
</section>

<section class="content-grid" style="grid-template-columns: 1fr;">
    <div class="glass-card table-card">
        <div class="card-header">
            <div>
                <h2 class="card-title">Toutes les Communautés</h2>
                <p class="card-subtitle">Gérer les communautés</p>
            </div>
        </div>
        <div class="table-wrapper">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Communauté</th>
                        <th>Propriétaire</th>
                        <th>Membres</th>
                        <th>Posts</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for communaute in communautes %}
                    <tr>
                        <td>
                            <div class="table-user-info">
                                <span class="table-user-name">{{ communaute.nom }}</span>
                                <span class="table-user-email">{{ communaute.description|slice(0, 50) }}{% if communaute.description|length > 50 %}...{% endif %}</span>
                            </div>
                        </td>
                        <td>
                            {% if communaute.owner %}
                                {{ communaute.owner.prenom }} {{ communaute.owner.nom }}
                            {% else %}
                                <span style="opacity:0.5">Aucun</span>
                            {% endif %}
                        </td>
                        <td><span class="badge badge-info">{{ communaute.members|length }}</span></td>
                        <td><span class="badge badge-primary">{{ communaute.posts|length }}</span></td>
                        <td>
                            <div class="action-buttons">
                                <a href="{{ path('backoffice_communaute_show', {id: communaute.id}) }}" class="card-btn small-btn">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                                    </svg>Voir
                                </a>
                                <a href="{{ path('backoffice_communaute_edit', {id: communaute.id}) }}" class="card-btn small-btn">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                    </svg>Modifier
                                </a>
                                <form method="post" action="{{ path('backoffice_communaute_delete', {id: communaute.id}) }}" 
                                      onsubmit="return confirm('Supprimer cette communauté ?');" style="display:inline;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ communaute.id) }}">
                                    <button type="submit" class="card-btn small-btn danger">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                                        </svg>Supprimer
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr><td colspan="5" style="text-align:center;padding:2rem;">Aucune communauté trouvée</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</section>

{% endblock %}
