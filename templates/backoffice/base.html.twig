<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}GlassAdmin Dashboard{% endblock %}</title>
    <meta name="description" content="3D Glassmorphism Dashboard Template">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('Backoffice/css/templatemo-glass-admin-style.css') }}">
    <link rel="stylesheet" href="{{ asset('Backoffice/css/custom-forms.css') }}">
    <link rel="stylesheet" href="{{ asset('Backoffice/css/form-errors.css') }}">
</head>
<body>
    <!-- Animated Background -->
    <div class="background"></div>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>

    <div class="dashboard">
        <!-- Sidebar -->
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <div class="logo">G</div>
                <span class="logo-text">GlassDash</span>
            </div>

            <ul class="nav-menu">
                <li class="nav-section">
                    <span class="nav-section-title">Main Menu</span>
                    <ul>
                        <li class="nav-item">
                            <a href="{{ path('app_backoffice') }}" class="nav-link">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <rect x="3" y="3" width="7" height="7" rx="1"/>
                                    <rect x="14" y="3" width="7" height="7" rx="1"/>
                                    <rect x="3" y="14" width="7" height="7" rx="1"/>
                                    <rect x="14" y="14" width="7" height="7" rx="1"/>
                                </svg>
                                Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="{{ path('backoffice_analytics') }}" class="nav-link">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                                    <path d="M2 17l10 5 10-5"/>
                                    <path d="M2 12l10 5 10-5"/>
                                </svg>
                                Analytics
                            </a>
                        </li>
                    </ul>
                </li>

                <li class="nav-section">
                    <span class="nav-section-title">{{ 'dashboard.management'|trans }}</span>
                    <ul>
                        <li class="nav-item">
                            <a href="{{ path('app_cours_index') }}" class="nav-link">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
                                    <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
                                </svg>
                                {{ 'courses.title'|trans }}
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="{{ path('backoffice_quiz_management') }}" class="nav-link">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M3 3h7v7H3z"/>
                                    <path d="M14 3h7v7h-7z"/>
                                    <path d="M14 14h7v7h-7z"/>
                                    <path d="M3 14h7v7H3z"/>
                                </svg>
                                {{ 'quiz.management'|trans }}
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="{{ path('backoffice_evenements') }}" class="nav-link">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                                    <line x1="16" y1="2" x2="16" y2="6"/>
                                    <line x1="8" y1="2" x2="8" y2="6"/>
                                    <line x1="3" y1="10" x2="21" y2="10"/>
                                </svg>
                                {{ 'events.title'|trans }}
                            </a>
                        </li>
                    </ul>
                </li>

                <li class="nav-section">
                    <span class="nav-section-title">{{ 'dashboard.community'|trans }}</span>
                    <ul>
                        <li class="nav-item">
                            <a href="{{ path('backoffice_communaute_index') }}" class="nav-link">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                                    <circle cx="9" cy="7" r="4"/>
                                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                                    <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                                </svg>
                                {{ 'nav.community'|trans }}
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="{{ path('backoffice_post_index') }}" class="nav-link">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                                    <polyline points="14 2 14 8 20 8"/>
                                </svg>
                                Posts
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="{{ path('backoffice_commentaire_index') }}" class="nav-link">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                                </svg>
                                Commentaires
                            </a>
                        </li>
                    </ul>
                </li>

                <li class="nav-section">
                    <span class="nav-section-title">{{ 'dashboard.system'|trans }}</span>
                    <ul>
                        <li class="nav-item">
                            <a href="{{ path('backoffice_users') }}" class="nav-link">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                                    <circle cx="9" cy="7" r="4"/>
                                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                                    <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                                </svg>
                                {{ 'users.title'|trans }}
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="{{ path('backoffice_settings') }}" class="nav-link">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="12" cy="12" r="3"/>
                                    <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                                </svg>
                                {{ 'settings.title'|trans }}
                            </a>
                        </li>
                    </ul>
                </li>

                <li class="nav-section">
                    <span class="nav-section-title">{{ 'dashboard.account'|trans }}</span>
                    <ul>
                        <li class="nav-item">
                            <a href="{{ path('backoffice_login') }}" class="nav-link">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                                    <polyline points="16 17 21 12 16 7"/>
                                    <line x1="21" y1="12" x2="9" y2="12"/>
                                </svg>
                                {{ 'nav.logout'|trans }}
                            </a>
                        </li>
                    </ul>
                </li>
            </ul>

            <div class="sidebar-footer">
                <div class="user-profile">
                    <div class="user-avatar">AD</div>
                    <div class="user-info">
                        <div class="user-name">Admin</div>
                        <div class="user-role">Administrator</div>
                    </div>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="6 9 12 15 18 9"/>
                    </svg>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Top Navbar -->
            <nav class="navbar">
                <h1 class="page-title">{% block page_title %}{{ 'dashboard.title'|trans }}{% endblock %}</h1>
                <div class="navbar-right">
                    <div class="search-box">
                        <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="11" cy="11" r="8"/>
                            <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                        </svg>
                        <input type="text" class="search-input" placeholder="{{ 'actions.search'|trans }}...">
                    </div>
                    
                    {# Sélecteur de langue #}
                    <div class="language-selector" style="position: relative; margin-right: 10px;">
                        <button class="nav-btn" id="language-toggle" title="{{ 'language.select'|trans }}" onclick="toggleLanguageMenu(event)">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 20px; height: 20px;">
                                <circle cx="12" cy="12" r="10"/>
                                <line x1="2" y1="12" x2="22" y2="12"/>
                                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                            </svg>
                        </button>
                        <div id="languageMenu" class="language-menu" style="display: none; position: absolute; top: 100%; right: 0; margin-top: 10px; background: rgba(255, 255, 255, 0.1); backdrop-filter: blur(20px); border-radius: 12px; padding: 10px; min-width: 150px; box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2); z-index: 1000;">
                            <a href="{{ path('app_change_language', {'locale': 'fr'}) }}" style="display: block; padding: 10px 15px; color: white; text-decoration: none; border-radius: 8px; transition: all 0.3s; {% if app.request.locale == 'fr' %}background: rgba(255, 255, 255, 0.2);{% endif %}">
                                🇫🇷 {{ 'language.french'|trans }}
                            </a>
                            <a href="{{ path('app_change_language', {'locale': 'en'}) }}" style="display: block; padding: 10px 15px; color: white; text-decoration: none; border-radius: 8px; transition: all 0.3s; {% if app.request.locale == 'en' %}background: rgba(255, 255, 255, 0.2);{% endif %}">
                                🇬🇧 {{ 'language.english'|trans }}
                            </a>
                            <a href="{{ path('app_change_language', {'locale': 'es'}) }}" style="display: block; padding: 10px 15px; color: white; text-decoration: none; border-radius: 8px; transition: all 0.3s; {% if app.request.locale == 'es' %}background: rgba(255, 255, 255, 0.2);{% endif %}">
                                🇪🇸 {{ 'language.spanish'|trans }}
                            </a>
                            <a href="{{ path('app_change_language', {'locale': 'ar'}) }}" style="display: block; padding: 10px 15px; color: white; text-decoration: none; border-radius: 8px; transition: all 0.3s; {% if app.request.locale == 'ar' %}background: rgba(255, 255, 255, 0.2);{% endif %}">
                                🇸🇦 {{ 'language.arabic'|trans }}
                            </a>
                        </div>
                    </div>
                    
                    <button class="nav-btn" id="theme-toggle" title="Toggle Light/Dark Mode">
                        <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="4"/>
                            <path d="M12 2v2"/><path d="M12 20v2"/>
                            <path d="M4.93 4.93l1.41 1.41"/><path d="M17.66 17.66l1.41 1.41"/>
                            <path d="M2 12h2"/><path d="M20 12h2"/>
                            <path d="M6.34 17.66l-1.41 1.41"/><path d="M19.07 4.93l-1.41 1.41"/>
                        </svg>
                    </button>
                </div>
            </nav>

            <!-- Page Content -->
            <div class="page-content">
                {% block body %}{% endblock %}
            </div>
        </main>
    </div>

    <script src="{{ asset('Backoffice/js/templatemo-glass-admin-script.js') }}"></script>
    <script>
        // Toggle language menu
        function toggleLanguageMenu(event) {
            event.preventDefault();
            event.stopPropagation();
            
            const menu = document.getElementById('languageMenu');
            menu.style.display = menu.style.display === 'none' ? 'block' : 'none';
        }
        
        // Close language menu when clicking outside
        document.addEventListener('click', function(event) {
            const menu = document.getElementById('languageMenu');
            const toggle = document.getElementById('language-toggle');
            
            if (menu && !menu.contains(event.target) && !toggle.contains(event.target)) {
                menu.style.display = 'none';
            }
        });
        
        // Hover effect for language menu items
        document.addEventListener('DOMContentLoaded', function() {
            const menuItems = document.querySelectorAll('.language-menu a');
            menuItems.forEach(item => {
                item.addEventListener('mouseenter', function() {
                    this.style.background = 'rgba(255, 255, 255, 0.2)';
                });
                item.addEventListener('mouseleave', function() {
                    if (!this.style.background.includes('0.2') || this.getAttribute('href').includes('{{ app.request.locale }}')) {
                        return;
                    }
                    this.style.background = 'transparent';
                });
            });
        });
    </script>
</body>
</html>
