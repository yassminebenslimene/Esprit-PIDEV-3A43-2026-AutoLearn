<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}GlassAdmin Dashboard{% endblock %}</title>
    <meta name="description" content="3D Glassmorphism Dashboard Template">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('backoffice/css/templatemo-glass-admin-style.css') }}">
    <link rel="stylesheet" href="{{ asset('backoffice/css/custom-forms.css') }}">
    <link rel="stylesheet" href="{{ asset('backoffice/css/form-errors.css') }}">
</head>
<body>
    <!-- Animated Background -->
    <div class="background"></div>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>

    <div class="dashboard">
        {# Include Sidebar Component #}
        {% include 'backoffice/_sidebar.html.twig' %}

        <!-- Main Content -->
        <main class="main-content">
            {# Include Navbar Component #}
            {% include 'backoffice/_navbar.html.twig' %}

            <!-- Page Content -->
            <div class="page-content">
                {% block body %}{% endblock %}
            </div>
        </main>
    </div>

    <script src="{{ asset('backoffice/js/templatemo-glass-admin-script.js') }}"></script>

    {# AI Chat Widget - Assistant Intelligent #}
    {% include 'ai_assistant/chat_widget.html.twig' %}
</body>
</html>
