<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}GlassAdmin Dashboard{% endblock %}</title>
    <meta name="description" content="3D Glassmorphism Dashboard Template">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('Backoffice/css/templatemo-glass-admin-style.css') }}">
    <link rel="stylesheet" href="{{ asset('Backoffice/css/custom-forms.css') }}">
    <link rel="stylesheet" href="{{ asset('Backoffice/css/form-errors.css') }}">
</head>
<body>
    <!-- Animated Background -->
    <div class="background"></div>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>

    <div class="dashboard">
        {# Include Sidebar Component #}
        {% include 'backoffice/_sidebar.html.twig' %}

        <!-- Main Content -->
        <main class="main-content">
            {# Include Navbar Component #}
            {% include 'backoffice/_navbar.html.twig' %}

            <!-- Page Content -->
            <div class="page-content">
                {% block body %}{% endblock %}
            </div>
        </main>
    </div>

    <script src="{{ asset('Backoffice/js/templatemo-glass-admin-script.js') }}"></script>
    <script>
        // Toggle language menu
        function toggleLanguageMenu(event) {
            event.preventDefault();
            event.stopPropagation();
            
            const menu = document.getElementById('languageMenu');
            menu.style.display = menu.style.display === 'none' ? 'block' : 'none';
        }
        
        // Close language menu when clicking outside
        document.addEventListener('click', function(event) {
            const menu = document.getElementById('languageMenu');
            const toggle = document.getElementById('language-toggle');
            
            if (menu && !menu.contains(event.target) && !toggle.contains(event.target)) {
                menu.style.display = 'none';
            }
        });
        
        // Hover effect for language menu items
        document.addEventListener('DOMContentLoaded', function() {
            const menuItems = document.querySelectorAll('.language-menu a');
            menuItems.forEach(item => {
                item.addEventListener('mouseenter', function() {
                    this.style.background = 'rgba(255, 255, 255, 0.2)';
                });
                item.addEventListener('mouseleave', function() {
                    if (!this.style.background.includes('0.2') || this.getAttribute('href').includes('{{ app.request.locale }}')) {
                        return;
                    }
                    this.style.background = 'transparent';
                });
            });
        });
    </script>

    {# AI Chat Widget - Assistant Intelligent #}
    {% include 'ai_assistant/chat_widget.html.twig' %}
</body>
</html>
