<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>

    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('backoffice/css/templatemo-glass-admin-style.css') }}">
</head>

<body>

<div class="background"></div>
<div class="orb orb-1"></div>
<div class="orb orb-2"></div>
<div class="orb orb-3"></div>

<div class="dashboard">

    <!-- Sidebar -->
    <aside class="sidebar">
        <!-- Tu peux copier ici exactement le même sidebar que exercice.html.twig -->
    </aside>

    <!-- Main Content -->
    <main class="main-content">

        <div class="glass-card">
            <h2 style="margin-bottom: 20px;">{{ title }}</h2>

            {{ form_start(form) }}

            <div class="form-group">
                <label>Question</label>
                {{ form_widget(form.question, {'attr': {'class': 'form-control'}}) }}
            </div>

            <div class="form-group">
                <label>Réponse</label>
                {{ form_widget(form.reponse, {'attr': {'class': 'form-control'}}) }}
            </div>

            <div class="form-group">
                <label>Points</label>
                {{ form_widget(form.points, {'attr': {'class': 'form-control'}}) }}
            </div>

            <div style="margin-top:20px;">
                <button type="submit" class="btn btn-primary">
                    💾 Enregistrer
                </button>

                <a href="{{ path('backoffice_exercices') }}" class="btn btn-secondary">
                    ⬅ Retour
                </a>
            </div>

            {{ form_end(form) }}

        </div>

    </main>
</div>

<script src="{{ asset('backoffice/js/templatemo-glass-admin-script.js') }}"></script>

</body>
</html>
