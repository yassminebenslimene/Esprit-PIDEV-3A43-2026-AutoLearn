{% extends 'backoffice/base.html.twig' %}

{% block title %}{{ title }}{% endblock %}
{% block page_title %}{{ title }}{% endblock %}

{% block body %}
    <div class="glass-card" style="padding: 30px;">
        <div style="display: flex; align-items: center; margin-bottom: 30px;">
            <div class="stat-icon cyan" style="margin-right: 15px;">
                <svg viewBox="0 0 24 24" fill="none" stroke="var(--emerald-light)" stroke-width="2" width="24" height="24">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                    <circle cx="9" cy="7" r="4"/>
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                    <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
            </div>
            <h2 class="card-title" style="margin-bottom: 0;">{{ title }}</h2>
        </div>

        {{ form_start(form, {'attr': {'style': 'display: flex; flex-direction: column; gap: 20px;'}}) }}

        <div class="form-group">
            <label style="display: block; margin-bottom: 8px; color: var(--text-muted); font-weight: 500; font-size: 14px;">Question</label>
            {{ form_widget(form.question, {'attr': {
                'style': 'width: 100%; padding: 12px; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; color: var(--text); font-family: inherit; font-size: 14px;',
                'class': 'form-control',
                'placeholder': 'Entrez la question...'
            }}) }}
        </div>

        <div class="form-group">
            <label style="display: block; margin-bottom: 8px; color: var(--text-muted); font-weight: 500; font-size: 14px;">Réponse</label>
            {{ form_widget(form.reponse, {'attr': {
                'style': 'width: 100%; padding: 12px; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; color: var(--text); font-family: inherit; font-size: 14px;',
                'class': 'form-control',
                'placeholder': 'Entrez la réponse...'
            }}) }}
        </div>

        <div class="form-group">
            <label style="display: block; margin-bottom: 8px; color: var(--text-muted); font-weight: 500; font-size: 14px;">Points</label>
            {{ form_widget(form.points, {'attr': {
                'style': 'width: 100%; padding: 12px; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; color: var(--text); font-family: inherit; font-size: 14px;',
                'class': 'form-control',
                'placeholder': 'Ex: 10',
                'min': '1',
                'step': '1'
            }}) }}
        </div>

        <div style="display: flex; gap: 15px; margin-top: 30px;">
            <button type="submit" class="btn btn-primary" style="background: linear-gradient(135deg, var(--emerald-light), var(--emerald)); color: white; padding: 12px 30px; border: none; border-radius: 8px; font-weight: 600; cursor: pointer; display: flex; align-items: center; gap: 8px;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
                    <polyline points="17 21 17 13 7 13 7 21"/>
                    <polyline points="7 3 7 8 15 8"/>
                </svg>
                💾 Enregistrer
            </button>
            <a href="{{ path('backoffice_exercices') }}" class="btn btn-secondary" style="background: rgba(255,255,255,0.1); color: var(--text); padding: 12px 30px; border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; font-weight: 500; text-decoration: none; display: flex; align-items: center; gap: 8px;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="19" y1="12" x2="5" y2="12"/>
                    <polyline points="12 19 5 12 12 5"/>
                </svg>
                ⬅ Retour
            </a>
        </div>

        {{ form_end(form) }}
    </div>
{% endblock %}
