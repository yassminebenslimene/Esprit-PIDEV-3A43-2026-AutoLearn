<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Analytics - 3D Glassmorphism Dashboard</title>
    <meta name="description" content="3D Glassmorphism Dashboard Template by TemplateMo">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('backoffice/css/templatemo-glass-admin-style.css') }}">
    <!--

TemplateMo 607 Glass Admin

https://templatemo.com/tm-607-glass-admin

-->
</head>
<body>
    <!-- Animated Background -->
    <div class="background"></div>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>

    <div class="dashboard">
        {# Include Sidebar Component #}
        {% include 'backoffice/_sidebar.html.twig' %}

        <!-- Main Content -->
        <main class="main-content">
            <!-- Top Navbar -->
            <nav class="navbar">
                <div class="page-header">
                    <h1 class="page-title">Analytics</h1>
                    <div class="page-breadcrumb">
                        <a href="{{ path('app_backoffice') }}">Dashboard</a>
                        <span>/</span>
                        <span>Analytics</span>
                    </div>
                </div>
                <div class="navbar-right">
                    <div class="search-box">
                        <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                        </svg>
                        <input type="text" class="search-input" placeholder="Search anything...">
                    </div>
                    <button class="nav-btn">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                        </svg>
                        <span class="notification-dot"></span>
                    </button>
                    <button class="nav-btn" id="theme-toggle" title="Toggle Light/Dark Mode">
                        <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/>
                            <path d="M4.93 4.93l1.41 1.41"/><path d="M17.66 17.66l1.41 1.41"/>
                            <path d="M2 12h2"/><path d="M20 12h2"/>
                            <path d="M6.34 17.66l-1.41 1.41"/><path d="M19.07 4.93l-1.41 1.41"/>
                        </svg>
                        <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display: none;">
                            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                        </svg>
                    </button>
                </div>
            </nav>

            <!-- Stats Cards - Different from Dashboard -->
            <section class="stats-grid">
                <div class="glass-card glass-card-3d stat-card">
                    <div class="stat-card-inner">
                        <div class="stat-info">
                            <h3>Total Chapitres</h3>
                            <div class="stat-value">{{ stats.totalChapitres }}</div>
                            <span class="stat-change positive">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg>
                                Contenu
                            </span>
                        </div>
                        <div class="stat-icon cyan">
                            <svg viewBox="0 0 24 24" fill="none" stroke="var(--emerald-light)" stroke-width="2">
                                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
                                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
                            </svg>
                        </div>
                    </div>
                </div>

                <div class="glass-card glass-card-3d stat-card">
                    <div class="stat-card-inner">
                        <div class="stat-info">
                            <h3>Total Exercices</h3>
                            <div class="stat-value">{{ stats.totalExercices }}</div>
                            <span class="stat-change positive">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg>
                                Pratique
                            </span>
                        </div>
                        <div class="stat-icon magenta">
                            <svg viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="2">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                                <polyline points="14 2 14 8 20 8"/>
                                <line x1="16" y1="13" x2="8" y2="13"/>
                                <line x1="16" y1="17" x2="8" y2="17"/>
                                <polyline points="10 9 9 9 8 9"/>
                            </svg>
                        </div>
                    </div>
                </div>

                <div class="glass-card glass-card-3d stat-card">
                    <div class="stat-card-inner">
                        <div class="stat-info">
                            <h3>Total Posts</h3>
                            <div class="stat-value">{{ stats.totalPosts }}</div>
                            <span class="stat-change positive">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg>
                                Discussions
                            </span>
                        </div>
                        <div class="stat-icon purple">
                            <svg viewBox="0 0 24 24" fill="none" stroke="var(--coral)" stroke-width="2">
                                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                            </svg>
                        </div>
                    </div>
                </div>

                <div class="glass-card glass-card-3d stat-card">
                    <div class="stat-card-inner">
                        <div class="stat-info">
                            <h3>Communautés</h3>
                            <div class="stat-value">{{ stats.totalCommunautes }}</div>
                            <span class="stat-change positive">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg>
                                Actives
                            </span>
                        </div>
                        <div class="stat-icon success">
                            <svg viewBox="0 0 24 24" fill="none" stroke="var(--success)" stroke-width="2">
                                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                                <circle cx="9" cy="7" r="4"/>
                                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                            </svg>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Content Grid -->
            <section class="content-grid">
                <!-- Main Chart -->
                <div class="glass-card chart-card">
                    <div class="card-header">
                        <div>
                            <h2 class="card-title">Aperçu des Cours</h2>
                            <p class="card-subtitle">Top 5 cours par nombre de chapitres</p>
                        </div>
                        <div class="card-actions">
                            <a href="{{ path('app_cours_index') }}" class="card-btn active">Voir Tous</a>
                        </div>
                    </div>
                    <div class="chart-wrapper">
                        <div class="chart-container">
                            <div class="chart-y-axis">
                                <span class="y-value">30</span>
                                <span class="y-value">24</span>
                                <span class="y-value">18</span>
                                <span class="y-value">12</span>
                                <span class="y-value">6</span>
                                <span class="y-value">0</span>
                            </div>
                            <div class="chart-placeholder">
                                {% for cours in topCours %}
                                {% set height = (cours.chapitres|length * 10) %}
                                {% if height > 200 %}
                                    {% set height = 200 %}
                                {% endif %}
                                <div class="chart-bar-group">
                                    <div class="chart-bar bar-emerald" style="height: {{ height }}px;"></div>
                                    <span class="chart-label">{{ cours.titre|slice(0, 10) }}</span>
                                </div>
                                {% else %}
                                <div style="text-align: center; padding: 40px; color: var(--text-muted);">
                                    Aucun cours disponible
                                </div>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Recent Events -->
                <div class="glass-card activity-card">
                    <div class="card-header">
                        <div>
                            <h2 class="card-title">Événements Récents</h2>
                            <p class="card-subtitle">Derniers événements créés</p>
                        </div>
                    </div>
                    <div class="activity-list">
                        {% for event in recentEvents %}
                        <div class="activity-item">
                            <div class="activity-avatar" style="background: linear-gradient(135deg, var(--emerald-light), var(--emerald));">
                                {{ loop.index }}
                            </div>
                            <div class="activity-content">
                                <p class="activity-text"><strong>{{ event.titre }}</strong></p>
                                <span class="activity-time">{{ event.type.value }} - {{ event.dateDebut|date('d/m/Y') }}</span>
                            </div>
                        </div>
                        {% else %}
                        <div class="activity-item">
                            <div class="activity-content">
                                <p class="activity-text">Aucun événement récent</p>
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                </div>
            </section>

            <!-- Bottom Grid - Completely Different from Dashboard -->
            <section class="bottom-grid">
                <!-- Top Challenges by Exercises -->
                <div class="glass-card">
                    <div class="card-header">
                        <div>
                            <h2 class="card-title">Top Challenges</h2>
                            <p class="card-subtitle">Par nombre d'exercices</p>
                        </div>
                    </div>
                    <div class="donut-container">
                        <div class="donut-chart">
                            <svg width="140" height="140" viewBox="0 0 140 140">
                                <circle class="donut-bg" cx="70" cy="70" r="54"/>
                                <circle class="donut-segment" cx="70" cy="70" r="54" stroke="var(--emerald-light)" stroke-dasharray="120 339.3" stroke-dashoffset="0"/>
                                <circle class="donut-segment" cx="70" cy="70" r="54" stroke="var(--gold)" stroke-dasharray="100 339.3" stroke-dashoffset="-120"/>
                                <circle class="donut-segment" cx="70" cy="70" r="54" stroke="var(--coral)" stroke-dasharray="119.3 339.3" stroke-dashoffset="-220"/>
                            </svg>
                            <div class="donut-center">
                                <div class="donut-value">{{ stats.totalExercices }}</div>
                                <div class="donut-label">Exercices</div>
                            </div>
                        </div>
                        <div class="donut-legend">
                            {% for challenge in topChallenges|slice(0, 3) %}
                            <div class="legend-item">
                                <span class="legend-color {% if loop.index == 1 %}cyan{% elseif loop.index == 2 %}magenta{% else %}purple{% endif %}"></span>
                                <span>{{ challenge.titre|slice(0, 15) }} ({{ challenge.exercices|length }})</span>
                            </div>
                            {% else %}
                            <div class="legend-item"><span>Aucun challenge</span></div>
                            {% endfor %}
                        </div>
                    </div>
                </div>

                <!-- Engagement Metrics -->
                <div class="glass-card progress-card">
                    <div class="card-header">
                        <div>
                            <h2 class="card-title">Engagement Utilisateurs</h2>
                            <p class="card-subtitle">Métriques d'activité</p>
                        </div>
                    </div>
                    <div class="progress-item">
                        <div class="progress-header"><span class="progress-label">👨‍🎓 Étudiants Actifs</span><span class="progress-value">{{ stats.totalEtudiants }}</span></div>
                        <div class="progress-bar"><div class="progress-fill cyan" style="width: {{ (stats.totalEtudiants / (stats.totalEtudiants + stats.totalAdmins) * 100)|round }}%;"></div></div>
                    </div>
                    <div class="progress-item">
                        <div class="progress-header"><span class="progress-label">💬 Posts Créés</span><span class="progress-value">{{ stats.totalPosts }}</span></div>
                        <div class="progress-bar"><div class="progress-fill magenta" style="width: {{ (stats.totalPosts / 50 * 100)|round }}%;"></div></div>
                    </div>
                    <div class="progress-item">
                        <div class="progress-header"><span class="progress-label">👥 Communautés</span><span class="progress-value">{{ stats.totalCommunautes }}</span></div>
                        <div class="progress-bar"><div class="progress-fill purple" style="width: {{ (stats.totalCommunautes / 10 * 100)|round }}%;"></div></div>
                    </div>
                    <div class="progress-item">
                        <div class="progress-header"><span class="progress-label">📅 Événements</span><span class="progress-value">{{ stats.totalEvenements }}</span></div>
                        <div class="progress-bar"><div class="progress-fill cyan" style="width: {{ (stats.totalEvenements / 20 * 100)|round }}%;"></div></div>
                    </div>
                </div>

                <!-- Content Performance -->
                <div class="glass-card progress-card">
                    <div class="card-header">
                        <div>
                            <h2 class="card-title">Performance Contenu</h2>
                            <p class="card-subtitle">Indicateurs de qualité</p>
                        </div>
                    </div>
                    <div class="progress-item">
                        <div class="progress-header"><span class="progress-label">📖 Chapitres</span><span class="progress-value">{{ stats.totalChapitres }}</span></div>
                        <div class="progress-bar"><div class="progress-fill cyan" style="width: {{ (stats.totalChapitres / 100 * 100)|round }}%;"></div></div>
                    </div>
                    <div class="progress-item">
                        <div class="progress-header"><span class="progress-label">📝 Quiz</span><span class="progress-value">{{ stats.totalQuiz }}</span></div>
                        <div class="progress-bar"><div class="progress-fill magenta" style="width: {{ (stats.totalQuiz / 50 * 100)|round }}%;"></div></div>
                    </div>
                    <div class="progress-item">
                        <div class="progress-header"><span class="progress-label">✍️ Exercices</span><span class="progress-value">{{ stats.totalExercices }}</span></div>
                        <div class="progress-bar"><div class="progress-fill purple" style="width: {{ (stats.totalExercices / 200 * 100)|round }}%;"></div></div>
                    </div>
                    <div class="progress-item">
                        <div class="progress-header"><span class="progress-label">👨‍💼 Admins</span><span class="progress-value">{{ stats.totalAdmins }}</span></div>
                        <div class="progress-bar"><div class="progress-fill cyan" style="width: {{ (stats.totalAdmins / 10 * 100)|round }}%;"></div></div>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <!-- Mobile Menu Toggle -->
    <button class="mobile-menu-toggle">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
    </button>

    <!-- Footer -->
    <footer class="site-footer">
        <p>Copyright © 2026 Your Company. Designed by <a href="https://templatemo.com" target="_blank" rel="nofollow">TemplateMo</a></p>
    </footer>

    <script src="{{ asset('backoffice/js/templatemo-glass-admin-script.js') }}"></script>
    <!-- TemplateMo 607 Glass Admin -->
    
    {# AI Chat Widget - Assistant Intelligent #}
    {% include 'ai_assistant/chat_widget.html.twig' %}
</body>
</html>