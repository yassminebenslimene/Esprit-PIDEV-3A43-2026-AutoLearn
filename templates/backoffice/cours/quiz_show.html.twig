{% extends 'backoffice/base.html.twig' %}

{% block title %}Quiz - {{ quiz.titre }}{% endblock %}
{% block page_title %}Détails du quiz{% endblock %}

{% block body %}
    <section class="content-grid">
        <div class="glass-card">
            <div class="card-header">
                <div>
                    <h2 class="card-title">{{ quiz.titre }}</h2>
                    <p class="card-subtitle">Chapitre: {{ chapitre.titre }} - Cours: {{ cours.titre }}</p>
                </div>
                <div class="card-actions" style="display: flex; gap: 12px;">
                    <a href="{{ path('app_cours_chapitre_quizzes', {'coursId': cours.id, 'chapitreId': chapitre.id}) }}" class="card-btn" style="background: rgba(255,255,255,0.1); color: var(--text-primary); padding: 8px 16px; border-radius: 8px; text-decoration: none;">
                        <svg style="width: 16px; height: 16px; display: inline-block; vertical-align: middle; margin-right: 4px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M19 12H5"/>
                            <path d="M12 19l-7-7 7-7"/>
                        </svg>
                        Retour
                    </a>
                    <a href="{{ path('app_cours_chapitre_quiz_edit', {'coursId': cours.id, 'chapitreId': chapitre.id, 'id': quiz.id}) }}" class="card-btn" style="background: linear-gradient(135deg, var(--emerald-light), var(--emerald)); color: white; padding: 8px 16px; border-radius: 8px; text-decoration: none;">
                        <svg style="width: 16px; height: 16px; display: inline-block; vertical-align: middle; margin-right: 4px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                        </svg>
                        Modifier
                    </a>
                </div>
            </div>
            <div class="card-body">
                <div class="detail-grid">
                    <div class="detail-item">
                        <label class="detail-label">Titre</label>
                        <div class="detail-value">{{ quiz.titre }}</div>
                    </div>

                    <div class="detail-item">
                        <label class="detail-label">Description</label>
                        <div class="detail-value">{{ quiz.description }}</div>
                    </div>

                    <div class="detail-item">
                        <label class="detail-label">État</label>
                        <div class="detail-value">
                            {% if quiz.etat == 'actif' %}
                                <span class="status-badge active" style="background: rgba(34, 197, 94, 0.2); color: #22c55e;">Actif</span>
                            {% elseif quiz.etat == 'inactif' %}
                                <span class="status-badge inactive" style="background: rgba(239, 68, 68, 0.2); color: #ef4444;">Inactif</span>
                            {% elseif quiz.etat == 'brouillon' %}
                                <span class="status-badge pending" style="background: rgba(251, 191, 36, 0.2); color: #fbbf24;">Brouillon</span>
                            {% else %}
                                <span class="status-badge" style="background: rgba(156, 163, 175, 0.2); color: #9ca3af;">Archivé</span>
                            {% endif %}
                        </div>
                    </div>

                    <div class="detail-item">
                        <label class="detail-label">Chapitre</label>
                        <div class="detail-value">{{ chapitre.titre }}</div>
                    </div>

                    <div class="detail-item">
                        <label class="detail-label">Cours</label>
                        <div class="detail-value">{{ cours.titre }}</div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
