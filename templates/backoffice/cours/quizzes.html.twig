{% extends 'backoffice/base.html.twig' %}

{% block title %}Quiz - {{ chapitre.titre }}{% endblock %}
{% block page_title %}Quiz du chapitre : {{ chapitre.titre }}{% endblock %}

{% block body %}
    <section class="content-grid">
        <div class="glass-card table-card">
            <div class="card-header">
                <div>
                    <h2 class="card-title">Quiz du chapitre</h2>
                    <p class="card-subtitle">{{ chapitre.titre }} - Cours: {{ cours.titre }}</p>
                </div>
                <div class="card-actions" style="display: flex; gap: 12px;">
                    <a href="{{ path('app_cours_chapitres', {'id': cours.id}) }}" class="card-btn" style="background: rgba(255,255,255,0.1); color: var(--text-primary); padding: 8px 16px; border-radius: 8px; text-decoration: none;">
                        <svg style="width: 16px; height: 16px; display: inline-block; vertical-align: middle; margin-right: 4px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M19 12H5"/>
                            <path d="M12 19l-7-7 7-7"/>
                        </svg>
                        Retour aux chapitres
                    </a>
                    <a href="{{ path('app_cours_chapitre_quiz_new', {'coursId': cours.id, 'chapitreId': chapitre.id}) }}" class="card-btn" style="background: linear-gradient(135deg, var(--emerald-light), var(--emerald)); color: white; padding: 8px 16px; border-radius: 8px; text-decoration: none;">
                        <svg style="width: 16px; height: 16px; display: inline-block; vertical-align: middle; margin-right: 4px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="12" y1="5" x2="12" y2="19"/>
                            <line x1="5" y1="12" x2="19" y2="12"/>
                        </svg>
                        Nouveau Quiz
                    </a>
                </div>
            </div>
            <div class="table-wrapper">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Titre</th>
                            <th>Description</th>
                            <th>État</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for quiz in quizzes %}
                        <tr>
                            <td>
                                <div style="max-width: 250px;">
                                    <span style="font-weight: 500;">{{ quiz.titre }}</span>
                                </div>
                            </td>
                            <td>
                                <div style="max-width: 350px;">
                                    <span style="font-size: 0.85em; color: var(--text-secondary);">
                                        {{ quiz.description|length > 100 ? quiz.description|slice(0, 100) ~ '...' : quiz.description }}
                                    </span>
                                </div>
                            </td>
                            <td>
                                {% if quiz.etat == 'actif' %}
                                    <span class="status-badge active" style="background: rgba(34, 197, 94, 0.2); color: #22c55e;">Actif</span>
                                {% elseif quiz.etat == 'inactif' %}
                                    <span class="status-badge inactive" style="background: rgba(239, 68, 68, 0.2); color: #ef4444;">Inactif</span>
                                {% elseif quiz.etat == 'brouillon' %}
                                    <span class="status-badge pending" style="background: rgba(251, 191, 36, 0.2); color: #fbbf24;">Brouillon</span>
                                {% else %}
                                    <span class="status-badge" style="background: rgba(156, 163, 175, 0.2); color: #9ca3af;">Archivé</span>
                                {% endif %}
                            </td>
                            <td>
                                <div style="display: flex; gap: 8px;">
                                    <a href="{{ path('app_cours_chapitre_quiz_show', {'coursId': cours.id, 'chapitreId': chapitre.id, 'id': quiz.id}) }}" style="padding: 6px 12px; background: rgba(255,255,255,0.1); border-radius: 6px; text-decoration: none; color: var(--text-primary);" title="Voir">
                                        <svg style="width: 16px; height: 16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                            <circle cx="12" cy="12" r="3"/>
                                        </svg>
                                    </a>
                                    <a href="{{ path('app_cours_chapitre_quiz_edit', {'coursId': cours.id, 'chapitreId': chapitre.id, 'id': quiz.id}) }}" style="padding: 6px 12px; background: rgba(255,255,255,0.1); border-radius: 6px; text-decoration: none; color: var(--text-primary);" title="Modifier">
                                        <svg style="width: 16px; height: 16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                        </svg>
                                    </a>
                                    <form method="post" action="{{ path('app_cours_chapitre_quiz_delete', {'coursId': cours.id, 'chapitreId': chapitre.id, 'id': quiz.id}) }}" style="display: inline;" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce quiz ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ quiz.id) }}">
                                        <button type="submit" style="padding: 6px 12px; background: rgba(239, 68, 68, 0.2); border: none; border-radius: 6px; color: #ef4444; cursor: pointer;" title="Supprimer">
                                            <svg style="width: 16px; height: 16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <polyline points="3,6 5,6 21,6"/>
                                                <path d="M19,6v14a2,2 0 0,1 -2,2H7a2,2 0 0,1 -2,-2V6m3,0V4a2,2 0 0,1 2,-2h4a2,2 0 0,1 2,2v2"/>
                                            </svg>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" style="text-align: center; padding: 40px; color: var(--text-secondary);">
                                <svg style="width: 48px; height: 48px; margin-bottom: 16px; opacity: 0.5;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M9 11l3 3L22 4"/>
                                    <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
                                </svg>
                                <br>Aucun quiz trouvé pour ce chapitre
                                <br><a href="{{ path('app_cours_chapitre_quiz_new', {'coursId': cours.id, 'chapitreId': chapitre.id}) }}" style="color: var(--emerald); text-decoration: none;">Créer le premier quiz</a>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </section>
{% endblock %}
