{% extends 'backoffice/base.html.twig' %}

{% block title %}Modifier Quiz - {{ quiz.titre }}{% endblock %}
{% block page_title %}Modifier le quiz{% endblock %}

{% block body %}
    <section class="content-grid">
        <div class="glass-card form-card">
            <div class="card-header">
                <div>
                    <h2 class="card-title">Modifier le quiz</h2>
                    <p class="card-subtitle">{{ quiz.titre }} - Chapitre: {{ chapitre.titre }}</p>
                </div>
            </div>
            <div class="card-body">
                {{ form_start(form, {'attr': {'class': 'custom-form'}}) }}
                    <div class="form-group">
                        {{ form_label(form.titre) }}
                        {{ form_widget(form.titre, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.titre) }}
                        {% if form.titre.vars.help %}
                            <small class="form-help">{{ form.titre.vars.help }}</small>
                        {% endif %}
                    </div>

                    <div class="form-group">
                        {{ form_label(form.description) }}
                        {{ form_widget(form.description, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.description) }}
                        {% if form.description.vars.help %}
                            <small class="form-help">{{ form.description.vars.help }}</small>
                        {% endif %}
                    </div>

                    <div class="form-group">
                        {{ form_label(form.etat) }}
                        {{ form_widget(form.etat, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.etat) }}
                        {% if form.etat.vars.help %}
                            <small class="form-help">{{ form.etat.vars.help }}</small>
                        {% endif %}
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">
                            <svg style="width: 16px; height: 16px; display: inline-block; vertical-align: middle; margin-right: 4px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
                                <polyline points="17 21 17 13 7 13 7 21"/>
                                <polyline points="7 3 7 8 15 8"/>
                            </svg>
                            Enregistrer
                        </button>
                        <a href="{{ path('app_cours_chapitre_quizzes', {'coursId': cours.id, 'chapitreId': chapitre.id}) }}" class="btn btn-secondary">
                            <svg style="width: 16px; height: 16px; display: inline-block; vertical-align: middle; margin-right: 4px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M19 12H5"/>
                                <path d="M12 19l-7-7 7-7"/>
                            </svg>
                            Annuler
                        </a>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>

        <div class="glass-card" style="margin-top: 20px;">
            <div class="card-header">
                <h3 class="card-title" style="font-size: 1.1em;">Zone de danger</h3>
            </div>
            <div class="card-body">
                <form method="post" action="{{ path('app_cours_chapitre_quiz_delete', {'coursId': cours.id, 'chapitreId': chapitre.id, 'id': quiz.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce quiz ? Cette action est irréversible.');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ quiz.id) }}">
                    <button type="submit" class="btn btn-danger">
                        <svg style="width: 16px; height: 16px; display: inline-block; vertical-align: middle; margin-right: 4px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="3,6 5,6 21,6"/>
                            <path d="M19,6v14a2,2 0 0,1 -2,2H7a2,2 0 0,1 -2,-2V6m3,0V4a2,2 0 0,1 2,-2h4a2,2 0 0,1 2,2v2"/>
                        </svg>
                        Supprimer ce quiz
                    </button>
                </form>
            </div>
        </div>
    </section>
{% endblock %}
