{% extends 'backoffice/base.html.twig' %}

{% block title %}Gestion des Cours{% endblock %}
{% block page_title %}Gestion des Cours{% endblock %}

{% block body %}
    <section class="content-grid">
        <div class="glass-card table-card">
            <div class="card-header">
                <div>
                    <h2 class="card-title">Liste des Cours</h2>
                    <p class="card-subtitle">Gérer tous les cours disponibles</p>
                </div>
                <div class="card-actions">
                    <a href="{{ path('app_cours_new') }}" class="card-btn" style="background: linear-gradient(135deg, var(--emerald-light), var(--emerald)); color: white; padding: 8px 16px; border-radius: 8px; text-decoration: none;">
                        <svg style="width: 16px; height: 16px; display: inline-block; vertical-align: middle; margin-right: 4px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="12" y1="5" x2="12" y2="19"/>
                            <line x1="5" y1="12" x2="19" y2="12"/>
                        </svg>
                        Nouveau Cours
                    </a>
                </div>
            </div>
            <div class="table-wrapper">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Titre</th>
                            <th>Matière</th>
                            <th>Niveau</th>
                            <th>Durée (h)</th>
                            <th>Chapitres</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for cour in cours %}
                        <tr>
                            <td>{{ cour.id }}</td>
                            <td>
                                <div style="max-width: 300px;">
                                    <span style="font-weight: 500;">{{ cour.titre }}</span>
                                    {% if cour.description %}
                                        <br><span style="font-size: 0.85em; color: var(--text-secondary);">{{ cour.description|length > 50 ? cour.description|slice(0, 50) ~ '...' : cour.description }}</span>
                                    {% endif %}
                                </div>
                            </td>
                            <td><span class="status-badge completed">{{ cour.matiere }}</span></td>
                            <td>{{ cour.niveau }}</td>
                            <td>{{ cour.duree }}h</td>
                            <td>
                                <span class="status-badge pending" style="background: rgba(59, 130, 246, 0.2); color: #3b82f6;">
                                    {{ cour.chapitres|length }} chapitre{{ cour.chapitres|length > 1 ? 's' : '' }}
                                </span>
                            </td>
                            <td>
                                <div style="display: flex; gap: 8px;">
                                    <a href="{{ path('app_cours_show', {'id': cour.id}) }}" style="padding: 6px 12px; background: rgba(255,255,255,0.1); border-radius: 6px; text-decoration: none; color: var(--text-primary);" title="Voir">
                                        <svg style="width: 16px; height: 16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                            <circle cx="12" cy="12" r="3"/>
                                        </svg>
                                    </a>
                                    <a href="{{ path('app_cours_edit', {'id': cour.id}) }}" style="padding: 6px 12px; background: rgba(255,255,255,0.1); border-radius: 6px; text-decoration: none; color: var(--text-primary);" title="Modifier">
                                        <svg style="width: 16px; height: 16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                        </svg>
                                    </a>
                                    <a href="{{ path('app_cours_chapitres', {'id': cour.id}) }}" style="padding: 6px 12px; background: rgba(59, 130, 246, 0.2); border-radius: 6px; text-decoration: none; color: var(--text-primary);" title="Voir chapitres">
                                        <svg style="width: 16px; height: 16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
                                            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
                                        </svg>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="7" style="text-align: center; padding: 40px; color: var(--text-secondary);">
                                <svg style="width: 48px; height: 48px; margin-bottom: 16px; opacity: 0.5;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
                                    <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
                                </svg>
                                <br>Aucun cours trouvé
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </section>
{% endblock %}
