{{ form_start(form, {'attr': {'class': 'glass-form', 'novalidate': 'novalidate'}}) }}

{# Ajout de styles spécifiques pour les erreurs et le required #}
<style>
    .form-group {
        margin-bottom: 1.2rem;
        position: relative;
    }
    .form-label {
        display: block;
        margin-bottom: 6px;
        font-weight: 500;
        color: rgba(255,255,255,0.9);
        font-size: 0.95rem;
    }
    .required-asterisk {
        color: #ff6b6b;
        margin-left: 4px;
    }
    .error-message {
        color: #ff8a8a;
        font-size: 0.85rem;
        margin-top: 4px;
        margin-bottom: 6px;
        padding: 6px 12px;
        background: rgba(255, 107, 107, 0.1);
        border-left: 3px solid #ff6b6b;
        border-radius: 4px;
    }
    .form-input.error {
        border-color: #ff6b6b !important;
        box-shadow: 0 0 0 2px rgba(255, 107, 107, 0.2);
    }
</style>

<div class="form-grid">
    {% for field in form %}
        {% if field.vars.name != '_token' %}
            <div class="form-group">
                {# Label avec astérisque si le champ est obligatoire #}
                {{ form_label(field, null, {
                    'label_attr': {'class': 'form-label'},
                    'required': false   # On gère nous-mêmes l'affichage du required
                }) }}
                {% if field.vars.required %}
                    <span class="required-asterisk">obligatoire *</span>
                {% endif %}

                {# Messages d'erreur (affichés au-dessus du champ) #}
                {% if field.vars.errors|length > 0 %}
                    <div class="error-message">
                        {{ form_errors(field) }}
                    </div>
                {% endif %}

                {# Widget du champ avec classe 'error' en cas d'erreur #}
                {% set widget_class = 'form-input' %}
                {% if field.vars.errors|length > 0 %}
                    {% set widget_class = widget_class ~ ' error' %}
                {% endif %}

                {{ form_widget(field, {'attr': {'class': widget_class}}) }}
                {{ form_help(field) }}
            </div>
        {% endif %}
    {% endfor %}
</div>

<div style="margin-top: 24px; display: flex; gap: 12px;">
    <button type="submit" class="card-btn" style="background: linear-gradient(135deg, var(--emerald-light), var(--emerald)); color: white; padding: 12px 24px; border: none; cursor: pointer;">
        <svg style="width: 16px; height: 16px; display: inline-block; vertical-align: middle; margin-right: 4px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="20 6 9 17 4 12"/>
        </svg>
        {{ button_label|default('Enregistrer') }}
    </button>
    <a href="{{ path('app_cours_index') }}" class="card-btn">Annuler</a>
</div>

{# Script pour enlever le style d'erreur dès que l'utilisateur tape #}
<script>
    document.querySelectorAll('.form-input.error').forEach(function(input) {
        input.addEventListener('input', function() {
            this.classList.remove('error');
            // Cacher le message d'erreur associé
            let errorDiv = this.closest('.form-group').querySelector('.error-message');
            if (errorDiv) {
                errorDiv.style.display = 'none';
            }
        });
    });
</script>

{{ form_end(form) }}