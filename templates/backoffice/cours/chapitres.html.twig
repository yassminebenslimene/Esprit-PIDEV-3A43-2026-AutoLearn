{% extends 'backoffice/base.html.twig' %}

{% block title %}Chapitres - {{ cours.titre }}{% endblock %}
{% block page_title %}Chapitres du cours : {{ cours.titre }}{% endblock %}

{% block body %}
    <section class="content-grid">
        <div class="glass-card table-card">
            <div class="card-header">
                <div>
                    <h2 class="card-title">Chapitres du cours</h2>
                    <p class="card-subtitle">{{ cours.titre }} - {{ cours.matiere }} ({{ cours.niveau }})</p>
                </div>
                <div class="card-actions" style="display: flex; gap: 12px;">
                    <a href="{{ path('app_cours_index') }}" class="card-btn" style="background: rgba(255,255,255,0.1); color: var(--text-primary); padding: 8px 16px; border-radius: 8px; text-decoration: none;">
                        <svg style="width: 16px; height: 16px; display: inline-block; vertical-align: middle; margin-right: 4px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M19 12H5"/>
                            <path d="M12 19l-7-7 7-7"/>
                        </svg>
                        Retour aux cours
                    </a>
                    <button id="generateChapterBtn" class="card-btn" style="background: linear-gradient(135deg, #8b5cf6, #6366f1); color: white; padding: 8px 16px; border-radius: 8px; border: none; cursor: pointer; display: flex; align-items: center; gap: 6px;">
                        <svg style="width: 16px; height: 16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                            <path d="M2 17l10 5 10-5"/>
                            <path d="M2 12l10 5 10-5"/>
                        </svg>
                        <span id="generateBtnText">🤖 Générer un Chapitre avec l'IA</span>
                    </button>
                    <a href="{{ path('app_cours_chapitre_new', {'id': cours.id}) }}" class="card-btn" style="background: linear-gradient(135deg, var(--emerald-light), var(--emerald)); color: white; padding: 8px 16px; border-radius: 8px; text-decoration: none;">
                        <svg style="width: 16px; height: 16px; display: inline-block; vertical-align: middle; margin-right: 4px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="12" y1="5" x2="12" y2="19"/>
                            <line x1="5" y1="12" x2="19" y2="12"/>
                        </svg>
                        Nouveau Chapitre
                    </a>
                </div>
            </div>
            <div class="table-wrapper">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Ordre</th>
                            <th>Titre</th>
                            <th>Contenu</th>
                            <th>Ressources</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for chapitre in chapitres %}
                        <tr>
                            <td>
                                <span class="status-badge pending" style="background: rgba(59, 130, 246, 0.2); color: #3b82f6;">
                                    {{ chapitre.ordre }}
                                </span>
                            </td>
                            <td>
                                <div style="max-width: 250px;">
                                    <span style="font-weight: 500;">{{ chapitre.titre }}</span>
                                </div>
                            </td>
                            <td>
                                <div style="max-width: 300px;">
                                    <span style="font-size: 0.85em; color: var(--text-secondary);">
                                        {{ chapitre.contenu|length > 80 ? chapitre.contenu|slice(0, 80) ~ '...' : chapitre.contenu }}
                                    </span>
                                </div>
                            </td>
                            <td>
                                {% if chapitre.ressources %}
                                    <span style="font-size: 0.85em; color: var(--text-secondary);">{{ chapitre.ressources }}</span>
                                {% else %}
                                    <span style="font-size: 0.85em; color: var(--text-muted);">Aucune</span>
                                {% endif %}
                            </td>
                            <td>
                                <div style="display: flex; gap: 8px;">
                                    <a href="{{ path('app_cours_chapitre_show', {'coursId': cours.id, 'id': chapitre.id}) }}" style="padding: 6px 12px; background: rgba(255,255,255,0.1); border-radius: 6px; text-decoration: none; color: var(--text-primary);" title="Voir">
                                        <svg style="width: 16px; height: 16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                            <circle cx="12" cy="12" r="3"/>
                                        </svg>
                                    </a>
                                    <a href="{{ path('app_cours_chapitre_quizzes', {'coursId': cours.id, 'chapitreId': chapitre.id}) }}" style="padding: 6px 12px; background: rgba(139, 92, 246, 0.2); border-radius: 6px; text-decoration: none; color: #8b5cf6;" title="Voir Quiz">
                                        <svg style="width: 16px; height: 16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M9 11l3 3L22 4"/>
                                            <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
                                        </svg>
                                    </a>
                                    <a href="{{ path('app_cours_chapitre_edit', {'coursId': cours.id, 'id': chapitre.id}) }}" style="padding: 6px 12px; background: rgba(255,255,255,0.1); border-radius: 6px; text-decoration: none; color: var(--text-primary);" title="Modifier">
                                        <svg style="width: 16px; height: 16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                        </svg>
                                    </a>
                                    <form method="post" action="{{ path('app_cours_chapitre_delete', {'coursId': cours.id, 'id': chapitre.id}) }}" style="display: inline;" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce chapitre ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ chapitre.id) }}">
                                        <button type="submit" style="padding: 6px 12px; background: rgba(239, 68, 68, 0.2); border: none; border-radius: 6px; color: #ef4444; cursor: pointer;" title="Supprimer">
                                            <svg style="width: 16px; height: 16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <polyline points="3,6 5,6 21,6"/>
                                                <path d="M19,6v14a2,2 0 0,1 -2,2H7a2,2 0 0,1 -2,-2V6m3,0V4a2,2 0 0,1 2,-2h4a2,2 0 0,1 2,2v2"/>
                                            </svg>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" style="text-align: center; padding: 40px; color: var(--text-secondary);">
                                <svg style="width: 48px; height: 48px; margin-bottom: 16px; opacity: 0.5;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
                                    <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
                                </svg>
                                <br>Aucun chapitre trouvé pour ce cours
                                <br><a href="{{ path('app_cours_chapitre_new', {'id': cours.id}) }}" style="color: var(--emerald); text-decoration: none;">Créer le premier chapitre</a>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </section>

    <!-- Modal pour saisir le titre du chapitre -->
    <div id="chapterTitleModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); z-index: 9999; align-items: center; justify-content: center;">
        <div style="background: linear-gradient(135deg, rgba(30, 41, 59, 0.95), rgba(15, 23, 42, 0.95)); padding: 32px; border-radius: 16px; max-width: 500px; width: 90%; box-shadow: 0 20px 60px rgba(0,0,0,0.5); border: 1px solid rgba(255,255,255,0.1);">
            <h3 style="margin: 0 0 20px 0; color: white; font-size: 24px;">🤖 Générer un Chapitre avec l'IA</h3>
            <p style="color: rgba(255,255,255,0.7); margin-bottom: 20px; font-size: 14px;">Entrez le titre du chapitre et choisissez le niveau de difficulté. L'IA créera automatiquement le contenu complet adapté.</p>
            
            <label style="display: block; color: rgba(255,255,255,0.9); margin-bottom: 8px; font-weight: 500;">Titre du chapitre :</label>
            <input type="text" id="chapterTitleInput" placeholder="Ex: Introduction aux bases de données relationnelles" style="width: 100%; padding: 12px; border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; background: rgba(255,255,255,0.05); color: white; font-size: 14px; margin-bottom: 20px;" />
            
            <label style="display: block; color: rgba(255,255,255,0.9); margin-bottom: 8px; font-weight: 500;">Niveau de difficulté :</label>
            <select id="chapterLevelSelect" style="width: 100%; padding: 12px; border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; background: rgba(255,255,255,0.05); color: white; font-size: 14px; margin-bottom: 24px; cursor: pointer;">
                <option value="debutant" style="background: #1e293b; color: white;">🟢 Débutant</option>
                <option value="intermediaire" style="background: #1e293b; color: white;">🟡 Intermédiaire</option>
                <option value="avance" style="background: #1e293b; color: white;">🔴 Avancé</option>
            </select>
            
            <div style="display: flex; gap: 12px; justify-content: flex-end;">
                <button id="cancelModalBtn" style="padding: 10px 20px; background: rgba(255,255,255,0.1); border: none; border-radius: 8px; color: white; cursor: pointer; font-size: 14px;">Annuler</button>
                <button id="confirmGenerateBtn" style="padding: 10px 20px; background: linear-gradient(135deg, #8b5cf6, #6366f1); border: none; border-radius: 8px; color: white; cursor: pointer; font-size: 14px; font-weight: 500;">Générer</button>
            </div>
        </div>
    </div>

    <script>
    document.addEventListener('DOMContentLoaded', function() {
        const generateBtn = document.getElementById('generateChapterBtn');
        const btnText = document.getElementById('generateBtnText');
        const modal = document.getElementById('chapterTitleModal');
        const titleInput = document.getElementById('chapterTitleInput');
        const cancelBtn = document.getElementById('cancelModalBtn');
        const confirmBtn = document.getElementById('confirmGenerateBtn');
        const coursId = {{ cours.id }};

        // Ouvrir le modal quand on clique sur le bouton
        generateBtn.addEventListener('click', function() {
            modal.style.display = 'flex';
            titleInput.value = '';
            document.getElementById('chapterLevelSelect').value = 'debutant';
            titleInput.focus();
        });

        // Fermer le modal
        cancelBtn.addEventListener('click', function() {
            modal.style.display = 'none';
        });

        // Fermer le modal si on clique en dehors
        modal.addEventListener('click', function(e) {
            if (e.target === modal) {
                modal.style.display = 'none';
            }
        });

        // Générer le chapitre avec le titre saisi
        confirmBtn.addEventListener('click', async function() {
            const chapterTitle = titleInput.value.trim();
            const chapterLevel = document.getElementById('chapterLevelSelect').value;
            
            if (!chapterTitle) {
                alert('Veuillez entrer un titre pour le chapitre');
                return;
            }

            // Fermer le modal
            modal.style.display = 'none';

            // Désactiver le bouton
            generateBtn.disabled = true;
            btnText.textContent = '⏳ Génération en cours...';
            generateBtn.style.opacity = '0.7';
            generateBtn.style.cursor = 'not-allowed';

            try {
                console.log('Envoi de la requête pour générer le chapitre:', chapterTitle, 'Niveau:', chapterLevel);
                
                const response = await fetch(`/backoffice/ai-generator/generate-chapter/${coursId}`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        chapterTitle: chapterTitle,
                        chapterLevel: chapterLevel
                    })
                });

                console.log('Réponse reçue, status:', response.status);

                if (!response.ok) {
                    const errorText = await response.text();
                    console.error('Erreur HTTP:', response.status, errorText);
                    throw new Error(`Erreur HTTP ${response.status}: ${errorText}`);
                }

                const data = await response.json();
                console.log('Données reçues:', data);

                if (data.success) {
                    // Afficher un message de succès
                    btnText.textContent = '✅ Chapitre généré !';
                    generateBtn.style.background = 'linear-gradient(135deg, #10b981, #059669)';
                    
                    // Recharger la page après 1 seconde pour afficher le nouveau chapitre
                    setTimeout(() => {
                        window.location.reload();
                    }, 1000);
                } else {
                    // Afficher l'erreur
                    console.error('Erreur de génération:', data.error);
                    btnText.textContent = '❌ Erreur: ' + (data.error || 'Erreur inconnue');
                    generateBtn.style.background = 'linear-gradient(135deg, #ef4444, #dc2626)';
                    
                    // Réactiver le bouton après 3 secondes
                    setTimeout(() => {
                        resetButton();
                    }, 3000);
                }
            } catch (error) {
                console.error('Erreur complète:', error);
                btnText.textContent = '❌ ' + error.message;
                generateBtn.style.background = 'linear-gradient(135deg, #ef4444, #dc2626)';
                
                // Réactiver le bouton après 5 secondes
                setTimeout(() => {
                    resetButton();
                }, 5000);
            }
        });

        // Permettre de valider avec Enter
        titleInput.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                confirmBtn.click();
            }
        });

        function resetButton() {
            generateBtn.disabled = false;
            btnText.textContent = '🤖 Générer un Chapitre avec l\'IA';
            generateBtn.style.background = 'linear-gradient(135deg, #8b5cf6, #6366f1)';
            generateBtn.style.opacity = '1';
            generateBtn.style.cursor = 'pointer';
        }
    });
    </script>
{% endblock %}