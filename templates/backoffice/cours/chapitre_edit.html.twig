{% extends 'backoffice/base.html.twig' %}

{% block title %}Modifier {{ chapitre.titre }} - {{ cours.titre }}{% endblock %}
{% block page_title %}Modifier le chapitre{% endblock %}

{% block body %}
    <section class="content-grid">
        <div class="glass-card form-card">
            <div class="card-header">
                <div>
                    <h2 class="card-title">Modifier le chapitre</h2>
                    <p class="card-subtitle">{{ chapitre.titre }} - Cours : {{ cours.titre }}</p>
                </div>
                <div class="card-actions" style="display: flex; gap: 12px;">
                    <a href="{{ path('app_cours_chapitre_show', {'coursId': cours.id, 'id': chapitre.id}) }}" class="card-btn" style="background: rgba(255,255,255,0.1); color: var(--text-primary); padding: 8px 16px; border-radius: 8px; text-decoration: none;">
                        <svg style="width: 16px; height: 16px; display: inline-block; vertical-align: middle; margin-right: 4px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                            <circle cx="12" cy="12" r="3"/>
                        </svg>
                        Voir le chapitre
                    </a>
                    <a href="{{ path('app_cours_chapitres', {'id': cours.id}) }}" class="card-btn" style="background: rgba(255,255,255,0.1); color: var(--text-primary); padding: 8px 16px; border-radius: 8px; text-decoration: none;">
                        <svg style="width: 16px; height: 16px; display: inline-block; vertical-align: middle; margin-right: 4px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M19 12H5"/>
                            <path d="M12 19l-7-7 7-7"/>
                        </svg>
                        Retour aux chapitres
                    </a>
                </div>
            </div>
            
            <div class="form-container">
                {{ form_start(form, {'attr': {'class': 'form-grid', 'enctype': 'multipart/form-data'}}) }}
                
                <div class="form-group">
                    {{ form_label(form.titre, 'Titre du chapitre', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.titre, {'attr': {'class': 'form-input', 'placeholder': 'Entrez le titre du chapitre'}}) }}
                    {{ form_errors(form.titre) }}
                </div>

                <div class="form-group">
                    {{ form_label(form.ordre, 'Ordre', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.ordre, {'attr': {'class': 'form-input', 'placeholder': 'Numéro d\'ordre du chapitre'}}) }}
                    {{ form_errors(form.ordre) }}
                </div>

                <div class="form-group full-width">
                    {{ form_label(form.contenu, 'Contenu', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.contenu, {'attr': {'class': 'form-textarea', 'rows': '8', 'placeholder': 'Contenu détaillé du chapitre'}}) }}
                    {{ form_errors(form.contenu) }}
                </div>

                <div class="form-group full-width">
                    {{ form_label(form.ressourceType, 'Type de ressource', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.ressourceType, {'attr': {'class': 'form-input', 'id': 'ressource-type-select', 'onchange': 'toggleRessourceFields()'}}) }}
                    {{ form_errors(form.ressourceType) }}
                </div>

                <div class="form-group full-width" id="ressource-lien-group" style="display: none;">
                    {{ form_label(form.ressources, 'Lien de la ressource', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.ressources, {'attr': {'class': 'form-input', 'placeholder': 'https://drive.google.com/... ou https://youtube.com/...'}}) }}
                    {{ form_errors(form.ressources) }}
                    <small style="color: rgba(255,255,255,0.6); margin-top: 4px; display: block;">
                        Exemples : Google Drive, YouTube, Vimeo, etc.
                    </small>
                </div>

                <div class="form-group full-width" id="ressource-fichier-group" style="display: none;">
                    {{ form_label(form.ressourceFichierUpload, 'Fichier de ressource', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.ressourceFichierUpload, {'attr': {'class': 'form-input', 'accept': '.pdf,.pptx,.ppt,.docx,.doc,.zip,.rar,.mp4,.avi,.mov'}}) }}
                    {{ form_errors(form.ressourceFichierUpload) }}
                    {% if chapitre.ressourceFichier %}
                        <div style="margin-top: 8px; padding: 8px; background: rgba(255,255,255,0.05); border-radius: 4px;">
                            <small style="color: rgba(255,255,255,0.8);">
                                Fichier actuel : <strong>{{ chapitre.ressourceFichier }}</strong>
                            </small>
                        </div>
                    {% endif %}
                    <small style="color: rgba(255,255,255,0.6); margin-top: 4px; display: block;">
                        Taille maximale : 100 Mo. Formats acceptés : PDF, PPTX, DOCX, ZIP, RAR, MP4, AVI, MOV
                    </small>
                </div>

                {# Le champ cours est automatiquement défini, on le cache #}
                {{ form_widget(form.cours, {'attr': {'style': 'display: none;'}}) }}

                <div class="form-actions full-width">
                    <button type="submit" class="btn btn-primary">
                        <svg style="width: 16px; height: 16px; display: inline-block; vertical-align: middle; margin-right: 4px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="20,6 9,17 4,12"/>
                        </svg>
                        Enregistrer les modifications
                    </button>
                    <a href="{{ path('app_cours_chapitre_show', {'coursId': cours.id, 'id': chapitre.id}) }}" class="btn btn-secondary">Annuler</a>
                </div>

                {{ form_end(form) }}
            </div>
        </div>
    </section>

    <script type="text/javascript">
        function toggleRessourceFields() {
            var select = document.getElementById('ressource-type-select');
            var lienGroup = document.getElementById('ressource-lien-group');
            var fichierGroup = document.getElementById('ressource-fichier-group');
            
            if (!select || !lienGroup || !fichierGroup) {
                console.error('Elements not found');
                return;
            }
            
            var value = select.value;
            console.log('Selected value:', value);
            
            // Hide all first
            lienGroup.style.display = 'none';
            fichierGroup.style.display = 'none';
            
            // Show the right one
            if (value === 'lien') {
                lienGroup.style.display = 'block';
                console.log('Showing lien group');
            } else if (value === 'fichier') {
                fichierGroup.style.display = 'block';
                console.log('Showing fichier group');
            }
        }
        
        // Execute immediately when script loads
        setTimeout(toggleRessourceFields, 100);
        
        // Also execute when DOM is ready
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', toggleRessourceFields);
        }
    </script>
{% endblock %}