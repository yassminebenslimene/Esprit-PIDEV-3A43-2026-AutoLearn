{% extends 'backoffice/base.html.twig' %}

{% block title %}{{ chapitre.titre }} - {{ cours.titre }}{% endblock %}
{% block page_title %}Chapitre : {{ chapitre.titre }}{% endblock %}

{% block body %}
    <section class="content-grid">
        <div class="glass-card">
            <div class="card-header">
                <div>
                    <h2 class="card-title">{{ chapitre.titre }}</h2>
                    <p class="card-subtitle">Cours : {{ cours.titre }} - Ordre : {{ chapitre.ordre }}</p>
                </div>
                <div class="card-actions" style="display: flex; gap: 12px;">
                    <a href="{{ path('app_cours_chapitres', {'id': cours.id}) }}" class="card-btn" style="background: rgba(255,255,255,0.1); color: var(--text-primary); padding: 8px 16px; border-radius: 8px; text-decoration: none;">
                        <svg style="width: 16px; height: 16px; display: inline-block; vertical-align: middle; margin-right: 4px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M19 12H5"/>
                            <path d="M12 19l-7-7 7-7"/>
                        </svg>
                        Retour aux chapitres
                    </a>
                    <a href="{{ path('app_cours_chapitre_edit', {'coursId': cours.id, 'id': chapitre.id}) }}" class="card-btn" style="background: linear-gradient(135deg, var(--emerald-light), var(--emerald)); color: white; padding: 8px 16px; border-radius: 8px; text-decoration: none;">
                        <svg style="width: 16px; height: 16px; display: inline-block; vertical-align: middle; margin-right: 4px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                        </svg>
                        Modifier
                    </a>
                </div>
            </div>
            
            <div style="padding: 24px;">
                <div class="info-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 32px;">
                    <div class="info-item">
                        <label style="display: block; font-weight: 500; color: var(--text-secondary); margin-bottom: 8px;">Cours</label>
                        <div style="padding: 12px; background: rgba(255,255,255,0.05); border-radius: 8px;">
                            {{ cours.titre }}
                        </div>
                    </div>
                    <div class="info-item">
                        <label style="display: block; font-weight: 500; color: var(--text-secondary); margin-bottom: 8px;">Ordre</label>
                        <div style="padding: 12px; background: rgba(255,255,255,0.05); border-radius: 8px;">
                            <span class="status-badge pending" style="background: rgba(59, 130, 246, 0.2); color: #3b82f6;">
                                Chapitre {{ chapitre.ordre }}
                            </span>
                        </div>
                    </div>
                </div>

                <div class="content-section" style="margin-bottom: 32px;">
                    <label style="display: block; font-weight: 500; color: var(--text-secondary); margin-bottom: 12px;">Contenu</label>
                    <div style="padding: 20px; background: rgba(255,255,255,0.05); border-radius: 8px; line-height: 1.6;">
                        {{ chapitre.contenu|nl2br }}
                    </div>
                </div>

                {% if chapitre.ressources %}
                <div class="resources-section">
                    <label style="display: block; font-weight: 500; color: var(--text-secondary); margin-bottom: 12px;">Ressources</label>
                    <div style="padding: 16px; background: rgba(255,255,255,0.05); border-radius: 8px;">
                        {{ chapitre.ressources }}
                    </div>
                </div>
                {% endif %}
            </div>
        </div>

        <div class="glass-card">
            <div class="card-header">
                <h3 class="card-title">Actions</h3>
            </div>
            <div style="padding: 24px;">
                <div style="display: flex; gap: 12px; flex-wrap: wrap;">
                    <a href="{{ path('app_cours_chapitre_edit', {'coursId': cours.id, 'id': chapitre.id}) }}" class="btn btn-primary">
                        <svg style="width: 16px; height: 16px; display: inline-block; vertical-align: middle; margin-right: 4px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                        </svg>
                        Modifier ce chapitre
                    </a>
                    
                    <form method="post" action="{{ path('app_cours_chapitre_delete', {'coursId': cours.id, 'id': chapitre.id}) }}" style="display: inline;" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce chapitre ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ chapitre.id) }}">
                        <button type="submit" class="btn btn-danger">
                            <svg style="width: 16px; height: 16px; display: inline-block; vertical-align: middle; margin-right: 4px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="3,6 5,6 21,6"/>
                                <path d="M19,6v14a2,2 0 0,1 -2,2H7a2,2 0 0,1 -2,-2V6m3,0V4a2,2 0 0,1 2,-2h4a2,2 0 0,1 2,2v2"/>
                            </svg>
                            Supprimer
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </section>
{% endblock %}