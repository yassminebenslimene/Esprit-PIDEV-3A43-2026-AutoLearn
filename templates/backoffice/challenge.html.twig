<script>
    // Variables pour les filtres
    let searchTimeout;
    
    // Éléments DOM
    const searchTitle = document.getElementById('searchTitle');
    const filterNiveau = document.getElementById('filterNiveau');
    const searchCreatedBy = document.getElementById('searchCreatedBy');
    const applyBtn = document.getElementById('applyFilters');
    const resetBtn = document.getElementById('resetFilters');
    const loadingOverlay = document.getElementById('loadingOverlay');
    const tableBody = document.getElementById('challengesTableBody');
    const resultsCount = document.getElementById('resultsCount');
    
    // Fonction pour charger les challenges filtrés via AJAX
    function loadFilteredChallenges() {
        // Afficher le loader
        if (loadingOverlay) loadingOverlay.classList.add('active');
        
        // Récupérer les valeurs des filtres
        const filters = {
            titre: searchTitle ? searchTitle.value : '',
            niveau: filterNiveau ? filterNiveau.value : '',
            createdBy: searchCreatedBy ? searchCreatedBy.value : ''
        };
        
        console.log('🔍 Filtres envoyés:', filters);
        
        // Envoyer la requête AJAX
        fetch('{{ path('backoffice_challenges_filter') }}', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify(filters)
        })
        .then(response => {
            console.log('📡 Statut réponse:', response.status);
            if (!response.ok) {
                throw new Error('Erreur HTTP: ' + response.status);
            }
            return response.json();
        })
        .then(data => {
            console.log('✅ Données reçues:', data);
            // Mettre à jour le tableau
            updateTable(data.challenges);
            // Mettre à jour le compteur
            if (resultsCount) {
                resultsCount.innerHTML = `<span>${data.count}</span> résultat(s) trouvé(s)`;
            }
        })
        .catch(error => {
            console.error('❌ Erreur lors du filtrage:', error);
        })
        .finally(() => {
            // Cacher le loader
            if (loadingOverlay) loadingOverlay.classList.remove('active');
        });
    }
    
    // Fonction pour mettre à jour le tableau
    function updateTable(challenges) {
        if (!tableBody) return;
        
        if (challenges.length === 0) {
            tableBody.innerHTML = `
                <tr>
                    <td colspan="6" style="text-align: center; padding: 40px; color: var(--text-muted);">
                        Aucun challenge trouvé
                    </td>
                </tr>
            `;
            return;
        }
        
        let html = '';
        challenges.forEach(challenge => {
            const niveauClass = challenge.niveau === 'Débutant' ? 'completed' : 
                               (challenge.niveau === 'Intermédiaire' ? 'processing' : 'pending');
            
            html += `
                <tr>
                    <td>${escapeHtml(challenge.titre)}</td>
                    <td>${escapeHtml(challenge.description)}</td>
                    <td>${challenge.duree || ''} min</td>
                    <td>
                        <span class="status-badge ${niveauClass}">
                            ${escapeHtml(challenge.niveau)}
                        </span>
                    </td>
                    <td>${challenge.createdBy ? escapeHtml(challenge.createdBy.nom) : 'N/A'}</td>
                    <td>
                        <div style="display: flex; gap: 8px;">
                            <a href="/backoffice/challenge/edit/${challenge.id}" 
                               class="btn btn-warning btn-sm" 
                               style="background: linear-gradient(135deg, var(--gold), var(--amber)); color: white; padding: 6px 12px; border-radius: 8px; text-decoration: none; font-size: 12px;">
                                ✏ Edit
                            </a>
                            <a href="/backoffice/challenge/delete/${challenge.id}" 
                               class="btn btn-danger btn-sm" 
                               onclick="return confirm('Confirmer la suppression ?')"
                               style="background: linear-gradient(135deg, var(--coral), var(--gold)); color: white; padding: 6px 12px; border-radius: 8px; text-decoration: none; font-size: 12px;">
                                🗑 Delete
                            </a>
                        </div>
                    </td>
                </tr>
            `;
        });
        
        tableBody.innerHTML = html;
    }
    
    // Fonction pour échapper les caractères HTML
    function escapeHtml(unsafe) {
        if (!unsafe) return '';
        return unsafe
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#039;");
    }
    
    // Fonction pour réinitialiser les filtres
    function resetFilters() {
        if (searchTitle) searchTitle.value = '';
        if (filterNiveau) filterNiveau.value = '';
        if (searchCreatedBy) searchCreatedBy.value = '';
        loadFilteredChallenges();
    }
    
    // Événements
    if (applyBtn) {
        applyBtn.addEventListener('click', loadFilteredChallenges);
    }
    
    if (resetBtn) {
        resetBtn.addEventListener('click', resetFilters);
    }
    
    // Filtrage en temps réel avec debounce
    [searchTitle, filterNiveau, searchCreatedBy].forEach(input => {
        if (input) {
            // Pour les champs de texte
            if (input.tagName === 'INPUT') {
                input.addEventListener('input', function() {
                    clearTimeout(searchTimeout);
                    searchTimeout = setTimeout(loadFilteredChallenges, 500);
                });
            }
            // Pour le select
            if (input.tagName === 'SELECT') {
                input.addEventListener('change', function() {
                    clearTimeout(searchTimeout);
                    searchTimeout = setTimeout(loadFilteredChallenges, 500);
                });
            }
        }
    });
    
    // Initialisation du compteur
    document.addEventListener('DOMContentLoaded', function() {
        const initialCount = {{ challenges|length }};
        if (resultsCount) {
            resultsCount.innerHTML = `<span>${initialCount}</span> résultat(s) trouvé(s)`;
        }
    });
</script>
</html>