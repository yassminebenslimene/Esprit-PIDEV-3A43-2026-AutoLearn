    <style>
        /* Styles pour les filtres */
        .filter-section {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 10px;
            padding: 20px;
            margin-bottom: 25px;
        }
        
        .filter-title {
            font-size: 14px;
            font-weight: 600;
            color: var(--text-muted);
            margin-bottom: 15px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .filter-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            margin-bottom: 15px;
        }
        
        .filter-group {
            display: flex;
            flex-direction: column;
            gap: 5px;
        }
        
        .filter-group label {
            font-size: 12px;
            color: var(--text-muted);
            font-weight: 500;
        }
        
        .filter-input {
            padding: 10px 12px;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 8px;
            color: var(--text);
            font-size: 13px;
            transition: all 0.3s;
            font-family: inherit;
        }
        
        .filter-input:focus {
            border-color: var(--emerald-light);
            outline: none;
            background: rgba(255,255,255,0.08);
        }
        
        .filter-input::placeholder {
            color: rgba(255,255,255,0.3);
        }
        
        .filter-select {
            padding: 10px 12px;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 8px;
            color: var(--text);
            font-size: 13px;
            cursor: pointer;
            font-family: inherit;
        }
        
        .filter-select option {
            background: #1a1a2e;
            color: var(--text);
        }
        
        .filter-actions {
            display: flex;
            gap: 10px;
            justify-content: flex-end;
            margin-top: 10px;
        }
        
        .filter-btn {
            padding: 8px 16px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s;
            border: none;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }
        
        .filter-btn i {
            font-size: 14px;
        }
        
        .filter-btn.apply {
            background: linear-gradient(135deg, var(--emerald-light), var(--emerald));
            color: white;
        }
        
        .filter-btn.reset {
            background: rgba(255,255,255,0.1);
            color: var(--text);
            border: 1px solid rgba(255,255,255,0.2);
        }
        
        .filter-btn.apply:hover, .filter-btn.reset:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }
        
        /* Indicateur de chargement */
        .loading-overlay {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.5);
            backdrop-filter: blur(3px);
            display: none;
            justify-content: center;
            align-items: center;
            border-radius: 10px;
            z-index: 10;
        }
        
        .loading-overlay.active {
            display: flex;
        }
        
        .loading-spinner {
            width: 40px;
            height: 40px;
            border: 3px solid rgba(255,255,255,0.3);
            border-top-color: var(--emerald-light);
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }
        
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
        
        .table-wrapper {
            position: relative;
            min-height: 200px;
        }
        
        /* Compteur de résultats */
        .results-count {
            font-size: 14px;
            color: var(--text-muted);
            margin-top: 10px;
            text-align: right;
        }
        
        .results-count span {
            color: var(--emerald-light);
            font-weight: 600;
        }
    </style>
</head>
