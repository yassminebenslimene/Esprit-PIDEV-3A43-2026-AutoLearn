{% extends 'backoffice/base.html.twig' %}

{% block title %}Gestion des Challenges{% endblock %}
{% block page_title %}Gestion des Challenges{% endblock %}

{% block body %}
    <div class="glass-card">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
            <h2 class="card-title">Liste des Challenges</h2>
            <a href="{{ path('backoffice_challenge_add') }}" class="btn btn-primary">
                ➕ Ajouter
            </a>
        </div>

        <div class="table-wrapper">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Titre</th>
                        <th>Description</th>
                        <th>Date début</th>
                        <th>Date fin</th>
                        <th>Niveau</th>
                        <th>Créé par</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for challenge in challenges %}
                    <tr>
                        <td>{{ challenge.titre }}</td>
                        <td>{{ challenge.description }}</td>
                        <td>{{ challenge.dateDebut|date('Y-m-d') }}</td>
                        <td>{{ challenge.dateFin|date('Y-m-d') }}</td>
                        <td>
                            <span class="status-badge {% if challenge.niveau == 'Facile' %}completed{% elseif challenge.niveau == 'Intermédiaire' %}processing{% else %}pending{% endif %}">
                                {{ challenge.niveau }}
                            </span>
                        </td>
                        <td>{{ challenge.createdBy ? challenge.createdBy.nom : 'N/A' }}</td>
                        <td>
                            <div style="display: flex; gap: 8px;">
                                <a href="{{ path('backoffice_challenge_edit', {'id': challenge.id}) }}" 
                                   class="btn btn-warning btn-sm" 
                                   style="background: linear-gradient(135deg, var(--gold), var(--amber)); color: white; padding: 6px 12px; border-radius: 8px; text-decoration: none; font-size: 12px;">
                                    ✏ Edit
                                </a>
                                <a href="{{ path('backoffice_challenge_delete', {'id': challenge.id}) }}" 
                                   class="btn btn-danger btn-sm" 
                                   onclick="return confirm('Confirmer la suppression ?')"
                                   style="background: linear-gradient(135deg, var(--coral), var(--gold)); color: white; padding: 6px 12px; border-radius: 8px; text-decoration: none; font-size: 12px;">
                                    🗑 Delete
                                </a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" style="text-align: center; padding: 40px; color: var(--text-muted);">
                            Aucun challenge trouvé
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
