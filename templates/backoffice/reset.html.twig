<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Reset Password - AutoLearn</title>
    <link rel="stylesheet" href="{{ asset('backoffice/css/templatemo-glass-admin-style.css') }}">
    <style>
        .alert {
            padding: 10px 15px;
            border-radius: 5px;
            margin: 10px 0;
        }
        .alert-error {
            background: #ffebee;
            color: #c62828;
            border: 1px solid #ffcdd2;
        }
        .alert-success {
            background: #e8f5e9;
            color: #2e7d32;
            border: 1px solid #c8e6c9;
        }
        .user-info {
            background: #f5f5f5;
            padding: 10px;
            border-radius: 5px;
            margin-bottom: 15px;
            font-size: 14px;
        }
        .error-message {
            color: #c62828;
            font-size: 14px;
            margin-top: 5px;
            display: block;
        }
        .input-error {
            border-color: #c62828 !important;
            box-shadow: 0 0 0 2px rgba(198, 40, 40, 0.2) !important;
        }
    </style>
</head>
<body>
    <div class="background"></div>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>

    <div class="login-page">
        <div class="login-container">
            <div class="login-card">
                <div class="login-header">
                    <div class="login-logo">A</div>
                    <h1 class="login-title">Reset Password</h1>
                    <p class="login-subtitle">Create a new password for your account</p>
                </div>
                
                {# Afficher seulement les messages de succès #}
                {% for message in app.flashes('success') %}
                    <div class="alert alert-success">
                        {{ message }}
                    </div>
                {% endfor %}
                
                {# Afficher les erreurs globales #}
                {% for message in app.flashes('error') %}
                    <div class="alert alert-error">
                        {{ message }}
                    </div>
                {% endfor %}
                
                {% if email %}
                    <div class="user-info">
                        <strong>Account:</strong> {{ email }}
                    </div>
                {% endif %}
                
                {# Formulaire avec validation HTML5 désactivée #}
                <form method="post" novalidate="novalidate">
                    {# Champ mot de passe - Validation serveur seulement #}
                    <div class="form-group">
                        <label class="form-label">New Password</label>
                        <input type="password" name="password" class="form-input {% if errors.password is defined and errors.password|length > 0 %}input-error{% endif %}" 
                               placeholder="Minimum 8 characters avec : majuscule, minuscule, chiffre, caractère spécial">
                        {# Afficher les erreurs serveur #}
                        {% if errors.password is defined %}
                            {% for error in errors.password %}
                                <span class="error-message">{{ error }}</span>
                            {% endfor %}
                        {% endif %}
                        <small style="color: var(--text-muted); font-size: 12px; margin-top: 5px; display: block;">
                            Exigences: 8+ caractères, majuscule, minuscule, chiffre, caractère spécial (@$!%*?&)
                        </small>
                    </div>
                    
                    {# Champ confirmation - Validation serveur seulement #}
                    <div class="form-group">
                        <label class="form-label">Confirm Password</label>
                        <input type="password" name="confirm_password" class="form-input {% if errors.confirm_password is defined and errors.confirm_password|length > 0 %}input-error{% endif %}" 
                               placeholder="Confirm your password">
                        {# Afficher les erreurs serveur #}
                        {% if errors.confirm_password is defined %}
                            {% for error in errors.confirm_password %}
                                <span class="error-message">{{ error }}</span>
                            {% endfor %}
                        {% endif %}
                    </div>
                    
                    <button type="submit" class="btn btn-primary" style="width: 100%; margin-bottom: 10px;">
                        Reset Password
                    </button>
                    
                    <a href="{{ path('app_forgot_password') }}" class="btn btn-secondary" style="width: 100%;">
                        ← Back to Forgot Password
                    </a>
                </form>
            </div>
        </div>
    </div>
</body>
</html>