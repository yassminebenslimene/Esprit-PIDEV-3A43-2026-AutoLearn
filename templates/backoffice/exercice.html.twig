<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GlassAdmin Dashboard - Gestion des Exercices</title>
    <meta name="description" content="3D Glassmorphism Dashboard Template by TemplateMo">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('backoffice/css/templatemo-glass-admin-style.css') }}">
    <!--
TemplateMo 607 Glass Admin
https://templatemo.com/tm-607-glass-admin
-->
</head>
<body>
    <!-- Animated Background -->
    <div class="background"></div>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>

    <div class="dashboard">
        {# Include Sidebar Component #}
        {% include 'backoffice/_sidebar.html.twig' %}

        <!-- Main Content -->
        <main class="main-content">
            <!-- Top Navbar -->
            <nav class="navbar">
                <h1 class="page-title">Gestion des Exercices</h1>
                <div class="navbar-right">
                    <div class="search-box">
                        <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="11" cy="11" r="8"/>
                            <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                        </svg>
                        <input type="text" class="search-input" placeholder="Search anything...">
                    </div>
                    <button class="nav-btn">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                            <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                        </svg>
                        <span class="notification-dot"></span>
                    </button>
                    <button class="nav-btn" id="theme-toggle" title="Toggle Light/Dark Mode">
                        <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="4"/>
                            <path d="M12 2v2"/><path d="M12 20v2"/>
                            <path d="M4.93 4.93l1.41 1.41"/><path d="M17.66 17.66l1.41 1.41"/>
                            <path d="M2 12h2"/><path d="M20 12h2"/>
                            <path d="M6.34 17.66l-1.41 1.41"/><path d="M19.07 4.93l-1.41 1.41"/>
                        </svg>
                        <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display: none;">
                            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                        </svg>
                    </button>
                </div>
            </nav>

            <!-- Content -->
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                <button onclick="openAIGeneratorModal()" 
                   class="btn btn-secondary" 
                   style="background: linear-gradient(135deg, #f3b562, #f0a53b); color: white; padding: 12px 24px; border: none; border-radius: 8px; font-weight: 600; cursor: pointer; display: inline-flex; align-items: center; gap: 8px;">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                        <path d="M2 17l10 5 10-5"/>
                        <path d="M2 12l10 5 10-5"/>
                    </svg>
                    🤖 Générer avec IA
                </button>
                <a href="{{ path('backoffice_exercice_add') }}" 
                   class="btn btn-primary" 
                   style="background: linear-gradient(135deg, var(--emerald-light), var(--emerald)); color: white; padding: 12px 24px; border: none; border-radius: 8px; font-weight: 600; text-decoration: none; display: inline-flex; align-items: center; gap: 8px;">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="12" y1="5" x2="12" y2="19"/>
                        <line x1="5" y1="12" x2="19" y2="12"/>
                    </svg>
                    + Ajouter un exercice
                </a>
            </div>

            <div class="glass-card">
                <div class="card-header">
                    <div>
                        <h2 class="card-title">Liste des Exercices</h2>
                        <p class="card-subtitle">Gestion des questions et réponses</p>
                    </div>
                    <div class="stat-icon cyan">
                        <svg viewBox="0 0 24 24" fill="none" stroke="var(--emerald-light)" stroke-width="2" width="24" height="24">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                            <circle cx="9" cy="7" r="4"/>
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                        </svg>
                    </div>
                </div>

                <div class="table-wrapper">
                    {% if exercices is empty %}
                        <div style="text-align: center; padding: 40px; color: var(--text-muted);">
                            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" style="margin-bottom: 16px;">
                                <circle cx="12" cy="12" r="10"/>
                                <line x1="12" y1="8" x2="12" y2="12"/>
                                <line x1="12" y1="16" x2="12.01" y2="16"/>
                            </svg>
                            <p style="font-size: 16px;">Aucun exercice trouvé.</p>
                        </div>
                    {% else %}
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Question</th>
                                    <th>Réponse</th>
                                    <th>Points</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for exercice in exercices %}
                                    <tr>
                                        <td><span style="font-weight: 600; color: var(--emerald-light);">#{{ exercice.id }}</span></td>
                                        <td>{{ exercice.question }}</td>
                                        <td>{{ exercice.reponse }}</td>
                                        <td>
                                            <span style="background: rgba(16, 185, 129, 0.1); color: var(--emerald-light); padding: 4px 10px; border-radius: 20px; font-weight: 600;">
                                                {{ exercice.points }} pts
                                            </span>
                                        </td>
                                        <td>
                                            <div style="display: flex; gap: 8px;">
                                                <a href="{{ path('backoffice_exercice_edit', {'id': exercice.id}) }}"
                                                   class="btn btn-warning btn-sm"
                                                   style="background: linear-gradient(135deg, var(--gold), var(--amber)); color: white; padding: 6px 12px; border-radius: 8px; text-decoration: none; font-size: 12px; display: inline-flex; align-items: center; gap: 4px;">
                                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                        <path d="M20 14.66V20a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h5.34"/>
                                                        <polygon points="18 2 22 6 12 16 8 16 8 12 18 2"/>
                                                    </svg>
                                                    Modifier
                                                </a>
                                                <a href="{{ path('backoffice_exercice_delete', {'id': exercice.id}) }}"
                                                   class="btn btn-danger btn-sm"
                                                   onclick="return confirm('Voulez-vous supprimer cet exercice ?')"
                                                   style="background: linear-gradient(135deg, var(--coral), var(--gold)); color: white; padding: 6px 12px; border-radius: 8px; text-decoration: none; font-size: 12px; display: inline-flex; align-items: center; gap: 4px;">
                                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                        <polyline points="3 6 5 6 21 6"/>
                                                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                                                        <line x1="10" y1="11" x2="10" y2="17"/>
                                                        <line x1="14" y1="11" x2="14" y2="17"/>
                                                    </svg>
                                                    Supprimer
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    {% endif %}
                </div>
            </div>
        </main>
    </div>

    <!-- Mobile Menu Toggle -->
    <button class="mobile-menu-toggle">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
    </button>

    <!-- Footer -->
    <footer class="site-footer">
        <p>Copyright © 2026 Your Company. Designed by <a href="https://templatemo.com" target="_blank" rel="nofollow">TemplateMo</a></p>
    </footer>

    <script src="{{ asset('backoffice/js/templatemo-glass-admin-script.js') }}"></script>
    <!-- TemplateMo 607 Glass Admin -->
    
    <!-- Modal de génération IA -->
    <div id="aiGeneratorModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); z-index: 9999; align-items: center; justify-content: center;">
        <div style="background: var(--glass-bg); backdrop-filter: blur(20px); border-radius: 20px; padding: 40px; max-width: 500px; width: 90%; box-shadow: 0 20px 60px rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1);">
            <h2 style="margin-bottom: 20px; color: var(--text); font-size: 24px;">🤖 Générer des exercices avec IA</h2>
            
            <div style="margin-bottom: 20px;">
                <label style="display: block; margin-bottom: 8px; color: var(--text); font-weight: 500;">Sujet</label>
                <input type="text" id="aiSujet" placeholder="Ex: Les boucles en PHP" style="width: 100%; padding: 12px; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; color: var(--text); font-family: inherit;">
            </div>
            
            <div style="margin-bottom: 20px;">
                <label style="display: block; margin-bottom: 8px; color: var(--text); font-weight: 500;">Niveau</label>
                <select id="aiNiveau" style="width: 100%; padding: 12px; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; color: var(--text); font-family: inherit;">
                    <option value="">Sélectionnez un niveau</option>
                    <option value="Débutant">Débutant</option>
                    <option value="Intermédiaire">Intermédiaire</option>
                    <option value="Avancé">Avancé</option>
                </select>
            </div>
            
            <div style="margin-bottom: 20px;">
                <label style="display: block; margin-bottom: 8px; color: var(--text); font-weight: 500;">Nombre d'exercices</label>
                <input type="number" id="aiNombre" value="5" min="1" max="10" style="width: 100%; padding: 12px; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; color: var(--text); font-family: inherit;">
            </div>
            
            <div id="aiGeneratorStatus" style="margin-bottom: 20px; padding: 12px; border-radius: 8px; display: none;"></div>
            
            <div style="display: flex; gap: 15px; justify-content: flex-end;">
                <button onclick="closeAIGeneratorModal()" style="padding: 12px 24px; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; color: var(--text); cursor: pointer; font-weight: 500;">
                    Annuler
                </button>
                <button onclick="generateExercices()" id="generateBtn" style="padding: 12px 24px; background: linear-gradient(135deg, #f3b562, #f0a53b); border: none; border-radius: 8px; color: white; cursor: pointer; font-weight: 600;">
                    🚀 Générer
                </button>
            </div>
        </div>
    </div>
    
    <script>
        function openAIGeneratorModal() {
            document.getElementById('aiGeneratorModal').style.display = 'flex';
        }
        
        function closeAIGeneratorModal() {
            document.getElementById('aiGeneratorModal').style.display = 'none';
            document.getElementById('aiGeneratorStatus').style.display = 'none';
            document.getElementById('aiSujet').value = '';
            document.getElementById('aiNiveau').value = '';
            document.getElementById('aiNombre').value = '5';
        }
        
        async function generateExercices() {
            const sujet = document.getElementById('aiSujet').value.trim();
            const niveau = document.getElementById('aiNiveau').value;
            const nombre = parseInt(document.getElementById('aiNombre').value);
            const statusDiv = document.getElementById('aiGeneratorStatus');
            const generateBtn = document.getElementById('generateBtn');
            
            // Validation
            if (!sujet) {
                statusDiv.style.display = 'block';
                statusDiv.style.background = 'rgba(241, 123, 123, 0.2)';
                statusDiv.style.color = '#f17b7b';
                statusDiv.innerHTML = '⚠️ Veuillez saisir un sujet';
                return;
            }
            
            if (!niveau) {
                statusDiv.style.display = 'block';
                statusDiv.style.background = 'rgba(241, 123, 123, 0.2)';
                statusDiv.style.color = '#f17b7b';
                statusDiv.innerHTML = '⚠️ Veuillez sélectionner un niveau';
                return;
            }
            
            // Afficher le statut de chargement
            statusDiv.style.display = 'block';
            statusDiv.style.background = 'rgba(127, 183, 126, 0.2)';
            statusDiv.style.color = '#7fb77e';
            statusDiv.innerHTML = '⏳ Génération en cours... Cela peut prendre quelques secondes.';
            generateBtn.disabled = true;
            generateBtn.style.opacity = '0.5';
            
            try {
                const response = await fetch('{{ path('backoffice_exercice_generate_ai') }}', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify({
                        sujet: sujet,
                        niveau: niveau,
                        nombre: nombre
                    })
                });
                
                const data = await response.json();
                
                if (data.success) {
                    statusDiv.style.background = 'rgba(127, 183, 126, 0.2)';
                    statusDiv.style.color = '#7fb77e';
                    statusDiv.innerHTML = `✅ ${data.count} exercice(s) généré(s) avec succès! Rechargement...`;
                    
                    // Recharger la page après 2 secondes
                    setTimeout(() => {
                        window.location.reload();
                    }, 2000);
                } else {
                    throw new Error(data.error || 'Erreur inconnue');
                }
            } catch (error) {
                statusDiv.style.background = 'rgba(241, 123, 123, 0.2)';
                statusDiv.style.color = '#f17b7b';
                statusDiv.innerHTML = `❌ Erreur: ${error.message}`;
                generateBtn.disabled = false;
                generateBtn.style.opacity = '1';
            }
        }
        
        // Fermer la modal en cliquant en dehors
        document.getElementById('aiGeneratorModal').addEventListener('click', function(e) {
            if (e.target === this) {
                closeAIGeneratorModal();
            }
        });
    </script>
    
    {# AI Chat Widget - Assistant Intelligent #}
    {% include 'ai_assistant/chat_widget.html.twig' %}
</body>
</html>