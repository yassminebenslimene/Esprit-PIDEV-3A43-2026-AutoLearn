<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AutoLearnAdmin Dashboard - 3D Glassmorphism Dashboard</title>
    <meta name="description" content="3D Glassmorphism Dashboard Template by TemplateMo">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('backoffice/css/templatemo-glass-admin-style.css') }}">
    <!--

TemplateMo 607 Glass Admin

https://templatemo.com/tm-607-glass-admin

-->
</head>
<body>
    <!-- Animated Background -->
    <div class="background"></div>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>

    <div class="dashboard">
        {# Include Sidebar Component #}
        {% include 'backoffice/_sidebar.html.twig' %}

        <!-- Main Content -->
        <main class="main-content">
            <!-- Top Navbar -->
            <nav class="navbar">
                <h1 class="page-title">Dashboard Overview</h1>
                <div class="navbar-right">
                    <div class="search-box">
                        <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="11" cy="11" r="8"/>
                            <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                        </svg>
                        <input type="text" class="search-input" placeholder="Search anything...">
                    </div>
                    <button class="nav-btn">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                            <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                        </svg>
                        <span class="notification-dot"></span>
                    </button>
                    <button class="nav-btn" id="theme-toggle" title="Toggle Light/Dark Mode">
                        <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="4"/>
                            <path d="M12 2v2"/><path d="M12 20v2"/>
                            <path d="M4.93 4.93l1.41 1.41"/><path d="M17.66 17.66l1.41 1.41"/>
                            <path d="M2 12h2"/><path d="M20 12h2"/>
                            <path d="M6.34 17.66l-1.41 1.41"/><path d="M19.07 4.93l-1.41 1.41"/>
                        </svg>
                        <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display: none;">
                            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                        </svg>
                    </button>
                </div>
            </nav>

            <!-- Stats Cards -->
            <section class="stats-grid">
                <div class="glass-card glass-card-3d stat-card">
                    <div class="stat-card-inner">
                        <div class="stat-info">
                            <h3>Total Étudiants</h3>
                            <div class="stat-value">{{ stats.totalEtudiants }}</div>
                            <span class="stat-change positive">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg>
                                Actifs
                            </span>
                        </div>
                        <div class="stat-icon cyan">
                            <svg viewBox="0 0 24 24" fill="none" stroke="var(--emerald-light)" stroke-width="2">
                                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
                                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                            </svg>
                        </div>
                    </div>
                </div>

                <div class="glass-card glass-card-3d stat-card">
                    <div class="stat-card-inner">
                        <div class="stat-info">
                            <h3>Total Cours</h3>
                            <div class="stat-value">{{ stats.totalCours }}</div>
                            <span class="stat-change positive">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg>
                                {{ stats.totalChapitres }} chapitres
                            </span>
                        </div>
                        <div class="stat-icon magenta">
                            <svg viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="2">
                                <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
                                <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
                            </svg>
                        </div>
                    </div>
                </div>

                <div class="glass-card glass-card-3d stat-card">
                    <div class="stat-card-inner">
                        <div class="stat-info">
                            <h3>Total Challenges</h3>
                            <div class="stat-value">{{ stats.totalChallenges }}</div>
                            <span class="stat-change positive">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg>
                                {{ stats.totalExercices }} exercices
                            </span>
                        </div>
                        <div class="stat-icon purple">
                            <svg viewBox="0 0 24 24" fill="none" stroke="var(--coral)" stroke-width="2">
                                <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                                <path d="M2 17l10 5 10-5M2 12l10 5 10-5"/>
                            </svg>
                        </div>
                    </div>
                </div>

                <div class="glass-card glass-card-3d stat-card">
                    <div class="stat-card-inner">
                        <div class="stat-info">
                            <h3>Événements</h3>
                            <div class="stat-value">{{ stats.totalEvenements }}</div>
                            <span class="stat-change positive">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg>
                                {{ stats.totalQuiz }} quiz
                            </span>
                        </div>
                        <div class="stat-icon success">
                            <svg viewBox="0 0 24 24" fill="none" stroke="var(--success)" stroke-width="2">
                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                                <line x1="16" y1="2" x2="16" y2="6"/>
                                <line x1="8" y1="2" x2="8" y2="6"/>
                                <line x1="3" y1="10" x2="21" y2="10"/>
                            </svg>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Content Grid -->
            <section class="content-grid">
                <!-- Chart Card -->
                <div class="glass-card chart-card">
                    <div class="card-header">
                        <div>
                            <h2 class="card-title">Activité Plateforme</h2>
                            <p class="card-subtitle">Statistiques mensuelles</p>
                        </div>
                        <div class="card-actions">
                            <button class="card-btn active">Mensuel</button>
                            <button class="card-btn">Hebdomadaire</button>
                        </div>
                    </div>
                    <div class="chart-wrapper">
                        <div class="chart-container">
                            <div class="chart-y-axis">
                                <span class="y-value">{{ stats.totalCours }}</span>
                                <span class="y-value">{{ (stats.totalCours * 0.8)|round }}</span>
                                <span class="y-value">{{ (stats.totalCours * 0.6)|round }}</span>
                                <span class="y-value">{{ (stats.totalCours * 0.4)|round }}</span>
                                <span class="y-value">{{ (stats.totalCours * 0.2)|round }}</span>
                                <span class="y-value">0</span>
                            </div>
                            <div class="chart-placeholder">
                                <div class="chart-bar-group"><div class="chart-bar bar-emerald" style="height: 80px;"></div><span class="chart-label">Cours</span></div>
                                <div class="chart-bar-group"><div class="chart-bar bar-gold" style="height: 120px;"></div><span class="chart-label">Chapitres</span></div>
                                <div class="chart-bar-group"><div class="chart-bar bar-coral" style="height: 90px;"></div><span class="chart-label">Quiz</span></div>
                                <div class="chart-bar-group"><div class="chart-bar bar-teal" style="height: 140px;"></div><span class="chart-label">Challenges</span></div>
                                <div class="chart-bar-group"><div class="chart-bar bar-amber" style="height: 100px;"></div><span class="chart-label">Exercices</span></div>
                                <div class="chart-bar-group"><div class="chart-bar bar-emerald" style="height: 70px;"></div><span class="chart-label">Événements</span></div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Activity Feed -->
                <div class="glass-card activity-card">
                    <div class="card-header">
                        <div>
                            <h2 class="card-title">Activité Récente</h2>
                            <p class="card-subtitle">Derniers utilisateurs</p>
                        </div>
                    </div>
                    <div class="activity-list">
                        {% for user in recentUsers %}
                        <div class="activity-item">
                            <div class="activity-avatar" style="background: linear-gradient(135deg, var(--emerald-light), var(--emerald));">
                                {{ user.prenom|slice(0, 1)|upper }}{{ user.nom|slice(0, 1)|upper }}
                            </div>
                            <div class="activity-content">
                                <p class="activity-text"><strong>{{ user.prenom }} {{ user.nom }}</strong> s'est inscrit</p>
                                <span class="activity-time">{{ user.email }}</span>
                            </div>
                        </div>
                        {% else %}
                        <div class="activity-item">
                            <div class="activity-content">
                                <p class="activity-text">Aucune activité récente</p>
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                </div>

                <!-- Data Table -->
                <div class="glass-card table-card">
                    <div class="card-header">
                        <div>
                            <h2 class="card-title">Challenges Actifs</h2>
                            <p class="card-subtitle">Derniers challenges créés</p>
                        </div>
                        <div class="card-actions">
                            <a href="{{ path('backoffice_challenges') }}" class="card-btn">Voir Tout</a>
                        </div>
                    </div>
                    <div class="table-wrapper">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Titre</th>
                                    <th>Niveau</th>
                                    <th>Durée</th>
                                    <th>Exercices</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for challenge in activeChallenges %}
                                <tr>
                                    <td>{{ challenge.titre }}</td>
                                    <td><span class="status-badge completed">{{ challenge.niveau }}</span></td>
                                    <td>{{ challenge.duree }} min</td>
                                    <td><span class="table-amount">{{ challenge.exercices|length }} exercices</span></td>
                                </tr>
                                {% else %}
                                <tr>
                                    <td colspan="4" style="text-align: center; padding: 40px; color: var(--text-muted);">
                                        Aucun challenge disponible
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>

            <!-- Bottom Grid -->
            <section class="bottom-grid">
                <!-- Platform Stats -->
                <div class="glass-card">
                    <div class="card-header">
                        <div>
                            <h2 class="card-title">Statistiques Communauté</h2>
                            <p class="card-subtitle">Engagement plateforme</p>
                        </div>
                    </div>
                    <div class="donut-container">
                        <div class="donut-chart">
                            <svg width="140" height="140" viewBox="0 0 140 140">
                                <circle class="donut-bg" cx="70" cy="70" r="54"/>
                                <circle class="donut-segment" cx="70" cy="70" r="54" stroke="var(--emerald-light)" stroke-dasharray="169.6 339.3" stroke-dashoffset="0"/>
                                <circle class="donut-segment" cx="70" cy="70" r="54" stroke="var(--gold)" stroke-dasharray="101.8 339.3" stroke-dashoffset="-169.6"/>
                                <circle class="donut-segment" cx="70" cy="70" r="54" stroke="var(--coral)" stroke-dasharray="67.9 339.3" stroke-dashoffset="-271.4"/>
                            </svg>
                            <div class="donut-center">
                                <div class="donut-value">{{ stats.totalCommunautes }}</div>
                                <div class="donut-label">Communautés</div>
                            </div>
                        </div>
                        <div class="donut-legend">
                            <div class="legend-item"><span class="legend-color cyan"></span><span>Posts ({{ stats.totalPosts }})</span></div>
                            <div class="legend-item"><span class="legend-color magenta"></span><span>Étudiants ({{ stats.totalEtudiants }})</span></div>
                            <div class="legend-item"><span class="legend-color purple"></span><span>Admins ({{ stats.totalAdmins }})</span></div>
                        </div>
                    </div>
                </div>

                <!-- Module Progress -->
                <div class="glass-card progress-card">
                    <div class="card-header">
                        <div>
                            <h2 class="card-title">Modules Plateforme</h2>
                            <p class="card-subtitle">Contenu disponible</p>
                        </div>
                    </div>
                    <div class="progress-item">
                        <div class="progress-header"><span class="progress-label">📚 Cours</span><span class="progress-value">{{ stats.totalCours }}</span></div>
                        <div class="progress-bar"><div class="progress-fill cyan" style="width: {{ (stats.totalCours / 20 * 100)|round }}%;"></div></div>
                    </div>
                    <div class="progress-item">
                        <div class="progress-header"><span class="progress-label">📝 Quiz</span><span class="progress-value">{{ stats.totalQuiz }}</span></div>
                        <div class="progress-bar"><div class="progress-fill magenta" style="width: {{ (stats.totalQuiz / 50 * 100)|round }}%;"></div></div>
                    </div>
                    <div class="progress-item">
                        <div class="progress-header"><span class="progress-label">🏆 Challenges</span><span class="progress-value">{{ stats.totalChallenges }}</span></div>
                        <div class="progress-bar"><div class="progress-fill purple" style="width: {{ (stats.totalChallenges / 30 * 100)|round }}%;"></div></div>
                    </div>
                    <div class="progress-item">
                        <div class="progress-header"><span class="progress-label">📅 Événements</span><span class="progress-value">{{ stats.totalEvenements }}</span></div>
                        <div class="progress-bar"><div class="progress-fill cyan" style="width: {{ (stats.totalEvenements / 15 * 100)|round }}%;"></div></div>
                    </div>
                </div>

                <!-- Quick Links -->
                <div class="glass-card progress-card">
                    <div class="card-header">
                        <div>
                            <h2 class="card-title">Accès Rapide</h2>
                            <p class="card-subtitle">Gestion plateforme</p>
                        </div>
                    </div>
                    <div style="display: flex; flex-direction: column; gap: 12px; padding: 10px 0;">
                        <a href="{{ path('app_cours_index') }}" style="padding: 12px; background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.1)); border-radius: 8px; text-decoration: none; color: var(--text-primary); display: flex; align-items: center; gap: 10px; transition: transform 0.2s;" onmouseover="this.style.transform='translateX(5px)'" onmouseout="this.style.transform='translateX(0)'">
                            <span style="font-size: 20px;">📚</span>
                            <span>Gérer les Cours</span>
                        </a>
                        <a href="{{ path('backoffice_challenges') }}" style="padding: 12px; background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.1)); border-radius: 8px; text-decoration: none; color: var(--text-primary); display: flex; align-items: center; gap: 10px; transition: transform 0.2s;" onmouseover="this.style.transform='translateX(5px)'" onmouseout="this.style.transform='translateX(0)'">
                            <span style="font-size: 20px;">🏆</span>
                            <span>Gérer les Challenges</span>
                        </a>
                        <a href="{{ path('backoffice_evenements') }}" style="padding: 12px; background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.1)); border-radius: 8px; text-decoration: none; color: var(--text-primary); display: flex; align-items: center; gap: 10px; transition: transform 0.2s;" onmouseover="this.style.transform='translateX(5px)'" onmouseout="this.style.transform='translateX(0)'">
                            <span style="font-size: 20px;">📅</span>
                            <span>Gérer les Événements</span>
                        </a>
                        <a href="{{ path('backoffice_users') }}" style="padding: 12px; background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.1)); border-radius: 8px; text-decoration: none; color: var(--text-primary); display: flex; align-items: center; gap: 10px; transition: transform 0.2s;" onmouseover="this.style.transform='translateX(5px)'" onmouseout="this.style.transform='translateX(0)'">
                            <span style="font-size: 20px;">👥</span>
                            <span>Gérer les Utilisateurs</span>
                        </a>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <!-- Mobile Menu Toggle -->
    <button class="mobile-menu-toggle">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
    </button>

    <!-- Footer -->
    <footer class="site-footer">
        <p>Copyright © 2026 Your Company. Designed by <a href="https://templatemo.com" target="_blank" rel="nofollow">TemplateMo</a></p>
    </footer>

    <script src="{{ asset('backoffice/js/templatemo-glass-admin-script.js') }}"></script>
    <!-- TemplateMo 607 Glass Admin -->
    
    {# AI Chat Widget - Assistant Intelligent #}
    {% include 'ai_assistant/chat_widget.html.twig' %}
</body>
</html>