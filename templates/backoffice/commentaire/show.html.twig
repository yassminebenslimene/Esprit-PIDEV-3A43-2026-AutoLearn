{% extends 'backoffice/base.html.twig' %}

{% block title %}Détails du Commentaire{% endblock %}

{% block page_title %}
Détails du Commentaire
{% endblock %}

{% block body %}

<nav class="navbar">
    <div class="page-header">
        <div class="page-breadcrumb">
            <a href="{{ path('app_backoffice') }}">Dashboard</a>
            <span>/</span>
            <a href="{{ path('backoffice_commentaire_index') }}">Commentaires</a>
            <span>/</span>
            <span>Détails</span>
        </div>
    </div>

    <div class="navbar-right">
        <a href="{{ path('backoffice_commentaire_index') }}" class="card-btn">
            Retour
        </a>
    </div>
</nav>


<section class="content-grid" style="grid-template-columns: 1fr;">

    <div class="glass-card">
        <div class="card-header">
            <h2 class="card-title">Informations du Commentaire</h2>
        </div>

        <div class="info-grid" style="display:grid; grid-template-columns:repeat(auto-fit,minmax(250px,1fr)); gap:1rem; margin-bottom:2rem;">

            <div class="info-item" style="padding:1rem; background:rgba(255,255,255,0.05); border-radius:12px;">
                <div class="info-label" style="opacity:0.7;">Auteur</div>
                <div class="info-value" style="font-weight:600;">
                    {% if commentaire.user %}
                        {{ commentaire.user.prenom }} {{ commentaire.user.nom }}
                    {% else %}
                        <span style="opacity:0.5">Anonyme</span>
                    {% endif %}
                </div>
            </div>

            <div class="info-item" style="padding:1rem; background:rgba(255,255,255,0.05); border-radius:12px;">
                <div class="info-label" style="opacity:0.7;">Post associé</div>
                <div class="info-value">
                    {% if commentaire.post %}
                        <a href="{{ path('backoffice_post_show', {id: commentaire.post.id}) }}">
                            Voir le post
                        </a>
                    {% else %}
                        -
                    {% endif %}
                </div>
            </div>

            <div class="info-item" style="padding:1rem; background:rgba(255,255,255,0.05); border-radius:12px;">
                <div class="info-label" style="opacity:0.7;">Date</div>
                <div class="info-value">
                    {{ commentaire.createdAt|date('d/m/Y à H:i') }}
                </div>
            </div>

        </div>

        <div style="margin-top:1rem;">
            <div class="info-label" style="opacity:0.7;">Contenu</div>
            <div style="white-space:pre-wrap; font-weight:500;">
                {{ commentaire.contenu }}
            </div>
        </div>
    </div>


    {% if commentaire.post %}
        <div class="glass-card">
            <div class="card-header">
                <h2 class="card-title">Post associé</h2>
            </div>

            <div style="padding:1rem; background:rgba(255,255,255,0.05); border-radius:12px;">

                <div style="margin-bottom:0.5rem;">
                    <strong>
                        {% if commentaire.post.user %}
                            {{ commentaire.post.user.prenom }} {{ commentaire.post.user.nom }}
                        {% else %}
                            Anonyme
                        {% endif %}
                    </strong>

                    <span style="opacity:0.7; font-size:0.875rem; margin-left:0.5rem;">
                        {{ commentaire.post.createdAt|date('d/m/Y à H:i') }}
                    </span>
                </div>

                <div>
                    {{ commentaire.post.contenu|slice(0,200) }}
                    {% if commentaire.post.contenu|length > 200 %}...{% endif %}
                </div>

                <div style="margin-top:1rem;">
                    <a href="{{ path('backoffice_post_show', {id: commentaire.post.id}) }}" class="card-btn">
                        Voir le post complet
                    </a>
                </div>

            </div>
        </div>
    {% endif %}

</section>

{% endblock %}