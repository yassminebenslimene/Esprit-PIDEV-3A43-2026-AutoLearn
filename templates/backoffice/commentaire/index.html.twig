{% extends 'backoffice/base.html.twig' %}

{% block title %}Commentaires{% endblock %}

{% block page_title %}
Commentaires
{% endblock %}

{% block body %}

<section class="stats-grid">
    <div class="glass-card glass-card-3d stat-card">
        <div class="stat-card-inner">
            <div class="stat-info">
                <h3>Total Commentaires</h3>
                <div class="stat-value">{{ commentaires|length }}</div>
            </div>
        </div>
    </div>
</section>


<section class="content-grid" style="grid-template-columns: 1fr;">
    <div class="glass-card table-card">

        <div class="card-header">
            <div>
                <h2 class="card-title">Tous les Commentaires</h2>
                <p class="card-subtitle">Gestion des commentaires</p>
            </div>
        </div>

        <div class="table-wrapper">
            <table class="data-table">
                <thead>
                <tr>
                    <th>Auteur</th>
                    <th>Contenu</th>
                    <th>Post</th>
                    <th>Date</th>
                    <th>Actions</th>
                </tr>
                </thead>

                <tbody>
                {% for commentaire in commentaires %}
                    <tr>

                        <td>
                            {% if commentaire.user %}
                                {{ commentaire.user.prenom }} {{ commentaire.user.nom }}
                            {% else %}
                                Anonyme
                            {% endif %}
                        </td>

                        <td style="max-width:300px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                            {{ commentaire.contenu }}
                        </td>

                        <td>
                            {% if commentaire.post %}
                                <a href="{{ path('backoffice_post_show', {id: commentaire.post.id}) }}">
                                    Voir Post
                                </a>
                            {% else %}
                                -
                            {% endif %}
                        </td>

                        <td>
                            {{ commentaire.createdAt|date('d/m/Y H:i') }}
                        </td>

                        <td>
                            <div style="display:flex; gap:5px;">

                                <a href="{{ path('backoffice_commentaire_show', {id: commentaire.id}) }}"
                                   class="card-btn small-btn">
                                    Voir
                                </a>

                                <form method="post"
                                      action="{{ path('backoffice_commentaire_delete', {id: commentaire.id}) }}"
                                      style="display:inline"
                                      onsubmit="return confirm('Supprimer ce commentaire ?');">

                                    <input type="hidden"
                                           name="_token"
                                           value="{{ csrf_token('delete' ~ commentaire.id) }}">

                                    <button class="card-btn small-btn danger">
                                        Supprimer
                                    </button>
                                </form>

                            </div>
                        </td>

                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" style="text-align:center;padding:2rem;">
                            Aucun commentaire trouvé
                        </td>
                    </tr>
                {% endfor %}
                </tbody>

            </table>
        </div>
    </div>
</section>

{% endblock %}