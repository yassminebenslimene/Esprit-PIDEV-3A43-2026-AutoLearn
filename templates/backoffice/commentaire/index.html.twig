{% extends 'backoffice/base.html.twig' %}

{% block title %}Commentaires - GlassAdmin Dashboard{% endblock %}
{% block page_title %}Commentaires{% endblock %}

{% block body %}
    <style>
        .badge {
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            display: inline-block;
        }
        .action-buttons { display: flex; gap: 5px; flex-wrap: wrap; }
        .small-btn {
            font-size: 12px !important;
            padding: 6px 10px !important;
            min-width: 70px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }
        .small-btn svg { margin-right: 4px; }
        .danger { background: var(--danger) !important; color: white !important; }
        .comment-content { max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    </style>

    <section class="stats-grid">
        <div class="glass-card glass-card-3d stat-card">
            <div class="stat-card-inner">
                <div class="stat-info">
                    <h3>Total Commentaires</h3>
                    <div class="stat-value">{{ commentaires|length }}</div>
                </div>
                <div class="stat-icon cyan">
                    <svg viewBox="0 0 24 24" fill="none" stroke="var(--cyan)" stroke-width="2">
                        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                    </svg>
                </div>
            </div>
        </div>
    </section>

    <section class="content-grid" style="grid-template-columns: 1fr;">
        <div class="glass-card table-card">
            <div class="card-header">
                <div>
                    <h2 class="card-title">Tous les Commentaires</h2>
                    <p class="card-subtitle">Gérer les commentaires</p>
                </div>
            </div>
            <div class="table-wrapper">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Auteur</th>
                            <th>Contenu</th>
                            <th>Post</th>
                            <th>Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for commentaire in commentaires %}
                        <tr>
                            <td>
                                {% if commentaire.user %}
                                    <div class="table-user">
                                        <div class="table-avatar" style="background: linear-gradient(135deg, var(--emerald-light), var(--emerald));">
                                            {{ commentaire.user.prenom|first|upper }}{{ commentaire.user.nom|first|upper }}
                                        </div>
                                        <div class="table-user-info">
                                            <span class="table-user-name">{{ commentaire.user.prenom }} {{ commentaire.user.nom }}</span>
                                        </div>
                                    </div>
                                {% else %}
                                    <span style="opacity:0.5">Anonyme</span>
                                {% endif %}
                            </td>
                            <td>
                                <div class="comment-content">{{ commentaire.contenu }}</div>
                            </td>
                            <td>
                                {% if commentaire.post %}
                                    <a href="{{ path('backoffice_post_show', {id: commentaire.post.id}) }}" style="color: var(--cyan);">
                                        Voir le post
                                    </a>
                                {% else %}
                                    <span style="opacity:0.5">-</span>
                                {% endif %}
                            </td>
                            <td>{{ commentaire.createdAt|date('d/m/Y H:i') }}</td>
                            <td>
                                <div class="action-buttons">
                                    <a href="{{ path('backoffice_commentaire_show', {id: commentaire.id}) }}" class="card-btn small-btn">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                                        </svg>Voir
                                    </a>
                                    <form method="post" action="{{ path('backoffice_commentaire_delete', {id: commentaire.id}) }}" 
                                          onsubmit="return confirm('Supprimer ce commentaire ?');" style="display:inline;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ commentaire.id) }}">
                                        <button type="submit" class="card-btn small-btn danger">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                                            </svg>Supprimer
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        {% else %}
                        <tr><td colspan="5" style="text-align:center;padding:2rem;">Aucun commentaire trouvé</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </section>
{% endblock %}
