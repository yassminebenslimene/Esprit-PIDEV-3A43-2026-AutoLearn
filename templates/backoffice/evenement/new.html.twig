{% extends "backoffice/base_admin.html.twig" %}

{% block admin_content %}
<div class="card glass-card">
    <div class="card-header">
        <h4>📅 Créer Événement</h4>
    </div>
    <div class="card-body">
        {{ form_start(form, {'attr': {'class': 'needs-validation'}}) }}
        
        <div class="row">
            <div class="col-md-6 mb-3">
                {{ form_row(form.titre, {'attr': {'class': 'form-control', 'placeholder': 'Titre de l\'événement'}}) }}
            </div>
            <div class="col-md-6 mb-3">
                {{ form_row(form.type, {'attr': {'class': 'form-select'}}) }}
            </div>
        </div>

        <div class="mb-3">
            {{ form_row(form.description, {'attr': {'class': 'form-control', 'rows': 3, 'placeholder': 'Description'}}) }}
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                {{ form_row(form.dateDebut, {'attr': {'class': 'form-control', 'type': 'datetime-local'}}) }}
            </div>
            <div class="col-md-6 mb-3">
                {{ form_row(form.dateFin, {'attr': {'class': 'form-control', 'type': 'datetime-local'}}) }}
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                {{ form_row(form.lieu, {'attr': {'class': 'form-control', 'placeholder': 'Salle/Localisation'}}) }}
            </div>
            <div class="col-md-6 mb-3">
                {{ form_row(form.capaciteMax, {'attr': {'class': 'form-control', 'type': 'number', 'min': 1}}) }}
            </div>
        </div>

        <div class="mb-3">
            {{ form_row(form.isCanceled) }}
            <small class="text-muted">Cocher pour annuler cet événement</small>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-success">✓ Créer</button>
            <a href="{{ path('app_evenement_index') }}" class="btn btn-secondary">Annuler</a>
        </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
