{% extends 'backoffice/base.html.twig' %}

{% block title %}Détails Événement{% endblock %}
{% block page_title %}Détails de l'Événement{% endblock %}

{% block body %}
<div class="glass-card">
    <h2 class="card-title">{{ evenement.titre }}</h2>
    
    <div style="margin-top: 20px;">
        <div class="detail-row">
            <strong>Type:</strong> {{ evenement.type.value }}
        </div>
        <div class="detail-row">
            <strong>Description:</strong> {{ evenement.description }}
        </div>
        <div class="detail-row">
            <strong>Date de début:</strong> {{ evenement.dateDebut|date('d/m/Y H:i') }}
        </div>
        <div class="detail-row">
            <strong>Date de fin:</strong> {{ evenement.dateFin|date('d/m/Y H:i') }}
        </div>
        <div class="detail-row">
            <strong>Statut:</strong> 
            <span class="status-badge {% if evenement.status.value == 'En cours' %}processing{% elseif evenement.status.value == 'Annulé' %}pending{% else %}completed{% endif %}">
                {{ evenement.status.value }}
            </span>
        </div>
        <div class="detail-row">
            <strong>Annulé:</strong> {{ evenement.isCanceled ? 'Oui' : 'Non' }}
        </div>
        <div class="detail-row">
            <strong>Nombre maximum d'équipes:</strong> {{ evenement.nbMax }}
        </div>
        <div class="detail-row">
            <strong>Nombre d'équipes inscrites:</strong> {{ evenement.equipes|length }}
        </div>
        <div class="detail-row">
            <strong>Nombre de participations:</strong> {{ evenement.participations|length }}
        </div>
    </div>

    <div style="margin-top: 30px; display: flex; gap: 10px;">
        <a href="{{ path('backoffice_evenement_edit', {'id': evenement.id}) }}" class="btn btn-primary">Modifier</a>
        <a href="{{ path('backoffice_evenements') }}" class="btn btn-secondary">Retour à la liste</a>
    </div>
</div>

<style>
.detail-row {
    padding: 12px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}
.detail-row:last-child {
    border-bottom: none;
}
</style>
{% endblock %}
