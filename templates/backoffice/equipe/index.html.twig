{% extends "backoffice/base_admin.html.twig" %}

{% block admin_content %}
<div class="card glass-card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h4>👥 Équipes</h4>
        {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('app_equipe_new') }}" class="btn btn-primary btn-sm">+ Ajouter Équipe</a>
        {% endif %}
    </div>
    <div class="card-body">
        {% if equipes|length > 0 %}
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Nom</th>
                        <th>Événement</th>
                        <th>Membres</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for equipe in equipes %}
                    <tr>
                        <td><strong>{{ equipe.nom }}</strong></td>
                        <td>{{ equipe.evenement.titre }}</td>
                        <td>
                            <span class="badge bg-secondary">{{ equipe.etudiants|length }} membre(s)</span>
                            <small>
                                {% for etudiant in equipe.etudiants %}
                                    <br>• {{ etudiant.prenom }} {{ etudiant.nom }}
                                {% endfor %}
                            </small>
                        </td>
                        <td>
                            <a href="{{ path('app_equipe_show', {id: equipe.id}) }}" class="btn btn-sm btn-info">Voir</a>
                            <a href="{{ path('app_equipe_edit', {id: equipe.id}) }}" class="btn btn-sm btn-warning">Éditer</a>
                            <form method="POST" action="{{ path('app_equipe_delete', {id: equipe.id}) }}" style="display:inline;" onsubmit="return confirm('Confirmer ?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ equipe.id) }}">
                                <button type="submit" class="btn btn-sm btn-danger">Supprimer</button>
                            </form>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% else %}
        <div class="alert alert-info">Aucune équipe créée.
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_equipe_new') }}">Créer la première</a>
            {% endif %}
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}
