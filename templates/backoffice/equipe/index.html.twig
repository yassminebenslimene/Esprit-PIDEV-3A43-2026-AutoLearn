{% extends 'backoffice/base.html.twig' %}

{% block title %}Gestion des Équipes{% endblock %}
{% block page_title %}Gestion des Équipes{% endblock %}

{% block body %}
<div class="glass-card">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
        <h2 class="card-title">Liste des Équipes</h2>
        <a href="{{ path('backoffice_equipe_new') }}" class="btn btn-primary">
            ➕ Ajouter une équipe
        </a>
    </div>

    {% for message in app.flashes('success') %}
        <div style="padding: 12px; background: rgba(127, 183, 126, 0.2); border-left: 3px solid #7fb77e; margin-bottom: 20px; border-radius: 8px;">
            {{ message }}
        </div>
    {% endfor %}

    <div class="table-wrapper">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Nom</th>
                    <th>Événement</th>
                    <th>Nombre d'étudiants</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for equipe in equipes %}
                <tr>
                    <td>{{ equipe.nom }}</td>
                    <td>{{ equipe.evenement.titre }}</td>
                    <td>{{ equipe.etudiants|length }}</td>
                    <td>
                        <div style="display: flex; gap: 8px;">
                            <a href="{{ path('backoffice_equipe_show', {'id': equipe.id}) }}" 
                               class="btn btn-sm" 
                               style="background: linear-gradient(135deg, #667eea, #764ba2); color: white; padding: 6px 12px; border-radius: 8px; text-decoration: none; font-size: 12px;">
                                👁 Voir
                            </a>
                            <a href="{{ path('backoffice_equipe_edit', {'id': equipe.id}) }}" 
                               class="btn btn-warning btn-sm" 
                               style="background: linear-gradient(135deg, var(--gold), var(--amber)); color: white; padding: 6px 12px; border-radius: 8px; text-decoration: none; font-size: 12px;">
                                ✏ Modifier
                            </a>
                            <a href="{{ path('backoffice_equipe_delete', {'id': equipe.id}) }}" 
                               class="btn btn-danger btn-sm" 
                               onclick="return confirm('Confirmer la suppression ?')"
                               style="background: linear-gradient(135deg, var(--coral), var(--gold)); color: white; padding: 6px 12px; border-radius: 8px; text-decoration: none; font-size: 12px;">
                                🗑 Supprimer
                            </a>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" style="text-align: center; padding: 40px; color: var(--text-muted);">
                        Aucune équipe trouvée
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
