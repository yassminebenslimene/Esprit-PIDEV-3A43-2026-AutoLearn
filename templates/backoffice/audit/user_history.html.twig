{% extends 'backoffice/base.html.twig' %}

{% block title %}Student History - {{ user.prenom }} {{ user.nom }}{% endblock %}
{% block page_title %}📜 Student History{% endblock %}

{% block body %}
<div class="audit-container">
    <!-- Back Button -->
    <div style="margin-bottom: 20px;">
        <a href="{{ path('backoffice_audit_index') }}" class="btn btn-secondary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="19" y1="12" x2="5" y2="12"/>
                <polyline points="12 19 5 12 12 5"/>
            </svg>
            Back to Audit Trail
        </a>
    </div>

    <!-- User Info Card -->
    <div class="glass-card">
        <div class="card-header">
            <h3>👤 Student Information</h3>
        </div>
        <div class="user-info-grid">
            <div class="user-info-item">
                <span class="label">ID:</span>
                <span class="value">#{{ user.id }}</span>
            </div>
            <div class="user-info-item">
                <span class="label">Name:</span>
                <span class="value">{{ user.prenom }} {{ user.nom }}</span>
            </div>
            <div class="user-info-item">
                <span class="label">Email:</span>
                <span class="value">{{ user.email }}</span>
            </div>
            <div class="user-info-item">
                <span class="label">Role:</span>
                <span class="value"><span class="badge">{{ user.role }}</span></span>
            </div>
            <div class="user-info-item">
                <span class="label">Total Revisions:</span>
                <span class="value"><span class="badge badge-info">{{ history|length }}</span></span>
            </div>
        </div>
    </div>

    <!-- History Timeline -->
    <div class="glass-card" style="margin-top: 30px;">
        <div class="card-header">
            <h3>📅 Complete History Timeline</h3>
        </div>

        {% if history is empty %}
            <div class="empty-state">
                <p>No history available for this student.</p>
            </div>
        {% else %}
            <div class="timeline">
                {% for entry in history %}
                    <div class="timeline-item">
                        <div class="timeline-marker">
                            <div class="timeline-icon timeline-icon-{{ entry.revtype|lower }}">
                                {% if entry.revtype == 'INS' %}
                                    ➕
                                {% elseif entry.revtype == 'UPD' %}
                                    ✏️
                                {% elseif entry.revtype == 'DEL' %}
                                    🗑️
                                {% endif %}
                            </div>
                        </div>
                        <div class="timeline-content">
                            <div class="timeline-header">
                                <div>
                                    <h4>
                                        {% if entry.revtype == 'INS' %}
                                            Student Created
                                        {% elseif entry.revtype == 'UPD' %}
                                            Student Updated
                                        {% elseif entry.revtype == 'DEL' %}
                                            Student Deleted
                                        {% endif %}
                                    </h4>
                                    <div class="timeline-meta">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <circle cx="12" cy="12" r="10"/>
                                            <polyline points="12 6 12 12 16 14"/>
                                        </svg>
                                        {{ entry.timestamp|date('Y-m-d H:i:s') }}
                                        {% if entry.username %}
                                            • by <span class="user-badge-sm">{{ entry.username }}</span>
                                        {% endif %}
                                    </div>
                                </div>
                                <span class="badge badge-primary">Rev #{{ entry.rev }}</span>
                            </div>

                            <div class="timeline-details">
                                <div class="detail-grid-compact">
                                    <div class="detail-compact">
                                        <span class="label">Email:</span>
                                        <span class="value">{{ entry.email }}</span>
                                    </div>
                                    <div class="detail-compact">
                                        <span class="label">Role:</span>
                                        <span class="value">{{ entry.role }}</span>
                                    </div>
                                    {% if entry.niveau %}
                                        <div class="detail-compact">
                                            <span class="label">Niveau:</span>
                                            <span class="value">{{ entry.niveau }}</span>
                                        </div>
                                    {% endif %}
                                    <div class="detail-compact">
                                        <span class="label">Suspended:</span>
                                        <span class="value">
                                            {% if entry.isSuspended %}
                                                <span class="badge badge-danger">Yes</span>
                                            {% else %}
                                                <span class="badge badge-success">No</span>
                                            {% endif %}
                                        </span>
                                    </div>
                                </div>
                            </div>

                            <div class="timeline-footer">
                                <a href="{{ path('backoffice_audit_revision_details', {revisionId: entry.rev}) }}" class="btn-link">
                                    View Full Revision →
                                </a>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</div>

<style>
.user-info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
    padding: 24px;
}

.user-info-item {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.user-info-item .label {
    font-size: 12px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.user-info-item .value {
    font-size: 16px;
    font-weight: 600;
}

.timeline {
    padding: 30px 20px;
}

.timeline-item {
    display: flex;
    gap: 20px;
    margin-bottom: 30px;
    position: relative;
}

.timeline-item:not(:last-child)::after {
    content: '';
    position: absolute;
    left: 24px;
    top: 50px;
    width: 2px;
    height: calc(100% + 10px);
    background: var(--glass-border);
}

.timeline-marker {
    flex-shrink: 0;
}

.timeline-icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    border: 3px solid var(--bg-dark);
}

.timeline-icon-ins {
    background: linear-gradient(135deg, #22c55e, #4ade80);
}

.timeline-icon-upd {
    background: linear-gradient(135deg, #0ea5e9, #38bdf8);
}

.timeline-icon-del {
    background: linear-gradient(135deg, #dc2626, #ef4444);
}

.timeline-content {
    flex: 1;
    background: rgba(255, 255, 255, 0.03);
    border-radius: 12px;
    border: 1px solid var(--glass-border);
    padding: 20px;
}

.timeline-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 15px;
    padding-bottom: 15px;
    border-bottom: 1px solid var(--glass-border);
}

.timeline-header h4 {
    font-size: 18px;
    margin-bottom: 6px;
}

.timeline-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--text-secondary);
}

.user-badge-sm {
    padding: 2px 8px;
    background: linear-gradient(135deg, var(--emerald), var(--emerald-light));
    border-radius: 4px;
    font-size: 12px;
}

.detail-grid-compact {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 12px;
    margin-bottom: 15px;
}

.detail-compact {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 12px;
    background: rgba(255, 255, 255, 0.02);
    border-radius: 6px;
}

.detail-compact .label {
    font-size: 12px;
    color: var(--text-muted);
}

.detail-compact .value {
    font-weight: 500;
}

.timeline-footer {
    padding-top: 12px;
    border-top: 1px solid var(--glass-border);
}

.btn-link {
    color: var(--emerald-light);
    font-size: 14px;
    font-weight: 500;
    transition: all var(--transition-fast);
}

.btn-link:hover {
    color: var(--gold);
}
</style>
{% endblock %}
