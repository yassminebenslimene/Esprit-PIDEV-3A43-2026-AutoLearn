{% extends 'backoffice/base.html.twig' %}

{% block title %}Audit Trail - Student Management{% endblock %}
{% block page_title %}📋 Audit Trail - Student Management{% endblock %}

{% block body %}
<div class="audit-container">
    <!-- Header with Stats -->
    <div class="audit-header">
        <div class="header-content">
            <h2>Professional Audit Bundle</h2>
            <p>Complete history of all student (Etudiant) management operations</p>
        </div>
        <div class="header-actions">
            <a href="{{ path('backoffice_audit_stats') }}" class="btn btn-primary">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="20" x2="18" y2="10"/>
                    <line x1="12" y1="20" x2="12" y2="4"/>
                    <line x1="6" y1="20" x2="6" y2="14"/>
                </svg>
                View Statistics
            </a>
        </div>
    </div>

    <!-- Info Cards -->
    <div class="info-cards">
        <div class="info-card">
            <div class="info-icon" style="background: linear-gradient(135deg, #059669, #34d399);">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 20h9"/>
                    <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
                </svg>
            </div>
            <div class="info-content">
                <h3>{{ revisions|length }}</h3>
                <p>Total Revisions</p>
            </div>
        </div>

        <div class="info-card">
            <div class="info-icon" style="background: linear-gradient(135deg, #d4a574, #e8c9a0);">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                    <circle cx="9" cy="7" r="4"/>
                </svg>
            </div>
            <div class="info-content">
                <h3>Student Tracking</h3>
                <p>Automatic Logging</p>
            </div>
        </div>

        <div class="info-card">
            <div class="info-icon" style="background: linear-gradient(135deg, #0ea5e9, #38bdf8);">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                </svg>
            </div>
            <div class="info-content">
                <h3>Real-time</h3>
                <p>Live Monitoring</p>
            </div>
        </div>
    </div>

    <!-- Revisions Table -->
    <div class="glass-card">
        <div class="card-header">
            <h3>📜 Revision History</h3>
            <span class="badge">{{ revisions|length }} revisions</span>
        </div>

        {% if revisions is empty %}
            <div class="empty-state">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
                <h3>No Audit Data Yet</h3>
                <p>The audit bundle is installed and ready. Create, update, or delete a student (Etudiant) to see audit data here.</p>
                <a href="{{ path('backoffice_users') }}" class="btn btn-primary" style="margin-top: 20px;">
                    Go to User Management
                </a>
            </div>
        {% else %}
            <div class="table-wrapper">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Revision ID</th>
                            <th>Timestamp</th>
                            <th>User</th>
                            <th>Changes</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for revision in revisions %}
                            <tr>
                                <td>
                                    <span class="badge badge-primary">#{{ revision.id }}</span>
                                </td>
                                <td>
                                    <div class="timestamp">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <circle cx="12" cy="12" r="10"/>
                                            <polyline points="12 6 12 12 16 14"/>
                                        </svg>
                                        {{ revision.timestamp|date('Y-m-d H:i:s') }}
                                    </div>
                                </td>
                                <td>
                                    {% if revision.username %}
                                        <span class="user-badge">{{ revision.username }}</span>
                                    {% else %}
                                        <span class="text-muted">System</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <span class="badge badge-info">{{ revision.changes_count }} changes</span>
                                </td>
                                <td>
                                    <a href="{{ path('backoffice_audit_revision_details', {revisionId: revision.id}) }}" class="btn-icon" title="View Details">
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                            <circle cx="12" cy="12" r="3"/>
                                        </svg>
                                    </a>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>

    <!-- How It Works Section -->
    <div class="glass-card" style="margin-top: 30px;">
        <div class="card-header">
            <h3>ℹ️ How the Audit Bundle Works</h3>
        </div>
        <div class="info-section">
            <div class="info-item">
                <div class="info-number">1</div>
                <div>
                    <h4>Automatic Tracking</h4>
                    <p>The bundle automatically tracks INSERT, UPDATE, and DELETE operations on Etudiant (student) entities only.</p>
                </div>
            </div>
            <div class="info-item">
                <div class="info-number">2</div>
                <div>
                    <h4>Complete History</h4>
                    <p>Every change is stored with the complete entity state, timestamp, and user who made the change.</p>
                </div>
            </div>
            <div class="info-item">
                <div class="info-number">3</div>
                <div>
                    <h4>Time Travel</h4>
                    <p>You can view the exact state of any student at any point in time by looking at revision history.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.audit-container {
    padding: 20px;
}

.audit-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
    padding: 30px;
    background: var(--glass-bg);
    backdrop-filter: blur(20px);
    border-radius: var(--border-radius);
    border: 1px solid var(--glass-border);
}

.header-content h2 {
    font-size: 28px;
    margin-bottom: 8px;
    background: linear-gradient(135deg, var(--emerald-light), var(--gold));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

.header-content p {
    color: var(--text-secondary);
    font-size: 14px;
}

.info-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
    margin-bottom: 30px;
}

.info-card {
    background: var(--glass-bg);
    backdrop-filter: blur(20px);
    border-radius: var(--border-radius);
    border: 1px solid var(--glass-border);
    padding: 24px;
    display: flex;
    align-items: center;
    gap: 20px;
    transition: all var(--transition-normal);
}

.info-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 40px var(--glass-shadow);
}

.info-icon {
    width: 60px;
    height: 60px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
}

.info-content h3 {
    font-size: 24px;
    margin-bottom: 4px;
}

.info-content p {
    color: var(--text-secondary);
    font-size: 14px;
}

.empty-state {
    text-align: center;
    padding: 60px 20px;
}

.empty-state svg {
    color: var(--text-muted);
    margin-bottom: 20px;
}

.empty-state h3 {
    font-size: 24px;
    margin-bottom: 10px;
}

.empty-state p {
    color: var(--text-secondary);
    max-width: 500px;
    margin: 0 auto;
}

.timestamp {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--text-secondary);
}

.user-badge {
    display: inline-block;
    padding: 6px 12px;
    background: linear-gradient(135deg, var(--emerald), var(--emerald-light));
    border-radius: 8px;
    font-size: 13px;
    font-weight: 500;
}

.info-section {
    padding: 20px;
}

.info-item {
    display: flex;
    gap: 20px;
    padding: 20px;
    margin-bottom: 15px;
    background: rgba(255, 255, 255, 0.03);
    border-radius: 12px;
    border: 1px solid var(--glass-border);
}

.info-number {
    width: 40px;
    height: 40px;
    background: linear-gradient(135deg, var(--emerald), var(--gold));
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 18px;
    flex-shrink: 0;
}

.info-item h4 {
    margin-bottom: 8px;
    font-size: 16px;
}

.info-item p {
    color: var(--text-secondary);
    font-size: 14px;
    line-height: 1.6;
}

.btn-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: var(--glass-bg);
    border-radius: 8px;
    border: 1px solid var(--glass-border);
    transition: all var(--transition-fast);
}

.btn-icon:hover {
    background: var(--emerald);
    border-color: var(--emerald);
    transform: scale(1.1);
}
</style>
{% endblock %}
