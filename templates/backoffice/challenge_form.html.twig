    <style>
        .selection-section {
            margin-top: 30px;
            border-top: 1px solid rgba(255,255,255,0.1);
            padding-top: 25px;
        }
        
        .selection-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }
        
        .selection-tabs {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
        }
        
        .selection-tab {
            padding: 10px 20px;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 8px;
            cursor: pointer;
            font-weight: 500;
            transition: all 0.3s;
        }
        
        .selection-tab.active {
            background: linear-gradient(135deg, var(--emerald-light), var(--emerald));
            color: white;
            border-color: transparent;
        }
        
        .items-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 15px;
            max-height: 400px;
            overflow-y: auto;
            padding: 5px;
        }
        
        .item-card {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 10px;
            padding: 15px;
            cursor: pointer;
            transition: all 0.3s;
            position: relative;
        }
        
        .item-card:hover {
            background: rgba(255,255,255,0.08);
            transform: translateY(-2px);
        }
        
        .item-card.selected {
            border-color: var(--emerald-light);
            background: rgba(16, 185, 129, 0.1);
            box-shadow: 0 0 15px rgba(16, 185, 129, 0.2);
        }
        
        .item-card.selected::before {
            content: "✓";
            position: absolute;
            top: 10px;
            right: 10px;
            width: 20px;
            height: 20px;
            background: var(--emerald-light);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: bold;
        }
        
        .item-title {
            font-weight: 600;
            margin-bottom: 5px;
            color: var(--text);
        }
        
        .item-details {
            display: flex;
            gap: 10px;
            font-size: 12px;
            color: var(--text-muted);
        }
        
        .item-badge {
            padding: 3px 8px;
            border-radius: 12px;
            background: rgba(255,255,255,0.1);
            font-size: 11px;
            font-weight: 500;
        }
        
        .selected-count {
            background: rgba(255,255,255,0.1);
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 14px;
        }
        
        .selected-count span {
            color: var(--emerald-light);
            font-weight: 700;
            margin: 0 5px;
        }
        
        .hidden-field {
            display: none;
        }
        
        /* Style pour les quiz et exercices */
        .item-type {
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            padding: 2px 6px;
            border-radius: 4px;
            background: rgba(255,255,255,0.15);
        }
        
        .item-question {
            font-size: 12px;
            color: var(--text-muted);
            margin-top: 5px;
            font-style: italic;
        }
        
        .item-points {
            font-weight: 600;
            color: var(--emerald-light);
        }
    </style>
</head>
