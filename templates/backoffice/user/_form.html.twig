{{ form_start(form, {'attr': {'novalidate': 'novalidate', 'id': 'user-form'}}) }}

{% for message in app.flashes('error') %}
    <div class="alert alert-danger">{{ message }}</div>
{% endfor %}

<div class="mb-3">
    {{ form_label(form.nom) }}
    {{ form_widget(form.nom, {'attr': {'class': 'form-control'}}) }}
    {{ form_errors(form.nom) }}
</div>

<div class="mb-3">
    {{ form_label(form.prenom) }}
    {{ form_widget(form.prenom, {'attr': {'class': 'form-control'}}) }}
    {{ form_errors(form.prenom) }}
</div>

<div class="mb-3">
    {{ form_label(form.email) }}
    {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
    {{ form_errors(form.email) }}
</div>

<div class="mb-3">
    {{ form_label(form.password) }}
    {{ form_widget(form.password, {'attr': {'class': 'form-control'}}) }}
    {{ form_errors(form.password) }}
    {% if is_edit|default(false) %}
        <small class="text-muted">Laisser vide pour ne pas changer</small>
    {% endif %}
</div>

<div class="mb-3">
    {{ form_label(form.role) }}
    {{ form_widget(form.role, {'attr': {'class': 'form-select', 'id': 'user_role'}}) }}
    {{ form_errors(form.role) }}
</div>

{% if form.niveau is defined %}
    <div class="mb-3" id="niveau-wrapper">
        {{ form_label(form.niveau) }}
        {{ form_widget(form.niveau, {'attr': {'class': 'form-select', 'id': 'user_niveau'}}) }}
        {{ form_errors(form.niveau) }}
    </div>
{% endif %}

<div class="d-flex gap-2">
    <button type="submit" class="btn btn-primary">{{ button_label|default('Enregistrer') }}</button>
    <a href="{{ path('app_user_index') }}" class="btn btn-secondary">Annuler</a>
</div>

{{ form_end(form) }}

{% if form.niveau is defined %}
<script>
document.addEventListener('DOMContentLoaded', function () {
    const roleSelect = document.getElementById('user_role');
    const niveauWrapper = document.getElementById('niveau-wrapper');
    const form = document.getElementById('user-form');

    function toggleNiveau() {
        if (roleSelect.value === 'ETUDIANT') {
            niveauWrapper.style.display = 'block';
        } else {
            niveauWrapper.style.display = 'none';
            const niveauSelect = document.getElementById('user_niveau');
            if (niveauSelect) niveauSelect.value = '';
        }
    }

    toggleNiveau();
    roleSelect.addEventListener('change', toggleNiveau);

    // Pré-remplir niveau à l'édition
    {% if user is defined and user.niveau is defined %}
        const niveauSelect = document.getElementById('user_niveau');
        if (niveauSelect) niveauSelect.value = '{{ user.niveau }}';
    {% endif %}

    // Validation front-end
    form.addEventListener('submit', function(event) {
        let isValid = true;

        ['nom', 'prenom', 'email'].forEach(function(fieldName) {
            const field = document.getElementById('user_' + fieldName);
            if (field && !field.value.trim()) {
                field.classList.add('is-invalid');
                isValid = false;
            } else if (field) {
                field.classList.remove('is-invalid');
            }
        });

        const emailField = document.getElementById('user_email');
        if (emailField && emailField.value && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailField.value)) {
            emailField.classList.add('is-invalid');
            isValid = false;
        }

        {% if not is_edit|default(false) %}
        const passwordField = document.getElementById('user_password');
        if (passwordField && !passwordField.value.trim()) {
            passwordField.classList.add('is-invalid');
            isValid = false;
        }
        {% endif %}

        const niveauSelect = document.getElementById('user_niveau');
        if (niveauSelect && roleSelect.value === 'ETUDIANT' && !niveauSelect.value) {
            niveauSelect.classList.add('is-invalid');
            isValid = false;
        } else if (niveauSelect) {
            niveauSelect.classList.remove('is-invalid');
        }

        if (!isValid) {
            event.preventDefault();
            event.stopPropagation();
        }
    });
});
</script>
{% endif %}
