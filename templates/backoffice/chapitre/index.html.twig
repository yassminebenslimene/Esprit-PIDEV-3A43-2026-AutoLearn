{% extends 'backoffice/base.html.twig' %}

{% block title %}Gestion des Chapitres{% endblock %}
{% block page_title %}Gestion des Chapitres{% endblock %}

{% block body %}
    <section class="content-grid">
        <div class="glass-card table-card">
            <div class="card-header">
                <div>
                    <h2 class="card-title">Liste des Chapitres</h2>
                    <p class="card-subtitle">Gérer tous les chapitres des cours</p>
                </div>
                <div class="card-actions">
                    <a href="{{ path('app_chapitre_new') }}" class="card-btn" style="background: linear-gradient(135deg, var(--gold), var(--amber)); color: white; padding: 8px 16px; border-radius: 8px; text-decoration: none;">
                        <svg style="width: 16px; height: 16px; display: inline-block; vertical-align: middle; margin-right: 4px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="12" y1="5" x2="12" y2="19"/>
                            <line x1="5" y1="12" x2="19" y2="12"/>
                        </svg>
                        Nouveau Chapitre
                    </a>
                </div>
            </div>
            <div class="table-wrapper">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Titre</th>
                            <th>Cours</th>
                            <th>Ordre</th>
                            <th>Ressources</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for chapitre in chapitres %}
                        <tr>
                            <td>{{ chapitre.id }}</td>
                            <td>
                                <div style="max-width: 300px;">
                                    <span style="font-weight: 500;">{{ chapitre.titre }}</span>
                                    {% if chapitre.contenu %}
                                        <br><span style="font-size: 0.85em; color: var(--text-secondary);">{{ chapitre.contenu|length > 50 ? chapitre.contenu|slice(0, 50) ~ '...' : chapitre.contenu }}</span>
                                    {% endif %}
                                </div>
                            </td>
                            <td>
                                {% if chapitre.cours %}
                                    <span class="status-badge processing">{{ chapitre.cours.titre }}</span>
                                {% else %}
                                    <span style="color: var(--text-secondary);">-</span>
                                {% endif %}
                            </td>
                            <td>
                                <span style="background: rgba(255,255,255,0.1); padding: 4px 12px; border-radius: 12px; font-weight: 500;">
                                    #{{ chapitre.ordre }}
                                </span>
                            </td>
                            <td>
                                {% if chapitre.ressources %}
                                    <span style="font-size: 0.9em;">{{ chapitre.ressources|length > 30 ? chapitre.ressources|slice(0, 30) ~ '...' : chapitre.ressources }}</span>
                                {% else %}
                                    <span style="color: var(--text-secondary);">-</span>
                                {% endif %}
                            </td>
                            <td>
                                <div style="display: flex; gap: 8px;">
                                    <a href="{{ path('app_chapitre_show', {'id': chapitre.id}) }}" style="padding: 6px 12px; background: rgba(255,255,255,0.1); border-radius: 6px; text-decoration: none; color: var(--text-primary);" title="Voir">
                                        <svg style="width: 16px; height: 16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                            <circle cx="12" cy="12" r="3"/>
                                        </svg>
                                    </a>
                                    <a href="{{ path('app_chapitre_edit', {'id': chapitre.id}) }}" style="padding: 6px 12px; background: rgba(255,255,255,0.1); border-radius: 6px; text-decoration: none; color: var(--text-primary);" title="Modifier">
                                        <svg style="width: 16px; height: 16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                        </svg>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" style="text-align: center; padding: 40px; color: var(--text-secondary);">
                                <svg style="width: 48px; height: 48px; margin-bottom: 16px; opacity: 0.5;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                                    <polyline points="14 2 14 8 20 8"/>
                                </svg>
                                <br>Aucun chapitre trouvé
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </section>
{% endblock %}
