{% extends 'backoffice/base.html.twig' %}

{% block title %}Nouveau Chapitre{% endblock %}
{% block page_title %}Créer un Nouveau Chapitre{% endblock %}

{% block body %}
    <section class="content-grid">
        <div class="glass-card">
            <div class="card-header">
                <div>
                    <h2 class="card-title">Nouveau Chapitre</h2>
                    <p class="card-subtitle">Remplissez les informations du chapitre</p>
                </div>
                <div class="card-actions">
                    <a href="{{ path('app_chapitre_index') }}" class="card-btn">
                        <svg style="width: 16px; height: 16px; display: inline-block; vertical-align: middle; margin-right: 4px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="19" y1="12" x2="5" y2="12"/>
                            <polyline points="12 19 5 12 12 5"/>
                        </svg>
                        Retour
                    </a>
                </div>
            </div>
            <div style="padding: 24px;">
                {{ include('backoffice/chapitre/_form.html.twig') }}
            </div>
        </div>
    </section>
{% endblock %}
