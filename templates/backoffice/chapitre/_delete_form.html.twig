<form method="post" action="{{ path('app_chapitre_delete', {'id': chapitre.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce chapitre ?');" style="display: inline;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ chapitre.id) }}">
    <button type="submit" class="card-btn" style="background: linear-gradient(135deg, #ff6b6b, #ee5a6f); color: white; padding: 10px 20px; border: none; cursor: pointer;">
        <svg style="width: 16px; height: 16px; display: inline-block; vertical-align: middle; margin-right: 4px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="3 6 5 6 21 6"/>
            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
            <line x1="10" y1="11" x2="10" y2="17"/>
            <line x1="14" y1="11" x2="14" y2="17"/>
        </svg>
        Supprimer
    </button>
</form>
