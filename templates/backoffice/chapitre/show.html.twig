{% extends 'backoffice/base.html.twig' %}

{% block title %}Détails du Chapitre{% endblock %}
{% block page_title %}Détails du Chapitre{% endblock %}

{% block body %}
    <section class="content-grid">
        <div class="glass-card">
            <div class="card-header">
                <div>
                    <h2 class="card-title">{{ chapitre.titre }}</h2>
                    <p class="card-subtitle">Informations détaillées du chapitre</p>
                </div>
                <div class="card-actions">
                    <a href="{{ path('app_chapitre_edit', {'id': chapitre.id}) }}" class="card-btn" style="background: linear-gradient(135deg, var(--gold), var(--amber)); color: white;">
                        <svg style="width: 16px; height: 16px; display: inline-block; vertical-align: middle; margin-right: 4px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                        </svg>
                        Modifier
                    </a>
                    <a href="{{ path('app_chapitre_index') }}" class="card-btn">Retour</a>
                </div>
            </div>
            <div style="padding: 24px;">
                <table style="width: 100%; border-collapse: collapse;">
                    <tbody>
                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.1);">
                            <th style="padding: 16px; text-align: left; width: 200px; color: var(--text-secondary);">ID</th>
                            <td style="padding: 16px;">{{ chapitre.id }}</td>
                        </tr>
                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.1);">
                            <th style="padding: 16px; text-align: left; color: var(--text-secondary);">Titre</th>
                            <td style="padding: 16px; font-weight: 500;">{{ chapitre.titre }}</td>
                        </tr>
                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.1);">
                            <th style="padding: 16px; text-align: left; color: var(--text-secondary);">Contenu</th>
                            <td style="padding: 16px;">{{ chapitre.contenu }}</td>
                        </tr>
                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.1);">
                            <th style="padding: 16px; text-align: left; color: var(--text-secondary);">Cours</th>
                            <td style="padding: 16px;">
                                {% if chapitre.cours %}
                                    <span class="status-badge processing">{{ chapitre.cours.titre }}</span>
                                {% else %}
                                    <span style="color: var(--text-secondary);">Non assigné</span>
                                {% endif %}
                            </td>
                        </tr>
                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.1);">
                            <th style="padding: 16px; text-align: left; color: var(--text-secondary);">Ordre</th>
                            <td style="padding: 16px;">
                                <span style="background: rgba(255,255,255,0.1); padding: 4px 12px; border-radius: 12px; font-weight: 500;">
                                    #{{ chapitre.ordre }}
                                </span>
                            </td>
                        </tr>
                        <tr>
                            <th style="padding: 16px; text-align: left; color: var(--text-secondary);">Ressources</th>
                            <td style="padding: 16px;">{{ chapitre.ressources ?? 'Aucune ressource' }}</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </section>
{% endblock %}
