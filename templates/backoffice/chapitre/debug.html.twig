{% extends 'backoffice/base.html.twig' %}

{% block title %}DEBUG Form{% endblock %}

{% block body %}
<div class="container mt-4">
    <h1>DEBUG - Formulaire Chapitre</h1>
    
    <p>Form is defined: <strong>{{ form is defined ? '✅ OUI' : '❌ NON' }}</strong></p>
    
    {% if form is defined %}
        <p>Nombre de champs: {{ form.children|length }}</p>
        
        <h3>Formulaire complet:</h3>
        {{ form(form) }}
        
        <h3>Champs individuels:</h3>
        {{ form_start(form) }}
        <div class="mb-3">
            <label>Titre:</label>
            {{ form_widget(form.titre, {'attr': {'class': 'form-control'}}) }}
        </div>
        {{ form_end(form) }}
    {% endif %}
</div>
{% endblock %}
