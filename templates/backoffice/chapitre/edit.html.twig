{% extends 'backoffice/base.html.twig' %}

{% block title %}Modifier Chapitre{% endblock %}
{% block page_title %}Modifier le Chapitre{% endblock %}

{% block body %}
    <section class="content-grid">
        <div class="glass-card">
            <div class="card-header">
                <div>
                    <h2 class="card-title">Modifier: {{ chapitre.titre }}</h2>
                    <p class="card-subtitle">Mettre à jour les informations du chapitre</p>
                </div>
                <div class="card-actions">
                    <a href="{{ path('app_chapitre_index') }}" class="card-btn">
                        <svg style="width: 16px; height: 16px; display: inline-block; vertical-align: middle; margin-right: 4px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="19" y1="12" x2="5" y2="12"/>
                            <polyline points="12 19 5 12 12 5"/>
                        </svg>
                        Retour
                    </a>
                </div>
            </div>
            <div style="padding: 24px;">
                {{ include('backoffice/chapitre/_form.html.twig', {'button_label': 'Mettre à jour'}) }}
                
                <div style="margin-top: 24px; padding-top: 24px; border-top: 1px solid rgba(255,255,255,0.1);">
                    {{ include('backoffice/chapitre/_delete_form.html.twig') }}
                </div>
            </div>
        </div>
    </section>
{% endblock %}
