{% extends "backoffice/base_admin.html.twig" %}

{% block admin_content %}
<div class="card glass-card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h4>📝 Participations</h4>
        <a href="{{ path('app_participation_new') }}" class="btn btn-primary btn-sm">+ Ajouter Participation</a>
    </div>
    <div class="card-body">
        {% if participations|length > 0 %}
        <div class="table-responsive">
            <table class="table table-hover table-sm">
                <thead>
                    <tr>
                        <th>Événement</th>
                        <th>Équipe</th>
                        <th>Statut</th>
                        <th>Date Inscription</th>
                        <th>Commentaire Admin</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for participation in participations %}
                    <tr>
                        <td><strong>{{ participation.evenement.titre }}</strong></td>
                        <td>{{ participation.equipe.nom }}</td>
                        <td>
                            {% if participation.statut.value == 'en_attente' %}
                                <span class="badge bg-warning">EN ATTENTE</span>
                            {% elseif participation.statut.value == 'acceptee' %}
                                <span class="badge bg-success">ACCEPTÉE</span>
                            {% elseif participation.statut.value == 'rejetee' %}
                                <span class="badge bg-danger">REJETÉE</span>
                            {% elseif participation.statut.value == 'annulee' %}
                                <span class="badge bg-secondary">ANNULÉE</span>
                            {% endif %}
                        </td>
                        <td>{{ participation.dateInscription|date('d/m/Y H:i') }}</td>
                        <td><small>{{ participation.commentaireAdmin ?? '-' }}</small></td>
                        <td>
                            <a href="{{ path('app_participation_show', {id: participation.id}) }}" class="btn btn-sm btn-info">Voir</a>
                            <a href="{{ path('app_participation_edit', {id: participation.id}) }}" class="btn btn-sm btn-warning">Éditer</a>
                            <form method="POST" action="{{ path('app_participation_delete', {id: participation.id}) }}" style="display:inline;" onsubmit="return confirm('Confirmer ?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ participation.id) }}">
                                <button type="submit" class="btn btn-sm btn-danger">Supprimer</button>
                            </form>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% else %}
        <div class="alert alert-info">Aucune participation créée. <a href="{{ path('app_participation_new') }}">Créer la première</a></div>
        {% endif %}
    </div>
</div>
{% endblock %}
