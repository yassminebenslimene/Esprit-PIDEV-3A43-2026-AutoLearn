{% extends 'backoffice/base.html.twig' %}

{% block title %}Gestion des Participations{% endblock %}
{% block page_title %}Gestion des Participations{% endblock %}

{% block body %}
<div class="glass-card">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
        <h2 class="card-title">Liste des Participations</h2>
        <a href="{{ path('backoffice_participation_new') }}" class="btn btn-primary">
            ➕ Ajouter une participation
        </a>
    </div>

    {% for message in app.flashes('success') %}
        <div style="padding: 12px; background: rgba(127, 183, 126, 0.2); border-left: 3px solid #7fb77e; margin-bottom: 20px; border-radius: 8px;">
            {{ message }}
        </div>
    {% endfor %}

    <div class="table-wrapper">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Équipe</th>
                    <th>Événement</th>
                    <th>Statut</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for participation in participations %}
                <tr>
                    <td>{{ participation.equipe.nom }}</td>
                    <td>{{ participation.evenement.titre }}</td>
                    <td>
                        <span class="status-badge {% if participation.statut.value == 'Accepté' %}completed{% elseif participation.statut.value == 'Refusé' %}pending{% else %}processing{% endif %}">
                            {{ participation.statut.value }}
                        </span>
                    </td>
                    <td>
                        <div style="display: flex; gap: 8px;">
                            <a href="{{ path('backoffice_participation_show', {'id': participation.id}) }}" 
                               class="btn btn-sm" 
                               style="background: linear-gradient(135deg, #667eea, #764ba2); color: white; padding: 6px 12px; border-radius: 8px; text-decoration: none; font-size: 12px;">
                                👁 Voir
                            </a>
                            <a href="{{ path('backoffice_participation_edit', {'id': participation.id}) }}" 
                               class="btn btn-warning btn-sm" 
                               style="background: linear-gradient(135deg, var(--gold), var(--amber)); color: white; padding: 6px 12px; border-radius: 8px; text-decoration: none; font-size: 12px;">
                                ✏ Modifier
                            </a>
                            <a href="{{ path('backoffice_participation_delete', {'id': participation.id}) }}" 
                               class="btn btn-danger btn-sm" 
                               onclick="return confirm('Confirmer la suppression ?')"
                               style="background: linear-gradient(135deg, var(--coral), var(--gold)); color: white; padding: 6px 12px; border-radius: 8px; text-decoration: none; font-size: 12px;">
                                🗑 Supprimer
                            </a>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" style="text-align: center; padding: 40px; color: var(--text-muted);">
                        Aucune participation trouvée
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
