{% extends 'backoffice/base.html.twig' %}

{% block title %}Modifier Participation{% endblock %}
{% block page_title %}Modifier la Participation{% endblock %}

{% block body %}
<div class="glass-card">
    <h2 class="card-title">Modifier la Participation</h2>
    
    {{ form_start(form, {'attr': {'class': 'custom-form'}}) }}
        <div class="form-group">
            {{ form_label(form.equipe, 'Équipe') }}
            {{ form_widget(form.equipe, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.equipe) }}
        </div>

        <div class="form-group">
            {{ form_label(form.evenement, 'Événement') }}
            {{ form_widget(form.evenement, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.evenement) }}
        </div>

        <div class="form-group">
            {{ form_label(form.statut, 'Statut') }}
            {{ form_widget(form.statut, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.statut) }}
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Enregistrer</button>
            <a href="{{ path('backoffice_participations') }}" class="btn btn-secondary">Annuler</a>
        </div>
    {{ form_end(form) }}
</div>
{% endblock %}
