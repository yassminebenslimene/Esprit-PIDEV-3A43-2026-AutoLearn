{% extends "backoffice/base_admin.html.twig" %}

{% block admin_content %}
<div class="card glass-card">
    <div class="card-header">
        <h4>📝 Éditer Participation</h4>
    </div>
    <div class="card-body">
        {{ form_start(form) }}
        
        <div class="row">
            <div class="col-md-6 mb-3">
                {{ form_row(form.evenement, {'attr': {'class': 'form-select'}}) }}
            </div>
            <div class="col-md-6 mb-3">
                {{ form_row(form.equipe, {'attr': {'class': 'form-select'}}) }}
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                {{ form_row(form.statut, {'attr': {'class': 'form-select'}}) }}
            </div>
            <div class="col-md-6 mb-3">
                {{ form_row(form.dateInscription, {'attr': {'class': 'form-control'}}) }}
            </div>
        </div>

        <div class="mb-3">
            {{ form_row(form.commentaireAdmin, {'attr': {'class': 'form-control', 'rows': 3}}) }}
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">✓ Mettre à jour</button>
            <a href="{{ path('app_participation_index') }}" class="btn btn-secondary">Retour</a>
        </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
