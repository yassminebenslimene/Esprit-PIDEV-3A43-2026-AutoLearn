{% extends 'backoffice/base.html.twig' %}

{% block title %}Détails Participation{% endblock %}
{% block page_title %}Détails de la Participation{% endblock %}

{% block body %}
<div class="glass-card">
    <h2 class="card-title">Participation</h2>
    
    <div style="margin-top: 20px;">
        <div class="detail-row">
            <strong>Équipe:</strong> {{ participation.equipe.nom }}
        </div>
        <div class="detail-row">
            <strong>Événement:</strong> {{ participation.evenement.titre }}
        </div>
        <div class="detail-row">
            <strong>Statut:</strong> 
            <span class="status-badge {% if participation.statut.value == 'Accepté' %}completed{% elseif participation.statut.value == 'Refusé' %}pending{% else %}processing{% endif %}">
                {{ participation.statut.value }}
            </span>
        </div>
        <div class="detail-row">
            <strong>Membres de l'équipe:</strong>
            <ul style="margin-top: 10px; padding-left: 20px;">
                {% for etudiant in participation.equipe.etudiants %}
                    <li>{{ etudiant.prenom }} {{ etudiant.nom }}</li>
                {% endfor %}
            </ul>
        </div>
    </div>

    <div style="margin-top: 30px; display: flex; gap: 10px;">
        <a href="{{ path('backoffice_participation_edit', {'id': participation.id}) }}" class="btn btn-primary">Modifier</a>
        <a href="{{ path('backoffice_participations') }}" class="btn btn-secondary">Retour à la liste</a>
    </div>
</div>

<style>
.detail-row {
    padding: 12px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}
.detail-row:last-child {
    border-bottom: none;
}
</style>
{% endblock %}
