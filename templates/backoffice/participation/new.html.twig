{% extends 'backoffice/base.html.twig' %}

{% block title %}Nouvelle Participation{% endblock %}
{% block page_title %}Créer une Participation{% endblock %}

{% block body %}
<div class="glass-card">
    <h2 class="card-title">Nouvelle Participation</h2>
    
    {{ form_start(form, {'attr': {'class': 'custom-form'}}) }}
        <div class="form-group">
            {{ form_label(form.equipe, 'Équipe') }}
            {{ form_widget(form.equipe, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.equipe) }}
        </div>

        <div class="form-group">
            {{ form_label(form.evenement, 'Événement') }}
            {{ form_widget(form.evenement, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.evenement) }}
        </div>

        <div class="form-group">
            {{ form_label(form.statut, 'Statut') }}
            {{ form_widget(form.statut, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.statut) }}
            <small style="color: var(--text-muted); display: block; margin-top: 5px;">
                Le statut sera automatiquement validé selon les règles de participation
            </small>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Créer</button>
            <a href="{{ path('backoffice_participations') }}" class="btn btn-secondary">Annuler</a>
        </div>
    {{ form_end(form) }}
</div>
{% endblock %}
