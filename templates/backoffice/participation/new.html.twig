{% extends "backoffice/base_admin.html.twig" %}

{% block admin_content %}
<div class="card glass-card">
    <div class="card-header">
        <h4>📝 Créer Participation</h4>
        <small class="text-muted">Le statut peut être auto-déterminé ou défini par l'admin</small>
    </div>
    <div class="card-body">
        {{ form_start(form, {'attr': {'class': 'needs-validation'}}) }}
        
        <div class="row">
            <div class="col-md-6 mb-3">
                {{ form_row(form.evenement, {'attr': {'class': 'form-select'}}) }}
            </div>
            <div class="col-md-6 mb-3">
                {{ form_row(form.equipe, {'attr': {'class': 'form-select'}}) }}
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                {{ form_row(form.statut, {'attr': {'class': 'form-select'}}) }}
                <small class="text-muted">EN ATTENTE = auto-déterminé selon capacité</small>
            </div>
            <div class="col-md-6 mb-3">
                {{ form_row(form.dateInscription, {'attr': {'class': 'form-control', 'type': 'datetime-local'}}) }}
            </div>
        </div>

        <div class="mb-3">
            {{ form_row(form.commentaireAdmin, {'attr': {'class': 'form-control', 'rows': 3, 'placeholder': 'Notes (optionnel)'}}) }}
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-success">✓ Créer</button>
            <a href="{{ path('app_participation_index') }}" class="btn btn-secondary">Annuler</a>
        </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
