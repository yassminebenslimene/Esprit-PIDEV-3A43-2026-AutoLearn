{% extends 'backoffice/base.html.twig' %}

{% block title %}Profile{% endblock %}
{% block page_title %}Profile{% endblock %}

{% block body %}
    {% for message in app.flashes('success') %}
        <div class="alert alert-success" style="padding: 12px 16px; background: rgba(5, 150, 105, 0.1); border: 1px solid var(--emerald); border-radius: 8px; margin-bottom: 20px; color: var(--emerald-light);">
            {{ message }}
        </div>
    {% endfor %}
    
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger" style="padding: 12px 16px; background: rgba(239, 68, 68, 0.1); border: 1px solid #ef4444; border-radius: 8px; margin-bottom: 20px; color: #fca5a5;">
            {{ message }}
        </div>
    {% endfor %}

    <div class="glass-card" style="padding: 30px;">
        <div class="profile-header" style="display: flex; align-items: center; gap: 20px; margin-bottom: 30px; padding-bottom: 20px; border-bottom: 1px solid rgba(255,255,255,0.1);">
            <div class="profile-avatar-large" style="width: 80px; height: 80px; border-radius: 50%; background: linear-gradient(135deg, var(--emerald-light), var(--emerald)); display: flex; align-items: center; justify-content: center; font-size: 32px; font-weight: 600; color: white; position: relative;">
                {{ user.prenom[:1]|upper }}{{ user.nom[:1]|upper }}
            </div>
            <div class="profile-info">
                <h2 style="margin: 0 0 8px 0; font-size: 24px; color: var(--text);">{{ user.prenom }} {{ user.nom }}</h2>
                <p style="margin: 0; color: var(--text-muted);">{{ user.email }} • {{ user.role }}</p>
            </div>
        </div>

        {{ form_start(form, {'attr': {'class': 'profile-form', 'novalidate': 'novalidate'}}) }}
        
        <div class="settings-section" style="margin-bottom: 30px;">
            <h3 style="margin: 0 0 20px 0; font-size: 18px; color: var(--text); font-weight: 600;">Profile Information</h3>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                <div class="form-group-settings">
                    {{ form_label(form.prenom, 'Prénom', {'label_attr': {'style': 'display: block; margin-bottom: 8px; color: var(--text-muted); font-weight: 500; font-size: 14px;'}}) }}
                    {{ form_widget(form.prenom, {'attr': {'style': 'width: 100%; padding: 12px; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; color: var(--text); font-family: inherit;'}}) }}
                    {{ form_errors(form.prenom) }}
                </div>
                <div class="form-group-settings">
                    {{ form_label(form.nom, 'Nom', {'label_attr': {'style': 'display: block; margin-bottom: 8px; color: var(--text-muted); font-weight: 500; font-size: 14px;'}}) }}
                    {{ form_widget(form.nom, {'attr': {'style': 'width: 100%; padding: 12px; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; color: var(--text); font-family: inherit;'}}) }}
                    {{ form_errors(form.nom) }}
                </div>
                <div class="form-group-settings" style="grid-column: 1 / -1;">
                    {{ form_label(form.email, 'Email', {'label_attr': {'style': 'display: block; margin-bottom: 8px; color: var(--text-muted); font-weight: 500; font-size: 14px;'}}) }}
                    {{ form_widget(form.email, {'attr': {'style': 'width: 100%; padding: 12px; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; color: var(--text); font-family: inherit;'}}) }}
                    {{ form_errors(form.email) }}
                </div>
            </div>
        </div>

        <div class="settings-section" style="margin-bottom: 30px;">
            <h3 style="margin: 0 0 20px 0; font-size: 18px; color: var(--text); font-weight: 600;">Changer le mot de passe</h3>
            <div style="display: grid; grid-template-columns: 1fr; gap: 20px;">
                <div class="form-group-settings">
                    {{ form_label(form.password, 'Nouveau mot de passe (optionnel)', {'label_attr': {'style': 'display: block; margin-bottom: 8px; color: var(--text-muted); font-weight: 500; font-size: 14px;'}}) }}
                    {{ form_widget(form.password, {'attr': {'style': 'width: 100%; padding: 12px; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; color: var(--text); font-family: inherit;', 'placeholder': 'Minimum 8 caractères'}}) }}
                    {{ form_errors(form.password) }}
                    <small style="display: block; margin-top: 6px; color: var(--text-muted); font-size: 12px;">Laissez vide si vous ne souhaitez pas changer le mot de passe</small>
                </div>
            </div>
        </div>

        <div style="display: flex; gap: 15px;">
            <button type="submit" class="btn btn-primary" style="background: linear-gradient(135deg, var(--emerald-light), var(--emerald)); color: white; padding: 12px 30px; border: none; border-radius: 8px; font-weight: 600; cursor: pointer; display: flex; align-items: center; gap: 8px;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
                    <polyline points="17 21 17 13 7 13 7 21"/>
                    <polyline points="7 3 7 8 15 8"/>
                </svg>
                Sauvegarder les modifications
            </button>
            <a href="{{ path('app_backoffice') }}" class="btn btn-secondary" style="background: rgba(255,255,255,0.1); color: var(--text); padding: 12px 30px; border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; font-weight: 500; text-decoration: none; display: flex; align-items: center; gap: 8px;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="19" y1="12" x2="5" y2="12"/>
                    <polyline points="12 19 5 12 12 5"/>
                </svg>
                Annuler
            </a>
        </div>

        {{ form_end(form) }}
    </div>
{% endblock %}
