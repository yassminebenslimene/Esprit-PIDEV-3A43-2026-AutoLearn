<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ user.prenom }} {{ user.nom }} - 3D Glassmorphism Dashboard</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('backoffice/css/templatemo-glass-admin-style.css') }}">
    <style>
        .user-profile-card {
            max-width: 700px;
            margin: 0 auto;
        }
        .user-avatar-large {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.5rem;
            font-weight: 600;
            margin: 0 auto 2rem;
            color: white;
        }
        .user-info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 1.5rem;
            margin-top: 2rem;
        }
        .info-item {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 12px;
            padding: 1.5rem;
            backdrop-filter: blur(10px);
        }
        .info-label {
            font-size: 0.85rem;
            color: var(--text-lighter);
            margin-bottom: 0.5rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .info-value {
            font-size: 1.1rem;
            color: var(--text-light);
            font-weight: 500;
        }
        .action-buttons {
            display: flex;
            gap: 1rem;
            justify-content: center;
            margin-top: 2rem;
        }
        .btn {
            padding: 0.75rem 1.5rem;
            border-radius: 12px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s ease;
            border: none;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }
        .btn-edit {
            background: linear-gradient(135deg, var(--gold), var(--amber));
            color: var(--text-dark);
        }
        .btn-delete {
            background: linear-gradient(135deg, var(--danger), var(--coral));
            color: white;
        }
        .btn-back {
            background: rgba(255, 255, 255, 0.1);
            color: var(--text-light);
        }
        .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
        }
        .badge-large {
            padding: 0.5rem 1rem;
            border-radius: 20px;
            font-size: 0.9rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
    </style>
</head>
<body>
    <!-- Animated Background -->
    <div class="background"></div>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>

    <div class="dashboard">
        <!-- Sidebar -->
<aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
        <div class="logo">G</div>
        <span class="logo-text">AutoLearn</span>
    </div>

    <ul class="nav-menu">
        <li class="nav-section">
            <span class="nav-section-title">Main Menu</span>
            <ul>
                <li class="nav-item">
                    <a href="{{ path('app_backoffice') }}" class="nav-link">
                        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
                            <rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
                        </svg>
                        Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a href="{{ path('backoffice_analytics') }}" class="nav-link">
                        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
                        </svg>
                        Analytics
                        <span class="nav-badge">New</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="{{ path('backoffice_users') }}" class="nav-link active">
                        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                        </svg>
                        Users
                    </a>
                </li>
                <li class="nav-item">
                    <a href="{{ path('backoffice_settings') }}" class="nav-link">
                        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="3"/>
                            <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                        </svg>
                        Settings
                    </a>
                </li>
            </ul>
        </li>

        <li class="nav-section">
            <span class="nav-section-title">Account</span>
            <ul>
                <li class="nav-item">
                    <a href="{{ path('backoffice_logout') }}" class="nav-link">
                        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                            <polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
                        </svg>
                        Logout
                    </a>
                </li>
            </ul>
        </li>
    </ul>

    <div class="sidebar-footer">
        <div class="user-profile">
            <div class="user-avatar">
                {% if app.user %}
                    {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
                {% else %}
                    TM
                {% endif %}
            </div>
            <div class="user-info">
                <div class="user-name">
                    {% if app.user %}
                        {{ app.user.prenom }} {{ app.user.nom }}
                    {% else %}
                        TemplateMo
                    {% endif %}
                </div>
                <div class="user-role">Administrator</div>
            </div>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="6 9 12 15 18 9"/>
            </svg>
        </div>
    </div>
</aside>
        <!-- Main Content -->
        <main class="main-content">
            <!-- Top Navbar -->
            <nav class="navbar">
                <div class="page-header">
                    <h1 class="page-title">User Profile</h1>
                    <div class="page-breadcrumb">
                        <a href="{{ path('app_backoffice') }}">Dashboard</a>
                        <span>/</span>
                        <a href="{{ path('backoffice_users') }}">Users</a>
                        <span>/</span>
                        <span>{{ user.prenom }} {{ user.nom }}</span>
                    </div>
                </div>
                <div class="navbar-right">
                    <!-- Navigation buttons identiques -->
                </div>
            </nav>

            <!-- User Profile Card -->
            <section class="content-grid">
                <div class="glass-card user-profile-card">
                    <div class="user-avatar-large" style="background: linear-gradient(135deg, 
                        {% if user.role == 'ADMIN' %}var(--danger), var(--coral)
                        {% else %}var(--emerald-light), var(--emerald)
                        {% endif %});">
                        {{ user.prenom|first|upper }}{{ user.nom|first|upper }}
                    </div>
                    
                    <h2 style="text-align: center; margin-bottom: 0.5rem;">{{ user.prenom }} {{ user.nom }}</h2>
                    <p style="text-align: center; color: var(--text-lighter); margin-bottom: 2rem;">{{ user.email }}</p>

                    <div class="user-info-grid">
                        <div class="info-item">
                            <div class="info-label">Role</div>
                            <div class="info-value">
                                <span class="badge-large" style="
                                    background: linear-gradient(135deg, 
                                    {% if user.role == 'ADMIN' %}var(--danger), var(--coral)
                                    {% else %}var(--emerald-light), var(--emerald)
                                    {% endif %});
                                    color: {% if user.role == 'ADMIN' %}white{% else %}white{% endif %};">
                                    {{ user.role }}
                                </span>
                            </div>
                        </div>

                        

                        {% if user.isEtudiant() and user.niveau %}
                        <div class="info-item">
                            <div class="info-label">Level</div>
                            <div class="info-value">
                                <span class="badge-large" style="
                                    background: linear-gradient(135deg, 
                                    {% if user.niveau == 'DEBUTANT' %}var(--emerald-light), var(--emerald)
                                    {% elseif user.niveau == 'INTERMEDIAIRE' %}var(--gold), var(--amber)
                                    {% else %}var(--coral), var(--danger)
                                    {% endif %});
                                    color: {% if user.niveau == 'INTERMEDIAIRE' %}var(--text-dark){% else %}white{% endif %};">
                                    {{ user.niveau }}
                                </span>
                            </div>
                        </div>
                        {% endif %}

                        <div class="info-item">
                            <div class="info-label">Member Since</div>
                            <div class="info-value">{{ user.createdAt|date('F d, Y') }}</div>
                        </div>

                        <div class="info-item">
                            <div class="info-label">Account ID</div>
                            <div class="info-value">#{{ user.id }}</div>
                        </div>

                        <div class="info-item">
                            <div class="info-label">Status</div>
                            <div class="info-value">
                                {% if user.isSuspended %}
                                    <span style="color: #dc3545; font-weight: 600;">● Suspendu</span>
                                {% else %}
                                    <span style="color: var(--emerald); font-weight: 600;">● Actif</span>
                                {% endif %}
                            </div>
                        </div>
                        
                        {% if user.isSuspended %}
                        <div class="info-item">
                            <div class="info-label">Raison de suspension</div>
                            <div class="info-value">{{ user.suspensionReason }}</div>
                        </div>
                        
                        <div class="info-item">
                            <div class="info-label">Date de suspension</div>
                            <div class="info-value">{{ user.suspendedAt|date('d/m/Y H:i') }}</div>
                        </div>
                        {% endif %}
                    </div>

                    <div class="action-buttons">
                        {% if user.role == 'ETUDIANT' %}
                        <a href="{{ path('backoffice_user_edit', {'id': user.id}) }}" class="btn btn-edit">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 8px;">
                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                            </svg>
                            Edit User
                        </a>
                        {% endif %}
                        
                        {% if user.role == 'ETUDIANT' %}
                            {% if user.isSuspended %}
                                <!-- Reactivate Button -->
                                <form method="post" action="{{ path('backoffice_user_reactivate', {'id': user.id}) }}" 
                                      onsubmit="return confirm('Réactiver le compte de {{ user.prenom }} {{ user.nom }}?');"
                                      style="display: inline;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('reactivate' ~ user.id) }}">
                                    <button type="submit" class="btn btn-edit" style="background: linear-gradient(135deg, #28a745, #20c997);">
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 8px;">
                                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                                            <polyline points="22 4 12 14.01 9 11.01"/>
                                        </svg>
                                        Réactiver
                                    </button>
                                </form>
                            {% else %}
                                <!-- Suspend Button -->
                                <button type="button" class="btn btn-delete" 
                                        style="background: linear-gradient(135deg, #ffc107, #ff9800);"
                                        onclick="showSuspendModal({{ user.id }}, '{{ user.prenom }} {{ user.nom }}')">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 8px;">
                                        <circle cx="12" cy="12" r="10"/>
                                        <line x1="15" y1="9" x2="9" y2="15"/>
                                        <line x1="9" y1="9" x2="15" y2="15"/>
                                    </svg>
                                    Suspendre
                                </button>
                            {% endif %}
                        {% endif %}
                        
                        <a href="{{ path('backoffice_users') }}" class="btn btn-back">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 8px;">
                                <path d="M19 12H5M12 19l-7-7 7-7"/>
                            </svg>
                            Back to List
                        </a>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <!-- Suspension Modal -->
    <div id="suspendModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); z-index: 9999; align-items: center; justify-content: center;">
        <div style="background: white; border-radius: 15px; padding: 30px; max-width: 500px; width: 90%; box-shadow: 0 10px 40px rgba(0,0,0,0.3);">
            <h2 style="margin: 0 0 20px 0; color: #333;">Suspendre le compte</h2>
            <p style="color: #666; margin-bottom: 20px;">Étudiant: <strong id="suspendUserName"></strong></p>
            
            <form id="suspendForm" method="post" action="">
                <input type="hidden" name="_token" id="suspendToken" value="{{ csrf_token('suspend' ~ user.id) }}">
                
                <label style="display: block; margin-bottom: 10px; color: #333; font-weight: bold;">Raison de la suspension:</label>
                <select name="reason" style="width: 100%; padding: 12px; border: 2px solid #e2e8f0; border-radius: 8px; margin-bottom: 20px; font-size: 14px;">
                    <option value="Compte inactif - Inactivité prolongée">Compte inactif - Inactivité prolongée</option>
                    <option value="Violation des règles de la plateforme">Violation des règles de la plateforme</option>
                    <option value="Comportement inapproprié envers d'autres utilisateurs">Comportement inapproprié envers d'autres utilisateurs</option>
                    <option value="Activité suspecte détectée sur le compte">Activité suspecte détectée sur le compte</option>
                    <option value="Non-paiement ou problème de facturation">Non-paiement ou problème de facturation</option>
                    <option value="Demande de suspension par l'étudiant">Demande de suspension par l'étudiant</option>
                    <option value="Vérification d'identité requise">Vérification d'identité requise</option>
                    <option value="Suspension temporaire pour enquête">Suspension temporaire pour enquête</option>
                </select>
                
                <div style="display: flex; gap: 10px; justify-content: flex-end;">
                    <button type="button" onclick="closeSuspendModal()" style="padding: 12px 24px; border: 2px solid #e2e8f0; background: white; border-radius: 8px; cursor: pointer; font-weight: bold;">
                        Annuler
                    </button>
                    <button type="submit" style="padding: 12px 24px; border: none; background: linear-gradient(135deg, #ffc107, #ff9800); color: white; border-radius: 8px; cursor: pointer; font-weight: bold;">
                        Confirmer la suspension
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script src="{{ asset('backoffice/js/templatemo-glass-admin-script.js') }}"></script>
    <script>
    // Suspension Modal Functions
    function showSuspendModal(userId, userName) {
        const modal = document.getElementById('suspendModal');
        const form = document.getElementById('suspendForm');
        const userNameSpan = document.getElementById('suspendUserName');
        const tokenInput = document.getElementById('suspendToken');
        
        // Set form action
        form.action = '/backoffice/users/' + userId + '/suspend';
        
        // Set user name
        userNameSpan.textContent = userName;
        
        // Show modal
        modal.style.display = 'flex';
    }
    
    function closeSuspendModal() {
        const modal = document.getElementById('suspendModal');
        modal.style.display = 'none';
    }
    
    // Close modal on outside click
    document.getElementById('suspendModal').addEventListener('click', function(e) {
        if (e.target === this) {
            closeSuspendModal();
        }
    });
    </script>

</body>
</html>