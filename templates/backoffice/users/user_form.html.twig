                    <div class="page-breadcrumb">
                        <a href="{{ path('app_backoffice') }}">Dashboard</a>
                        <span>/</span>
                        <a href="{{ path('backoffice_users') }}">Users</a>
                        <span>/</span>
                        <span>{{ title }}</span>
                    </div>
                </div>
                <div class="navbar-right">
                    <button class="nav-btn" id="theme-toggle" title="Toggle Light/Dark Mode">
