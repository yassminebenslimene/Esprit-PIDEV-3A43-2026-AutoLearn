                                    <path d="M3 3h7v7H3z"/>
                                    <path d="M14 3h7v7h-7z"/>
                                    <path d="M14 14h7v7h-7z"/>
                                    <path d="M3 14h7v7H3z"/>
                                </svg>
                                Gestion Quiz
                            </a>
                        </li>
                        <li class="nav-item">
