                <div class="glass-card form-container">
                    {{ form_start(form, {'attr': {'class': 'form'}}) }}
                    
                    <div class="form-row">
                        <div class="form-group">
                            {{ form_label(form.prenom) }}
                            {{ form_widget(form.prenom, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.prenom) }}
                        </div>
                        
                        <div class="form-group">
                            {{ form_label(form.nom) }}
                            {{ form_widget(form.nom, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.nom) }}
                        </div>
                    </div>

                    <div class="form-group">
                        {{ form_label(form.email) }}
                        {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.email) }}
                    </div>

                    <div class="form-group">
                        {{ form_label(form.password) }}
                        {{ form_widget(form.password, {'attr': {'class': 'form-control'}}) }}
                        <div class="form-help">
 8 caractères min avec : majuscule, minuscule, chiffre, caractère spécial (@$!%*?&)                        </div>
                        {{ form_errors(form.password) }}
                    </div>

                    {# ONLY SHOW ROLE FIELD IF IT EXISTS AND WE'RE NOT HIDING IT #}
                    {% if form.role is defined and not hide_role|default(false) %}
                        <div class="form-group">
                            {{ form_label(form.role) }}
                            {{ form_widget(form.role, {'attr': {'class': 'form-control form-select'}}) }}
                            {{ form_errors(form.role) }}
                        </div>
                    {% endif %}

                    {# ADMIN FORM - Niveau field disabled when role is not ETUDIANT #}
<div class="form-group" id="niveau-field">
    {{ form_label(form.niveau) }}
    
    {# Si le rôle est défini dans le formulaire (mode création admin) #}
    {% if form.role is defined %}
        {{ form_widget(form.niveau, {
            'attr': {
                'class': 'form-control form-select',
                'id': 'user_niveau',
                'disabled': form.role.vars.value != 'ETUDIANT'
            }
        }) }}
    {% else %}
        {# Mode édition - toujours activé car on ne modifie que des étudiants #}
        {{ form_widget(form.niveau, {'attr': {'class': 'form-control form-select', 'id': 'user_niveau'}}) }}
    {% endif %}
    
    {{ form_errors(form.niveau) }}
</div>

                    <div class="btn-group">
                        <button type="submit" class="btn btn-primary">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 8px;">
                                <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
                                <polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/>
                            </svg>
                            {{ button_label|default('Save') }}
                        </button>
                        
                        <a href="
                            {% if hide_role|default(false) and app.user and app.user.isEtudiant() %}
                                {{ path('backoffice_settings') }}
                            {% else %}
                                {{ path('backoffice_users') }}
                            {% endif %}
                        " class="btn btn-secondary">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 8px;">
                                <path d="M19 12H5M12 19l-7-7 7-7"/>
                            </svg>
                            Cancel
                        </a>
                    </div>
                    
                    {{ form_end(form) }}
                </div>
            </section>
        </main>
    </div>

    <script>
    document.addEventListener('DOMContentLoaded', function() {
        const roleSelect = document.querySelector('#{{ form.role is defined ? form.role.vars.id : '' }}');
        const niveauField = document.getElementById('niveau-field');
        
        function toggleNiveauField() {
            // If role field doesn't exist (edit mode), always show niveau
            {% if form.role is not defined or hide_role|default(false) %}
                niveauField.style.display = 'block';
                const niveauSelect = niveauField.querySelector('select');
                if (niveauSelect) niveauSelect.required = true;
            {% else %}
                // Role field exists, toggle based on value
                if (roleSelect && roleSelect.value === 'ETUDIANT') {
                    niveauField.style.display = 'block';
                    niveauField.querySelector('select').required = true;
                } else {
                    niveauField.style.display = 'none';
                    niveauField.querySelector('select').required = false;
                    niveauField.querySelector('select').value = '';
                }
            {% endif %}
        }
        
        // Initial toggle
        toggleNiveauField();
        
        // Toggle on change - only if role field exists
        {% if form.role is defined and not hide_role|default(false) %}
            if (roleSelect) {
                roleSelect.addEventListener('change', toggleNiveauField);
            }
        {% endif %}
        
        // Auto-hide flash messages
        setTimeout(function() {
            const flashMessages = document.querySelectorAll('.flash-message');
            flashMessages.forEach(function(message) {
                message.style.animation = 'slideIn 0.3s ease reverse';
                setTimeout(function() {
                    message.remove();
                }, 300);
            });
        }, 5000);
    });
    </script>
    
    <script src="{{ asset('backoffice/js/templatemo-glass-admin-script.js') }}"></script>
    
    {# AI Chat Widget - Assistant Intelligent #}
    {% include 'ai_assistant/chat_widget.html.twig' %}
</body>
</html>