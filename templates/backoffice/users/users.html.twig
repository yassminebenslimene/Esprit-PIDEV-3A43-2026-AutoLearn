{% extends 'backoffice/base.html.twig' %}

{% block title %}Users{% endblock %}
{% block page_title %}Users{% endblock %}

{% block body %}
    <style>
        .badge {
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            display: inline-block;
        }
        .badge-admin {
            background: linear-gradient(135deg, var(--danger), var(--coral));
            color: white;
        }
        .badge-user {
            background: linear-gradient(135deg, var(--emerald-light), var(--emerald));
            color: white;
        }
        .level-badge {
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            display: inline-block;
        }
        .level-badge.debutant {
            background: linear-gradient(135deg, var(--emerald-light), var(--emerald));
            color: white;
        }
        .level-badge.intermediaire {
            background: linear-gradient(135deg, var(--gold), var(--amber));
            color: var(--text-dark);
        }
        .level-badge.avance {
            background: linear-gradient(135deg, var(--coral), var(--danger));
            color: white;
        }
        .action-buttons {
            display: flex;
            gap: 5px;
            flex-wrap: wrap;
        }
        .small-btn {
            font-size: 12px !important;
            padding: 6px 10px !important;
            min-width: 70px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }
        .small-btn svg {
            margin-right: 4px;
        }
        .danger {
            background: var(--danger) !important;
            border-color: var(--danger) !important;
            color: white !important;
        }
    </style>

    <!-- Flash Messages -->
    {% for message in app.flashes('success') %}
    <div style="padding: 12px 16px; background: rgba(5, 150, 105, 0.1); border: 1px solid var(--emerald); border-radius: 8px; margin-bottom: 20px; color: var(--emerald-light);">
        {{ message }}
    </div>
    {% endfor %}
    {% for message in app.flashes('error') %}
    <div style="padding: 12px 16px; background: rgba(239, 68, 68, 0.1); border: 1px solid #ef4444; border-radius: 8px; margin-bottom: 20px; color: #fca5a5;">
        {{ message }}
    </div>
    {% endfor %}

    <!-- Stats Cards -->
    <section class="stats-grid">
        <div class="glass-card glass-card-3d stat-card">
            <div class="stat-card-inner">
                <div class="stat-info">
                    <h3>Total Users</h3>
                    <div class="stat-value">{{ totalUsers|default(0) }}</div>
                    <span class="stat-change positive">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg>
                        {% if totalUsers > 0 %}
                            +{{ ((newTodayCount|default(0)) / totalUsers * 100)|round(1) }}%
                        {% else %}
                            0%
                        {% endif %}
                    </span>
                </div>
                <div class="stat-icon cyan">
                    <svg viewBox="0 0 24 24" fill="none" stroke="var(--emerald-light)" stroke-width="2">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                    </svg>
                </div>
            </div>
        </div>

        <div class="glass-card glass-card-3d stat-card">
            <div class="stat-card-inner">
                <div class="stat-info">
                    <h3>Students</h3>
                    <div class="stat-value">{{ totalStudents|default(0) }}</div>
                    <span class="stat-change positive">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg>
                        {{ totalStudents > 0 ? '+12.5%' : '0%' }}
                    </span>
                </div>
                <div class="stat-icon magenta">
                    <svg viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
                    </svg>
                </div>
            </div>
        </div>

        <div class="glass-card glass-card-3d stat-card">
            <div class="stat-card-inner">
                <div class="stat-info">
                    <h3>Admins</h3>
                    <div class="stat-value">{{ totalAdmins|default(0) }}</div>
                    <span class="stat-change positive">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg>
                        {{ totalAdmins > 0 ? '+5.2%' : '0%' }}
                    </span>
                </div>
                <div class="stat-icon purple">
                    <svg viewBox="0 0 24 24" fill="none" stroke="var(--coral)" stroke-width="2">
                        <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/>
                        <line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/>
                    </svg>
                </div>
            </div>
        </div>

        <div class="glass-card glass-card-3d stat-card">
            <div class="stat-card-inner">
                <div class="stat-info">
                    <h3>New Today</h3>
                    <div class="stat-value">{{ newTodayCount|default(0) }}</div>
                    <span class="stat-change {{ newTodayCount > 0 ? 'positive' : 'negative' }}">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/>
                        </svg>
                        {{ newTodayCount > 0 ? '+18.7%' : '-3.1%' }}
                    </span>
                </div>
                <div class="stat-icon success">
                    <svg viewBox="0 0 24 24" fill="none" stroke="var(--success)" stroke-width="2">
                        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                    </svg>
                </div>
            </div>
        </div>
    </section>

    <!-- Users Table -->
    <section class="content-grid" style="grid-template-columns: 1fr;">
        <div class="glass-card table-card">
            <div class="card-header">
                <div>
                    <h2 class="card-title">All Users</h2>
                    <p class="card-subtitle">Manage your user base</p>
                </div>
                <div class="card-actions">
                    <a href="{{ path('backoffice_user_new') }}" class="card-btn">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 6px;">
                            <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
                        </svg>
                        Add Student
                    </a>
                    <a href="{{ path('backoffice_users_export') }}" class="card-btn">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 6px;">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                            <polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
                        </svg>
                        Export CSV
                    </a>
                </div>
            </div>
            <div class="table-wrapper">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Role</th>
                            <th>Level</th>
                            <th>Joined</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% if users is defined and users|length > 0 %}
                            {% for user in users %}
                            {% if user.id != app.user.id %}
                            <tr>
                                <td>
                                    <div class="table-user">
                                        <div class="table-avatar" style="background: linear-gradient(135deg, 
                                            {% if user.role == 'ADMIN' %}var(--danger), var(--coral)
                                            {% else %}var(--emerald-light), var(--emerald)
                                            {% endif %});">
                                            {{ user.prenom|first|upper }}{{ user.nom|first|upper }}
                                        </div>
                                        <div class="table-user-info">
                                            <span class="table-user-name">{{ user.prenom }} {{ user.nom }}</span>
                                            <span class="table-user-email">{{ user.email }}</span>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    {% if user.role == 'ADMIN' %}
                                        <span class="badge badge-admin">Administrator</span>
                                    {% else %}
                                        <span class="badge badge-user">Student</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if user.isEtudiant() and user.niveau %}
                                        <span class="level-badge {{ user.niveau|lower }}">
                                            {{ user.niveau }}
                                        </span>
                                    {% else %}
                                        —
                                    {% endif %}
                                </td>
                                <td>{{ user.createdAt|date('M d, Y') }}</td>
                                <td>
                                    {% if user.isSuspended %}
                                        <span class="status-badge suspended" style="background: linear-gradient(135deg, #dc3545, #c82333);">Suspendu</span>
                                    {% else %}
                                        <span class="status-badge completed">Actif</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <div class="action-buttons">
                                        <a href="{{ path('backoffice_user_show', {'id': user.id}) }}" class="card-btn small-btn">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                                <circle cx="12" cy="12" r="3"/>
                                            </svg>
                                            View
                                        </a>
                                        
                                        {% if user.role == 'ETUDIANT' %}
                                        <a href="{{ path('backoffice_user_edit', {'id': user.id}) }}" class="card-btn small-btn">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                            </svg>
                                            Edit
                                        </a>
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                            {% endif %}
                            {% endfor %}
                        {% else %}
                            <tr>
                                <td colspan="6" style="text-align: center; padding: 2rem;">
                                    No users found
                                    {% if search %}
                                        for "{{ search }}"
                                    {% endif %}
                                </td>
                            </tr>
                        {% endif %}
                    </tbody>
                </table>
            </div>
            
            {% if search and users|length > 0 %}
            <div style="padding: 1rem; text-align: center;">
                <a href="{{ path('backoffice_users') }}" class="card-btn" style="font-size: 0.9rem;">
                    Clear search
                </a>
            </div>
            {% endif %}
        </div>
    </section>
{% endblock %}
