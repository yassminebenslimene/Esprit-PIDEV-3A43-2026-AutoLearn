<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Users - 3D Glassmorphism Dashboard</title>
    <meta name="description" content="3D Glassmorphism Dashboard Template by TemplateMo">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('backoffice/css/templatemo-glass-admin-style.css') }}">
    <style>
        /* Badges pour les rôles */
        .badge {
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            display: inline-block;
        }
        .badge-admin {
            background: linear-gradient(135deg, var(--danger), var(--coral));
            color: white;
        }
        .badge-user {
            background: linear-gradient(135deg, var(--emerald-light), var(--emerald));
            color: white;
        }
        
        /* Badges pour les niveaux */
        .level-badge {
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            display: inline-block;
        }
        .level-badge.debutant {
            background: linear-gradient(135deg, var(--emerald-light), var(--emerald));
            color: white;
        }
        .level-badge.intermediaire {
            background: linear-gradient(135deg, var(--gold), var(--amber));
            color: var(--text-dark);
        }
        .level-badge.avance {
            background: linear-gradient(135deg, var(--coral), var(--danger));
            color: white;
        }
        
        /* Boutons d'action */
        .action-buttons {
            display: flex;
            gap: 5px;
            flex-wrap: wrap;
        }
        .small-btn {
            font-size: 12px !important;
            padding: 6px 10px !important;
            min-width: 70px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }
        .small-btn svg {
            margin-right: 4px;
        }
        .danger {
            background: var(--danger) !important;
            border-color: var(--danger) !important;
            color: white !important;
        }
        
        /* Flash messages */
        .flash-message {
            position: fixed;
            top: 100px;
            right: 30px;
            padding: 1rem 1.5rem;
            border-radius: 12px;
            z-index: 1000;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
            animation: slideIn 0.3s ease;
            backdrop-filter: blur(10px);
        }
        .flash-success {
            background: linear-gradient(135deg, var(--emerald), var(--emerald-light));
            color: white;
        }
        .flash-error {
            background: linear-gradient(135deg, var(--danger), var(--coral));
            color: white;
        }
        @keyframes slideIn {
            from { transform: translateX(100%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }
        
        /* Stats actualisées */
        .stat-value {
            font-size: 2rem;
            font-weight: 700;
        }
        
        /* Form search */
        .search-form {
            display: inline;
        }
        .search-input {
            background: transparent;
            border: none;
            padding: 0;
            width: 100%;
        }
    </style>
</head>
<body>
    <!-- Animated Background -->
    <div class="background"></div>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>

    <div class="dashboard">
        <!-- Sidebar -->
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <div class="logo">G</div>
                <span class="logo-text">AutoLearn</span>
            </div>

            <ul class="nav-menu">
                <li class="nav-section">
                    <span class="nav-section-title">Main Menu</span>
                    <ul>
                        <li class="nav-item">
                            <a href="{{ path('app_backoffice') }}" class="nav-link">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
                                    <rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
                                </svg>
                                Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="{{ path('backoffice_analytics') }}" class="nav-link">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
                                </svg>
                                Analytics
                                <span class="nav-badge">New</span>
                            </a>
                        </li>
                    </ul>
                </li>

                <li class="nav-section">
                    <span class="nav-section-title">Gestion</span>
                    <ul>
                        <li class="nav-item">
                            <a href="{{ path('backoffice_quiz_management') }}" class="nav-link">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M3 3h7v7H3z"/>
                                    <path d="M14 3h7v7h-7z"/>
                                    <path d="M14 14h7v7h-7z"/>
                                    <path d="M3 14h7v7H3z"/>
                                </svg>
                                Gestion Quiz
                            </a>
                        </li>
                    </ul>
                </li>

                <li class="nav-section">
                    <span class="nav-section-title">Système</span>
                    <ul>
                        <li class="nav-item">
                            <a href="{{ path('app_cours_index') }}" class="nav-link">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
                                    <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
                                </svg>
                                Cours
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="{{ path('app_chapitre_index') }}" class="nav-link">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                                    <polyline points="14 2 14 8 20 8"/>
                                    <line x1="16" y1="13" x2="8" y2="13"/>
                                    <line x1="16" y1="17" x2="8" y2="17"/>
                                    <polyline points="10 9 9 9 8 9"/>
                                </svg>
                                Chapitres
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="{{ path('backoffice_users') }}" class="nav-link active">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
                                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                                </svg>
                                Users
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="{{ path('backoffice_challenges') }}" class="nav-link">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
                                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                                </svg>
                                challenges
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="{{ path('backoffice_exercices') }}" class="nav-link">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
                                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                                </svg>
                                exercices
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="{{ path('backoffice_settings') }}" class="nav-link">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="12" cy="12" r="3"/>
                                    <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                                </svg>
                                Settings
                            </a>
                        </li>
                    </ul>
                </li>

                <li class="nav-section">
                    <span class="nav-section-title">Account</span>
                    <ul>
                        <li class="nav-item">
                            <a href="{{ path('backoffice_logout') }}" class="nav-link">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                                    <polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
                                </svg>
                                Logout
                            </a>
                        </li>
                    </ul>
                </li>
            </ul>

            <div class="sidebar-footer">
                <div class="user-profile">
                    <div class="user-avatar">
                        {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
                    </div>
                    <div class="user-info">
                        <div class="user-name">{{ app.user.prenom }} {{ app.user.nom }}</div>
                        <div class="user-role">Administrator</div>
                    </div>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="6 9 12 15 18 9"/>
                    </svg>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Top Navbar -->
            <nav class="navbar">
                <div class="page-header">
                    <h1 class="page-title">Users</h1>
                    <div class="page-breadcrumb">
                        <a href="{{ path('app_backoffice') }}">Dashboard</a>
                        <span>/</span>
                        <span>Users</span>
                    </div>
                </div>
                <div class="navbar-right">
                    <div class="search-box">
                        <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                        </svg>
                        <form method="get" action="{{ path('backoffice_users') }}" class="search-form">
                            <input type="text" 
                                   name="search" 
                                   class="search-input" 
                                   placeholder="Search users..." 
                                   value="{{ search|default('') }}">
                        </form>
                    </div>
                    <button class="nav-btn">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                        </svg>
                        <span class="notification-dot"></span>
                    </button>
                    <button class="nav-btn" id="theme-toggle" title="Toggle Light/Dark Mode">
                        <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/>
                            <path d="M4.93 4.93l1.41 1.41"/><path d="M17.66 17.66l1.41 1.41"/>
                            <path d="M2 12h2"/><path d="M20 12h2"/>
                            <path d="M6.34 17.66l-1.41 1.41"/><path d="M19.07 4.93l-1.41 1.41"/>
                        </svg>
                        <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display: none;">
                            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                        </svg>
                    </button>
                </div>
            </nav>

            <!-- Flash Messages -->
            {% for message in app.flashes('success') %}
            <div class="flash-message flash-success">
                {{ message }}
            </div>
            {% endfor %}
            {% for message in app.flashes('error') %}
            <div class="flash-message flash-error">
                {{ message }}
            </div>
            {% endfor %}

            <!-- Stats Cards -->
            <section class="stats-grid">
                <div class="glass-card glass-card-3d stat-card">
                    <div class="stat-card-inner">
                        <div class="stat-info">
                            <h3>Total Users</h3>
                            <div class="stat-value">{{ totalUsers|default(0) }}</div>
                            <span class="stat-change positive">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg>
                                {% if totalUsers > 0 %}
                                    +{{ ((newTodayCount|default(0)) / totalUsers * 100)|round(1) }}%
                                {% else %}
                                    0%
                                {% endif %}
                            </span>
                        </div>
                        <div class="stat-icon cyan">
                            <svg viewBox="0 0 24 24" fill="none" stroke="var(--emerald-light)" stroke-width="2">
                                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
                                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                            </svg>
                        </div>
                    </div>
                </div>

                <div class="glass-card glass-card-3d stat-card">
                    <div class="stat-card-inner">
                        <div class="stat-info">
                            <h3>Students</h3>
                            <div class="stat-value">{{ totalStudents|default(0) }}</div>
                            <span class="stat-change positive">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg>
                                {{ totalStudents > 0 ? '+12.5%' : '0%' }}
                            </span>
                        </div>
                        <div class="stat-icon magenta">
                            <svg viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="2">
                                <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
                            </svg>
                        </div>
                    </div>
                </div>

                <div class="glass-card glass-card-3d stat-card">
                    <div class="stat-card-inner">
                        <div class="stat-info">
                            <h3>Admins</h3>
                            <div class="stat-value">{{ totalAdmins|default(0) }}</div>
                            <span class="stat-change positive">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg>
                                {{ totalAdmins > 0 ? '+5.2%' : '0%' }}
                            </span>
                        </div>
                        <div class="stat-icon purple">
                            <svg viewBox="0 0 24 24" fill="none" stroke="var(--coral)" stroke-width="2">
                                <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/>
                                <line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/>
                            </svg>
                        </div>
                    </div>
                </div>

                <div class="glass-card glass-card-3d stat-card">
                    <div class="stat-card-inner">
                        <div class="stat-info">
                            <h3>New Today</h3>
                            <div class="stat-value">{{ newTodayCount|default(0) }}</div>
                            <span class="stat-change {{ newTodayCount > 0 ? 'positive' : 'negative' }}">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/>
                                </svg>
                                {{ newTodayCount > 0 ? '+18.7%' : '-3.1%' }}
                            </span>
                        </div>
                        <div class="stat-icon success">
                            <svg viewBox="0 0 24 24" fill="none" stroke="var(--success)" stroke-width="2">
                                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                            </svg>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Users Table -->
            <section class="content-grid" style="grid-template-columns: 1fr;">
                <div class="glass-card table-card" style="grid-column: span 1;">
                    <div class="card-header">
                        <div>
                            <h2 class="card-title">All Users</h2>
                            <p class="card-subtitle">Manage your user base</p>
                        </div>
                        <div class="card-actions">
    <a href="{{ path('backoffice_user_new') }}" class="card-btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 6px;">
            <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        Add Student
    </a>
    <a href="{{ path('backoffice_users_export') }}" class="card-btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 6px;">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Export CSV
    </a>
</div>
                    </div>
                    <div class="table-wrapper">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>User</th>
                                    <th>Role</th>
                                    <th>Level</th>
                                    <th>Joined</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% if users is defined and users|length > 0 %}
                                    {% for user in users %}
                                    {% if user.id != app.user.id %}
                                    <tr>
                                        <td>
                                            <div class="table-user">
                                                <div class="table-avatar" style="background: linear-gradient(135deg, 
                                                    {% if user.role == 'ADMIN' %}var(--danger), var(--coral)
                                                    {% else %}var(--emerald-light), var(--emerald)
                                                    {% endif %});">
                                                    {{ user.prenom|first|upper }}{{ user.nom|first|upper }}
                                                </div>
                                                <div class="table-user-info">
                                                    <span class="table-user-name">{{ user.prenom }} {{ user.nom }}</span>
                                                    <span class="table-user-email">{{ user.email }}</span>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            {% if user.role == 'ADMIN' %}
                                                <span class="badge badge-admin">Administrator</span>
                                            {% else %}
                                                <span class="badge badge-user">Student</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if user.isEtudiant() and user.niveau %}
                                                <span class="level-badge {{ user.niveau|lower }}">
                                                    {{ user.niveau }}
                                                </span>
                                            {% else %}
                                                —
                                            {% endif %}
                                        </td>
                                        <td>{{ user.createdAt|date('M d, Y') }}</td>
                                        <td>
                                            {% if user.isSuspended %}
                                                <span class="status-badge suspended" style="background: linear-gradient(135deg, #dc3545, #c82333);">Suspendu</span>
                                            {% else %}
                                                <span class="status-badge completed">Actif</span>
                                            {% endif %}
                                        </td>
                                        <td>
    <div class="action-buttons">
        <!-- View - always visible for everyone -->
        <a href="{{ path('backoffice_user_show', {'id': user.id}) }}" 
           class="card-btn small-btn">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                <circle cx="12" cy="12" r="3"/>
            </svg>
            View
        </a>
        
        <!-- Activities - always visible for everyone -->
        <button type="button" 
                class="card-btn small-btn" 
                style="background: linear-gradient(135deg, #6366f1, #8b5cf6) !important;"
                onclick="showActivitiesModal({{ user.id }}, '{{ user.prenom }} {{ user.nom }}')">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
            </svg>
            Activities
        </button>
        
        <!-- Edit - ONLY for students -->
        {% if user.role == 'ETUDIANT' %}
            <a href="{{ path('backoffice_user_edit', {'id': user.id}) }}" 
               class="card-btn small-btn">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                </svg>
                Edit
            </a>
        {% endif %}
        
        <!-- Suspend/Reactivate - ONLY for students -->
        {% if user.role == 'ETUDIANT' %}
            {% if user.isSuspended %}
                <!-- Reactivate Button -->
                <form method="post" 
                      action="{{ path('backoffice_user_reactivate', {'id': user.id}) }}" 
                      onsubmit="return confirm('Réactiver le compte de {{ user.prenom }} {{ user.nom }}?');"
                      style="display: inline;">
                    <input type="hidden" name="_token" value="{{ csrf_token('reactivate' ~ user.id) }}">
                    <button type="submit" class="card-btn small-btn" style="background: linear-gradient(135deg, #28a745, #20c997) !important;">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                            <polyline points="22 4 12 14.01 9 11.01"/>
                        </svg>
                        Réactiver
                    </button>
                </form>
            {% else %}
                <!-- Suspend Button -->
                <button type="button" 
                        class="card-btn small-btn" 
                        style="background: linear-gradient(135deg, #ffc107, #ff9800) !important;"
                        onclick="showSuspendModal({{ user.id }}, '{{ user.prenom }} {{ user.nom }}')">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="15" y1="9" x2="9" y2="15"/>
                        <line x1="9" y1="9" x2="15" y2="15"/>
                    </svg>
                    Suspendre
                </button>
            {% endif %}
        {% endif %}
                                                    {% endif %}

    </div>
</td>
                                    </tr>
                                    {% endfor %}
                                {% else %}
                                    <tr>
                                        <td colspan="6" style="text-align: center; padding: 2rem;">
                                            No users found
                                            {% if search %}
                                                for "{{ search }}"
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endif %}
                            </tbody>
                        </table>
                    </div>
                    
                    {% if search and users|length > 0 %}
                    <div style="padding: 1rem; text-align: center;">
                        <a href="{{ path('backoffice_users') }}" class="card-btn" style="font-size: 0.9rem;">
                            Clear search
                        </a>
                    </div>
                    {% endif %}
                </div>
            </section>
        </main>
    </div>

    <!-- Mobile Menu Toggle -->
    <button class="mobile-menu-toggle">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
    </button>

    <!-- Suspension Modal -->
    <div id="suspendModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); z-index: 9999; align-items: center; justify-content: center;">
        <div style="background: white; border-radius: 15px; padding: 30px; max-width: 500px; width: 90%; box-shadow: 0 10px 40px rgba(0,0,0,0.3);">
            <h2 style="margin: 0 0 20px 0; color: #333;">Suspendre le compte</h2>
            <p style="color: #666; margin-bottom: 20px;">Étudiant: <strong id="suspendUserName"></strong></p>
            
            <form id="suspendForm" method="post" action="">
                <input type="hidden" name="_token" id="suspendToken" value="">
                
                <label style="display: block; margin-bottom: 10px; color: #333; font-weight: bold;">Raison de la suspension:</label>
                <select name="reason" style="width: 100%; padding: 12px; border: 2px solid #e2e8f0; border-radius: 8px; margin-bottom: 20px; font-size: 14px;">
                    <option value="Compte inactif - Inactivité prolongée">Compte inactif - Inactivité prolongée</option>
                    <option value="Violation des règles de la plateforme">Violation des règles de la plateforme</option>
                    <option value="Comportement inapproprié envers d'autres utilisateurs">Comportement inapproprié envers d'autres utilisateurs</option>
                    <option value="Activité suspecte détectée sur le compte">Activité suspecte détectée sur le compte</option>
                    <option value="Non-paiement ou problème de facturation">Non-paiement ou problème de facturation</option>
                    <option value="Demande de suspension par l'étudiant">Demande de suspension par l'étudiant</option>
                    <option value="Vérification d'identité requise">Vérification d'identité requise</option>
                    <option value="Suspension temporaire pour enquête">Suspension temporaire pour enquête</option>
                </select>
                
                <div style="display: flex; gap: 10px; justify-content: flex-end;">
                    <button type="button" onclick="closeSuspendModal()" style="padding: 12px 24px; border: 2px solid #e2e8f0; background: white; border-radius: 8px; cursor: pointer; font-weight: bold;">
                        Annuler
                    </button>
                    <button type="submit" style="padding: 12px 24px; border: none; background: linear-gradient(135deg, #ffc107, #ff9800); color: white; border-radius: 8px; cursor: pointer; font-weight: bold;">
                        Confirmer la suspension
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Activities Modal -->
    <div id="activitiesModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); z-index: 9999; align-items: center; justify-content: center;">
        <div style="background: white; border-radius: 15px; padding: 30px; max-width: 1200px; width: 95%; max-height: 90vh; overflow-y: auto; box-shadow: 0 10px 40px rgba(0,0,0,0.3);">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                <div>
                    <h2 style="margin: 0; color: #333;">Activity History</h2>
                    <p style="color: #666; margin: 5px 0 0 0;">User: <strong id="activitiesUserName"></strong></p>
                </div>
                <button type="button" onclick="closeActivitiesModal()" style="background: none; border: none; font-size: 28px; cursor: pointer; color: #999; line-height: 1;">&times;</button>
            </div>
            
            <div id="activitiesContent" style="min-height: 200px;">
                <div style="text-align: center; padding: 40px; color: #999;">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-bottom: 10px;">
                        <circle cx="12" cy="12" r="10"/>
                        <polyline points="12 6 12 12 16 14"/>
                    </svg>
                    <p>Loading activities...</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="site-footer">
        <p>Copyright © 2026 Your Company. Designed by <a href="https://templatemo.com" target="_blank" rel="nofollow">TemplateMo</a></p>
    </footer>

    <script src="{{ asset('backoffice/js/templatemo-glass-admin-script.js') }}"></script>
    <script>
    // Store CSRF tokens for each user
    const suspendTokens = {
        {% for user in users %}
        {% if user.role == 'ETUDIANT' and user.id != app.user.id %}
        {{ user.id }}: '{{ csrf_token('suspend' ~ user.id) }}',
        {% endif %}
        {% endfor %}
    };
    
    // Suspension Modal Functions
    function showSuspendModal(userId, userName) {
        const modal = document.getElementById('suspendModal');
        const form = document.getElementById('suspendForm');
        const userNameSpan = document.getElementById('suspendUserName');
        const tokenInput = document.getElementById('suspendToken');
        
        // Set form action
        form.action = '/backoffice/users/' + userId + '/suspend';
        
        // Set user name
        userNameSpan.textContent = userName;
        
        // Set CSRF token
        tokenInput.value = suspendTokens[userId] || '';
        
        // Show modal
        modal.style.display = 'flex';
    }
    
    function closeSuspendModal() {
        const modal = document.getElementById('suspendModal');
        modal.style.display = 'none';
    }
    
    // Close modal on outside click
    document.getElementById('suspendModal').addEventListener('click', function(e) {
        if (e.target === this) {
            closeSuspendModal();
        }
    });
    
    // Activities Modal Functions
    function showActivitiesModal(userId, userName) {
        const modal = document.getElementById('activitiesModal');
        const userNameSpan = document.getElementById('activitiesUserName');
        const contentDiv = document.getElementById('activitiesContent');
        
        // Set user name
        userNameSpan.textContent = userName;
        
        // Show modal
        modal.style.display = 'flex';
        
        // Load activities via AJAX
        fetch('/backoffice/user-activity/user/' + userId + '/json')
            .then(response => response.json())
            .then(data => {
                if (data.activities && data.activities.length > 0) {
                    let html = '<div style="margin-bottom: 20px; display: grid; grid-template-columns: repeat(4, 1fr); gap: 15px;">';
                    
                    // Statistics
                    const totalActivities = data.activities.length;
                    const successfulLogins = data.activities.filter(a => a.action === 'user.login' && a.success).length;
                    const failedActions = data.activities.filter(a => !a.success).length;
                    const suspensions = data.activities.filter(a => a.action === 'user.suspended').length;
                    
                    html += '<div style="background: linear-gradient(135deg, #10b981, #059669); padding: 15px; border-radius: 10px; text-align: center;">';
                    html += '<div style="font-size: 28px; font-weight: bold; color: white;">' + totalActivities + '</div>';
                    html += '<div style="font-size: 12px; color: rgba(255,255,255,0.9);">Total Activities</div>';
                    html += '</div>';
                    
                    html += '<div style="background: linear-gradient(135deg, #3b82f6, #2563eb); padding: 15px; border-radius: 10px; text-align: center;">';
                    html += '<div style="font-size: 28px; font-weight: bold; color: white;">' + successfulLogins + '</div>';
                    html += '<div style="font-size: 12px; color: rgba(255,255,255,0.9);">Successful Logins</div>';
                    html += '</div>';
                    
                    html += '<div style="background: linear-gradient(135deg, #f59e0b, #d97706); padding: 15px; border-radius: 10px; text-align: center;">';
                    html += '<div style="font-size: 28px; font-weight: bold; color: white;">' + suspensions + '</div>';
                    html += '<div style="font-size: 12px; color: rgba(255,255,255,0.9);">Suspensions</div>';
                    html += '</div>';
                    
                    html += '<div style="background: linear-gradient(135deg, #ef4444, #dc2626); padding: 15px; border-radius: 10px; text-align: center;">';
                    html += '<div style="font-size: 28px; font-weight: bold; color: white;">' + failedActions + '</div>';
                    html += '<div style="font-size: 12px; color: rgba(255,255,255,0.9);">Failed Actions</div>';
                    html += '</div>';
                    
                    html += '</div>';
                    
                    html += '<div style="overflow-x: auto;"><table style="width: 100%; border-collapse: collapse;">';
                    html += '<thead><tr style="background: linear-gradient(135deg, #667eea, #764ba2); color: white;">';
                    html += '<th style="padding: 12px; text-align: left; border-bottom: 2px solid #e2e8f0;">Date/Time</th>';
                    html += '<th style="padding: 12px; text-align: left; border-bottom: 2px solid #e2e8f0;">Action</th>';
                    html += '<th style="padding: 12px; text-align: left; border-bottom: 2px solid #e2e8f0;">Details</th>';
                    html += '<th style="padding: 12px; text-align: left; border-bottom: 2px solid #e2e8f0;">Device</th>';
                    html += '<th style="padding: 12px; text-align: left; border-bottom: 2px solid #e2e8f0;">Status</th>';
                    html += '</tr></thead><tbody>';
                    
                    data.activities.forEach((activity, index) => {
                        const bgColor = index % 2 === 0 ? '#f8f9fa' : 'white';
                        html += '<tr style="background: ' + bgColor + ';">';
                        html += '<td style="padding: 12px; border-bottom: 1px solid #e2e8f0; font-size: 13px; color: #1f2937; font-weight: 500;">' + activity.createdAt + '</td>';
                        
                        // Action with icon
                        let actionIcon = '';
                        let actionColor = '#6366f1';
                        let actionLabel = activity.action;
                        
                        if (activity.action.includes('login')) {
                            actionIcon = '🔐';
                            actionColor = '#10b981';
                            actionLabel = 'Login';
                        } else if (activity.action.includes('suspend')) {
                            actionIcon = '⛔';
                            actionColor = '#f59e0b';
                            actionLabel = 'Suspended';
                        } else if (activity.action.includes('reactivat')) {
                            actionIcon = '✅';
                            actionColor = '#22c55e';
                            actionLabel = 'Reactivated';
                        } else if (activity.action.includes('created')) {
                            actionIcon = '➕';
                            actionColor = '#3b82f6';
                            actionLabel = 'Created';
                        } else if (activity.action.includes('updated')) {
                            actionIcon = '✏️';
                            actionColor = '#8b5cf6';
                            actionLabel = 'Updated';
                        } else if (activity.action.includes('deleted')) {
                            actionIcon = '🗑️';
                            actionColor = '#ef4444';
                            actionLabel = 'Deleted';
                        } else if (activity.action.includes('viewed')) {
                            actionIcon = '👁️';
                            actionColor = '#6366f1';
                            actionLabel = 'Viewed';
                        }
                        
                        html += '<td style="padding: 12px; border-bottom: 1px solid #e2e8f0;"><span style="background: ' + actionColor + '; color: white; padding: 4px 12px; border-radius: 12px; font-size: 12px; font-weight: bold; display: inline-block;">' + actionIcon + ' ' + actionLabel + '</span></td>';
                        
                        // Details column
                        html += '<td style="padding: 12px; border-bottom: 1px solid #e2e8f0; font-size: 13px; color: #1f2937;">';
                        if (activity.metadata) {
                            if (activity.metadata.suspended_by_name) {
                                html += '<div><strong style="color: #374151;">By:</strong> ' + activity.metadata.suspended_by_name + '</div>';
                            }
                            if (activity.metadata.reactivated_by_name) {
                                html += '<div><strong style="color: #374151;">By:</strong> ' + activity.metadata.reactivated_by_name + '</div>';
                            }
                            if (activity.metadata.created_by_name) {
                                html += '<div><strong style="color: #374151;">By:</strong> ' + activity.metadata.created_by_name + '</div>';
                            }
                            if (activity.metadata.updated_by_name) {
                                html += '<div><strong style="color: #374151;">By:</strong> ' + activity.metadata.updated_by_name + '</div>';
                            }
                            if (activity.metadata.viewed_by_name) {
                                html += '<div><strong style="color: #374151;">By:</strong> ' + activity.metadata.viewed_by_name + '</div>';
                            }
                            if (activity.metadata.suspension_reason) {
                                html += '<div style="color: #f59e0b;"><strong style="color: #374151;">Reason:</strong> ' + activity.metadata.suspension_reason.substring(0, 40) + '...</div>';
                            }
                            if (activity.metadata.changes_count) {
                                html += '<div style="color: #8b5cf6;"><strong style="color: #374151;">Fields changed:</strong> ' + activity.metadata.changes_count + '</div>';
                            }
                            if (activity.metadata.suspension_duration_days) {
                                html += '<div style="color: #22c55e;"><strong style="color: #374151;">Duration:</strong> ' + activity.metadata.suspension_duration_days + ' days</div>';
                            }
                        }
                        if (!activity.metadata || Object.keys(activity.metadata).length === 0) {
                            html += '<span style="color: #999;">—</span>';
                        }
                        html += '</td>';
                        
                        // Device column
                        html += '<td style="padding: 12px; border-bottom: 1px solid #e2e8f0; font-size: 12px; color: #1f2937;">';
                        if (activity.metadata && activity.metadata.browser) {
                            html += '<div><strong style="color: #374151;">Browser:</strong> ' + activity.metadata.browser + '</div>';
                        }
                        if (activity.metadata && activity.metadata.platform) {
                            html += '<div><strong style="color: #374151;">OS:</strong> ' + activity.metadata.platform + '</div>';
                        }
                        if (activity.ipAddress) {
                            html += '<div style="font-family: monospace; color: #6366f1;"><strong style="color: #374151;">IP:</strong> ' + activity.ipAddress + '</div>';
                        }
                        if (!activity.metadata || (!activity.metadata.browser && !activity.metadata.platform && !activity.ipAddress)) {
                            html += '<span style="color: #999;">—</span>';
                        }
                        html += '</td>';
                        
                        // Status
                        if (activity.success) {
                            html += '<td style="padding: 12px; border-bottom: 1px solid #e2e8f0;"><span style="background: #10b981; color: white; padding: 4px 12px; border-radius: 12px; font-size: 12px; font-weight: bold;">✓ Success</span></td>';
                        } else {
                            html += '<td style="padding: 12px; border-bottom: 1px solid #e2e8f0;"><span style="background: #ef4444; color: white; padding: 4px 12px; border-radius: 12px; font-size: 12px; font-weight: bold;">✗ Failed</span>';
                            if (activity.errorMessage) {
                                html += '<br><small style="color: #ef4444;">' + activity.errorMessage + '</small>';
                            }
                            html += '</td>';
                        }
                        html += '</tr>';
                    });
                    
                    html += '</tbody></table></div>';
                    
                    // Add link to full view
                    html += '<div style="text-align: center; margin-top: 20px; padding-top: 20px; border-top: 2px solid #e2e8f0;">';
                    html += '<a href="/backoffice/user-activity/user/' + userId + '" style="display: inline-flex; align-items: center; gap: 8px; padding: 12px 24px; background: linear-gradient(135deg, #6366f1, #8b5cf6); color: white; text-decoration: none; border-radius: 10px; font-weight: bold;">';
                    html += '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>';
                    html += 'View Full Activity Timeline';
                    html += '</a>';
                    html += '</div>';
                    
                    contentDiv.innerHTML = html;
                } else {
                    contentDiv.innerHTML = '<div style="text-align: center; padding: 40px; color: #999;"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-bottom: 10px;"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg><p>No activities recorded for this user</p></div>';
                }
            })
            .catch(error => {
                console.error('Error loading activities:', error);
                contentDiv.innerHTML = '<div style="text-align: center; padding: 40px; color: #ef4444;"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-bottom: 10px;"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg><p>Error loading activities</p></div>';
            });
    }
    
    function closeActivitiesModal() {
        const modal = document.getElementById('activitiesModal');
        modal.style.display = 'none';
    }
    
    function showMetadata(index) {
        if (window.activitiesMetadata && window.activitiesMetadata[index]) {
            alert(JSON.stringify(window.activitiesMetadata[index], null, 2));
        }
    }
    
    // Close activities modal on outside click
    document.getElementById('activitiesModal').addEventListener('click', function(e) {
        if (e.target === this) {
            closeActivitiesModal();
        }
    });
    
    document.addEventListener('DOMContentLoaded', function() {
        // Auto-hide flash messages
        setTimeout(function() {
            const flashMessages = document.querySelectorAll('.flash-message');
            flashMessages.forEach(function(message) {
                message.style.animation = 'slideIn 0.3s ease reverse';
                setTimeout(function() {
                    message.remove();
                }, 300);
            });
        }, 5000);
        
        // Search form submission
        const searchInput = document.querySelector('.search-input');
        const searchForm = document.querySelector('.search-form');
        
        searchInput.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                searchForm.submit();
            }
        });
        
        // Update stats with real data
        const statValues = document.querySelectorAll('.stat-value');
        statValues.forEach(function(stat) {
            const value = parseInt(stat.textContent);
            if (!isNaN(value)) {
                // Animate counting up
                let start = 0;
                const end = value;
                const duration = 1500;
                const increment = end / (duration / 16);
                
                const timer = setInterval(function() {
                    start += increment;
                    if (start >= end) {
                        stat.textContent = end.toLocaleString();
                        clearInterval(timer);
                    } else {
                        stat.textContent = Math.floor(start).toLocaleString();
                    }
                }, 16);
            }
        });
    });
    </script>
    <!-- TemplateMo 607 Glass Admin -->
</body>
</html>