<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register - 3D Glassmorphism Dashboard</title>
    <meta name="description" content="3D Glassmorphism Dashboard Template by TemplateMo">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('backoffice/css/templatemo-glass-admin-style.css') }}">
</head>
<body>
    <div class="background"></div>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>

    <div class="login-page">
        <div class="login-container">
            <div class="login-card">
                <div class="login-header">
                    <div class="login-logo">G</div>
                    <h1 class="login-title">Create Account</h1>
                    <p class="login-subtitle">Start your journey with GlassDash</p>
                </div>

                {# Affichage des erreurs #}
                {% if errors is defined and errors|length > 0 %}
                    <div class="alert alert-danger" style="color: red; background: rgba(255,0,0,0.1); padding: 10px; border-radius: 5px; margin-bottom: 15px;">
                        <ul style="margin: 0; padding-left: 20px;">
                            {% for error in errors %}
                                <li>{{ error }}</li>
                            {% endfor %}
                        </ul>
                    </div>
                {% endif %}

                <form method="post" action="{{ path('backoffice_register') }}">
                    {# NOM et PRÉNOM séparés #}
                    <div class="form-group">
                        <label class="form-label" for="nom">Nom</label>
                        <input 
                            type="text" 
                            id="nom" 
                            name="nom" 
                            class="form-input" 
                            placeholder="Votre nom" 
                            value="{{ old_values.nom }}" 
                            required
                        >
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="prenom">Prénom</label>
                        <input 
                            type="text" 
                            id="prenom" 
                            name="prenom" 
                            class="form-input" 
                            placeholder="Votre prénom" 
                            value="{{ old_values.prenom }}" 
                            required
                        >
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="email">Email Address</label>
                        <input 
                            type="email" 
                            id="email" 
                            name="email" 
                            class="form-input" 
                            placeholder="Enter your email" 
                            value="{{ old_values.email }}" 
                            required
                        >
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="password">Password</label>
                        <input 
                            type="password" 
                            id="password" 
                            name="password" 
                            class="form-input" 
                            placeholder="Create a password (min. 6 caractères)" 
                            required
                        >
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="confirm-password">Confirm Password</label>
                        <input 
                            type="password" 
                            id="confirm-password" 
                            name="confirm_password" 
                            class="form-input" 
                            placeholder="Confirm your password" 
                            required
                        >
                    </div>

                    {# ROLE (Admin/Etudiant) #}
                    <div class="form-group">
                        <label class="form-label" for="role">Type de compte</label>
                        <select id="role" name="role" class="form-input" required>
                            <option value="">-- Sélectionnez un rôle --</option>
                            <option value="ADMIN" {{ old_values.role == 'ADMIN' ? 'selected' : '' }}>Administrateur</option>
                            <option value="ETUDIANT" {{ old_values.role == 'ETUDIANT' ? 'selected' : '' }}>Étudiant</option>
                        </select>
                    </div>

                    {# NIVEAU (seulement pour étudiant) #}
                    <div class="form-group" id="niveau-group" style="display: {% if old_values.role == 'ETUDIANT' %}block{% else %}none{% endif %};">
                        <label class="form-label" for="niveau">Niveau</label>
                        <select id="niveau" name="niveau" class="form-input">
                            <option value="">-- Sélectionnez un niveau --</option>
                            <option value="DEBUTANT" {{ old_values.niveau == 'DEBUTANT' ? 'selected' : '' }}>Débutant</option>
                            <option value="INTERMEDIAIRE" {{ old_values.niveau == 'INTERMEDIAIRE' ? 'selected' : '' }}>Intermédiaire</option>
                            <option value="AVANCE" {{ old_values.niveau == 'AVANCE' ? 'selected' : '' }}>Avancé</option>
                        </select>
                    </div>

                    <div class="form-row" style="margin-bottom: 24px;">
                        <label class="checkbox-label">
                            <input type="checkbox" name="terms" required>
                            I agree to the <a href="#" style="color: var(--emerald-light);">Terms & Conditions</a>
                        </label>
                    </div>

                    {# CSRF Token #}
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('register') }}">

                    <button type="submit" class="btn btn-primary">
                        Create Account
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="5" y1="12" x2="19" y2="12"/>
                            <polyline points="12 5 19 12 12 19"/>
                        </svg>
                    </button>
                </form>

                <p class="login-footer">
                    Already have an account? <a href="{{ path('backoffice_login') }}">Sign In</a>
                </p>
            </div>
        </div>
    </div>

    <script>
    document.addEventListener('DOMContentLoaded', function() {
        const roleSelect = document.getElementById('role');
        const niveauGroup = document.getElementById('niveau-group');
        const niveauSelect = document.getElementById('niveau');

        function toggleNiveau() {
            if (roleSelect.value === 'ETUDIANT') {
                niveauGroup.style.display = 'block';
                niveauSelect.required = true;
            } else {
                niveauGroup.style.display = 'none';
                niveauSelect.required = false;
                niveauSelect.value = '';
            }
        }

        // Initial state
        toggleNiveau();
        
        // On change
        roleSelect.addEventListener('change', toggleNiveau);
    });
    </script>

    <script src="{{ asset('backoffice/js/templatemo-glass-admin-script.js') }}"></script>
</body>
</html>