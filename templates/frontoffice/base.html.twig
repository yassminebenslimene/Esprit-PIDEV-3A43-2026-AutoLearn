<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@100;200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">

    <title>{% block title %}Scholar - AutoLearn{% endblock %}</title>

    {% block stylesheets %}
        <!-- Bootstrap -->
        <link rel="stylesheet" href="{{ asset('frontoffice/vendor/bootstrap/css/bootstrap.min.css') }}">

        <!-- FrontOffice CSS -->
        <link rel="stylesheet" href="{{ asset('frontoffice/css/animate.css') }}">
        <link rel="stylesheet" href="{{ asset('frontoffice/css/flex-slider.css') }}">
        <link rel="stylesheet" href="{{ asset('frontoffice/css/fontawesome.css') }}">
        <link rel="stylesheet" href="{{ asset('frontoffice/css/owl.css') }}">
        <link rel="stylesheet" href="{{ asset('frontoffice/css/templatemo-scholar.css') }}">

        <!-- Swiper -->
        <link rel="stylesheet" href="https://unpkg.com/swiper@7/swiper-bundle.min.css"/>
    {% endblock %}
    
    <style>
        /* Fix navbar position */
        .header-area {
            position: fixed !important;
            top: 0 !important;
            left: 0 !important;
            right: 0 !important;
            z-index: 9999 !important;
            background-color: rgba(122, 106, 216, 0.95) !important;
            backdrop-filter: blur(10px) !important;
            margin-bottom: 0 !important;
        }
        
        /* Add padding to body to compensate for fixed header */
        body {
            padding-top: 80px !important;
        }
        
        /* Remove any white space after header */
        .header-area + * {
            margin-top: 0 !important;
        }
        
        /* Profile Dropdown Styles */
        .main-nav {
            display: flex !important;
            align-items: center !important;
            height: 80px !important;
        }
        
        /* FORCE NAVBAR ON SINGLE LINE */
        .main-nav .nav {
            flex-wrap: nowrap !important;
            white-space: nowrap !important;
        }
        
        .main-nav .nav li a {
            padding: 0 10px !important;
            font-size: 14px !important;
        }
        
        .main-nav .nav .profile-dropdown-btn {
            padding: 0 10px !important;
        }
        
        /* Notification Badge Styles */
        .notification-badge {
            position: absolute;
            top: 5px;
            right: 5px;
            background: #ff4444;
            color: white;
            border-radius: 50%;
            width: 10px;
            height: 10px;
            display: flex !important;
            align-items: center;
            justify-content: center;
            font-size: 8px;
            font-weight: 700;
            box-shadow: 0 2px 6px rgba(255, 68, 68, 0.6);
            animation: pulse 2s infinite;
            z-index: 10;
        }
        
        .badge-count {
            color: white;
            font-size: 10px;
        }
        
        @keyframes pulse {
            0%, 100% {
                transform: scale(1);
                box-shadow: 0 2px 6px rgba(255, 68, 68, 0.6);
            }
            50% {
                transform: scale(1.2);
                box-shadow: 0 4px 12px rgba(255, 68, 68, 0.8);
            }
        }
        
        .main-nav .nav {
            display: flex !important;
            align-items: center !important;
            height: 100% !important;
            margin-bottom: 0 !important;
        }
        
        .main-nav .nav li {
            display: flex !important;
            align-items: center !important;
            height: 100% !important;
            margin: 0 !important;
        }
        
        .main-nav .nav li a {
            display: flex !important;
            align-items: center !important;
            height: 100% !important;
            line-height: 1 !important;
            padding-top: 0 !important;
            padding-bottom: 0 !important;
        }
        
        .main-nav .nav li.profile-dropdown-container {
            position: relative !important;
            display: flex !important;
            align-items: center !important;
            height: 100% !important;
        }
        
        .main-nav .nav .profile-dropdown-btn {
            background: none !important;
            border: none !important;
            padding: 0 15px !important;
            color: #1e1e1e !important;
            font-weight: 500 !important;
            text-decoration: none !important;
            cursor: pointer !important;
            display: flex !important;
            align-items: center !important;
            height: 100% !important;
            line-height: 1 !important;
            gap: 5px !important;
        }
        
        .main-nav .nav .profile-dropdown-btn i {
            display: flex !important;
            align-items: center !important;
        }
        
        .main-nav .nav .profile-dropdown-menu {
            display: none;
            position: absolute !important;
            top: 100% !important;
            right: 0 !important;
            z-index: 999999 !important;
            min-width: 220px !important;
            background: white !important;
            border-radius: 8px !important;
            box-shadow: 0 5px 25px rgba(0,0,0,0.15) !important;
            padding: 10px 0 !important;
            margin-top: 0 !important;
            list-style: none !important;
        }
        
        .main-nav .nav .profile-dropdown-menu.show {
            display: block !important;
        }
        
        .main-nav .nav .profile-dropdown-menu li {
            width: 100% !important;
            margin: 0 !important;
            padding: 0 !important;
            display: block !important;
            height: auto !important;
        }
        
        .main-nav .nav .profile-dropdown-menu a {
            display: block !important;
            padding: 12px 20px !important;
            color: #333 !important;
            text-decoration: none !important;
            font-size: 15px !important;
            transition: all 0.2s !important;
            line-height: normal !important;
            height: auto !important;
        }
        
        .main-nav .nav .profile-dropdown-menu a:hover {
            background: linear-gradient(105deg, #7a6ad8 0%, #4e3b9c 100%) !important;
            color: white !important;
        }
        
        .main-nav .nav .profile-dropdown-menu i {
            margin-right: 10px !important;
            width: 18px !important;
            text-align: center !important;
        }
        
        .main-nav .nav .profile-dropdown-divider {
            height: 1px !important;
            background: #eeeeee !important;
            margin: 8px 0 !important;
        }
        
        @media (max-width: 992px) {
            .main-nav,
            .main-nav .nav,
            .main-nav .nav li,
            .main-nav .nav li a,
            .main-nav .nav li.profile-dropdown-container,
            .main-nav .nav .profile-dropdown-btn {
                height: auto !important;
                min-height: 50px !important;
            }
            
            .main-nav .nav .profile-dropdown-menu {
                position: static !important;
                width: 100% !important;
                box-shadow: none !important;
                background: transparent !important;
            }
            
            .main-nav .nav .profile-dropdown-menu a {
                color: white !important;
                padding-left: 30px !important;
            }
            
            .main-nav .nav .profile-dropdown-divider {
                background: rgba(255,255,255,0.2) !important;
            }
        }
    </style>
</head>
<body>

<!-- ***** Preloader Start ***** -->
<div id="js-preloader" class="js-preloader">
