                            <li style="position: relative;">
                                <a href="{{ path('app_notifications_index') }}" style="position: relative; display: inline-flex; align-items: center; gap: 5px;">
                                    <i class="fa fa-bell"></i>
                                    <span id="notification-badge" class="notification-badge" style="display: none;"></span>
                                </a>
                            </li>
                            
                            {# Dropdown Profil #}
                            <li class="profile-dropdown-container">
                                <a href="javascript:void(0);" onclick="toggleProfileDropdown(event)" class="profile-dropdown-btn">
                                    <i class="fa fa-user-circle"></i>
                                    <i class="fa fa-chevron-down" style="font-size: 10px; margin-left: 3px;"></i>
                                </a>
                                <ul class="profile-dropdown-menu" id="profileDropdown">
                                    <li>
                                        <a href="{{ path('app_profile') }}">
                                            <i class="fa fa-id-card"></i> {{ 'nav.profile'|trans }}
                                        </a>
                                    </li>
                                    <li>
                                        <a href="{{ path('app_mes_participations') }}">
                                            <i class="fa fa-trophy"></i> {{ 'nav.my_participations'|trans }}
                                        </a>
                                    </li>
                                    <li class="profile-dropdown-divider"></li>
                                    <li>
                                        <a href="{{ path('backoffice_logout') }}">
                                            <i class="fa fa-sign-out"></i> {{ 'nav.logout'|trans }}
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        {% else %}
                            <li><a href="{{ path('backoffice_login') }}">{{ 'nav.login'|trans }}</a></li>
                        {% endif %}
                        
                        {# Sélecteur de langue compact #}
                        <li class="profile-dropdown-container">
                            <a href="javascript:void(0);" onclick="toggleLanguageDropdown(event)" class="profile-dropdown-btn">
                                <i class="fa fa-globe"></i>
                                <i class="fa fa-chevron-down" style="font-size: 10px; margin-left: 3px;"></i>
                            </a>
                            <ul class="profile-dropdown-menu" id="languageDropdown">
                                <li>
                                    <a href="{{ path('app_change_language', {'locale': 'fr'}) }}">
                                        <i class="fa fa-flag"></i> Français
                                    </a>
                                </li>
                                <li>
                                    <a href="{{ path('app_change_language', {'locale': 'en'}) }}">
                                        <i class="fa fa-flag"></i> English
                                    </a>
                                </li>
                                <li>
                                    <a href="{{ path('app_change_language', {'locale': 'es'}) }}">
                                        <i class="fa fa-flag"></i> Español
                                    </a>
                                </li>
                                <li>
                                    <a href="{{ path('app_change_language', {'locale': 'ar'}) }}">
                                        <i class="fa fa-flag"></i> العربية
                                    </a>
                                </li>
                            </ul>
                        </li>
                    </ul>
                    <form id="logout-form-nav" action="{{ path('backoffice_logout') }}" method="POST" style="display: none;">
                        <input type="hidden" name="_token" value="{{ csrf_token('logout') }}">
                    </form>
                    <a class='menu-trigger'>
                        <span>Menu</span>
                    </a>
                    <!-- ***** Menu End ***** -->
                </nav>
            </div>
        </div>
    </div>
</header>
<!-- ***** Header Area End ***** -->

