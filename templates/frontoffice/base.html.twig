                        <li><a href="{{ path('app_frontoffice') }}#cours">{{ 'nav.courses'|trans }}</a></li>
                        <li><a href="{{ path('app_events') }}">{{ 'nav.events'|trans }}</a></li>
                        <li><a href="{{ path('app_frontoffice') }}#challenge">{{ 'nav.challenges'|trans }}</a></li>
                        <li><a href="{{ path('front_communaute') }}">{{ 'nav.community'|trans }}</a></li>
                        <li><a href="{{ path('app_about') }}">{{ 'nav.about'|trans }}</a></li>
                        
                        {% if app.user %}
