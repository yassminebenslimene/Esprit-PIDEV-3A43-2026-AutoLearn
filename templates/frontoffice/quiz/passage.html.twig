{# Template de passage de quiz avec design style Kahoot - Interface interactive pour les étudiants #}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ quiz.titre }} - Passage du Quiz</title>

    {# Chargement des styles Bootstrap et FontAwesome pour l'interface #}
    <link rel="stylesheet" href="{{ asset('frontoffice/vendor/bootstrap/css/bootstrap.min.css') }}">
    <link rel="stylesheet" href="{{ asset('frontoffice/css/fontawesome.css') }}">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        /* Styles de base - Reset et configuration globale */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        /* Fond dégradé violet avec motif diagonal pour l'ambiance Kahoot */
        body {
            font-family: 'Inter', sans-serif;
            background: #46178f;
            background-image: 
                repeating-linear-gradient(45deg, transparent, transparent 35px, rgba(255,255,255,.05) 35px, rgba(255,255,255,.05) 70px);
            min-height: 100vh;
            overflow-x: hidden;
        }
        
        /* Écran de chargement animé style Kahoot avec logo en rotation */
        .loading-screen {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            animation: fadeOut 0.5s ease-out 2s forwards;
        }
        
        .loading-logo {
            width: 120px;
            height: 120px;
            position: relative;
            animation: rotozoom 1.5s ease-in-out infinite;
        }
        
        .logo-shape {
            position: absolute;
            width: 60px;
            height: 60px;
            border-radius: 10px;
        }
        
        .logo-shape:nth-child(1) {
            top: 0;
            left: 0;
            background: #e74c3c;
            animation: pulse1 1.5s ease-in-out infinite;
        }
        
        .logo-shape:nth-child(2) {
            top: 0;
            right: 0;
            background: #3498db;
            animation: pulse2 1.5s ease-in-out infinite;
        }
        
        .logo-shape:nth-child(3) {
            bottom: 0;
            left: 0;
            background: #f39c12;
            animation: pulse3 1.5s ease-in-out infinite;
        }
        
        .logo-shape:nth-child(4) {
            bottom: 0;
            right: 0;
            background: #2ecc71;
            animation: pulse4 1.5s ease-in-out infinite;
        }
        
        .loading-text {
            margin-top: 40px;
            color: white;
            font-size: 28px;
            font-weight: 800;
            text-align: center;
            animation: fadeInOut 1.5s ease-in-out infinite;
        }
        
        .loading-subtitle {
            margin-top: 10px;
            color: rgba(255, 255, 255, 0.8);
            font-size: 16px;
            font-weight: 500;
        }
        
        @keyframes rotozoom {
            0%, 100% { transform: scale(1) rotate(0deg); }
            25% { transform: scale(1.2) rotate(90deg); }
            50% { transform: scale(1) rotate(180deg); }
            75% { transform: scale(1.2) rotate(270deg); }
        }
        
        @keyframes pulse1 {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.1); }
        }
        
        @keyframes pulse2 {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.1); }
            25% { transform: scale(1.05); }
        }
        
        @keyframes pulse3 {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.1); }
            75% { transform: scale(1.05); }
        }
        
        @keyframes pulse4 {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.1); }
            12.5% { transform: scale(1.05); }
        }
        
        @keyframes fadeInOut {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }
        
        @keyframes fadeOut {
            to {
                opacity: 0;
                visibility: hidden;
            }
        }
        
        /* Container principal */
        .quiz-container {
            max-width: 100%;
            padding: 0;
        }
        
        /* En-tête du quiz avec titre et chronomètre - Affichage fixe en haut */
        .quiz-header {
            background: rgba(0, 0, 0, 0.3);
            padding: 20px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            backdrop-filter: blur(10px);
        }
        
        /* Conteneur de l'image du quiz dans le header */
        .quiz-image-container {
            width: 60px;
            height: 60px;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
            flex-shrink: 0;
        }
        
        /* Image du quiz dans le header */
        .quiz-header-image {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }
        
        /* Conteneur de l'image principale du quiz au centre de la page */
        .quiz-image-display {
            width: 100%;
            max-width: 600px;
            margin: 30px auto;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 10px 40px rgba(0,0,0,0.3);
            animation: fadeInUp 0.6s ease-out;
        }
        
        /* Image principale du quiz - Grande et centrée */
        .quiz-main-image {
            width: 100%;
            height: auto;
            max-height: 400px;
            object-fit: contain;
            display: block;
            background: white;
        }
        
        .quiz-title {
            color: white;
            font-size: 24px;
            font-weight: 700;
        }
        
        .nav-quiz-btn {
            width: 50px;
            height: 50px;
            background: rgba(255, 255, 255, 0.2);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 20px;
            text-decoration: none;
            transition: all 0.3s ease;
            backdrop-filter: blur(10px);
            border: 2px solid rgba(255, 255, 255, 0.3);
        }
        
        .nav-quiz-btn:hover {
            background: rgba(255, 255, 255, 0.3);
            transform: scale(1.1);
            box-shadow: 0 5px 15px rgba(255, 255, 255, 0.3);
            color: white;
        }
        
        .quiz-info {
            display: flex;
            align-items: center;
            gap: 20px;
        }
        
        /* Bouton pour activer/désactiver le son */
        .sound-toggle {
            width: 50px;
            height: 50px;
            background: rgba(255, 255, 255, 0.9);
            border: none;
            border-radius: 50%;
            color: #46178f;
            font-size: 20px;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 5px 20px rgba(0,0,0,0.3);
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .sound-toggle:hover {
            background: white;
            transform: scale(1.1);
        }
        
        .sound-toggle.muted {
            background: rgba(231, 76, 60, 0.9);
            color: white;
        }
        
        .timer-container {
            display: flex;
            align-items: center;
            gap: 15px;
            padding: 15px 30px;
            background: white;
            border-radius: 50px;
            font-weight: 800;
            font-size: 24px;
            color: #46178f;
            box-shadow: 0 5px 20px rgba(0,0,0,0.3);
        }
        
        .timer-container.warning {
            background: #f39c12;
            color: white;
            animation: pulse 1s infinite;
        }
        
        .timer-container.danger {
            background: #e74c3c;
            color: white;
            animation: pulse 0.5s infinite;
        }
        
        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }
        
        /* Carte de question - Affichage centré avec animation d'entrée */
        .question-card {
            min-height: calc(100vh - 200px);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
            animation: slideIn 0.5s ease-out;
        }
        
        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        .question-number {
            background: white;
            color: #46178f;
            padding: 10px 30px;
            border-radius: 50px;
            font-weight: 800;
            font-size: 18px;
            margin-bottom: 30px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.2);
        }
        
        .question-text {
            background: white;
            color: #333;
            font-size: 32px;
            font-weight: 700;
            padding: 40px 60px;
            border-radius: 20px;
            text-align: center;
            max-width: 900px;
            margin-bottom: 50px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.3);
            line-height: 1.4;
        }
        
        .question-points {
            color: white;
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 40px;
        }
        
        /* Grille des options de réponse - 4 couleurs distinctes style Kahoot */
        .options-list {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
            max-width: 1000px;
            width: 100%;
            padding: 0 20px;
        }
        
        .option-item {
            position: relative;
            min-height: 180px;
            border-radius: 15px;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 30px;
            font-size: 20px;
            font-weight: 700;
            color: white;
            text-align: center;
            border: 5px solid transparent;
            box-shadow: 0 8px 20px rgba(0,0,0,0.3);
        }
        
        /* Couleurs Kahoot pour les 4 options */
        .option-item:nth-child(1) {
            background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
        }
        
        .option-item:nth-child(2) {
            background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
        }
        
        .option-item:nth-child(3) {
            background: linear-gradient(135deg, #f39c12 0%, #e67e22 100%);
        }
        
        .option-item:nth-child(4) {
            background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
        }
        
        .option-item:hover {
            transform: scale(1.05);
            box-shadow: 0 12px 30px rgba(0,0,0,0.4);
        }
        
        .option-item.selected {
            border-color: white;
            transform: scale(1.08);
            box-shadow: 0 15px 40px rgba(255,255,255,0.3);
        }
        
        .option-item input[type="radio"] {
            display: none;
        }
        
        .option-icon {
            position: absolute;
            top: 15px;
            left: 15px;
            width: 40px;
            height: 40px;
            background: rgba(255,255,255,0.3);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
        }
        
        /* Icônes géométriques Kahoot */
        .option-item:nth-child(1) .option-icon::before {
            content: '▲';
        }
        
        .option-item:nth-child(2) .option-icon::before {
            content: '◆';
        }
        
        .option-item:nth-child(3) .option-icon::before {
            content: '●';
        }
        
        .option-item:nth-child(4) .option-icon::before {
            content: '■';
        }
        
        .option-text {
            position: relative;
            z-index: 1;
        }
        
        /* Barre de progression fixe en bas - Affiche le nombre de questions répondues */
        .progress-bar-container {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: rgba(0,0,0,0.3);
            padding: 15px 40px;
            backdrop-filter: blur(10px);
            z-index: 99;
        }
        
        /* Boutons de navigation précédent/suivant - Positionnés en bas au centre */
        .question-navigation {
            position: fixed;
            bottom: 90px;
            left: 0;
            right: 0;
            display: flex;
            justify-content: center;
            gap: 20px;
            z-index: 100;
        }
        
        .nav-btn {
            width: 60px;
            height: 60px;
            background: rgba(255, 255, 255, 0.9);
            border: none;
            border-radius: 50%;
            color: #46178f;
            font-size: 24px;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 5px 20px rgba(0,0,0,0.3);
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .nav-btn:hover:not(:disabled) {
            transform: scale(1.1);
            box-shadow: 0 8px 30px rgba(0,0,0,0.4);
            background: white;
        }
        
        .nav-btn:disabled {
            opacity: 0.3;
            cursor: not-allowed;
        }
        
        .nav-btn i {
            pointer-events: none;
        }
        
        /* Masquer toutes les questions sauf celle active - Navigation par index */
        .question-card {
            display: none;
        }
        
        .question-card.active {
            display: flex;
        }
        
        .progress-text {
            color: white;
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 10px;
            text-align: center;
        }
        
        .progress-bar-custom {
            height: 12px;
            background: rgba(255,255,255,0.2);
            border-radius: 10px;
            overflow: hidden;
        }
        
        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, #2ecc71 0%, #27ae60 100%);
            transition: width 0.3s ease;
            border-radius: 10px;
        }
        
        /* Bouton de soumission du quiz - Positionné en bas à droite */
        .submit-container {
            position: fixed;
            bottom: 80px;
            right: 40px;
            z-index: 100;
        }
        
        .btn-submit {
            padding: 20px 40px;
            background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
            color: white;
            border: none;
            border-radius: 50px;
            font-size: 20px;
            font-weight: 800;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 8px 25px rgba(46, 204, 113, 0.4);
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .btn-submit:hover:not(:disabled) {
            transform: translateY(-3px);
            box-shadow: 0 12px 35px rgba(46, 204, 113, 0.6);
        }
        
        .btn-submit:disabled {
            background: #95a5a6;
            cursor: not-allowed;
            box-shadow: none;
        }
        
        /* Adaptation responsive pour mobile et tablette */
        @media (max-width: 768px) {
            .quiz-header {
                flex-direction: column;
                gap: 15px;
            }
            
            .question-text {
                font-size: 24px;
                padding: 30px 40px;
            }
            
            .options-list {
                grid-template-columns: 1fr;
            }
            
            .submit-container {
                bottom: 100px;
                right: 20px;
            }
        }
    </style>
</head>
<body>
    {# Écran de chargement affiché pendant 2 secondes au démarrage #}
    <div class="loading-screen" id="loadingScreen">
        <div class="loading-logo">
            <div class="logo-shape"></div>
            <div class="logo-shape"></div>
            <div class="logo-shape"></div>
            <div class="logo-shape"></div>
        </div>
        <div class="loading-text">Chargement du Quiz...</div>
        <div class="loading-subtitle">{{ quiz.titre }}</div>
    </div>

    {# Conteneur principal du quiz #}
    <div class="quiz-container">
        {# En-tête avec navigation entre quiz et chronomètre #}
        <div class="quiz-header">
            <div style="display: flex; align-items: center; gap: 15px;">
                {% if previousQuiz %}
                <a href="{{ path('app_quiz_start', {'id': previousQuiz.id}) }}" class="nav-quiz-btn" title="Quiz précédent">
                    <i class="fa fa-chevron-left"></i>
                </a>
                {% endif %}
                
                <h1 class="quiz-title">{{ quiz.titre }}</h1>
                {% if nextQuiz %}
                <a href="{{ path('app_quiz_start', {'id': nextQuiz.id}) }}" class="nav-quiz-btn" title="Quiz suivant">
                    <i class="fa fa-chevron-right"></i>
                </a>
                {% endif %}
            </div>
            <div class="quiz-info">
                {# Bouton pour activer/désactiver le son #}
                <button type="button" class="sound-toggle" id="sound-toggle" title="Activer/Désactiver le son">
                    <i class="fa fa-volume-up"></i>
                </button>
                
                {# Affichage du chronomètre si une durée maximale est définie #}
                {% if dureeMaxMinutes %}
                <div class="timer-container" id="timer">
                    <i class="fa fa-clock"></i>
                    <span id="timer-display">{{ dureeMaxMinutes }}:00</span>
                </div>
                {% endif %}
            </div>
        </div>

        {# Formulaire contenant toutes les questions du quiz #}
        <form id="quiz-form" method="POST" action="{{ path('app_quiz_submit', {'id': quiz.id}) }}">
            {# Boucle sur toutes les questions - Seule la première est visible au départ #}
            {% for question in quizData %}
            {# Carte de question avec numéro, texte, points et options #}
            <div class="question-card {% if loop.first %}active{% endif %}" data-question-index="{{ loop.index0 }}" data-question-id="{{ question.id }}">
                <span class="question-number">Question {{ loop.index }} / {{ quizData|length }}</span>
                
                {# Image du quiz si elle existe - Affichée au centre pour que l'étudiant puisse répondre en se basant sur l'image #}
                {% if quiz.imageName %}
                <div class="quiz-image-display">
                    <img src="{{ vich_uploader_asset(quiz, 'imageFile') }}" alt="{{ quiz.titre }}" class="quiz-main-image">
                </div>
                {% endif %}
                
                <div class="question-text">{{ question.texte }}</div>
                <div class="question-points">
                    <i class="fa fa-star"></i> {{ question.points }} point{{ question.points > 1 ? 's' : '' }}
                </div>
                
                {# Grille des options de réponse avec 4 couleurs Kahoot (rouge, bleu, orange, vert) #}
                <div class="options-list">
                    {% for option in question.options %}
                    <label class="option-item" data-option-id="{{ option.id }}">
                        <div class="option-icon"></div>
                        <input type="radio" 
                               name="answers[{{ question.id }}]" 
                               value="{{ option.id }}"
                               onchange="updateProgress()">
                        <span class="option-text">{{ option.texte }}</span>
                    </label>
                    {% endfor %}
                </div>
            </div>
            {% endfor %}
        </form>
        
        {# Boutons de navigation entre les questions (précédent/suivant) #}
        <div class="question-navigation">
            <button type="button" class="nav-btn" id="prev-btn" onclick="previousQuestion()" disabled>
                <i class="fa fa-chevron-left"></i>
            </button>
            <button type="button" class="nav-btn" id="next-btn" onclick="nextQuestion()">
                <i class="fa fa-chevron-right"></i>
            </button>
        </div>
        
        {# Bouton de soumission du quiz - Activé uniquement quand toutes les questions sont répondues #}
        <div class="submit-container">
            <button type="submit" form="quiz-form" class="btn-submit" id="submit-btn">
                <i class="fa fa-check-circle"></i> Soumettre le Quiz
            </button>
        </div>
        
        {# Barre de progression affichant le nombre de questions répondues #}
        <div class="progress-bar-container">
            <div class="progress-text">
                <span id="answered-count">0</span> / {{ quizData|length }} questions répondues
            </div>
            <div class="progress-bar-custom">
                <div class="progress-fill" id="progress-fill" style="width: 0%"></div>
            </div>
        </div>
    </div>

    <script src="{{ asset('frontoffice/vendor/jquery/jquery.min.js') }}"></script>
    <script>
        // ========== SYSTÈME DE SONS - Effets sonores pour l'interactivité ==========
        const AudioContext = window.AudioContext || window.webkitAudioContext;
        const audioCtx = new AudioContext();
        
        // Variable globale pour activer/désactiver le son
        let soundEnabled = true;

        // Son de démarrage (montée joyeuse)
        function playStartSound() {
            if (!soundEnabled) return;
            const oscillator = audioCtx.createOscillator();
            const gainNode = audioCtx.createGain();
            
            oscillator.connect(gainNode);
            gainNode.connect(audioCtx.destination);
            
            oscillator.frequency.setValueAtTime(523.25, audioCtx.currentTime); // C5
            oscillator.frequency.setValueAtTime(659.25, audioCtx.currentTime + 0.1); // E5
            oscillator.frequency.setValueAtTime(783.99, audioCtx.currentTime + 0.2); // G5
            
            oscillator.type = 'sine';
            gainNode.gain.setValueAtTime(0.3, audioCtx.currentTime);
            gainNode.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.4);
            
            oscillator.start(audioCtx.currentTime);
            oscillator.stop(audioCtx.currentTime + 0.4);
        }

        // Son de clic sur une réponse (pop court)
        function playClickSound() {
            if (!soundEnabled) return;
            const oscillator = audioCtx.createOscillator();
            const gainNode = audioCtx.createGain();
            
            oscillator.connect(gainNode);
            gainNode.connect(audioCtx.destination);
            
            oscillator.frequency.setValueAtTime(800, audioCtx.currentTime);
            oscillator.type = 'sine';
            
            gainNode.gain.setValueAtTime(0.2, audioCtx.currentTime);
            gainNode.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.1);
            
            oscillator.start(audioCtx.currentTime);
            oscillator.stop(audioCtx.currentTime + 0.1);
        }

        // Son de sélection (confirmation)
        function playSelectSound() {
            if (!soundEnabled) return;
            const oscillator = audioCtx.createOscillator();
            const gainNode = audioCtx.createGain();
            
            oscillator.connect(gainNode);
            gainNode.connect(audioCtx.destination);
            
            oscillator.frequency.setValueAtTime(1046.50, audioCtx.currentTime); // C6
            oscillator.type = 'triangle';
            
            gainNode.gain.setValueAtTime(0.15, audioCtx.currentTime);
            gainNode.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.15);
            
            oscillator.start(audioCtx.currentTime);
            oscillator.stop(audioCtx.currentTime + 0.15);
        }

        // Son de soumission (fanfare)
        function playSubmitSound() {
            if (!soundEnabled) return;
            const oscillator = audioCtx.createOscillator();
            const gainNode = audioCtx.createGain();
            
            oscillator.connect(gainNode);
            gainNode.connect(audioCtx.destination);
            
            // Fanfare de soumission
            oscillator.frequency.setValueAtTime(659.25, audioCtx.currentTime); // E5
            oscillator.frequency.setValueAtTime(783.99, audioCtx.currentTime + 0.1); // G5
            oscillator.frequency.setValueAtTime(1046.50, audioCtx.currentTime + 0.2); // C6
            oscillator.frequency.setValueAtTime(1318.51, audioCtx.currentTime + 0.3); // E6
            
            oscillator.type = 'triangle';
            gainNode.gain.setValueAtTime(0.25, audioCtx.currentTime);
            gainNode.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.5);
            
            oscillator.start(audioCtx.currentTime);
            oscillator.stop(audioCtx.currentTime + 0.5);
        }

        // Jouer le son de démarrage au chargement
        setTimeout(() => {
            playStartSound();
        }, 100);
        
        // ========== GESTION DU BOUTON SON ==========
        const soundToggle = document.getElementById('sound-toggle');
        
        // Charger la préférence de son depuis localStorage
        const savedSoundPreference = localStorage.getItem('quizSoundEnabled');
        if (savedSoundPreference !== null) {
            soundEnabled = savedSoundPreference === 'true';
            updateSoundButton();
        }
        
        // Fonction pour mettre à jour l'apparence du bouton
        function updateSoundButton() {
            const icon = soundToggle.querySelector('i');
            if (soundEnabled) {
                soundToggle.classList.remove('muted');
                icon.className = 'fa fa-volume-up';
                soundToggle.title = 'Désactiver le son';
            } else {
                soundToggle.classList.add('muted');
                icon.className = 'fa fa-volume-mute';
                soundToggle.title = 'Activer le son';
            }
        }
        
        // Gérer le clic sur le bouton son
        soundToggle.addEventListener('click', function() {
            soundEnabled = !soundEnabled;
            updateSoundButton();
            // Sauvegarder la préférence dans localStorage
            localStorage.setItem('quizSoundEnabled', soundEnabled);
            
            // Jouer un son de confirmation si le son est activé
            if (soundEnabled) {
                playClickSound();
            }
        });

        // ========== FIN SYSTÈME DE SONS ==========

        // Variables globales pour la gestion du quiz
        const totalQuestions = {{ quizData|length }};
        const dureeMaxSecondes = {{ dureeMaxMinutes ? dureeMaxMinutes * 60 : 'null' }};
        const timestampDebut = {{ timestampDebut }};
        const checkTimeUrl = "{{ path('app_quiz_check_time', {'id': quiz.id}) }}";
        
        let timerInterval;
        let tempsEcoule = 0;
        let currentQuestionIndex = 0;

        // Fonction pour afficher une question spécifique par son index
        function showQuestion(index) {
            const questions = document.querySelectorAll('.question-card');
            questions.forEach((q, i) => {
                q.classList.toggle('active', i === index);
            });
            
            // Mettre à jour les boutons de navigation
            document.getElementById('prev-btn').disabled = (index === 0);
            document.getElementById('next-btn').disabled = (index === questions.length - 1);
            
            currentQuestionIndex = index;
        }

        // Fonction pour revenir à la question précédente
        function previousQuestion() {
            if (currentQuestionIndex > 0) {
                playClickSound();
                showQuestion(currentQuestionIndex - 1);
            }
        }

        // Fonction pour passer à la question suivante
        function nextQuestion() {
            if (currentQuestionIndex < totalQuestions - 1) {
                playClickSound();
                showQuestion(currentQuestionIndex + 1);
            }
        }

        // Navigation au clavier avec les flèches gauche/droite
        document.addEventListener('keydown', function(e) {
            if (e.key === 'ArrowLeft') {
                previousQuestion();
            } else if (e.key === 'ArrowRight') {
                nextQuestion();
            }
        });

        // Masquer l'écran de chargement après 2 secondes
        setTimeout(() => {
            document.getElementById('loadingScreen').style.display = 'none';
        }, 2000);

        // Démarrage et gestion du chronomètre avec vérification serveur
        function startTimer() {
            if (!dureeMaxSecondes) return;

            timerInterval = setInterval(() => {
                tempsEcoule = Math.floor(Date.now() / 1000) - timestampDebut;
                const tempsRestant = Math.max(0, dureeMaxSecondes - tempsEcoule);
                
                updateTimerDisplay(tempsRestant);
                
                // Vérifier côté serveur toutes les 30 secondes
                if (tempsEcoule % 30 === 0) {
                    checkServerTime();
                }
                
                // Soumission automatique si temps écoulé
                if (tempsRestant === 0) {
                    clearInterval(timerInterval);
                    autoSubmit();
                }
            }, 1000);
        }

        // Mise à jour de l'affichage du chronomètre avec changement de couleur selon le temps restant
        function updateTimerDisplay(secondes) {
            const minutes = Math.floor(secondes / 60);
            const secs = secondes % 60;
            const display = `${minutes}:${secs.toString().padStart(2, '0')}`;
            
            document.getElementById('timer-display').textContent = display;
            
            const timerContainer = document.getElementById('timer');
            timerContainer.classList.remove('warning', 'danger');
            
            if (secondes <= 60) {
                timerContainer.classList.add('danger');
            } else if (secondes <= 300) {
                timerContainer.classList.add('warning');
            }
        }

        // Vérification du temps restant côté serveur toutes les 30 secondes
        function checkServerTime() {
            fetch(checkTimeUrl)
                .then(response => response.json())
                .then(data => {
                    if (data.temps_expire) {
                        clearInterval(timerInterval);
                        autoSubmit();
                    }
                })
                .catch(error => console.error('Erreur vérification temps:', error));
        }

        // Soumission automatique du quiz quand le temps est écoulé
        function autoSubmit() {
            alert('Le temps est écoulé ! Le quiz va être soumis automatiquement.');
            document.getElementById('quiz-form').submit();
        }

        // Mise à jour de la barre de progression et activation du bouton submit
        function updateProgress() {
            const answeredCount = document.querySelectorAll('input[type="radio"]:checked').length;
            const percentage = (answeredCount / totalQuestions) * 100;
            
            document.getElementById('answered-count').textContent = answeredCount;
            document.getElementById('progress-fill').style.width = percentage + '%';
            
            // Activer le bouton submit si toutes les questions sont répondues
            const submitBtn = document.getElementById('submit-btn');
            if (answeredCount === totalQuestions) {
                submitBtn.disabled = false;
            }
        }

        // Gestion visuelle de la sélection des options avec effet sonore
        document.querySelectorAll('.option-item input[type="radio"]').forEach(radio => {
            radio.addEventListener('change', function() {
                // Jouer le son de sélection
                playSelectSound();
                
                // Retirer la classe selected de toutes les options de cette question
                const questionCard = this.closest('.question-card');
                questionCard.querySelectorAll('.option-item').forEach(opt => {
                    opt.classList.remove('selected');
                });
                
                // Ajouter la classe selected à l'option choisie
                this.closest('.option-item').classList.add('selected');
            });
        });

        // Son de clic au survol des options pour feedback interactif
        document.querySelectorAll('.option-item').forEach(option => {
            option.addEventListener('mouseenter', function() {
                playClickSound();
            });
        });

        // Son de fanfare lors de la soumission du quiz
        document.getElementById('submit-btn').addEventListener('click', function(e) {
            if (!this.disabled) {
                playSubmitSound();
            }
        });

        // Désactiver le bouton submit au départ - Activé quand toutes les questions sont répondues
        document.getElementById('submit-btn').disabled = true;

        // Démarrer le chronomètre au chargement de la page
        startTimer();
    </script>
</body>
</html>
