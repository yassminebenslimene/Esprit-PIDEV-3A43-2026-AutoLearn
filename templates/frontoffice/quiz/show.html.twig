<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ quiz.titre }}</title>

    <link rel="stylesheet" href="{{ asset('frontoffice/vendor/bootstrap/css/bootstrap.min.css') }}">
    <link rel="stylesheet" href="{{ asset('frontoffice/css/fontawesome.css') }}">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }
        .quiz-container {
            max-width: 900px;
            margin: 0 auto;
        }
        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: white;
            text-decoration: none;
            margin-bottom: 20px;
            padding: 10px 20px;
            background: rgba(255, 255, 255, 0.2);
            border-radius: 25px;
            transition: all 0.3s ease;
        }
        .back-link:hover {
            background: rgba(255, 255, 255, 0.3);
            color: white;
            transform: translateX(-5px);
        }
        .quiz-header {
            background: white;
            padding: 40px;
            border-radius: 20px;
            margin-bottom: 30px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.2);
            text-align: center;
        }
        .quiz-header h1 {
            color: #667eea;
            font-size: 36px;
            font-weight: 800;
            margin-bottom: 15px;
        }
        .quiz-header p {
            color: #666;
            font-size: 16px;
            line-height: 1.6;
        }
        .quiz-info {
            display: flex;
            justify-content: center;
            gap: 30px;
            margin-top: 20px;
            padding-top: 20px;
            border-top: 2px solid #f0f0f0;
        }
        .quiz-info-item {
            display: flex;
            align-items: center;
            gap: 8px;
            color: #888;
            font-size: 14px;
        }
        .quiz-info-item i {
            color: #667eea;
        }
        .question-card {
            background: white;
            border-radius: 20px;
            padding: 35px;
            margin-bottom: 25px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.1);
            transition: all 0.3s ease;
        }
        .question-card:hover {
            box-shadow: 0 8px 30px rgba(0,0,0,0.15);
        }
        .question-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }
        .question-number {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 8px 20px;
            border-radius: 25px;
            font-size: 14px;
            font-weight: 700;
            letter-spacing: 0.5px;
        }
        .question-points {
            color: #f59e0b;
            font-size: 14px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 5px;
        }
        .question-text {
            font-size: 20px;
            font-weight: 600;
            color: #1f2937;
            margin-bottom: 25px;
            line-height: 1.6;
        }
        .options-list {
            display: grid;
            gap: 12px;
        }
        .option-item {
            background: #f9fafb;
            border: 3px solid #e5e7eb;
            border-radius: 15px;
            padding: 18px 20px;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            position: relative;
            overflow: hidden;
        }
        .option-item::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            height: 100%;
            width: 0;
            background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
            transition: width 0.3s ease;
        }
        .option-item:hover {
            border-color: #667eea;
            background: #f3f4f6;
            transform: translateX(5px);
        }
        .option-item:hover::before {
            width: 100%;
        }
        .option-item.selected {
            background: linear-gradient(135deg, rgba(102, 126, 234, 0.15) 0%, rgba(118, 75, 162, 0.15) 100%);
            border-color: #667eea;
            border-width: 3px;
        }
        .option-item input[type="radio"] {
            appearance: none;
            width: 24px;
            height: 24px;
            border: 3px solid #d1d5db;
            border-radius: 50%;
            margin-right: 15px;
            cursor: pointer;
            position: relative;
            transition: all 0.3s ease;
            flex-shrink: 0;
            z-index: 1;
        }
        .option-item input[type="radio"]:checked {
            border-color: #667eea;
            background: #667eea;
        }
        .option-item input[type="radio"]:checked::after {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 10px;
            height: 10px;
            background: white;
            border-radius: 50%;
        }
        .option-text {
            font-size: 16px;
            color: #374151;
            font-weight: 500;
            z-index: 1;
        }
        .no-options-warning {
            background: #fef3c7;
            border: 2px solid #fbbf24;
            border-radius: 10px;
            padding: 15px;
            color: #92400e;
            text-align: center;
            font-weight: 500;
        }
        .submit-btn {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 18px 40px;
            border: none;
            border-radius: 30px;
            font-size: 18px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s ease;
            width: 100%;
            margin-top: 30px;
            box-shadow: 0 5px 20px rgba(102, 126, 234, 0.4);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }
        .submit-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 30px rgba(102, 126, 234, 0.6);
        }
        .submit-btn:active {
            transform: translateY(-1px);
        }
        .progress-bar {
            background: white;
            border-radius: 20px;
            padding: 20px;
            margin-bottom: 30px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.1);
        }
        .progress-text {
            font-size: 14px;
            color: #666;
            margin-bottom: 10px;
            font-weight: 600;
        }
        .progress-track {
            background: #e5e7eb;
            height: 10px;
            border-radius: 10px;
            overflow: hidden;
        }
        .progress-fill {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            height: 100%;
            width: 0%;
            transition: width 0.3s ease;
            border-radius: 10px;
        }
    </style>
</head>
<body>
    <div class="quiz-container">
        <a href="{{ path('app_frontoffice_quiz_list', {'chapitreId': chapitre.id}) }}" class="back-link">
            <i class="fa fa-arrow-left"></i>
            <span>Retour à la liste des quiz</span>
        </a>

        <div class="quiz-header">
            <h1>{{ quiz.titre }}</h1>
            <p>{{ quiz.description }}</p>
            <div class="quiz-info">
                <div class="quiz-info-item">
                    <i class="fa fa-question-circle"></i>
                    <span>{{ quiz.questions|length }} question(s)</span>
                </div>
                <div class="quiz-info-item">
                    <i class="fa fa-star"></i>
                    <span>
                        {% set totalPoints = 0 %}
                        {% for question in quiz.questions %}
                            {% set totalPoints = totalPoints + question.point %}
                        {% endfor %}
                        {{ totalPoints }} point(s) au total
                    </span>
                </div>
            </div>
        </div>

        <div class="progress-bar">
            <div class="progress-text">Progression : <span id="progressText">0/{{ quiz.questions|length }}</span></div>
            <div class="progress-track">
                <div class="progress-fill" id="progressFill"></div>
            </div>
        </div>

        <form method="post" action="{{ path('app_frontoffice_quiz_submit', {'chapitreId': chapitre.id, 'id': quiz.id}) }}" id="quizForm">
            {% for question in quiz.questions %}
                <div class="question-card" data-question-index="{{ loop.index }}">
                    <div class="question-header">
                        <span class="question-number">Question {{ loop.index }}</span>
                        <span class="question-points">
                            <i class="fa fa-star"></i>
                            {{ question.point }} point(s)
                        </span>
                    </div>
                    <div class="question-text">{{ question.texteQuestion }}</div>

                    <div class="options-list">
                        {% if question.options|length > 0 %}
                            {% for option in question.options %}
                                <label class="option-item" for="option_{{ option.id }}">
                                    <input 
                                        type="radio" 
                                        name="answers[{{ question.id }}]" 
                                        value="{{ option.id }}" 
                                        id="option_{{ option.id }}"
                                        data-question="{{ question.id }}"
                                        required
                                    >
                                    <span class="option-text">{{ option.texteOption }}</span>
                                </label>
                            {% endfor %}
                        {% else %}
                            <div class="no-options-warning">
                                <i class="fa fa-exclamation-triangle"></i>
                                Aucune option disponible pour cette question. Veuillez contacter l'administrateur.
                            </div>
                        {% endif %}
                    </div>
                </div>
            {% endfor %}

            <button type="submit" class="submit-btn" id="submitBtn">
                <i class="fa fa-check-circle"></i>
                <span>Soumettre mes réponses</span>
            </button>
        </form>
    </div>

    <script src="{{ asset('frontoffice/vendor/jquery/jquery.min.js') }}"></script>
    <script>
        const totalQuestions = {{ quiz.questions|length }};
        let answeredQuestions = new Set();

        // Gestion de la sélection des options
        document.querySelectorAll('.option-item input[type="radio"]').forEach(radio => {
            radio.addEventListener('change', function() {
                // Retirer la classe selected de toutes les options du même groupe
                const name = this.name;
                document.querySelectorAll(`input[name="${name}"]`).forEach(r => {
                    r.closest('.option-item').classList.remove('selected');
                });
                
                // Ajouter la classe selected à l'option sélectionnée
                this.closest('.option-item').classList.add('selected');
                
                // Mettre à jour la progression
                const questionId = this.getAttribute('data-question');
                answeredQuestions.add(questionId);
                updateProgress();
            });
        });

        // Mise à jour de la barre de progression
        function updateProgress() {
            const answered = answeredQuestions.size;
            const percentage = (answered / totalQuestions) * 100;
            
            document.getElementById('progressText').textContent = `${answered}/${totalQuestions}`;
            document.getElementById('progressFill').style.width = `${percentage}%`;
        }

        // Validation avant soumission
        document.getElementById('quizForm').addEventListener('submit', function(e) {
            const questions = document.querySelectorAll('.question-card');
            let allAnswered = true;
            let unansweredQuestions = [];

            questions.forEach((question, index) => {
                const radios = question.querySelectorAll('input[type="radio"]');
                if (radios.length > 0) {
                    const answered = Array.from(radios).some(radio => radio.checked);
                    if (!answered) {
                        allAnswered = false;
                        unansweredQuestions.push(index + 1);
                    }
                }
            });

            if (!allAnswered) {
                e.preventDefault();
                alert(`⚠️ Veuillez répondre à toutes les questions avant de soumettre.\n\nQuestions non répondues : ${unansweredQuestions.join(', ')}`);
                
                // Scroll vers la première question non répondue
                const firstUnanswered = document.querySelector(`.question-card[data-question-index="${unansweredQuestions[0]}"]`);
                if (firstUnanswered) {
                    firstUnanswered.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    firstUnanswered.style.animation = 'shake 0.5s';
                    setTimeout(() => {
                        firstUnanswered.style.animation = '';
                    }, 500);
                }
            }
        });

        // Animation de shake pour les questions non répondues
        const style = document.createElement('style');
        style.textContent = `
            @keyframes shake {
                0%, 100% { transform: translateX(0); }
                25% { transform: translateX(-10px); }
                75% { transform: translateX(10px); }
            }
        `;
        document.head.appendChild(style);
    </script>
</body>
</html>
