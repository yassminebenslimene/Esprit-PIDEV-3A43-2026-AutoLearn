<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Résultats - {{ quiz.titre }}</title>

    <link rel="stylesheet" href="{{ asset('frontoffice/vendor/bootstrap/css/bootstrap.min.css') }}">
    <link rel="stylesheet" href="{{ asset('frontoffice/css/fontawesome.css') }}">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Inter', sans-serif;
            background: #46178f;
            background-image: 
                repeating-linear-gradient(45deg, transparent, transparent 35px, rgba(255,255,255,.05) 35px, rgba(255,255,255,.05) 70px);
            min-height: 100vh;
            overflow-x: hidden;
            padding: 20px;
        }
        
        .result-container {
            max-width: 1100px;
            margin: 0 auto;
        }
        
        /* Header de résultats - Style Kahoot */
        .result-header {
            background: white;
            padding: 60px 50px;
            border-radius: 20px;
            margin-bottom: 40px;
            box-shadow: 0 15px 50px rgba(0,0,0,0.3);
            text-align: center;
            position: relative;
            overflow: hidden;
            animation: slideDown 0.6s ease-out;
        }
        
        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-50px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        .result-header::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 8px;
            background: linear-gradient(90deg, #e74c3c 0%, #3498db 25%, #f39c12 50%, #2ecc71 75%, #e74c3c 100%);
        }
        
        .result-icon {
            font-size: 100px;
            margin-bottom: 25px;
            animation: bounceIn 0.8s ease-out;
            width: 120px;
            height: 120px;
            margin: 0 auto 25px;
            border-radius: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            box-shadow: 0 10px 40px rgba(0,0,0,0.2);
        }
        
        .result-icon i {
            font-size: 60px;
        }
        
        .result-icon.excellent {
            background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
        }
        
        .result-icon.good {
            background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
        }
        
        .result-icon.average {
            background: linear-gradient(135deg, #f39c12 0%, #e67e22 100%);
        }
        
        .result-icon.poor {
            background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
        }
        
        @keyframes bounceIn {
            0% { transform: scale(0) rotate(-180deg); opacity: 0; }
            50% { transform: scale(1.2) rotate(10deg); }
            100% { transform: scale(1) rotate(0deg); opacity: 1; }
        }
        
        .result-title {
            font-size: 42px;
            font-weight: 800;
            color: #1f2937;
            margin-bottom: 15px;
        }
        
        .quiz-name {
            font-size: 22px;
            color: #46178f;
            font-weight: 700;
            margin-bottom: 40px;
        }
        
        /* Score Display - Style Kahoot */
        .score-display {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 50px;
            margin: 40px 0;
            flex-wrap: wrap;
        }
        
        .score-item {
            text-align: center;
            animation: fadeInUp 0.8s ease-out;
            animation-fill-mode: both;
        }
        
        .score-item:nth-child(1) {
            animation-delay: 0.2s;
        }
        
        .score-item:nth-child(2) {
            animation-delay: 0.4s;
        }
        
        .score-item:nth-child(3) {
            animation-delay: 0.6s;
        }
        
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        .score-value {
            font-size: 56px;
            font-weight: 800;
            background: linear-gradient(135deg, #46178f 0%, #764ba2 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            line-height: 1;
        }
        
        .score-label {
            font-size: 14px;
            color: #6b7280;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-top: 10px;
        }
        
        /* Cercle de pourcentage - Style Kahoot */
        .percentage-circle {
            width: 180px;
            height: 180px;
            border-radius: 50%;
            background: conic-gradient(
                {% set pct = result.percentage ?? percentage %}
                {% if pct >= 80 %}#2ecc71{% elseif pct >= 60 %}#3498db{% elseif pct >= 40 %}#f39c12{% else %}#e74c3c{% endif %} 0% {{ pct }}%, 
                #e5e7eb {{ pct }}% 100%
            );
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            animation: rotateIn 1s ease-out;
        }
        
        @keyframes rotateIn {
            from {
                transform: rotate(-180deg) scale(0);
                opacity: 0;
            }
            to {
                transform: rotate(0deg) scale(1);
                opacity: 1;
            }
        }
        
        .percentage-inner {
            width: 145px;
            height: 145px;
            border-radius: 50%;
            background: white;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }
        
        .percentage-value {
            font-size: 42px;
            font-weight: 800;
            {% set pct = result.percentage ?? percentage %}
            {% if pct >= 80 %}
                color: #2ecc71;
            {% elseif pct >= 60 %}
                color: #3498db;
            {% elseif pct >= 40 %}
                color: #f39c12;
            {% else %}
                color: #e74c3c;
            {% endif %}
        }
        
        .percentage-text {
            font-size: 13px;
            color: #6b7280;
            font-weight: 700;
            text-transform: uppercase;
        }
        
        /* Badge de performance - Style Kahoot */
        .performance-badge {
            display: inline-block;
            padding: 15px 35px;
            border-radius: 50px;
            font-weight: 800;
            font-size: 18px;
            margin-top: 30px;
            box-shadow: 0 8px 25px rgba(0,0,0,0.2);
            animation: pulse 2s ease-in-out infinite;
        }
        
        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }
        
        .badge-excellent {
            background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
            color: white;
        }
        
        .badge-good {
            background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
            color: white;
        }
        
        .badge-average {
            background: linear-gradient(135deg, #f39c12 0%, #e67e22 100%);
            color: white;
        }
        
        .badge-poor {
            background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
            color: white;
        }
        
        /* Section Title */
        .section-title {
            font-size: 28px;
            font-weight: 800;
            color: white;
            margin-bottom: 25px;
            display: flex;
            align-items: center;
            gap: 12px;
            text-shadow: 0 2px 10px rgba(0,0,0,0.2);
        }
        
        /* Result Cards - Style Kahoot */
        .result-card {
            background: white;
            border-radius: 18px;
            padding: 30px;
            margin-bottom: 25px;
            box-shadow: 0 8px 25px rgba(0,0,0,0.2);
            border-left: 8px solid;
            transition: all 0.4s ease;
            animation: fadeInUp 0.6s ease-out;
            animation-fill-mode: both;
        }
        
        {% set detailsList = result.details ?? results %}
        {% for i in 1..detailsList|length %}
        .result-card:nth-child({{ i }}) {
            animation-delay: {{ i * 0.1 }}s;
        }
        {% endfor %}
        
        .result-card:hover {
            transform: translateX(8px);
            box-shadow: 0 12px 35px rgba(0,0,0,0.3);
        }
        
        .result-card.correct {
            border-left-color: #2ecc71;
        }
        
        .result-card.incorrect {
            border-left-color: #e74c3c;
        }
        
        .question-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            flex-wrap: wrap;
            gap: 10px;
        }
        
        .question-number {
            font-size: 15px;
            font-weight: 800;
            color: #46178f;
            background: rgba(70, 23, 143, 0.1);
            padding: 8px 20px;
            border-radius: 50px;
        }
        
        .question-status {
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 800;
            font-size: 16px;
            padding: 8px 20px;
            border-radius: 50px;
        }
        
        .status-correct {
            color: #2ecc71;
            background: rgba(46, 204, 113, 0.1);
        }
        
        .status-incorrect {
            color: #e74c3c;
            background: rgba(231, 76, 60, 0.1);
        }
        
        .question-text {
            font-size: 20px;
            font-weight: 700;
            color: #1f2937;
            margin-bottom: 25px;
            line-height: 1.6;
        }
        
        /* Answer Items - Style Kahoot */
        .answers-list {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }
        
        .answer-item {
            padding: 15px 20px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 16px;
            transition: all 0.3s ease;
            border: 3px solid;
        }
        
        .answer-icon {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            font-weight: 800;
            flex-shrink: 0;
        }
        
        .answer-item.selected {
            background: rgba(59, 130, 246, 0.15);
            border-color: #3b82f6;
            font-weight: 700;
        }
        
        .answer-item.selected .answer-icon {
            background: #3b82f6;
            color: white;
        }
        
        .answer-item.correct {
            background: rgba(46, 204, 113, 0.15);
            border-color: #2ecc71;
            font-weight: 700;
        }
        
        .answer-item.correct .answer-icon {
            background: #2ecc71;
            color: white;
        }
        
        .answer-item.incorrect {
            background: rgba(231, 76, 60, 0.15);
            border-color: #e74c3c;
            font-weight: 700;
        }
        
        .answer-item.incorrect .answer-icon {
            background: #e74c3c;
            color: white;
        }
        
        .answer-item.neutral {
            background: #f9fafb;
            border-color: #e5e7eb;
        }
        
        .answer-item.neutral .answer-icon {
            background: #e5e7eb;
            color: #6b7280;
        }
        
        .answer-label {
            font-size: 13px;
            color: #6b7280;
            font-weight: 700;
            margin-left: auto;
            padding: 5px 15px;
            background: rgba(0,0,0,0.05);
            border-radius: 20px;
        }
        
        /* Action Buttons - Style Kahoot */
        .action-buttons {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
            margin-top: 40px;
        }
        
        .btn-action {
            padding: 18px 30px;
            border-radius: 50px;
            text-align: center;
            text-decoration: none;
            font-weight: 800;
            font-size: 17px;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            box-shadow: 0 6px 20px rgba(0,0,0,0.2);
        }
        
        .btn-action:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }
        
        .btn-retry {
            background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
            color: white;
        }
        
        .btn-back {
            background: white;
            color: #46178f;
            border: 3px solid #46178f;
        }
        
        .btn-home {
            background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
            color: white;
        }
        
        /* Responsive */
        @media (max-width: 768px) {
            .result-header {
                padding: 40px 30px;
            }
            
            .result-title {
                font-size: 32px;
            }
            
            .score-display {
                gap: 30px;
            }
            
            .percentage-circle {
                width: 150px;
                height: 150px;
            }
            
            .percentage-inner {
                width: 120px;
                height: 120px;
            }
            
            .action-buttons {
                grid-template-columns: 1fr;
            }
        }
        
        /* Statistiques des tentatives */
        .attempts-summary {
            background: white;
            border-radius: 20px;
            padding: 40px;
            margin-bottom: 40px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.2);
            animation: fadeInUp 0.8s ease-out;
            animation-delay: 0.4s;
            animation-fill-mode: both;
        }
        
        .attempts-title {
            display: flex;
            align-items: center;
            gap: 15px;
            font-size: 28px;
            font-weight: 800;
            color: #1f2937;
            margin-bottom: 30px;
            text-align: center;
            justify-content: center;
        }
        
        .attempts-title i {
            color: #46178f;
            font-size: 32px;
        }
        
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 25px;
            margin-bottom: 30px;
        }
        
        .stat-card {
            background: rgba(70, 23, 143, 0.05);
            border-radius: 15px;
            padding: 25px;
            display: flex;
            align-items: center;
            gap: 20px;
            transition: all 0.3s ease;
            border-left: 4px solid #46178f;
        }
        
        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(70, 23, 143, 0.2);
        }
        
        .stat-icon {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            color: white;
            background: linear-gradient(135deg, #46178f 0%, #6b21a8 100%);
        }
        
        .stat-icon.success {
            background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
        }
        
        .stat-icon.warning {
            background: linear-gradient(135deg, #f39c12 0%, #e67e22 100%);
        }
        
        .stat-icon.info {
            background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
        }
        
        .stat-icon.danger {
            background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
        }
        
        .stat-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 5px;
        }
        
        .stat-number {
            font-size: 32px;
            font-weight: 800;
            color: #1f2937;
        }
        
        .stat-number.success {
            color: #2ecc71;
        }
        
        .stat-number.warning {
            color: #f39c12;
        }
        
        .stat-number.info {
            color: #3498db;
        }
        
        .stat-number.danger {
            color: #e74c3c;
        }
        
        .stat-label {
            font-size: 14px;
            color: #6b7280;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .success-message {
            background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
            color: white;
            padding: 20px 30px;
            border-radius: 15px;
            display: flex;
            align-items: center;
            gap: 15px;
            font-weight: 700;
            font-size: 16px;
            box-shadow: 0 8px 25px rgba(46, 204, 113, 0.3);
        }
        
        .success-message i {
            font-size: 24px;
        }
    </style>
</head>
<body>
    <div class="result-container">
        <div class="result-header">
            <div class="result-icon {% set pct = result.percentage ?? percentage %}{% if pct >= 80 %}excellent{% elseif pct >= 60 %}good{% elseif pct >= 40 %}average{% else %}poor{% endif %}">
                {% if pct >= 80 %}
                    <i class="fa fa-trophy"></i>
                {% elseif pct >= 60 %}
                    <i class="fa fa-thumbs-up"></i>
                {% elseif pct >= 40 %}
                    <i class="fa fa-chart-line"></i>
                {% else %}
                    <i class="fa fa-book-open"></i>
                {% endif %}
            </div>
            <h1 class="result-title">Résultats du Quiz</h1>
            <p class="quiz-name">{{ quiz.titre }}</p>
            
            <div class="score-display">
                <div class="score-item">
                    <div class="score-value">{{ result.score ?? score }}</div>
                    <div class="score-label">Points obtenus</div>
                </div>
                
                <div class="percentage-circle">
                    <div class="percentage-inner">
                        <div class="percentage-value">{{ pct|number_format(0) }}%</div>
                        <div class="percentage-text">Réussite</div>
                    </div>
                </div>
                
                <div class="score-item">
                    <div class="score-value">{{ result.totalPoints ?? totalPoints }}</div>
                    <div class="score-label">Points total</div>
                </div>
            </div>

            <div class="performance-badge 
                {% if pct >= 80 %}badge-excellent
                {% elseif pct >= 60 %}badge-good
                {% elseif pct >= 40 %}badge-average
                {% else %}badge-poor
                {% endif %}">
                {% if pct >= 80 %}
                    🏆 Excellent travail !
                {% elseif pct >= 60 %}
                    👍 Bien joué !
                {% elseif pct >= 40 %}
                    💪 Peut mieux faire
                {% else %}
                    📚 Continuez à réviser
                {% endif %}
            </div>
        </div>

        {% block after_result_header %}{% endblock %}

        <h2 class="section-title">
            <i class="fa fa-list-alt"></i>
            Détails des réponses
        </h2>

        {% set detailsList = result.details ?? results %}
        {% for questionId, detail in detailsList %}
            <div class="result-card {% if detail.isCorrect %}correct{% else %}incorrect{% endif %}">
                <div class="question-header">
                    <span class="question-number">Question {{ loop.index }}</span>
                    <span class="question-status {% if detail.isCorrect %}status-correct{% else %}status-incorrect{% endif %}">
                        {% if detail.isCorrect %}
                            <i class="fa fa-check-circle"></i> Correct
                        {% else %}
                            <i class="fa fa-times-circle"></i> Incorrect
                        {% endif %}
                    </span>
                </div>

                <div class="question-text">{{ detail.question.texteQuestion }}</div>

                <div class="answers-list">
                    {% for option in detail.question.options %}
                        {% set selectedId = detail.selectedOption %}
                        <div class="answer-item 
                            {% if option.id == selectedId and option.isEstCorrecte %}correct
                            {% elseif option.id == selectedId and not option.isEstCorrecte %}incorrect
                            {% elseif option.isEstCorrecte %}correct
                            {% else %}neutral
                            {% endif %}">
                            <div class="answer-icon">
                                {% if option.isEstCorrecte %}
                                    ✓
                                {% elseif option.id == selectedId %}
                                    ✗
                                {% else %}
                                    •
                                {% endif %}
                            </div>
                            <span>{{ option.texteOption }}</span>
                            {% if option.id == selectedId %}
                                <span class="answer-label">Votre réponse</span>
                            {% elseif option.isEstCorrecte and option.id != selectedId %}
                                <span class="answer-label">Bonne réponse</span>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>

                {% block after_question_answers %}{% endblock %}
            </div>
        {% endfor %}

        {% if statistiques is defined %}
            <div class="attempts-summary">
                <h3 class="attempts-title">
                    <i class="fa fa-chart-line"></i>
                    Vos statistiques pour ce quiz
                </h3>
                
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-icon">
                            <i class="fa fa-play-circle"></i>
                        </div>
                        <div class="stat-content">
                            <span class="stat-number">{{ statistiques.nombreTentatives }}</span>
                            <span class="stat-label">
                                Tentative{{ statistiques.nombreTentatives > 1 ? 's' : '' }}
                                {% if statistiques.maxTentatives %}
                                    / {{ statistiques.maxTentatives }}
                                {% endif %}
                            </span>
                        </div>
                    </div>
                    
                    {% if statistiques.derniersResultats %}
                        <div class="stat-card">
                            <div class="stat-icon {{ statistiques.aReussi ? 'success' : 'warning' }}">
                                <i class="fa {{ statistiques.aReussi ? 'fa-trophy' : 'fa-target' }}"></i>
                            </div>
                            <div class="stat-content">
                                <span class="stat-number {{ statistiques.aReussi ? 'success' : 'warning' }}">
                                    {{ statistiques.derniersResultats.percentage|round(1) }}%
                                </span>
                                <span class="stat-label">Meilleur score</span>
                            </div>
                        </div>
                    {% endif %}
                    
                    <div class="stat-card">
                        <div class="stat-icon {{ statistiques.peutRecommencer ? 'info' : 'danger' }}">
                            <i class="fa {{ statistiques.peutRecommencer ? 'fa-redo' : 'fa-ban' }}"></i>
                        </div>
                        <div class="stat-content">
                            <span class="stat-number {{ statistiques.peutRecommencer ? 'info' : 'danger' }}">
                                {{ statistiques.peutRecommencer ? 'OUI' : 'NON' }}
                            </span>
                            <span class="stat-label">Peut recommencer</span>
                        </div>
                    </div>
                </div>
                
                {% if statistiques.aReussi %}
                    <div class="success-message">
                        <i class="fa fa-check-circle"></i>
                        <span>Félicitations ! Vous avez réussi ce quiz avec {{ statistiques.derniersResultats.percentage|round(1) }}% (seuil: {{ statistiques.seuilReussite }}%)</span>
                    </div>
                {% endif %}
            </div>
        {% endif %}

        <div class="action-buttons">
            <a href="{{ path('app_quiz_start', {'id': quiz.id}) }}" class="btn-action btn-retry">
                <i class="fa fa-redo"></i>
                Refaire le quiz
            </a>
            <a href="{{ path('app_frontoffice_quiz_list', {'chapitreId': chapitre.id ?? chapitreId}) }}" class="btn-action btn-back">
                <i class="fa fa-arrow-left"></i>
                Autres quiz
            </a>
            <a href="{{ path('app_chapitre_index_front', {'id': chapitre.cours.id}) }}" class="btn-action btn-home">
                <i class="fa fa-home"></i>
                Retour aux chapitres
            </a>
        </div>
    </div>

    <script src="{{ asset('frontoffice/vendor/jquery/jquery.min.js') }}"></script>
    <script>
        // Système de sons
        const AudioContext = window.AudioContext || window.webkitAudioContext;
        const audioCtx = new AudioContext();

        // Son de résultat (selon le score)
        function playResultSound(percentage) {
            const oscillator = audioCtx.createOscillator();
            const gainNode = audioCtx.createGain();
            
            oscillator.connect(gainNode);
            gainNode.connect(audioCtx.destination);
            
            if (percentage >= 80) {
                // Son de victoire (fanfare montante)
                oscillator.frequency.setValueAtTime(523.25, audioCtx.currentTime); // C5
                oscillator.frequency.setValueAtTime(659.25, audioCtx.currentTime + 0.1); // E5
                oscillator.frequency.setValueAtTime(783.99, audioCtx.currentTime + 0.2); // G5
                oscillator.frequency.setValueAtTime(1046.50, audioCtx.currentTime + 0.3); // C6
                oscillator.type = 'sine';
                gainNode.gain.setValueAtTime(0.35, audioCtx.currentTime);
                gainNode.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.6);
                oscillator.start(audioCtx.currentTime);
                oscillator.stop(audioCtx.currentTime + 0.6);
            } else if (percentage >= 50) {
                // Son de réussite (montée joyeuse)
                oscillator.frequency.setValueAtTime(523.25, audioCtx.currentTime); // C5
                oscillator.frequency.setValueAtTime(659.25, audioCtx.currentTime + 0.15); // E5
                oscillator.type = 'triangle';
                gainNode.gain.setValueAtTime(0.3, audioCtx.currentTime);
                gainNode.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.4);
                oscillator.start(audioCtx.currentTime);
                oscillator.stop(audioCtx.currentTime + 0.4);
            } else {
                // Son d'échec (descente triste)
                oscillator.frequency.setValueAtTime(523.25, audioCtx.currentTime); // C5
                oscillator.frequency.setValueAtTime(392.00, audioCtx.currentTime + 0.15); // G4
                oscillator.frequency.setValueAtTime(329.63, audioCtx.currentTime + 0.3); // E4
                oscillator.type = 'sine';
                gainNode.gain.setValueAtTime(0.25, audioCtx.currentTime);
                gainNode.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.5);
                oscillator.start(audioCtx.currentTime);
                oscillator.stop(audioCtx.currentTime + 0.5);
            }
        }

        // Jouer le son selon le pourcentage
        const percentage = {{ result.percentage ?? percentage }};
        setTimeout(() => {
            playResultSound(percentage);
        }, 800);
    </script>
</body>
</html>
