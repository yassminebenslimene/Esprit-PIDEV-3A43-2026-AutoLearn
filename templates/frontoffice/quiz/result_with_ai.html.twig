{# 
    Template de résultats de quiz avec analyse IA
    - Affiche les résultats du quiz avec un design moderne style Kahoot
    - Intègre la navbar et sidebar 
    - Inclut l'analyse pédagogique par IA
    - Propose un chat interactif avec le tuteur IA
#}
{% extends 'frontoffice/base.html.twig' %}

{% block title %}Résultats - {{ quiz.titre }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {# Police Inter pour un design moderne #}
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        /* === STYLES GÉNÉRAUX === */
        body {
            background: #46178f; /* Fond violet principal */
            background-image: 
                repeating-linear-gradient(45deg, transparent, transparent 35px, rgba(255,255,255,.05) 35px, rgba(255,255,255,.05) 70px);
            min-height: 100vh;
            padding: 100px 20px 20px; /* Espace pour la navbar fixe */
        }
        
        .result-container {
            max-width: 1100px;
            margin: 0 auto;
        }
        
        /* === HEADER DE RÉSULTATS === */
        /* Design inspiré de Kahoot avec animations */
        .result-header {
            background: white;
            padding: 60px 50px;
            border-radius: 20px;
            margin-bottom: 40px;
            box-shadow: 0 15px 50px rgba(0,0,0,0.3);
            text-align: center;
            position: relative;
            overflow: hidden;
            animation: slideDown 0.6s ease-out;
        }
        
        /* === ANIMATIONS === */
        /* Animation de descente pour le header */
        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-50px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        .result-header::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 8px;
            /* Barre colorée style Kahoot en haut du header */
            background: linear-gradient(90deg, #e74c3c 0%, #3498db 25%, #f39c12 50%, #2ecc71 75%, #e74c3c 100%);
        }
        
        /* === ICÔNE DE RÉSULTAT === */
        /* Icône animée selon la performance (trophée, pouce, graphique, livre) */
            font-size: 100px;
            margin-bottom: 25px;
            animation: bounceIn 0.8s ease-out;
            width: 120px;
            height: 120px;
            margin: 0 auto 25px;
            border-radius: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            box-shadow: 0 10px 40px rgba(0,0,0,0.2);
        }
        
        .result-icon i {
            font-size: 60px;
        }
        
        .result-icon.excellent {
            background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
        }
        
        .result-icon.good {
            background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
        }
        
        .result-icon.average {
            background: linear-gradient(135deg, #f39c12 0%, #e67e22 100%);
        }
        
        .result-icon.poor {
            background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
        }
        
        @keyframes bounceIn {
            0% { transform: scale(0) rotate(-180deg); opacity: 0; }
            50% { transform: scale(1.2) rotate(10deg); }
            100% { transform: scale(1) rotate(0deg); opacity: 1; }
        }
        
        .result-title {
            font-size: 42px;
            font-weight: 800;
            color: #1f2937;
            margin-bottom: 15px;
        }
        
        /* Nom du quiz affiché sous le titre */
        .quiz-name {
            font-size: 22px;
            color: #46178f;
            font-weight: 700;
            margin-bottom: 40px;
        }
        
        /* === AFFICHAGE DU SCORE === */
        /* Conteneur flex pour afficher les 3 éléments de score côte à côte */
        .score-display {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 50px;
            margin: 40px 0;
            flex-wrap: wrap;
        }
        
        /* Chaque élément de score avec animation décalée */
        .score-item {
            text-align: center;
            animation: fadeInUp 0.8s ease-out;
            animation-fill-mode: both;
        }
        
        /* Délais d'animation pour effet cascade */
        .score-item:nth-child(1) {
            animation-delay: 0.2s;
        }
        
        .score-item:nth-child(2) {
            animation-delay: 0.4s;
        }
        
        .score-item:nth-child(3) {
            animation-delay: 0.6s;
        }
        
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        /* Valeur numérique du score avec dégradé violet */
        .score-value {
            font-size: 56px;
            font-weight: 800;
            background: linear-gradient(135deg, #46178f 0%, #764ba2 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            line-height: 1;
        }
        
        /* Label sous le score (ex: "Points obtenus") */
        .score-label {
            font-size: 14px;
            color: #6b7280;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-top: 10px;
        }
        
        /* === CERCLE DE POURCENTAGE === */
        /* Cercle animé affichant le pourcentage de réussite avec couleur dynamique */
        .percentage-circle {
            width: 180px;
            height: 180px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            animation: rotateIn 1s ease-out;
        }
        
        @keyframes rotateIn {
            from {
                transform: rotate(-180deg) scale(0);
                opacity: 0;
            }
            to {
                transform: rotate(0deg) scale(1);
                opacity: 1;
            }
        }
        
        /* Cercle intérieur blanc contenant le pourcentage */
        .percentage-inner {
            width: 145px;
            height: 145px;
            border-radius: 50%;
            background: white;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }
        
        /* Valeur du pourcentage en grand */
        .percentage-value {
            font-size: 42px;
            font-weight: 800;
        }
        
        .percentage-text {
            font-size: 13px;
            color: #6b7280;
            font-weight: 700;
            text-transform: uppercase;
        }
        
        /* === BADGE DE PERFORMANCE === */
        /* Badge coloré avec message selon le score (Excellent, Bien joué, etc.) */
        .performance-badge {
            display: inline-block;
            padding: 15px 35px;
            border-radius: 50px;
            font-weight: 800;
            font-size: 18px;
            margin-top: 30px;
            box-shadow: 0 8px 25px rgba(0,0,0,0.2);
            animation: pulse 2s ease-in-out infinite;
        }
        
        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }
        
        /* Badges colorés selon la performance */
        .badge-excellent {
            background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
            color: white;
        }
        
        .badge-good {
            background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
            color: white;
        }
        
        .badge-average {
            background: linear-gradient(135deg, #f39c12 0%, #e67e22 100%);
            color: white;
        }
        
        .badge-poor {
            background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
            color: white;
        }
        
        /* === TITRE DE SECTION === */
        /* Titre blanc avec icône pour les sections principales */
        .section-title {
            font-size: 28px;
            font-weight: 800;
            color: white;
            margin-bottom: 25px;
            display: flex;
            align-items: center;
            gap: 12px;
            text-shadow: 0 2px 10px rgba(0,0,0,0.2);
        }
        
        /* === CARTES DE RÉSULTATS === */
        /* Carte blanche pour chaque question avec bordure colorée (vert/rouge) */
        .result-card {
            background: white;
            border-radius: 18px;
            padding: 30px;
            margin-bottom: 25px;
            box-shadow: 0 8px 25px rgba(0,0,0,0.2);
            border-left: 8px solid;
            transition: all 0.4s ease;
            animation: fadeInUp 0.6s ease-out;
            animation-fill-mode: both;
        }
        
        .result-card:hover {
            transform: translateX(8px);
            box-shadow: 0 12px 35px rgba(0,0,0,0.3);
        }
        
        /* Bordures colorées selon le résultat */
        .result-card.correct {
            border-left-color: #2ecc71;
        }
        
        .result-card.incorrect {
            border-left-color: #e74c3c;
        }
        
        /* En-tête de la question avec numéro et statut */
        .question-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            flex-wrap: wrap;
            gap: 10px;
        }
        
        /* Badge violet avec le numéro de la question */
        .question-number {
            font-size: 15px;
            font-weight: 800;
            color: #46178f;
            background: rgba(70, 23, 143, 0.1);
            padding: 8px 20px;
            border-radius: 50px;
        }
        
        /* Badge de statut (Correct/Incorrect) avec icône */
        .question-status {
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 800;
            font-size: 16px;
            padding: 8px 20px;
            border-radius: 50px;
        }
        
        /* Statuts colorés */
        .status-correct {
            color: #2ecc71;
            background: rgba(46, 204, 113, 0.1);
        }
        
        .status-incorrect {
            color: #e74c3c;
            background: rgba(231, 76, 60, 0.1);
        }
        
        /* Texte de la question en gras */
        .question-text {
            font-size: 20px;
            font-weight: 700;
            color: #1f2937;
            margin-bottom: 25px;
            line-height: 1.6;
        }
        
        /* === LISTE DES RÉPONSES === */
        /* Conteneur vertical pour les options de réponse */
        .answers-list {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }
        
        /* Chaque option de réponse avec bordure et icône */
        .answer-item {
            padding: 15px 20px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 16px;
            transition: all 0.3s ease;
            border: 3px solid;
        }
        
        /* Icône circulaire pour chaque réponse (✓, ✗, •) */
        .answer-icon {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            font-weight: 800;
            flex-shrink: 0;
        }
        
        /* Styles pour les différents états de réponse */
        /* Réponse sélectionnée par l'utilisateur */
        .answer-item.selected {
            background: rgba(59, 130, 246, 0.15);
            border-color: #3b82f6;
            font-weight: 700;
        }
        
        .answer-item.selected .answer-icon {
            background: #3b82f6;
            color: white;
        }
        
        /* Bonne réponse en vert */
        .answer-item.correct {
            background: rgba(46, 204, 113, 0.15);
            border-color: #2ecc71;
            font-weight: 700;
        }
        
        .answer-item.correct .answer-icon {
            background: #2ecc71;
            color: white;
        }
        
        /* Mauvaise réponse en rouge */
        .answer-item.incorrect {
            background: rgba(231, 76, 60, 0.15);
            border-color: #e74c3c;
            font-weight: 700;
        }
        
        .answer-item.incorrect .answer-icon {
            background: #e74c3c;
            color: white;
        }
        
        /* Réponse non sélectionnée en gris */
        .answer-item.neutral {
            background: #f9fafb;
            border-color: #e5e7eb;
        }
        
        .answer-item.neutral .answer-icon {
            background: #e5e7eb;
            color: #6b7280;
        }
        
        /* Label indiquant "Votre réponse" ou "Bonne réponse" */
        .answer-label {
            font-size: 13px;
            color: #6b7280;
            font-weight: 700;
            margin-left: auto;
            padding: 5px 15px;
            background: rgba(0,0,0,0.05);
            border-radius: 20px;
        }
        
        /* Styles pour la carte de résumé pédagogique IA */
        .ai-summary-card {
            background: white;
            border-radius: 20px;
            padding: 40px;
            margin-bottom: 40px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.2);
            animation: fadeInUp 0.8s ease-out;
            animation-delay: 0.2s;
            animation-fill-mode: both;
            border: 3px solid #8b5cf6;
        }
        
        .ai-summary-header {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-bottom: 30px;
            padding-bottom: 20px;
            border-bottom: 3px solid #f3f4f6;
        }
        
        .ai-summary-header i {
            font-size: 32px;
            color: #8b5cf6;
        }
        
        .ai-summary-header h3 {
            font-size: 28px;
            font-weight: 800;
            color: #1f2937;
            margin: 0;
        }
        
        .ai-summary-content {
            display: flex;
            flex-direction: column;
            gap: 25px;
        }
        
        .summary-section {
            background: rgba(139, 92, 246, 0.05);
            padding: 20px;
            border-radius: 15px;
            border-left: 4px solid #8b5cf6;
        }
        
        .summary-section h4 {
            font-size: 18px;
            font-weight: 700;
            color: #1f2937;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .summary-icon {
            font-size: 32px;
            margin-bottom: 10px;
        }
        
        .summary-message {
            font-size: 18px;
            color: #374151;
            line-height: 1.6;
            margin: 0;
        }
        
        .summary-list {
            list-style: none;
            padding: 0;
            margin: 0;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        
        .summary-list li {
            padding: 12px 15px;
            border-radius: 10px;
            font-size: 16px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .summary-list li::before {
            content: '•';
            font-size: 24px;
            font-weight: 800;
        }
        
        .summary-list.success li {
            background: rgba(46, 204, 113, 0.1);
            color: #27ae60;
        }
        
        .summary-list.success li::before {
            color: #2ecc71;
        }
        
        .summary-list.warning li {
            background: rgba(243, 156, 18, 0.1);
            color: #d68910;
        }
        
        .summary-list.warning li::before {
            color: #f39c12;
        }
        
        .summary-list.info li {
            background: rgba(52, 152, 219, 0.1);
            color: #2980b9;
        }
        
        .summary-list.info li::before {
            color: #3498db;
        }
        
        .summary-encouragement {
            background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);
            color: white;
            padding: 20px 30px;
            border-radius: 15px;
            font-size: 18px;
            font-weight: 700;
            text-align: center;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 15px;
            box-shadow: 0 8px 25px rgba(139, 92, 246, 0.3);
        }
        
        .summary-encouragement i {
            font-size: 24px;
        }
        
        /* Explications IA par question */
        .ai-explanation {
            margin-top: 20px;
            background: linear-gradient(135deg, rgba(139, 92, 246, 0.05) 0%, rgba(124, 58, 237, 0.05) 100%);
            border-radius: 15px;
            padding: 20px;
            border: 2px solid rgba(139, 92, 246, 0.2);
        }
        
        .ai-explanation-header {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 15px;
            font-weight: 700;
            color: #8b5cf6;
            font-size: 16px;
        }
        
        .ai-explanation-header i {
            font-size: 20px;
        }
        
        .ai-explanation-content {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }
        
        .ai-message {
            font-size: 16px;
            color: #374151;
            font-weight: 600;
            margin: 0;
        }
        
        .ai-detail {
            padding: 15px;
            border-radius: 10px;
            font-size: 15px;
            line-height: 1.6;
        }
        
        .ai-detail strong {
            display: block;
            margin-bottom: 8px;
            font-size: 14px;
        }
        
        .ai-detail p {
            margin: 0;
            color: #4b5563;
        }
        
        .ai-detail.error {
            background: rgba(231, 76, 60, 0.1);
            border-left: 4px solid #e74c3c;
        }
        
        .ai-detail.success {
            background: rgba(46, 204, 113, 0.1);
            border-left: 4px solid #2ecc71;
        }
        
        .ai-detail.info {
            background: rgba(52, 152, 219, 0.1);
            border-left: 4px solid #3498db;
        }
        
        .ai-resources {
            background: rgba(243, 156, 18, 0.1);
            padding: 15px;
            border-radius: 10px;
            border-left: 4px solid #f39c12;
        }
        
        .ai-resources strong {
            display: block;
            margin-bottom: 10px;
            color: #d68910;
            font-size: 14px;
        }
        
        .ai-resources ul {
            margin: 0;
            padding-left: 20px;
        }
        
        .ai-resources li {
            color: #4b5563;
            margin-bottom: 5px;
        }
        
        /* Statistiques des tentatives */
        .attempts-summary {
            background: white;
            border-radius: 20px;
            padding: 40px;
            margin-bottom: 40px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.2);
            animation: fadeInUp 0.8s ease-out;
            animation-delay: 0.4s;
            animation-fill-mode: both;
        }
        
        .attempts-title {
            display: flex;
            align-items: center;
            gap: 15px;
            font-size: 28px;
            font-weight: 800;
            color: #1f2937;
            margin-bottom: 30px;
            text-align: center;
            justify-content: center;
        }
        
        .attempts-title i {
            color: #46178f;
            font-size: 32px;
        }
        
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 25px;
            margin-bottom: 30px;
        }
        
        .stat-card {
            background: rgba(70, 23, 143, 0.05);
            border-radius: 15px;
            padding: 25px;
            display: flex;
            align-items: center;
            gap: 20px;
            transition: all 0.3s ease;
            border-left: 4px solid #46178f;
        }
        
        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(70, 23, 143, 0.2);
        }
        
        .stat-icon {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            color: white;
            background: linear-gradient(135deg, #46178f 0%, #6b21a8 100%);
        }
        
        .stat-icon.success {
            background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
        }
        
        .stat-icon.warning {
            background: linear-gradient(135deg, #f39c12 0%, #e67e22 100%);
        }
        
        .stat-icon.info {
            background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
        }
        
        .stat-icon.danger {
            background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
        }
        
        .stat-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 5px;
        }
        
        .stat-number {
            font-size: 32px;
            font-weight: 800;
            color: #1f2937;
        }
        
        .stat-number.success {
            color: #2ecc71;
        }
        
        .stat-number.warning {
            color: #f39c12;
        }
        
        .stat-number.info {
            color: #3498db;
        }
        
        .stat-number.danger {
            color: #e74c3c;
        }
        
        .stat-label {
            font-size: 14px;
            color: #6b7280;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .success-message {
            background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
            color: white;
            padding: 20px 30px;
            border-radius: 15px;
            display: flex;
            align-items: center;
            gap: 15px;
            font-weight: 700;
            font-size: 16px;
            box-shadow: 0 8px 25px rgba(46, 204, 113, 0.3);
        }
        
        .success-message i {
            font-size: 24px;
        }
        
        /* Action Buttons */
        .action-buttons {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
            margin-top: 40px;
        }
        
        .btn-action {
            padding: 18px 30px;
            border-radius: 50px;
            text-align: center;
            text-decoration: none;
            font-weight: 800;
            font-size: 17px;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            box-shadow: 0 6px 20px rgba(0,0,0,0.2);
        }
        
        .btn-action:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
            text-decoration: none;
        }
        
        .btn-retry {
            background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
            color: white;
        }
        
        .btn-back {
            background: white;
            color: #46178f;
            border: 3px solid #46178f;
        }
        
        .btn-home {
            background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
            color: white;
        }
        
        /* Styles pour le bouton flottant animé de l'assistant IA */
        .ai-assistant-button {
            position: fixed;
            bottom: 30px;
            right: 30px;
            display: flex;
            align-items: center;
            gap: 15px;
            background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);
            color: white;
            padding: 15px 25px;
            border-radius: 50px;
            cursor: pointer;
            box-shadow: 0 10px 30px rgba(139, 92, 246, 0.4);
            z-index: 1000;
            transition: all 0.3s ease;
            animation: slideInRight 0.8s ease-out, float 3s ease-in-out infinite;
        }
        
        @keyframes slideInRight {
            from {
                opacity: 0;
                transform: translateX(100px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }
        
        @keyframes float {
            0%, 100% {
                transform: translateY(0px);
            }
            50% {
                transform: translateY(-10px);
            }
        }
        
        .ai-assistant-button:hover {
            transform: translateY(-5px) scale(1.05);
            box-shadow: 0 15px 40px rgba(139, 92, 246, 0.5);
        }
        
        .assistant-avatar {
            width: 50px;
            height: 50px;
            background: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            color: #8b5cf6;
            animation: bounce 2s ease-in-out infinite;
        }
        
        @keyframes bounce {
            0%, 20%, 50%, 80%, 100% {
                transform: translateY(0);
            }
            40% {
                transform: translateY(-10px);
            }
            60% {
                transform: translateY(-5px);
            }
        }
        
        .assistant-text {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }
        
        .assistant-greeting {
            font-size: 16px;
            font-weight: 700;
        }
        
        .assistant-cta {
            font-size: 14px;
            opacity: 0.9;
            animation: pulse 2s ease-in-out infinite;
        }
        
        @keyframes pulse {
            0%, 100% {
                opacity: 0.9;
            }
            50% {
                opacity: 1;
                transform: scale(1.05);
            }
        }
        
        .pulse-ring {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 100%;
            height: 100%;
            border: 3px solid rgba(139, 92, 246, 0.6);
            border-radius: 50px;
            animation: pulseRing 2s ease-out infinite;
        }
        
        @keyframes pulseRing {
            0% {
                transform: translate(-50%, -50%) scale(1);
                opacity: 1;
            }
            100% {
                transform: translate(-50%, -50%) scale(1.3);
                opacity: 0;
            }
        }
        
        .ai-assistant-button.hidden {
            display: none;
        }
        
        /* Chat avec le tuteur IA */
        .ai-tutor-chat {
            background: white;
            border-radius: 20px;
            padding: 0;
            margin-bottom: 40px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.2);
            overflow: hidden;
            border: 3px solid #8b5cf6;
            animation: fadeInUp 0.8s ease-out;
            animation-fill-mode: both;
            position: fixed;
            bottom: 30px;
            right: 30px;
            width: 450px;
            height: 650px;
            z-index: 999;
            display: flex;
            flex-direction: column;
        }
        
        .ai-tutor-chat.show {
            display: flex;
            animation: slideInUp 0.5s ease-out;
        }
        
        @keyframes slideInUp {
            from {
                opacity: 0;
                transform: translateY(50px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        .chat-header {
            background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);
            color: white;
            padding: 25px 30px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        
        .chat-header-left {
            display: flex;
            align-items: center;
            gap: 15px;
        }
        
        .chat-header i {
            font-size: 28px;
        }
        
        .chat-header h3 {
            font-size: 18px;
            font-weight: 800;
            margin: 0;
        }
        
        .chat-status {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
            opacity: 0.9;
        }
        
        .status-indicator {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: #2ecc71;
            animation: pulse 2s ease-in-out infinite;
        }
        
        .chat-close-btn {
            background: rgba(255, 255, 255, 0.2);
            border: none;
            color: white;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            transition: all 0.3s ease;
        }
        
        .chat-close-btn:hover {
            background: rgba(255, 255, 255, 0.3);
            transform: rotate(90deg);
        }
        
        .chat-messages {
            padding: 20px;
            flex: 1;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 20px;
            background: #f9fafb;
            min-height: 0;
        }
        
        .chat-message {
            display: flex;
            gap: 15px;
            animation: slideIn 0.3s ease-out;
        }
        
        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        .chat-message.user {
            flex-direction: row-reverse;
        }
        
        .message-avatar {
            width: 45px;
            height: 45px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            flex-shrink: 0;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }
        
        .message-avatar.user {
            background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
            color: white;
        }
        
        .message-avatar.ai {
            background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);
            color: white;
        }
        
        .message-content {
            flex: 1;
            max-width: 75%;
        }
        
        .message-bubble {
            padding: 15px 20px;
            border-radius: 18px;
            font-size: 15px;
            line-height: 1.6;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }
        
        .chat-message.user .message-bubble {
            background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
            color: white;
            border-bottom-right-radius: 4px;
        }
        
        .chat-message.ai .message-bubble {
            background: white;
            color: #1f2937;
            border: 2px solid #e5e7eb;
            border-bottom-left-radius: 4px;
        }
        
        .message-time {
            font-size: 12px;
            color: #9ca3af;
            margin-top: 5px;
            padding: 0 5px;
        }
        
        .chat-message.user .message-time {
            text-align: right;
        }
        
        .chat-suggestions {
            padding: 12px 20px;
            background: white;
            border-top: 2px solid #f3f4f6;
            flex-shrink: 0;
            max-height: 120px;
            overflow-y: auto;
        }
        
        .suggestions-title {
            font-size: 12px;
            font-weight: 700;
            color: #6b7280;
            margin-bottom: 10px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .suggestions-list {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }
        
        .suggestion-btn {
            padding: 8px 15px;
            background: rgba(139, 92, 246, 0.1);
            color: #8b5cf6;
            border: 2px solid rgba(139, 92, 246, 0.3);
            border-radius: 20px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        
        .suggestion-btn:hover {
            background: #8b5cf6;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(139, 92, 246, 0.3);
        }
        
        .chat-input-area {
            padding: 15px 20px;
            background: white;
            border-top: 2px solid #f3f4f6;
            flex-shrink: 0;
        }
        
        .chat-input-wrapper {
            display: flex;
            gap: 10px;
            align-items: flex-end;
        }
        
        .chat-input {
            flex: 1;
            padding: 12px 18px;
            border: 2px solid #e5e7eb;
            border-radius: 25px;
            font-size: 14px;
            font-family: 'Inter', sans-serif;
            resize: none;
            min-height: 45px;
            max-height: 100px;
            transition: all 0.3s ease;
        }
        
        .chat-input:focus {
            outline: none;
            border-color: #8b5cf6;
            box-shadow: 0 0 0 3px rgba(139, 92, 246, 0.1);
        }
        
        .chat-send-btn {
            padding: 12px 25px;
            background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);
            color: white;
            border: none;
            border-radius: 25px;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(139, 92, 246, 0.3);
            white-space: nowrap;
        }
        
        .chat-send-btn:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(139, 92, 246, 0.4);
        }
        
        .chat-send-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }
        
        .chat-loading {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 15px 20px;
            background: white;
            border: 2px solid #e5e7eb;
            border-radius: 18px;
            color: #6b7280;
            font-size: 15px;
        }
        
        .loading-dots {
            display: flex;
            gap: 5px;
        }
        
        .loading-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #8b5cf6;
            animation: bounce 1.4s ease-in-out infinite;
        }
        
        .loading-dot:nth-child(1) {
            animation-delay: 0s;
        }
        
        .loading-dot:nth-child(2) {
            animation-delay: 0.2s;
        }
        
        .loading-dot:nth-child(3) {
            animation-delay: 0.4s;
        }
        
        .chat-empty {
            text-align: center;
            padding: 60px 30px;
            color: #9ca3af;
        }
        
        .chat-empty i {
            font-size: 64px;
            margin-bottom: 20px;
            opacity: 0.3;
        }
        
        .chat-empty p {
            font-size: 16px;
            margin: 0;
        }
        
        /* Responsive */
        @media (max-width: 768px) {
            body {
                padding: 80px 10px 10px;
            }
            
            .result-header {
                padding: 40px 30px;
            }
            
            .result-title {
                font-size: 32px;
            }
            
            .score-display {
                gap: 30px;
            }
            
            .percentage-circle {
                width: 150px;
                height: 150px;
            }
            
            .percentage-inner {
                width: 120px;
                height: 120px;
            }
            
            .action-buttons {
                grid-template-columns: 1fr;
            }
            
            .ai-summary-card {
                padding: 25px 20px;
            }
            
            .ai-assistant-button {
                bottom: 20px;
                right: 20px;
                padding: 12px 20px;
            }
            
            .assistant-avatar {
                width: 40px;
                height: 40px;
                font-size: 20px;
            }
            
            .assistant-text {
                display: none;
            }
            
            .ai-tutor-chat {
                width: calc(100vw - 40px);
                right: 20px;
                bottom: 20px;
                height: 550px;
            }
            
            .message-content {
                max-width: 85%;
            }
            
            .suggestions-list {
                flex-direction: column;
            }
            
            .suggestion-btn {
                width: 100%;
                text-align: left;
            }
        }
    </style>
{% endblock %}

{% block body %}
{# === CONTENEUR PRINCIPAL DES RÉSULTATS === #}
<div class="result-container">
    {# === HEADER AVEC SCORE ET POURCENTAGE === #}
    {# Affiche l'icône de performance, le titre, le nom du quiz et les statistiques principales #}
    <div class="result-header">
        {% set pct = result.percentage ?? percentage %}
        {# Icône dynamique selon le score: trophée (80%+), pouce (60%+), graphique (40%+), livre (<40%) #}
        <div class="result-icon {% if pct >= 80 %}excellent{% elseif pct >= 60 %}good{% elseif pct >= 40 %}average{% else %}poor{% endif %}">
            {% if pct >= 80 %}
                <i class="fa fa-trophy"></i>
            {% elseif pct >= 60 %}
                <i class="fa fa-thumbs-up"></i>
            {% elseif pct >= 40 %}
                <i class="fa fa-chart-line"></i>
            {% else %}
                <i class="fa fa-book-open"></i>
            {% endif %}
        </div>
        <h1 class="result-title">Résultats du Quiz</h1>
        <p class="quiz-name">{{ quiz.titre }}</p>
        
        {# === AFFICHAGE DU SCORE === #}
        {# Trois éléments: Points obtenus, Cercle de pourcentage, Points total #}
        <div class="score-display">
            <div class="score-item">
                <div class="score-value">{{ result.score ?? score }}</div>
                <div class="score-label">Points obtenus</div>
            </div>
            
            <div class="percentage-circle" style="background: conic-gradient(
                {% if pct >= 80 %}#2ecc71{% elseif pct >= 60 %}#3498db{% elseif pct >= 40 %}#f39c12{% else %}#e74c3c{% endif %} 0% {{ pct }}%, 
                #e5e7eb {{ pct }}% 100%
            );">
                <div class="percentage-inner">
                    <div class="percentage-value" style="color: {% if pct >= 80 %}#2ecc71{% elseif pct >= 60 %}#3498db{% elseif pct >= 40 %}#f39c12{% else %}#e74c3c{% endif %};">
                        {{ pct|number_format(0) }}%
                    </div>
                    <div class="percentage-text">Réussite</div>
                </div>
            </div>
            
            <div class="score-item">
                <div class="score-value">{{ result.totalPoints ?? totalPoints }}</div>
                <div class="score-label">Points total</div>
            </div>
        </div>

        <div class="performance-badge 
            {% if pct >= 80 %}badge-excellent
            {% elseif pct >= 60 %}badge-good
            {% elseif pct >= 40 %}badge-average
            {% else %}badge-poor
            {% endif %}">
            {% if pct >= 80 %}
                🏆 Excellent travail !
            {% elseif pct >= 60 %}
                👍 Bien joué !
            {% elseif pct >= 40 %}
                💪 Peut mieux faire
            {% else %}
                📚 Continuez à réviser
            {% endif %}
        </div>
    </div>

    {# === CARTE DE RÉSUMÉ PÉDAGOGIQUE IA === #}
    {# Analyse globale générée par l'IA: points forts, points à améliorer, conseils de révision #}
    {% if resumePedagogique is defined and resumePedagogique %}
        <div class="ai-summary-card">
            <div class="ai-summary-header">
                <i class="fa fa-robot"></i>
                <h3>Analyse pédagogique par IA</h3>
            </div>
            
            <div class="ai-summary-content">
                <div class="summary-section">
                    <div class="summary-icon">💬</div>
                    <p class="summary-message">{{ resumePedagogique.message_general }}</p>
                </div>
                
                {# Section des points forts identifiés par l'IA #}
                {% if resumePedagogique.points_forts %}
                    <div class="summary-section">
                        <h4><i class="fa fa-check-circle"></i> Points forts</h4>
                        <ul class="summary-list success">
                            {% for point in resumePedagogique.points_forts %}
                                <li>{{ point }}</li>
                            {% endfor %}
                        </ul>
                    </div>
                {% endif %}
                
                {# Section des points à améliorer suggérés par l'IA #}
                {% if resumePedagogique.points_amelioration %}
                    <div class="summary-section">
                        <h4><i class="fa fa-chart-line"></i> Points à améliorer</h4>
                        <ul class="summary-list warning">
                            {% for point in resumePedagogique.points_amelioration %}
                                <li>{{ point }}</li>
                            {% endfor %}
                        </ul>
                    </div>
                {% endif %}
                
                {# Section des conseils de révision personnalisés #}
                {% if resumePedagogique.conseils_revision %}
                    <div class="summary-section">
                        <h4><i class="fa fa-lightbulb"></i> Conseils de révision</h4>
                        <ul class="summary-list info">
                            {% for conseil in resumePedagogique.conseils_revision %}
                                <li>{{ conseil }}</li>
                            {% endfor %}
                        </ul>
                    </div>
                {% endif %}
                
                <div class="summary-encouragement">
                    <i class="fa fa-heart"></i>
                    {{ resumePedagogique.encouragement }}
                </div>
            </div>
        </div>
    {% endif %}
    
    {# === SECTION DES DÉTAILS DES RÉPONSES === #}
    {# Liste toutes les questions avec les réponses de l'utilisateur et les corrections #}
    <h2 class="section-title">
        <i class="fa fa-list-alt"></i>
        Détails des réponses
    </h2>

    {# === BOUCLE SUR CHAQUE QUESTION === #}
    {% set detailsList = result.details ?? results %}
    {% for questionId, detail in detailsList %}
        {# Carte de question avec bordure verte (correct) ou rouge (incorrect) #}
        <div class="result-card {% if detail.isCorrect %}correct{% else %}incorrect{% endif %}">
            <div class="question-header">
                <span class="question-number">Question {{ loop.index }}</span>
                <span class="question-status {% if detail.isCorrect %}status-correct{% else %}status-incorrect{% endif %}">
                    {% if detail.isCorrect %}
                        <i class="fa fa-check-circle"></i> Correct
                    {% else %}
                        <i class="fa fa-times-circle"></i> Incorrect
                    {% endif %}
                </span>
            </div>

            <div class="question-text">{{ detail.question.texteQuestion }}</div>

            <div class="answers-list">
                {% for option in detail.question.options %}
                    {% set selectedId = detail.selectedOption %}
                    <div class="answer-item 
                        {% if option.id == selectedId and option.isEstCorrecte %}correct
                        {% elseif option.id == selectedId and not option.isEstCorrecte %}incorrect
                        {% elseif option.isEstCorrecte %}correct
                        {% else %}neutral
                        {% endif %}">
                        <div class="answer-icon">
                            {% if option.isEstCorrecte %}
                                ✓
                            {% elseif option.id == selectedId %}
                                ✗
                            {% else %}
                                •
                            {% endif %}
                        </div>
                        <span>{{ option.texteOption }}</span>
                        {% if option.id == selectedId %}
                            <span class="answer-label">Votre réponse</span>
                        {% elseif option.isEstCorrecte and option.id != selectedId %}
                            <span class="answer-label">Bonne réponse</span>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>

            {# === EXPLICATIONS IA PAR QUESTION === #}
            {# Affiche l'analyse détaillée de l'IA pour chaque question #}
            {% if explications is defined and explications[questionId] is defined %}
                {% set explication = explications[questionId] %}
                <div class="ai-explanation">
                    <div class="ai-explanation-header">
                        <i class="fa fa-robot"></i>
                        <span>Explication de votre professeur IA</span>
                    </div>
                    
                    <div class="ai-explanation-content">
                        {% if explication.message is defined %}
                            <p class="ai-message">{{ explication.message }}</p>
                        {% endif %}
                        
                        {% if explication.pourquoi_incorrect is defined and explication.pourquoi_incorrect %}
                            <div class="ai-detail error">
                                <strong>❌ Pourquoi c'est incorrect :</strong>
                                <p>{{ explication.pourquoi_incorrect }}</p>
                            </div>
                        {% endif %}
                        
                        {% if explication.pourquoi_correct is defined and explication.pourquoi_correct %}
                            <div class="ai-detail success">
                                <strong>✅ Explication :</strong>
                                <p>{{ explication.pourquoi_correct }}</p>
                            </div>
                        {% endif %}
                        
                        {% if explication.conseil is defined and explication.conseil %}
                            <div class="ai-detail info">
                                <strong>💡 Conseil :</strong>
                                <p>{{ explication.conseil }}</p>
                            </div>
                        {% endif %}
                        
                        {% if explication.ressources is defined and explication.ressources %}
                            <div class="ai-resources">
                                <strong>📚 Pour aller plus loin :</strong>
                                <ul>
                                    {% for ressource in explication.ressources %}
                                        <li>{{ ressource }}</li>
                                    {% endfor %}
                                </ul>
                            </div>
                        {% endif %}
                    </div>
                </div>
            {% endif %}
        </div>
    {% endfor %}

    {# === STATISTIQUES DES TENTATIVES === #}
    {# Affiche le nombre de tentatives, le meilleur score et si l'utilisateur peut recommencer #}
    {% if statistiques is defined %}
        <div class="attempts-summary">
            <h3 class="attempts-title">
                <i class="fa fa-chart-line"></i>
                Vos statistiques pour ce quiz
            </h3>
            
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-icon">
                        <i class="fa fa-play-circle"></i>
                    </div>
                    <div class="stat-content">
                        <span class="stat-number">{{ statistiques.nombreTentatives }}</span>
                        <span class="stat-label">
                            Tentative{{ statistiques.nombreTentatives > 1 ? 's' : '' }}
                            {% if statistiques.maxTentatives %}
                                / {{ statistiques.maxTentatives }}
                            {% endif %}
                        </span>
                    </div>
                </div>
                
                {% if statistiques.derniersResultats %}
                    <div class="stat-card">
                        <div class="stat-icon {{ statistiques.aReussi ? 'success' : 'warning' }}">
                            <i class="fa {{ statistiques.aReussi ? 'fa-trophy' : 'fa-target' }}"></i>
                        </div>
                        <div class="stat-content">
                            <span class="stat-number {{ statistiques.aReussi ? 'success' : 'warning' }}">
                                {{ statistiques.derniersResultats.percentage|round(1) }}%
                            </span>
                            <span class="stat-label">Meilleur score</span>
                        </div>
                    </div>
                {% endif %}
                
                <div class="stat-card">
                    <div class="stat-icon {{ statistiques.peutRecommencer ? 'info' : 'danger' }}">
                        <i class="fa {{ statistiques.peutRecommencer ? 'fa-redo' : 'fa-ban' }}"></i>
                    </div>
                    <div class="stat-content">
                        <span class="stat-number {{ statistiques.peutRecommencer ? 'info' : 'danger' }}">
                            {{ statistiques.peutRecommencer ? 'OUI' : 'NON' }}
                        </span>
                        <span class="stat-label">Peut recommencer</span>
                    </div>
                </div>
            </div>
            
            {% if statistiques.aReussi %}
                <div class="success-message">
                    <i class="fa fa-check-circle"></i>
                    <span>Félicitations ! Vous avez réussi ce quiz avec {{ statistiques.derniersResultats.percentage|round(1) }}% (seuil: {{ statistiques.seuilReussite }}%)</span>
                </div>
            {% endif %}
        </div>
    {% endif %}

    {# === BOUTONS D'ACTION === #}
    {# Trois boutons: Refaire le quiz, Autres quiz, Retour aux chapitres #}
    <div class="action-buttons">
        <a href="{{ path('app_quiz_start', {'id': quiz.id}) }}" class="btn-action btn-retry">
            <i class="fa fa-redo"></i>
            Refaire le quiz
        </a>
        <a href="{{ path('app_frontoffice_quiz_list', {'chapitreId': chapitre.id ?? chapitreId}) }}" class="btn-action btn-back">
            <i class="fa fa-arrow-left"></i>
            Autres quiz
        </a>
        <a href="{{ path('app_chapitre_index_front') }}" class="btn-action btn-home">
            <i class="fa fa-home"></i>
            Retour aux chapitres
        </a>
    </div>
</div>

{# === BOUTON FLOTTANT DU CHAT IA === #}
{# Bouton animé en bas à droite pour ouvrir le chat avec le tuteur IA #}
<div class="ai-assistant-button" id="aiAssistantBtn">
    <div class="assistant-avatar">
        <i class="fa fa-robot"></i>
    </div>
    <div class="assistant-text">
        <span class="assistant-greeting">Besoin d'aide ?</span>
        <span class="assistant-cta">Cliquez ici 👉</span>
    </div>
    <div class="pulse-ring"></div>
</div>

{# === FENÊTRE DE CHAT AVEC LE TUTEUR IA === #}
{# Interface conversationnelle pour poser des questions sur le quiz #}
{# Comprend: header, zone de messages, suggestions, zone de saisie #}
<div class="ai-tutor-chat" id="aiTutorChat" style="display: none;">
    <div class="chat-header">
        <div class="chat-header-left">
            <i class="fa fa-robot"></i>
            <div>
                <h3>Posez vos questions au professeur IA</h3>
                <div class="chat-status">
                    <span class="status-indicator"></span>
                    <span>En ligne</span>
                </div>
            </div>
        </div>
        <button class="chat-close-btn" id="closeChatBtn">
            <i class="fa fa-times"></i>
        </button>
    </div>
    
    {# === ZONE DE MESSAGES DU CHAT === #}
    {# Affiche la conversation entre l'utilisateur et l'IA #}
    <div class="chat-messages" id="chatMessages">
        <div class="chat-empty">
            <i class="fa fa-comments"></i>
            <p>Posez une question sur le quiz ou cliquez sur une suggestion ci-dessous</p>
        </div>
    </div>
    
    {# === SUGGESTIONS DE QUESTIONS === #}
    {# Questions prédéfinies pour faciliter l'interaction avec l'IA #}
    <div class="chat-suggestions">
        <div class="suggestions-title">💡 Suggestions de questions</div>
        <div class="suggestions-list" id="suggestionsList">
            <button class="suggestion-btn" data-question="Pourquoi ma réponse est incorrecte ?">
                Pourquoi ma réponse est incorrecte ?
            </button>
            <button class="suggestion-btn" data-question="Peux-tu m'expliquer ce concept ?">
                Peux-tu m'expliquer ce concept ?
            </button>
            <button class="suggestion-btn" data-question="Comment puis-je améliorer ma compréhension ?">
                Comment puis-je améliorer ma compréhension ?
            </button>
        </div>
    </div>
    
    {# === ZONE DE SAISIE === #}
    {# Textarea avec auto-resize et bouton d'envoi #}
    <div class="chat-input-area">
        <div class="chat-input-wrapper">
            <textarea 
                class="chat-input" 
                id="chatInput" 
                placeholder="Posez votre question ici..."
                rows="1"
            ></textarea>
            <button class="chat-send-btn" id="sendBtn">
                <i class="fa fa-paper-plane"></i>
                Envoyer
            </button>
        </div>
    </div>
</div>

{# === JAVASCRIPT DU CHAT IA === #}
{# Gère l'ouverture/fermeture du chat, l'envoi de messages, les animations #}
<script>
document.addEventListener('DOMContentLoaded', function() {
    // === INITIALISATION DES ÉLÉMENTS DOM === //
    const chatMessages = document.getElementById('chatMessages');
    const chatInput = document.getElementById('chatInput');
    const sendBtn = document.getElementById('sendBtn');
    const suggestionsList = document.getElementById('suggestionsList');
    const aiAssistantBtn = document.getElementById('aiAssistantBtn');
    const aiTutorChat = document.getElementById('aiTutorChat');
    const closeChatBtn = document.getElementById('closeChatBtn');
    const quizId = {{ quiz.id }};
    
    let isLoading = false;
    
    // === GESTION DE L'OUVERTURE/FERMETURE DU CHAT === //
    // Ouvrir le chat au clic sur le bouton flottant
    aiAssistantBtn.addEventListener('click', function() {
        aiTutorChat.style.display = 'flex';
        aiTutorChat.classList.add('show');
        aiAssistantBtn.classList.add('hidden');
    });
    
    // Fermer le chat
    closeChatBtn.addEventListener('click', function() {
        aiTutorChat.style.display = 'none';
        aiTutorChat.classList.remove('show');
        aiAssistantBtn.classList.remove('hidden');
    });
    
    // === CHARGEMENT DES SUGGESTIONS === //
    // Récupère les suggestions de questions depuis l'API
    loadSuggestions();
    
    // Auto-resize textarea
    chatInput.addEventListener('input', function() {
        this.style.height = 'auto';
        this.style.height = (this.scrollHeight) + 'px';
    });
    
    // Envoyer avec Enter (Shift+Enter pour nouvelle ligne)
    chatInput.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            sendMessage();
        }
    });
    
    // Bouton envoyer
    sendBtn.addEventListener('click', sendMessage);
    
    // Suggestions cliquables
    suggestionsList.addEventListener('click', function(e) {
        if (e.target.classList.contains('suggestion-btn')) {
            const question = e.target.dataset.question;
            chatInput.value = question;
            sendMessage();
        }
    });
    
    function loadSuggestions() {
        fetch(`/quiz/tutor/${quizId}/suggestions`)
            .then(response => response.json())
            .then(data => {
                if (data.success && data.suggestions) {
                    suggestionsList.innerHTML = '';
                    data.suggestions.forEach(suggestion => {
                        const btn = document.createElement('button');
                        btn.className = 'suggestion-btn';
                        btn.dataset.question = suggestion;
                        btn.textContent = suggestion;
                        suggestionsList.appendChild(btn);
                    });
                }
            })
            .catch(error => console.error('Erreur chargement suggestions:', error));
    }
    
    // === FONCTION D'ENVOI DE MESSAGE === //
    // Envoie la question à l'API et affiche la réponse
    function sendMessage() {
        const question = chatInput.value.trim();
        
        if (!question || isLoading) return;
        
        // Supprimer le message vide si présent
        const emptyMsg = chatMessages.querySelector('.chat-empty');
        if (emptyMsg) {
            emptyMsg.remove();
        }
        
        // Afficher le message de l'utilisateur
        addMessage(question, 'user');
        
        // Vider l'input
        chatInput.value = '';
        chatInput.style.height = 'auto';
        
        // Afficher le loading
        showLoading();
        
        // Désactiver l'envoi
        isLoading = true;
        sendBtn.disabled = true;
        
        // Envoyer la requête
        fetch(`/quiz/tutor/${quizId}/ask`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({ question: question })
        })
        .then(response => response.json())
        .then(data => {
            hideLoading();
            
            if (data.success) {
                addMessage(data.reponse, 'ai');
            } else {
                addMessage('Désolé, je ne peux pas répondre pour le moment. ' + (data.error || ''), 'ai');
            }
        })
        .catch(error => {
            hideLoading();
            addMessage('Une erreur est survenue. Veuillez réessayer.', 'ai');
            console.error('Erreur:', error);
        })
        .finally(() => {
            isLoading = false;
            sendBtn.disabled = false;
        });
    }
    
    // === FONCTION D'AFFICHAGE DE MESSAGE === //
    // Crée et affiche un message dans le chat (utilisateur ou IA)
    function addMessage(text, type) {
        const messageDiv = document.createElement('div');
        messageDiv.className = `chat-message ${type}`;
        
        const avatar = document.createElement('div');
        avatar.className = `message-avatar ${type}`;
        avatar.innerHTML = type === 'user' ? '<i class="fa fa-user"></i>' : '<i class="fa fa-robot"></i>';
        
        const content = document.createElement('div');
        content.className = 'message-content';
        
        const bubble = document.createElement('div');
        bubble.className = 'message-bubble';
        bubble.textContent = text;
        
        const time = document.createElement('div');
        time.className = 'message-time';
        time.textContent = new Date().toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
        
        content.appendChild(bubble);
        content.appendChild(time);
        messageDiv.appendChild(avatar);
        messageDiv.appendChild(content);
        
        chatMessages.appendChild(messageDiv);
        chatMessages.scrollTop = chatMessages.scrollHeight;
    }
    
    function showLoading() {
        const loadingDiv = document.createElement('div');
        loadingDiv.className = 'chat-message ai';
        loadingDiv.id = 'loadingMessage';
        
        const avatar = document.createElement('div');
        avatar.className = 'message-avatar ai';
        avatar.innerHTML = '<i class="fa fa-robot"></i>';
        
        const content = document.createElement('div');
        content.className = 'message-content';
        
        const loading = document.createElement('div');
        loading.className = 'chat-loading';
        loading.innerHTML = `
            <span>Le professeur réfléchit</span>
            <div class="loading-dots">
                <div class="loading-dot"></div>
                <div class="loading-dot"></div>
                <div class="loading-dot"></div>
            </div>
        `;
        
        content.appendChild(loading);
        loadingDiv.appendChild(avatar);
        loadingDiv.appendChild(content);
        
        chatMessages.appendChild(loadingDiv);
        chatMessages.scrollTop = chatMessages.scrollHeight;
    }
    
    function hideLoading() {
        const loading = document.getElementById('loadingMessage');
        if (loading) {
            loading.remove();
        }
    }
});
</script>
{% endblock %}
