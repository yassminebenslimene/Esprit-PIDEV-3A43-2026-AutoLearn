            margin: 0;
            padding-left: 20px;
        }
        
        .ai-resources li {
            color: #4b5563;
            margin-bottom: 5px;
        }
        
        /* Styles pour le bouton flottant animé de l'assistant IA */
        .ai-assistant-button {
            position: fixed;
            bottom: 30px;
            right: 30px;
            display: flex;
            align-items: center;
            gap: 15px;
            background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);
            color: white;
            padding: 15px 25px;
            border-radius: 50px;
            cursor: pointer;
            box-shadow: 0 10px 30px rgba(139, 92, 246, 0.4);
            z-index: 1000;
            transition: all 0.3s ease;
            animation: slideInRight 0.8s ease-out, float 3s ease-in-out infinite;
        }
        
        @keyframes slideInRight {
            from {
                opacity: 0;
                transform: translateX(100px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }
        
        @keyframes float {
            0%, 100% {
                transform: translateY(0px);
            }
            50% {
                transform: translateY(-10px);
            }
        }
        
        .ai-assistant-button:hover {
            transform: translateY(-5px) scale(1.05);
            box-shadow: 0 15px 40px rgba(139, 92, 246, 0.5);
        }
        
        .assistant-avatar {
            width: 50px;
            height: 50px;
            background: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            color: #8b5cf6;
            animation: bounce 2s ease-in-out infinite;
        }
        
        @keyframes bounce {
            0%, 20%, 50%, 80%, 100% {
                transform: translateY(0);
            }
            40% {
                transform: translateY(-10px);
            }
            60% {
                transform: translateY(-5px);
            }
        }
        
        .assistant-text {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }
        
        .assistant-greeting {
            font-size: 16px;
            font-weight: 700;
        }
        
        .assistant-cta {
            font-size: 14px;
            opacity: 0.9;
            animation: pulse 2s ease-in-out infinite;
        }
        
        @keyframes pulse {
            0%, 100% {
                opacity: 0.9;
            }
            50% {
                opacity: 1;
                transform: scale(1.05);
            }
        }
        
        .pulse-ring {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 100%;
            height: 100%;
            border: 3px solid rgba(139, 92, 246, 0.6);
            border-radius: 50px;
            animation: pulseRing 2s ease-out infinite;
        }
        
        @keyframes pulseRing {
            0% {
                transform: translate(-50%, -50%) scale(1);
                opacity: 1;
            }
            100% {
                transform: translate(-50%, -50%) scale(1.3);
                opacity: 0;
            }
        }
        
        .ai-assistant-button.hidden {
            display: none;
        }
        
        /* Styles pour le bouton de fermeture du chat */
        .chat-close-btn {
            background: rgba(255, 255, 255, 0.2);
            border: none;
            color: white;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            transition: all 0.3s ease;
        }
        
        .chat-close-btn:hover {
            background: rgba(255, 255, 255, 0.3);
