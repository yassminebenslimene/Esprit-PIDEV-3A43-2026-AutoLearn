<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    {# Titre dynamique avec le nom du chapitre #}
    <title>Quiz - {{ chapitre.titre }}</title>

    {# Importation des styles Bootstrap et FontAwesome #}
    <link rel="stylesheet" href="{{ asset('frontoffice/vendor/bootstrap/css/bootstrap.min.css') }}">
    <link rel="stylesheet" href="{{ asset('frontoffice/css/fontawesome.css') }}">
    {# Police Inter pour un design moderne #}
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        /* === STYLES GÉNÉRAUX === */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        /* Fond violet avec motif diagonal */
        body {
            font-family: 'Inter', sans-serif;
            background: #46178f;
            background-image: 
                repeating-linear-gradient(45deg, transparent, transparent 35px, rgba(255,255,255,.05) 35px, rgba(255,255,255,.05) 70px);
            min-height: 100vh;
            overflow-x: hidden;
            padding: 0;
        }
        
        /* === HEADER AVEC BOUTON RETOUR === */
        /* Barre supérieure avec effet de flou */
        .quiz-list-header {
            background: rgba(0, 0, 0, 0.3);
            padding: 20px 40px;
            backdrop-filter: blur(10px);
        }
        
        /* Lien de retour avec icône et effet hover */
        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            color: white;
            text-decoration: none;
            padding: 12px 25px;
            background: rgba(255, 255, 255, 0.2);
            border-radius: 50px;
            transition: all 0.3s ease;
            font-weight: 600;
            font-size: 16px;
        }
        
        /* Animation de déplacement au hover */
        .back-link:hover {
            background: rgba(255, 255, 255, 0.3);
            color: white;
            transform: translateX(-5px);
        }
        
        /* === CONTENEUR PRINCIPAL === */
        /* Conteneur centré avec padding */
        .quiz-list-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 40px 20px;
        }
        
        /* === GRILLE DE QUIZ === */
        /* Grille responsive avec cartes de quiz style Kahoot */
        .quiz-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
            gap: 30px;
            margin-bottom: 30px;
        }
        
        /* === CARTE DE QUIZ === */
        /* Carte blanche avec ombre et animations */
        .quiz-card {
            background: white;
            border-radius: 20px;
            padding: 35px;
            box-shadow: 0 8px 25px rgba(0,0,0,0.2);
            transition: all 0.4s ease;
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            animation: fadeInUp 0.6s ease-out;
            animation-fill-mode: both;
        }
        
        /* Barre colorée style Kahoot en haut de chaque carte */
        .quiz-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 6px;
            background: linear-gradient(90deg, #e74c3c 0%, #3498db 25%, #f39c12 50%, #2ecc71 75%, #e74c3c 100%);
        }
        
        /* Effet de levée et agrandissement au hover */
        .quiz-card:hover {
            transform: translateY(-10px) scale(1.02);
            box-shadow: 0 15px 45px rgba(0,0,0,0.3);
        }
        
        /* Délais d'animation pour effet cascade sur les cartes */
        {% for i in 1..20 %}
        .quiz-card:nth-child({{ i }}) {
            animation-delay: {{ i * 0.1 }}s;
        }
        {% endfor %}
        
        /* Animation de montée avec fondu */
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(40px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        /* === ICÔNE DU QUIZ === */
        /* Icône colorée en haut de chaque carte */
        .quiz-icon {
            font-size: 56px;
            margin-bottom: 20px;
            text-align: center;
            width: 80px;
            height: 80px;
            margin: 0 auto 20px;
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            box-shadow: 0 5px 20px rgba(0,0,0,0.3);
        }
        
        .quiz-icon i {
            font-size: 40px;
        }
        
        /* Couleurs variées pour les icônes (rotation de 4 couleurs) */
        .quiz-card:nth-child(4n+1) .quiz-icon {
            background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
        }
        
        .quiz-card:nth-child(4n+2) .quiz-icon {
            background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
        }
        
        .quiz-card:nth-child(4n+3) .quiz-icon {
            background: linear-gradient(135deg, #f39c12 0%, #e67e22 100%);
        }
        
        .quiz-card:nth-child(4n+4) .quiz-icon {
            background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
        }
        
        /* Titre du quiz en gras et centré */
        .quiz-title {
            font-size: 26px;
            font-weight: 800;
            color: #1f2937;
            margin-bottom: 15px;
            line-height: 1.3;
            text-align: center;
        }
        
        /* Description du quiz avec flex-grow pour pousser le contenu en bas */
        .quiz-description {
            color: #6b7280;
            margin-bottom: 25px;
            line-height: 1.6;
            flex-grow: 1;
            text-align: center;
            font-size: 15px;
        }
        
        /* === MÉTADONNÉES DU QUIZ === */
        /* Affiche nombre de questions, points et durée */
        .quiz-meta {
            display: flex;
            justify-content: center;
            gap: 25px;
            margin-bottom: 25px;
            padding: 20px;
            background: rgba(70, 23, 143, 0.05);
            border-radius: 15px;
        }
        
        /* Chaque élément de métadonnée (icône + valeur + label) */
        .meta-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 5px;
        }
        
        /* Icône circulaire colorée pour chaque métadonnée */
        .meta-icon {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            color: white;
        }
        
        /* Couleurs différentes pour chaque type de métadonnée */
        .meta-item:nth-child(1) .meta-icon {
            background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
        }
        
        .meta-item:nth-child(2) .meta-icon {
            background: linear-gradient(135deg, #f39c12 0%, #e67e22 100%);
        }
        
        .meta-item:nth-child(3) .meta-icon {
            background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
        }
        
        /* Valeur numérique en gros et gras */
        .meta-value {
            font-size: 18px;
            font-weight: 800;
            color: #1f2937;
        }
        
        .meta-label {
            font-size: 12px;
            color: #6b7280;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        /* === BOUTON DÉMARRER === */
        /* Bouton vert style Kahoot pour commencer le quiz */
        .btn-start-quiz {
            background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
            color: white;
            padding: 18px 30px;
            border-radius: 50px;
            text-decoration: none;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            transition: all 0.3s ease;
            font-weight: 800;
            font-size: 18px;
            box-shadow: 0 6px 20px rgba(46, 204, 113, 0.4);
            border: none;
        }
        
        /* Effet de levée au hover */
        .btn-start-quiz:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 30px rgba(46, 204, 113, 0.6);
            color: white;
        }
        
        /* Bouton orange pour nouvelle tentative */
        .btn-start-quiz.retry {
            background: linear-gradient(135deg, #f39c12 0%, #e67e22 100%);
            box-shadow: 0 6px 20px rgba(243, 156, 18, 0.4);
        }
        
        .btn-start-quiz.retry:hover {
            box-shadow: 0 10px 30px rgba(243, 156, 18, 0.6);
        }
        
        /* Bouton bleu pour quiz déjà réussi */
        .btn-start-quiz.success {
            background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
            box-shadow: 0 6px 20px rgba(52, 152, 219, 0.4);
        }
        
        .btn-start-quiz.success:hover {
            box-shadow: 0 10px 30px rgba(52, 152, 219, 0.6);
        }
        
        /* Bouton gris désactivé pour tentatives épuisées */
        .btn-start-quiz.disabled {
            background: linear-gradient(135deg, #95a5a6 0%, #7f8c8d 100%);
            box-shadow: 0 6px 20px rgba(149, 165, 166, 0.4);
            cursor: not-allowed;
            opacity: 0.7;
        }
        
        .btn-start-quiz.disabled:hover {
            transform: none;
            box-shadow: 0 6px 20px rgba(149, 165, 166, 0.4);
        }
        
        /* === INFORMATIONS SUR LES TENTATIVES === */
        /* Carte affichant l'historique des tentatives de l'utilisateur */
        .quiz-attempts-info {
            background: rgba(70, 23, 143, 0.05);
            border-radius: 15px;
            padding: 20px;
            margin-bottom: 20px;
            border-left: 4px solid #46178f;
        }
        
        /* En-tête de la section tentatives */
        .attempts-header {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 15px;
            font-weight: 700;
            color: #46178f;
            font-size: 16px;
        }
        
        /* Statistiques des tentatives (nombre et score) */
        .attempts-stats {
            display: flex;
            justify-content: space-around;
            gap: 15px;
            margin-bottom: 15px;
        }
        
        /* Chaque statistique individuelle */
        .stat-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 5px;
        }
        
        /* Valeur de la statistique en gros */
        .stat-value {
            font-size: 24px;
            font-weight: 800;
            color: #1f2937;
        }
        
        /* Couleurs selon le résultat */
        .stat-value.success {
            color: #2ecc71;
        }
        
        .stat-value.failed {
            color: #e74c3c;
        }
        
        /* Label de la statistique en petit */
        .stat-label {
            font-size: 12px;
            color: #6b7280;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            text-align: center;
        }
        
        /* Badge vert "Quiz réussi !" */
        .success-badge {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
            color: white;
            padding: 10px 20px;
            border-radius: 25px;
            font-weight: 700;
            font-size: 14px;
            box-shadow: 0 4px 15px rgba(46, 204, 113, 0.3);
        }
        
        /* === ÉTAT VIDE === */
        /* Affiché quand aucun quiz n'est disponible */
        .empty-state {
            background: white;
            border-radius: 20px;
            padding: 80px 40px;
            text-align: center;
            box-shadow: 0 10px 40px rgba(0,0,0,0.2);
            animation: fadeInUp 0.6s ease-out;
        }
        
        /* Icône grise pour l'état vide */
        .empty-state-icon {
            font-size: 100px;
            margin-bottom: 25px;
            opacity: 0.6;
            width: 120px;
            height: 120px;
            margin: 0 auto 25px;
            background: linear-gradient(135deg, #e5e7eb 0%, #d1d5db 100%);
            border-radius: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #6b7280;
        }
        
        .empty-state-icon i {
            font-size: 60px;
        }
        
        /* Titre de l'état vide */
        .empty-state-title {
            font-size: 32px;
            font-weight: 800;
            color: #1f2937;
            margin-bottom: 15px;
        }
        
        /* Texte explicatif de l'état vide */
        .empty-state-text {
            font-size: 18px;
            color: #6b7280;
            line-height: 1.8;
        }
        
        /* === MESSAGES FLASH === */
        /* Messages de succès, erreur ou avertissement */
        .flash-message {
            background: white;
            padding: 20px 30px;
            border-radius: 15px;
            margin-bottom: 25px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.2);
            display: flex;
            align-items: center;
            gap: 15px;
            animation: slideDown 0.5s ease-out;
        }
        
        /* Types de messages avec bordures colorées */
        .flash-message.error {
            border-left: 6px solid #ef4444;
            background: #fef2f2;
        }
        
        .flash-message.warning {
            border-left: 6px solid #f59e0b;
            background: #fffbeb;
        }
        
        .flash-message.success {
            border-left: 6px solid #10b981;
            background: #f0fdf4;
        }
        
        /* Icônes colorées selon le type de message */
        .flash-message i {
            font-size: 28px;
        }
        
        .flash-message.error i {
            color: #ef4444;
        }
        
        .flash-message.warning i {
            color: #f59e0b;
        }
        
        .flash-message.success i {
            color: #10b981;
        }
        
        /* Texte du message flash */
        .flash-message-text {
            flex: 1;
            font-size: 16px;
            font-weight: 600;
            color: #1f2937;
        }
        
        /* === RESPONSIVE === */
        /* Adaptations pour mobile et tablette */
        @media (max-width: 768px) {
            .quiz-list-header {
                padding: 15px 20px;
            }
            
            .page-header {
                padding: 40px 30px;
            }
            
            .page-title {
                font-size: 32px;
            }
            
            .quiz-grid {
                grid-template-columns: 1fr;
            }
            
            .quiz-meta {
                flex-direction: column;
                gap: 15px;
            }
        }
    </style>
</head>
<body>
    {# === HEADER AVEC BOUTON RETOUR === #}
    <div class="quiz-list-header">
        {# Lien pour retourner à la liste des chapitres #}
        <a href="{{ path('app_chapitre_index_front') }}" class="back-link">
            <i class="fa fa-arrow-left"></i>
            <span>Retour aux chapitres</span>
        </a>
    </div>

    {# === CONTENEUR PRINCIPAL === #}
    <div class="quiz-list-container">
        {# === MESSAGES FLASH === #}
        {# Affiche les messages de succès, erreur ou avertissement #}
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="flash-message {{ type }}">
                    <i class="fa 
                        {% if type == 'error' %}fa-exclamation-circle
                        {% elseif type == 'warning' %}fa-exclamation-triangle
                        {% elseif type == 'success' %}fa-check-circle
                        {% else %}fa-info-circle
                        {% endif %}"></i>
                    <span class="flash-message-text">{{ message }}</span>
                </div>
            {% endfor %}
        {% endfor %}

        {# === VÉRIFICATION SI AUCUN QUIZ === #}
        {% if quizzes is empty %}
            {# État vide avec icône et message #}
            <div class="empty-state">
                <div class="empty-state-icon">
                    <i class="fa fa-inbox"></i>
                </div>
                <h3 class="empty-state-title">Aucun quiz disponible</h3>
                <p class="empty-state-text">
                    Il n'y a pas encore de quiz actif pour ce chapitre.<br>
                    Revenez plus tard pour tester vos connaissances !
                </p>
            </div>
        {% else %}
            {# === GRILLE DES QUIZ === #}
            {# Affiche tous les quiz disponibles pour ce chapitre #}
            <div class="quiz-grid">
                {# === BOUCLE SUR CHAQUE QUIZ === #}
                {% for quiz in quizzes %}
                    <div class="quiz-card">
                        {# === ICÔNE DU QUIZ === #}
                        {# Rotation de 8 icônes différentes #}
                        <div class="quiz-icon">
                            {% set iconIndex = loop.index % 8 %}
                            {% if iconIndex == 1 %}
                                <i class="fa fa-brain"></i>
                            {% elseif iconIndex == 2 %}
                                <i class="fa fa-lightbulb"></i>
                            {% elseif iconIndex == 3 %}
                                <i class="fa fa-graduation-cap"></i>
                            {% elseif iconIndex == 4 %}
                                <i class="fa fa-book"></i>
                            {% elseif iconIndex == 5 %}
                                <i class="fa fa-pencil-alt"></i>
                            {% elseif iconIndex == 6 %}
                                <i class="fa fa-certificate"></i>
                            {% elseif iconIndex == 7 %}
                                <i class="fa fa-award"></i>
                            {% else %}
                                <i class="fa fa-star"></i>
                            {% endif %}
                        </div>
                        {# Titre et description du quiz #}
                        <h2 class="quiz-title">{{ quiz.titre }}</h2>
                        <p class="quiz-description">{{ quiz.description }}</p>
                        
                        {# === MÉTADONNÉES === #}
                        {# Nombre de questions, points total et durée #}
                        <div class="quiz-meta">
                            <div class="meta-item">
                                <div class="meta-icon">
                                    <i class="fa fa-question-circle"></i>
                                </div>
                                <span class="meta-value">{{ quiz.questions|length }}</span>
                                <span class="meta-label">Questions</span>
                            </div>
                            <div class="meta-item">
                                <div class="meta-icon">
                                    <i class="fa fa-star"></i>
                                </div>
                                <span class="meta-value">
                                    {% set totalPoints = 0 %}
                                    {% for question in quiz.questions %}
                                        {% set totalPoints = totalPoints + question.point %}
                                    {% endfor %}
                                    {{ totalPoints }}
                                </span>
                                <span class="meta-label">Points</span>
                            </div>
                            {% if quiz.dureeMaxMinutes %}
                            <div class="meta-item">
                                <div class="meta-icon">
                                    <i class="fa fa-clock"></i>
                                </div>
                                <span class="meta-value">{{ quiz.dureeMaxMinutes }}</span>
                                <span class="meta-label">Minutes</span>
                            </div>
                            {% endif %}
                        </div>
                        
                        {# === STATISTIQUES DES TENTATIVES === #}
                        {# Affiche l'historique si l'utilisateur a déjà passé le quiz #}
                        {% if quizStatistiques[quiz.id] is defined %}
                            {% set stats = quizStatistiques[quiz.id] %}
                            
                            {% if stats.nombreTentatives > 0 %}
                                <div class="quiz-attempts-info">
                                    <div class="attempts-header">
                                        <i class="fa fa-history"></i>
                                        <span>Vos tentatives</span>
                                    </div>
                                    
                                    <div class="attempts-stats">
                                        <div class="stat-item">
                                            <span class="stat-value">{{ stats.nombreTentatives }}</span>
                                            <span class="stat-label">
                                                {% if stats.maxTentatives %}
                                                    / {{ stats.maxTentatives }}
                                                {% endif %}
                                                tentative{{ stats.nombreTentatives > 1 ? 's' : '' }}
                                            </span>
                                        </div>
                                        
                                        {% if stats.derniersResultats %}
                                            <div class="stat-item">
                                                <span class="stat-value {{ stats.aReussi ? 'success' : 'failed' }}">
                                                    {{ stats.derniersResultats.percentage|round(1) }}%
                                                </span>
                                                <span class="stat-label">dernier score</span>
                                            </div>
                                        {% endif %}
                                    </div>
                                    
                                    {% if stats.aReussi %}
                                        <div class="success-badge">
                                            <i class="fa fa-check-circle"></i>
                                            <span>Quiz réussi !</span>
                                        </div>
                                    {% endif %}
                                </div>
                            {% endif %}
                        {% endif %}
                        
                        {# === BOUTON D'ACTION === #}
                        {# Bouton adapté selon l'état: désactivé, nouvelle tentative, refaire, ou commencer #}
                        {% if quizStatistiques[quiz.id] is defined %}
                            {% set stats = quizStatistiques[quiz.id] %}
                            
                            {% if not stats.peutRecommencer %}
                                <button class="btn-start-quiz disabled" disabled>
                                    <i class="fa fa-ban"></i>
                                    <span>
                                        {% if stats.nombreTentatives >= stats.maxTentatives %}
                                            Tentatives épuisées ({{ stats.nombreTentatives }}/{{ stats.maxTentatives }})
                                        {% else %}
                                            Quiz non disponible
                                        {% endif %}
                                    </span>
                                </button>
                            {% elseif stats.aReussi %}
                                <a href="{{ path('app_quiz_start', {'id': quiz.id}) }}" class="btn-start-quiz success">
                                    <i class="fa fa-redo"></i>
                                    <span>Refaire le quiz</span>
                                </a>
                            {% elseif stats.nombreTentatives > 0 %}
                                <a href="{{ path('app_quiz_start', {'id': quiz.id}) }}" class="btn-start-quiz retry">
                                    <i class="fa fa-redo"></i>
                                    <span>Nouvelle tentative</span>
                                </a>
                            {% else %}
                                <a href="{{ path('app_quiz_start', {'id': quiz.id}) }}" class="btn-start-quiz">
                                    <i class="fa fa-play-circle"></i>
                                    <span>Commencer le quiz</span>
                                </a>
                            {% endif %}
                        {% else %}
                            <a href="{{ path('app_quiz_start', {'id': quiz.id}) }}" class="btn-start-quiz">
                                <i class="fa fa-play-circle"></i>
                                <span>Commencer le quiz</span>
                            </a>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>

    {# === JAVASCRIPT === #}
    {# Système de sons pour les interactions #}
    <script src="{{ asset('frontoffice/vendor/jquery/jquery.min.js') }}"></script>
    <script>
        // Initialisation du contexte audio pour les sons
        const AudioContext = window.AudioContext || window.webkitAudioContext;
        const audioCtx = new AudioContext();

        // Son de démarrage du quiz (montée joyeuse en 3 notes)
        function playStartQuizSound() {
            const oscillator = audioCtx.createOscillator();
            const gainNode = audioCtx.createGain();
            
            oscillator.connect(gainNode);
            gainNode.connect(audioCtx.destination);
            
            oscillator.frequency.setValueAtTime(523.25, audioCtx.currentTime); // C5
            oscillator.frequency.setValueAtTime(659.25, audioCtx.currentTime + 0.1); // E5
            oscillator.frequency.setValueAtTime(783.99, audioCtx.currentTime + 0.2); // G5
            
            oscillator.type = 'sine';
            gainNode.gain.setValueAtTime(0.3, audioCtx.currentTime);
            gainNode.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.4);
            
            oscillator.start(audioCtx.currentTime);
            oscillator.stop(audioCtx.currentTime + 0.4);
        }

        // Son subtil au survol des cartes et boutons
        function playHoverSound() {
            const oscillator = audioCtx.createOscillator();
            const gainNode = audioCtx.createGain();
            
            oscillator.connect(gainNode);
            gainNode.connect(audioCtx.destination);
            
            oscillator.frequency.setValueAtTime(600, audioCtx.currentTime);
            oscillator.type = 'sine';
            
            gainNode.gain.setValueAtTime(0.1, audioCtx.currentTime);
            gainNode.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.08);
            
            oscillator.start(audioCtx.currentTime);
            oscillator.stop(audioCtx.currentTime + 0.08);
        }

        // Ajouter les sons aux boutons "Commencer le quiz"
        document.querySelectorAll('.btn-start-quiz').forEach(btn => {
            // Son au clic
            btn.addEventListener('click', function(e) {
                playStartQuizSound();
            });
            
            // Son au survol
            btn.addEventListener('mouseenter', function() {
                playHoverSound();
            });
        });

        // Ajouter son au survol des cartes de quiz
        document.querySelectorAll('.quiz-card').forEach(card => {
            card.addEventListener('mouseenter', function() {
                playHoverSound();
            });
        });
    </script>
</body>
</html>
