{% extends 'frontoffice/equipe/new.html.twig' %}

{% block title %}Edit Team{% endblock %}

{% block body %}
<div class="form-section">
    <div class="container">
        <div class="form-container">
            <div class="form-header">
                <h1>Edit Team</h1>
                <p>Modify your team information</p>
            </div>

            {{ form_start(form) }}
            
            <div class="form-group">
                {{ form_label(form.nom, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.nom) }}
                {{ form_errors(form.nom) }}
            </div>

            <div class="form-group">
                {{ form_label(form.evenement, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.evenement) }}
                {{ form_errors(form.evenement) }}
                <div class="form-help">
                    <span class="help-icon">ℹ️</span>
                    <span>Select the event your team will participate in</span>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">
                    {{ form.etudiants.vars.label }}
                    <span class="selected-count" id="selected-count">0 selected</span>
                </label>
                
                <div class="selection-tip">
                    <strong>💡 How to select students:</strong>
                    <p>• Hold <kbd>Ctrl</kbd> (Windows) or <kbd>Cmd</kbd> (Mac) and click to select multiple students</p>
                    <p>• You must select between 4 and 6 students</p>
                    <p>• Click on a selected student again to deselect</p>
                </div>
                
                {{ form_widget(form.etudiants, {'attr': {'class': 'form-control form-select-multiple', 'id': 'student-select'}}) }}
                {{ form_errors(form.etudiants) }}
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    ✓ Save Changes
                </button>
                <a href="{{ path('app_mes_equipes') }}" class="btn btn-secondary">
                    ✗ Cancel
                </a>
            </div>

            {{ form_end(form) }}
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const select = document.getElementById('student-select');
        const counter = document.getElementById('selected-count');
        
        if (select && counter) {
            function updateCount() {
                const selected = Array.from(select.selectedOptions).length;
                counter.textContent = selected + ' selected';
                
                if (selected >= 4 && selected <= 6) {
                    counter.style.background = '#48bb78';
                } else if (selected > 0) {
                    counter.style.background = '#ed8936';
                } else {
                    counter.style.background = '#667eea';
                }
            }
            
            select.addEventListener('change', updateCount);
            updateCount();
        }
    });
</script>
{% endblock %}
