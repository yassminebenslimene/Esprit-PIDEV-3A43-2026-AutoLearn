{% extends 'frontoffice/base.html.twig' %}

{% block title %}Modifier l'équipe{% endblock %}

{% block body %}
<div class="container" style="margin-top: 120px; margin-bottom: 80px;">
    <div class="row">
        <div class="col-lg-8 offset-lg-2">
            <div class="section-heading text-center">
                <h2>Modifier l'équipe</h2>
                <p>Modifiez les informations de votre équipe</p>
            </div>

            <div class="contact-us" style="background: white; padding: 40px; border-radius: 10px; box-shadow: 0 0 20px rgba(0,0,0,0.1);">
                {{ form_start(form) }}
                
                <div class="row">
                    <div class="col-lg-12">
                        <fieldset>
                            {{ form_label(form.nom) }}
                            {{ form_widget(form.nom, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.nom) }}
                        </fieldset>
                    </div>

                    <div class="col-lg-12">
                        <fieldset>
                            {{ form_label(form.evenement) }}
                            {{ form_widget(form.evenement, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.evenement) }}
                        </fieldset>
                    </div>

                    <div class="col-lg-12">
                        <fieldset>
                            {{ form_label(form.etudiants) }}
                            {{ form_widget(form.etudiants, {'attr': {'class': 'form-control', 'size': '10'}}) }}
                            {{ form_errors(form.etudiants) }}
                            <small class="form-text text-muted">{{ form_help(form.etudiants) }}</small>
                        </fieldset>
                    </div>

                    <div class="col-lg-12">
                        <fieldset>
                            <button type="submit" class="btn btn-primary" style="background-color: #7a6ad8; border: none; padding: 12px 30px; border-radius: 5px; color: white; font-weight: 600;">
                                Enregistrer les modifications
                            </button>
                            <a href="{{ path('app_mes_equipes') }}" class="btn btn-secondary" style="margin-left: 10px; padding: 12px 30px; border-radius: 5px;">
                                Annuler
                            </a>
                        </fieldset>
                    </div>
                </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>

<style>
    .form-control {
        width: 100%;
        padding: 12px 20px;
        margin: 8px 0;
        border: 1px solid #ddd;
        border-radius: 5px;
        font-size: 14px;
    }
    
    fieldset {
        margin-bottom: 20px;
    }
    
    label {
        font-weight: 600;
        color: #2a2a2a;
        margin-bottom: 8px;
        display: block;
    }
    
    .form-text {
        color: #666;
        font-size: 13px;
        margin-top: 5px;
    }
</style>
{% endblock %}
