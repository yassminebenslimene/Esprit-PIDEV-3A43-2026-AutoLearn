{% extends 'frontoffice/base.html.twig' %}

{% block title %}Mes équipes{% endblock %}

{% block body %}
<div class="container" style="margin-top: 120px; margin-bottom: 80px;">
    <div class="row">
        <div class="col-lg-12">
            <div class="section-heading text-center">
                <h2>Mes équipes</h2>
                <p>Gérez vos équipes et participez aux événements</p>
            </div>

            <div style="text-align: right; margin-bottom: 20px;">
                <a href="{{ path('app_equipe_new') }}" class="btn btn-primary" style="background-color: #7a6ad8; border: none; padding: 12px 30px; border-radius: 5px; color: white; font-weight: 600; text-decoration: none;">
                    + Créer une nouvelle équipe
                </a>
            </div>

            {% for message in app.flashes('success') %}
                <div class="alert alert-success" style="padding: 15px; background-color: #d4edda; border: 1px solid #c3e6cb; border-radius: 5px; margin-bottom: 20px;">
                    {{ message }}
                </div>
            {% endfor %}

            {% for message in app.flashes('error') %}
                <div class="alert alert-danger" style="padding: 15px; background-color: #f8d7da; border: 1px solid #f5c6cb; border-radius: 5px; margin-bottom: 20px;">
                    {{ message }}
                </div>
            {% endfor %}

            {% if equipes is empty %}
                <div style="text-align: center; padding: 60px; background: white; border-radius: 10px; box-shadow: 0 0 20px rgba(0,0,0,0.1);">
                    <h4>Vous n'avez pas encore d'équipe</h4>
                    <p>Créez votre première équipe pour participer aux événements !</p>
                    <a href="{{ path('app_equipe_new') }}" class="btn btn-primary" style="background-color: #7a6ad8; border: none; padding: 12px 30px; border-radius: 5px; color: white; font-weight: 600; text-decoration: none; display: inline-block; margin-top: 20px;">
                        Créer une équipe
                    </a>
                </div>
            {% else %}
                <div class="row">
                    {% for equipe in equipes %}
                        <div class="col-lg-4 col-md-6" style="margin-bottom: 30px;">
                            <div style="background: white; padding: 30px; border-radius: 10px; box-shadow: 0 0 20px rgba(0,0,0,0.1); height: 100%;">
                                <h4 style="color: #7a6ad8; margin-bottom: 15px;">{{ equipe.nom }}</h4>
                                <p style="color: #666; margin-bottom: 10px;">
                                    <strong>Événement:</strong> {{ equipe.evenement.titre }}
                                </p>
                                <p style="color: #666; margin-bottom: 15px;">
                                    <strong>Membres:</strong> {{ equipe.etudiants|length }} étudiants
                                </p>
                                <div style="margin-top: 20px;">
                                    <a href="{{ path('app_equipe_show', {'id': equipe.id}) }}" class="btn btn-sm" style="background-color: #f5f5f5; padding: 8px 15px; border-radius: 5px; text-decoration: none; color: #333; margin-right: 5px;">
                                        Voir détails
                                    </a>
                                    <a href="{{ path('app_equipe_edit', {'id': equipe.id}) }}" class="btn btn-sm" style="background-color: #7a6ad8; padding: 8px 15px; border-radius: 5px; text-decoration: none; color: white;">
                                        Modifier
                                    </a>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
