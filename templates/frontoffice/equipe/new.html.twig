{% extends 'frontoffice/base.html.twig' %}

{% block title %}Create New Team{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .form-section {
            padding: 120px 0 80px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
        }
        
        .form-container {
            background: white;
            border-radius: 20px;
            padding: 50px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.2);
            max-width: 800px;
            margin: 0 auto;
        }
        
        .form-header {
            text-align: center;
            margin-bottom: 40px;
        }
        
        .form-header h1 {
            font-size: 36px;
            font-weight: 700;
            color: #2d3748;
            margin-bottom: 10px;
        }
        
        .form-header p {
            font-size: 16px;
            color: #718096;
        }
        
        .form-group {
            margin-bottom: 30px;
        }
        
        .form-label {
            display: block;
            font-weight: 600;
            color: #2d3748;
            margin-bottom: 10px;
            font-size: 15px;
        }
        
        .form-control {
            width: 100%;
            padding: 15px 20px;
            border: 2px solid #e2e8f0;
            border-radius: 10px;
            font-size: 15px;
            transition: all 0.3s ease;
            font-family: 'Poppins', sans-serif;
        }
        
        .form-control:focus {
            outline: none;
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }
        
        .student-checkboxes {
            display: grid;
            grid-template-columns: 1fr;
            gap: 10px;
            max-height: 400px;
            overflow-y: auto;
            padding: 15px;
            background: #f7fafc;
            border-radius: 10px;
            border: 2px solid #e2e8f0;
        }
        
        .student-checkboxes label {
            display: flex;
            align-items: center;
            padding: 12px 15px;
            background: white;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.2s ease;
            border: 2px solid transparent;
        }
        
        .student-checkboxes label:hover {
            background: #edf2f7;
            border-color: #667eea;
        }
        
        .student-checkboxes input[type="checkbox"] {
            margin-right: 12px;
            width: 20px;
            height: 20px;
            cursor: pointer;
        }
        
        .student-checkboxes input[type="checkbox"]:checked + span {
            font-weight: 600;
            color: #667eea;
        }
        
        .form-help {
            margin-top: 8px;
            font-size: 14px;
            color: #718096;
            display: flex;
            align-items: start;
            gap: 8px;
        }
        
        .help-icon {
            color: #667eea;
            font-weight: bold;
            flex-shrink: 0;
        }
        
        .selection-tip {
            background: #ebf4ff;
            border-left: 4px solid #667eea;
            padding: 15px 20px;
            border-radius: 8px;
            margin-bottom: 15px;
        }
        
        .selection-tip strong {
            color: #667eea;
            display: block;
            margin-bottom: 5px;
        }
        
        .selection-tip p {
            margin: 0;
            color: #4a5568;
            font-size: 14px;
        }
        
        .form-actions {
            display: flex;
            gap: 15px;
            margin-top: 40px;
            justify-content: center;
        }
        
        .btn {
            padding: 15px 40px;
            border-radius: 10px;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s ease;
            border: none;
            cursor: pointer;
            font-size: 16px;
        }
        
        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }
        
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(102, 126, 234, 0.4);
        }
        
        .btn-secondary {
            background: #f7fafc;
            color: #4a5568;
            border: 2px solid #e2e8f0;
        }
        
        .btn-secondary:hover {
            background: #edf2f7;
        }
        
        .form-error {
            color: #e53e3e;
            font-size: 14px;
            margin-top: 5px;
        }
        
        .selected-count {
            display: inline-block;
            background: #667eea;
            color: white;
            padding: 5px 15px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 600;
            margin-left: 10px;
        }
    </style>
{% endblock %}

{% block body %}
<div class="form-section">
    <div class="container">
        <div class="form-container">
            <div class="form-header">
                <h1>Create New Team</h1>
                {% if evenement is defined %}
                    <p>For event: <strong>{{ evenement.titre }}</strong></p>
                {% else %}
                    <p>Form your team of 4 to 6 students</p>
                {% endif %}
            </div>

            {{ form_start(form) }}
            
            <div class="form-group">
                {{ form_label(form.nom, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.nom) }}
                {{ form_errors(form.nom) }}
            </div>

            <div class="form-group">
                <label class="form-label">
                    {{ form.etudiants.vars.label }}
                    <span class="selected-count" id="selected-count">0 selected</span>
                </label>
                
                <div class="selection-tip">
                    <strong>💡 How to select students:</strong>
                    <p>• Check the boxes next to the students you want in your team</p>
                    <p>• You must select between 4 and 6 students</p>
                    <p>• Click on a checked box again to deselect</p>
                </div>
                
                {{ form_widget(form.etudiants, {'attr': {'id': 'student-select'}}) }}
                {{ form_errors(form.etudiants) }}
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    ✓ Create Team
                </button>
                <a href="{{ path('app_mes_equipes') }}" class="btn btn-secondary">
                    ✗ Cancel
                </a>
            </div>

            {{ form_end(form) }}
        </div>
    </div>
</div>

<script>
    // Compteur de sélection pour checkboxes
    document.addEventListener('DOMContentLoaded', function() {
        const checkboxes = document.querySelectorAll('#student-select input[type="checkbox"]');
        const counter = document.getElementById('selected-count');
        
        if (checkboxes.length > 0 && counter) {
            function updateCount() {
                const selected = Array.from(checkboxes).filter(cb => cb.checked).length;
                counter.textContent = selected + ' selected';
                
                if (selected >= 4 && selected <= 6) {
                    counter.style.background = '#48bb78';
                } else if (selected > 0) {
                    counter.style.background = '#ed8936';
                } else {
                    counter.style.background = '#667eea';
                }
            }
            
            checkboxes.forEach(cb => cb.addEventListener('change', updateCount));
            updateCount();
        }
    });
</script>
{% endblock %}
