<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@100;200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">

    <title>Scholar - Online School HTML5 Template</title>

    {% block stylesheets %}
        <!-- Bootstrap -->
        <link rel="stylesheet" href="{{ asset('frontoffice/vendor/bootstrap/css/bootstrap.min.css') }}">

        <!-- FrontOffice CSS -->
        <link rel="stylesheet" href="{{ asset('frontoffice/css/animate.css') }}">
        <link rel="stylesheet" href="{{ asset('frontoffice/css/flex-slider.css') }}">
        <link rel="stylesheet" href="{{ asset('frontoffice/css/fontawesome.css') }}">
        <link rel="stylesheet" href="{{ asset('frontoffice/css/owl.css') }}">
        <link rel="stylesheet" href="{{ asset('frontoffice/css/templatemo-scholar.css') }}">

        <!-- Progress Bar CSS -->
        <link rel="stylesheet" href="{{ asset('frontoffice/css/progress-bar.css') }}">

        <!-- Swiper -->
        <link rel="stylesheet" href="https://unpkg.com/swiper@7/swiper-bundle.min.css"/>
    {% endblock %}
    
    <style>
        /* Fix navbar position */
        .header-area {
            position: fixed !important;
            top: 0 !important;
            left: 0 !important;
            right: 0 !important;
            z-index: 9999 !important;
            background-color: rgba(122, 106, 216, 0.95) !important;
            backdrop-filter: blur(10px) !important;
            margin-bottom: 0 !important;
        }
        
        /* Add padding to body to compensate for fixed header */
        body {
            padding-top: 80px !important;
        }
        
        /* Remove any white space after header */
        .header-area + * {
            margin-top: 0 !important;
        }
        
        /* Notification Badge Styles */
        .notification-badge {
            position: absolute;
            top: 5px;
            right: 5px;
            background: #ff4444;
            color: white;
            border-radius: 50%;
            width: 10px;
            height: 10px;
            display: flex !important;
            align-items: center;
            justify-content: center;
            font-size: 8px;
            font-weight: 700;
            box-shadow: 0 2px 6px rgba(255, 68, 68, 0.6);
            animation: pulse 2s infinite;
            z-index: 10;
        }
        
        .badge-count {
            color: white;
            font-size: 10px;
        }
        
        @keyframes pulse {
            0%, 100% {
                transform: scale(1);
                box-shadow: 0 2px 6px rgba(255, 68, 68, 0.6);
            }
            50% {
                transform: scale(1.2);
                box-shadow: 0 4px 12px rgba(255, 68, 68, 0.8);
            }
        }
        
        /* Reset any conflicting styles - AVEC CENTRAGE VERTICAL */
        .main-nav {
            display: flex !important;
            align-items: center !important;
            height: 80px !important;
        }
        
        .main-nav .nav {
            display: flex !important;
            align-items: center !important;
            height: 100% !important;
            margin-bottom: 0 !important;
        }
        
        .main-nav .nav li {
            display: flex !important;
            align-items: center !important;
            height: 100% !important;
            margin: 0 !important;
        }
        
        .main-nav .nav li a {
            display: flex !important;
            align-items: center !important;
            height: 100% !important;
            line-height: 1 !important;
            padding-top: 0 !important;
            padding-bottom: 0 !important;
        }
        
        .main-nav .nav li.profile-dropdown-container {
            position: relative !important;
            display: flex !important;
            align-items: center !important;
            height: 100% !important;
        }
        
        .main-nav .nav .profile-dropdown-btn {
            background: none !important;
            border: none !important;
            padding: 0 15px !important;
            color: #1e1e1e !important;
            font-weight: 500 !important;
            text-decoration: none !important;
            cursor: pointer !important;
            display: flex !important;
            align-items: center !important;
            height: 100% !important;
            line-height: 1 !important;
            gap: 5px !important;
        }
        
        .main-nav .nav .profile-dropdown-btn i {
            display: flex !important;
            align-items: center !important;
        }
        
        .main-nav .nav .profile-dropdown-menu {
            display: none;
            position: absolute !important;
            top: 100% !important;
            right: 0 !important;
            z-index: 999999 !important;
            min-width: 220px !important;
            background: white !important;
            border-radius: 8px !important;
            box-shadow: 0 5px 25px rgba(0,0,0,0.15) !important;
            padding: 10px 0 !important;
            margin-top: 0 !important;
            list-style: none !important;
        }
        
        .main-nav .nav .profile-dropdown-menu.show {
            display: block !important;
        }
        
        .main-nav .nav .profile-dropdown-menu li {
            width: 100% !important;
            margin: 0 !important;
            padding: 0 !important;
            display: block !important;
            height: auto !important;
        }
        
        .main-nav .nav .profile-dropdown-menu a {
            display: block !important;
            padding: 12px 20px !important;
            color: #333 !important;
            text-decoration: none !important;
            font-size: 15px !important;
            transition: all 0.2s !important;
            line-height: normal !important;
            height: auto !important;
        }
        
        .main-nav .nav .profile-dropdown-menu a:hover {
            background: linear-gradient(105deg, #7a6ad8 0%, #4e3b9c 100%) !important;
            color: white !important;
        }
        
        .main-nav .nav .profile-dropdown-menu i {
            margin-right: 10px !important;
            width: 18px !important;
            text-align: center !important;
        }
        
        .main-nav .nav .profile-dropdown-divider {
            height: 1px !important;
            background: #eeeeee !important;
            margin: 8px 0 !important;
        }
        
        /* Fix pour les autres liens de la navbar */
        .main-nav .nav .scroll-to-section {
            display: flex !important;
            align-items: center !important;
            height: 100% !important;
        }
        
        .main-nav .nav .scroll-to-section a {
            display: flex !important;
            align-items: center !important;
            height: 100% !important;
            padding: 0 15px !important;
            line-height: 1 !important;
        }
        
        /* Force navbar items to stay on one line */
        .main-nav .nav {
            flex-wrap: nowrap !important;
            white-space: nowrap !important;
        }
        
        /* Reduce padding for compact layout */
        .main-nav .nav li a {
            padding: 0 10px !important;
            font-size: 14px !important;
        }
        
        .main-nav .nav .profile-dropdown-btn {
            padding: 0 10px !important;
        }
        
        @media (max-width: 992px) {
            .main-nav,
            .main-nav .nav,
            .main-nav .nav li,
            .main-nav .nav li a,
            .main-nav .nav li.profile-dropdown-container,
            .main-nav .nav .profile-dropdown-btn {
                height: auto !important;
                min-height: 50px !important;
            }
            
            .main-nav .nav .profile-dropdown-menu {
                position: static !important;
                width: 100% !important;
                box-shadow: none !important;
                background: transparent !important;
            }
            
            .main-nav .nav .profile-dropdown-menu a {
                color: white !important;
                padding-left: 30px !important;
            }
            
            .main-nav .nav .profile-dropdown-divider {
                background: rgba(255,255,255,0.2) !important;
            }
        }
    </style>
</head>
<body>

<!-- ***** Preloader Start ***** -->
<div id="js-preloader" class="js-preloader">
    <div class="preloader-inner">
        <span class="dot"></span>
        <div class="dots">
            <span></span>
            <span></span>
            <span></span>
        </div>
    </div>
</div>
<!-- ***** Preloader End ***** -->

<!-- ***** Header Area Start ***** -->
<header class="header-area header-sticky">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <nav class="main-nav">
                    <!-- ***** Logo Start ***** -->
                    <a href="{{ path('app_frontoffice') }}" class="logo">
                        <h1>AutoLearn</h1>
                    </a>
                    <!-- ***** Logo End ***** -->
                    
                    <!-- ***** Search Start ***** -->
                    <div class="search-input">
                        <form id="search" action="{{ path('app_search') }}" method="GET">
                            <input type="text" placeholder="{{ 'search.placeholder'|trans }}" id='searchText' name="q" required minlength="2" />
                            <button type="submit" style="background: none; border: none; cursor: pointer;">
                                <i class="fa fa-search"></i>
                            </button>
                        </form>
                    </div>
                    <!-- ***** Search End ***** -->
                    
                    <!-- ***** Menu Start ***** -->
                    <ul class="nav">
                        <li class="scroll-to-section"><a href="#top" class="active">{{ 'nav.home'|trans }}</a></li>
                        <li class="scroll-to-section"><a href="#cours">{{ 'nav.courses'|trans }}</a></li>
                        <li class="scroll-to-section"><a href="#events">{{ 'nav.events'|trans }}</a></li>
                        <li class="scroll-to-section"><a href="#challenge">{{ 'nav.challenges'|trans }}</a></li>
                        <li><a href="{{ path('front_communaute') }}">{{ 'nav.community'|trans }}</a></li>
                        <li><a href="{{ path('app_about') }}">{{ 'nav.about'|trans }}</a></li>
                        
                        {% if app.user %}
                            {# Notifications avec badge #}
                            <li style="position: relative;">
                                <a href="{{ path('app_notifications_index') }}" style="position: relative; display: inline-flex; align-items: center; gap: 5px;">
                                    <i class="fa fa-bell"></i>
                                    <span id="notification-badge" class="notification-badge" style="display: none;"></span>
                                </a>
                            </li>
                            
                            {# Dropdown Profil #}
                            <li class="profile-dropdown-container">
                                <a href="javascript:void(0);" onclick="toggleProfileDropdown(event)" class="profile-dropdown-btn">
                                    <i class="fa fa-user-circle"></i>
                                    <i class="fa fa-chevron-down" style="font-size: 10px; margin-left: 3px;"></i>
                                </a>
                                <ul class="profile-dropdown-menu" id="profileDropdown">
                                    <li>
                                        <a href="{{ path('app_profile') }}">
                                            <i class="fa fa-id-card"></i> {{ 'nav.profile'|trans }}
                                        </a>
                                    </li>
                                    <li>
                                        <a href="{{ path('app_mes_participations') }}">
                                            <i class="fa fa-trophy"></i> {{ 'nav.my_participations'|trans }}
                                        </a>
                                    </li>
                                    <li class="profile-dropdown-divider"></li>
                                    <li>
                                        <a href="{{ path('backoffice_logout') }}">
                                            <i class="fa fa-sign-out"></i> {{ 'nav.logout'|trans }}
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        {% else %}
                            <li><a href="{{ path('backoffice_login') }}">{{ 'nav.login'|trans }}</a></li>
                        {% endif %}
                        
                        {# Sélecteur de langue compact #}
                        <li class="profile-dropdown-container">
                            <a href="javascript:void(0);" onclick="toggleLanguageDropdown(event)" class="profile-dropdown-btn">
                                <i class="fa fa-globe"></i>
                                <i class="fa fa-chevron-down" style="font-size: 10px; margin-left: 3px;"></i>
                            </a>
                            <ul class="profile-dropdown-menu" id="languageDropdown">
                                <li>
                                    <a href="{{ path('app_change_language', {'locale': 'fr'}) }}">
                                        <i class="fa fa-flag"></i> Français
                                    </a>
                                </li>
                                <li>
                                    <a href="{{ path('app_change_language', {'locale': 'en'}) }}">
                                        <i class="fa fa-flag"></i> English
                                    </a>
                                </li>
                                <li>
                                    <a href="{{ path('app_change_language', {'locale': 'es'}) }}">
                                        <i class="fa fa-flag"></i> Español
                                    </a>
                                </li>
                                <li>
                                    <a href="{{ path('app_change_language', {'locale': 'ar'}) }}">
                                        <i class="fa fa-flag"></i> العربية
                                    </a>
                                </li>
                            </ul>
                        </li>
                    </ul>
                    </ul> 
                    <!-- ***** Menu End ***** -->
                    
                    <form id="logout-form-nav" action="{{ path('backoffice_logout') }}" method="POST" style="display: none;">
                        <input type="hidden" name="_token" value="{{ csrf_token('logout') }}">
                    </form>
                    <a class='menu-trigger'>
                        <span>Menu</span>
                    </a>
                </nav>
            </div>
        </div>
    </div>
</header>
<!-- ***** Header Area End ***** -->

<!-- Flash Messages -->
{% for label, messages in app.flashes %}
    {% for message in messages %}
        <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert" style="position: fixed; top: 100px; right: 20px; z-index: 9999; min-width: 300px; max-width: 500px; box-shadow: 0 5px 25px rgba(0,0,0,0.2);">
            {% if label == 'success' %}
                <i class="fa fa-check-circle" style="margin-right: 10px;"></i>
            {% elseif label == 'error' %}
                <i class="fa fa-exclamation-circle" style="margin-right: 10px;"></i>
            {% else %}
                <i class="fa fa-info-circle" style="margin-right: 10px;"></i>
            {% endif %}
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}
{% endfor %}

<!-- ***** Main Banner Start ***** -->
<div class="main-banner" id="top">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="owl-carousel owl-banner">
                    <div class="item item-1">
                        <div class="header-text">
                            <span class="category">{{ 'frontoffice.banner.our_courses'|trans }}</span>
                            <h2>{{ 'frontoffice.banner.learn_programming'|trans }}</h2>
                            <p>{{ 'frontoffice.banner.discover_courses'|trans }}</p>
                            <div class="buttons">
                                <div class="main-button">
                                    <a href="#cours">{{ 'frontoffice.banner.view_courses'|trans }}</a>
                                </div>
                                <div class="icon-button">
                                    <a href="#courses"><i class="fa fa-play"></i> {{ 'frontoffice.banner.start_now'|trans }}</a>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="item item-2">
                        <div class="header-text">
                            <span class="category">{{ 'frontoffice.banner.best_results'|trans }}</span>
                            <h2>{{ 'frontoffice.banner.develop_skills'|trans }}</h2>
                            <p>{{ 'frontoffice.banner.progress_fast'|trans }}</p>
                            <div class="buttons">
                                <div class="main-button">
                                    <a href="#challenge">{{ 'frontoffice.banner.take_challenge'|trans }}</a>
                                </div>
                                <div class="icon-button">
                                    <a href="#courses"><i class="fa fa-play"></i> {{ 'frontoffice.banner.explore_courses'|trans }}</a>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="item item-3">
                        <div class="header-text">
                            <span class="category">{{ 'frontoffice.banner.online_learning'|trans }}</span>
                            <h2>{{ 'frontoffice.banner.learn_at_pace'|trans }}</h2>
                            <p>{{ 'frontoffice.banner.access_247'|trans }}</p>
                            <div class="buttons">
                                <div class="main-button">
                                    <a href="{{ path('backoffice_register') }}">{{ 'frontoffice.banner.register_free'|trans }}</a>
                                </div>
                                <div class="icon-button">
                                    <a href="#cours"><i class="fa fa-play"></i> {{ 'frontoffice.banner.discover_autolearn'|trans }}</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- ***** Main Banner End ***** -->

{% if app.user %}
    {# LOGGED IN USER: Show Cours → Challenge → Events → Contact #}
    
    <!-- ***** Cours Section Start ***** -->
    <div class="services section" id="cours">
        <div class="container">
            <div class="row">
                <div class="col-lg-12 text-center">
                    <div class="section-heading">
                        <h6>Nos Cours</h6>
                        <h2>Découvrez Nos Cours de Programmation</h2>
                    </div>
                </div>
            </div>

            <div class="row">
                {% if cours is empty %}
                    <div class="col-12 text-center">
                        <p>{{ 'courses.no_courses'|trans }}</p>
                    </div>
                {% else %}
                    {% for cour in cours %}
                        <div class="col-lg-4 col-md-6">
                            <div class="service-item">
                                <div class="icon">
                                    <img src="{{ asset('frontoffice/images/service-01.png') }}" alt="icône cours">
                                </div>
                                <div class="main-content">
                                    <h4>{{ cour.titre }}</h4>
                                    <p>{{ cour.description|length > 100 ? cour.description|slice(0, 100) ~ '...' : cour.description }}</p>

                                    {# Afficher la progression si l'utilisateur est connecté #}
                                    {% if app.user and coursProgress[cour.id] is defined %}
                                        {% set progress = coursProgress[cour.id] %}
                                        <div style="margin: 15px 0;">
                                            {% include 'components/progress_bar.html.twig' with {
                                                'percentage': progress.percentage,
                                                'show_label': true,
                                                'completed': progress.completed_chapters,
                                                'total': progress.total_chapters
                                            } %}
                                        </div>
                                    {% endif %}

                                    <div class="main-button">
                                        <a href="{{ path('app_frontoffice_chapitre_by_cours', {'coursId': cour.id}) }}" class="btn">
                                            {{ 'courses.view'|trans }}
                                        </a>
                                        <a href="{{ path('front_communaute_cours', {'coursId': cour.id}) }}" class="btn" style="background: linear-gradient(135deg, #6c5ce7, #4a69bd);">
                                            <i class="fa fa-users me-1"></i> {{ 'nav.community'|trans }}
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                {% endif %}
            </div>
        </div>
    </div>
    <!-- ***** Cours Section End ***** -->

<!-- ***** About Us Section Start ***** -->
<section class="about-us" style="padding: 80px 0;">
    <div class="container">
        <!-- Mission -->
        <div class="row" style="margin-bottom: 60px;">
            <div class="col-lg-6">
                <div class="section-heading">
                    <h6>Notre Mission</h6>
                    <h2>Révolutionner l'apprentissage en ligne</h2>
                    <div class="div-dec"></div>
                </div>
            </div>
            <div class="col-lg-6">
                <p style="font-size: 16px; line-height: 1.8; color: #666;">
                    AutoLearn est une plateforme d'apprentissage en ligne innovante qui combine l'intelligence artificielle 
                    et la pédagogie moderne pour offrir une expérience d'apprentissage personnalisée et efficace. 
                    Notre mission est de rendre l'éducation accessible à tous, partout et à tout moment.
                </p>
            </div>
        </div>

        <!-- Fonctionnalités Principales -->
        <div class="row" style="margin-bottom: 60px;">
            <div class="col-lg-12">
                <div class="section-heading text-center" style="margin-bottom: 50px;">
                    <h6>Nos Fonctionnalités</h6>
                    <h2>Ce qui nous rend uniques</h2>
                    <div class="div-dec" style="margin: 20px auto;"></div>
                </div>
            </div>
        </div>

        <div class="row">
            <!-- Feature 1 -->
            <div class="col-lg-4 col-md-6" style="margin-bottom: 30px;">
                <div class="service-item" style="background: white; padding: 40px 30px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); height: 100%; transition: transform 0.3s;">
                    <div class="icon" style="font-size: 48px; color: #7a6ad8; margin-bottom: 20px;">
                        <i class="fa fa-robot"></i>
                    </div>
                    <h4 style="margin-bottom: 15px; color: #1e1e1e;">Intelligence Artificielle</h4>
                    <p style="color: #666; line-height: 1.6;">
                        Correction automatique et analyse sémantique des réponses grâce à l'IA Groq. 
                        Génération intelligente d'exercices adaptés à votre niveau.
                    </p>
                </div>
            </div>

            <!-- Feature 2 -->
            <div class="col-lg-4 col-md-6" style="margin-bottom: 30px;">
                <div class="service-item" style="background: white; padding: 40px 30px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); height: 100%; transition: transform 0.3s;">
                    <div class="icon" style="font-size: 48px; color: #7a6ad8; margin-bottom: 20px;">
                        <i class="fa fa-trophy"></i>
                    </div>
                    <h4 style="margin-bottom: 15px; color: #1e1e1e;">Challenges Interactifs</h4>
                    <p style="color: #666; line-height: 1.6;">
                        Participez à des challenges stimulants avec feedback détaillé et explications personnalisées. 
                        Suivez votre progression en temps réel.
                    </p>
                </div>
            </div>

            <!-- Feature 3 -->
            <div class="col-lg-4 col-md-6" style="margin-bottom: 30px;">
                <div class="service-item" style="background: white; padding: 40px 30px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); height: 100%; transition: transform 0.3s;">
                    <div class="icon" style="font-size: 48px; color: #7a6ad8; margin-bottom: 20px;">
                        <i class="fa fa-users"></i>
                    </div>
                    <h4 style="margin-bottom: 15px; color: #1e1e1e;">Communauté Active</h4>
                    <p style="color: #666; line-height: 1.6;">
                        Rejoignez une communauté d'apprenants passionnés. Partagez vos connaissances, 
                        posez des questions et collaborez avec d'autres étudiants.
                    </p>
                </div>
            </div>

            <!-- Feature 4 -->
            <div class="col-lg-4 col-md-6" style="margin-bottom: 30px;">
                <div class="service-item" style="background: white; padding: 40px 30px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); height: 100%; transition: transform 0.3s;">
                    <div class="icon" style="font-size: 48px; color: #7a6ad8; margin-bottom: 20px;">
                        <i class="fa fa-book"></i>
                    </div>
                    <h4 style="margin-bottom: 15px; color: #1e1e1e;">Cours Structurés</h4>
                    <p style="color: #666; line-height: 1.6;">
                        Accédez à des cours complets organisés par chapitres et niveaux de difficulté. 
                        Apprenez à votre rythme avec du contenu de qualité.
                    </p>
                </div>
            </div>

            <!-- Feature 5 -->
            <div class="col-lg-4 col-md-6" style="margin-bottom: 30px;">
                <div class="service-item" style="background: white; padding: 40px 30px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); height: 100%; transition: transform 0.3s;">
                    <div class="icon" style="font-size: 48px; color: #7a6ad8; margin-bottom: 20px;">
                        <i class="fa fa-calendar"></i>
                    </div>
                    <h4 style="margin-bottom: 15px; color: #1e1e1e;">Événements en Direct</h4>
                    <p style="color: #666; line-height: 1.6;">
                        Participez à des événements en ligne, webinaires et sessions de formation en direct. 
                        Interagissez avec des experts et des formateurs qualifiés.
                    </p>
                </div>
            </div>

            <!-- Feature 6 -->
            <div class="col-lg-4 col-md-6" style="margin-bottom: 30px;">
                <div class="service-item" style="background: white; padding: 40px 30px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); height: 100%; transition: transform 0.3s;">
                    <div class="icon" style="font-size: 48px; color: #7a6ad8; margin-bottom: 20px;">
                        <i class="fa fa-chart-line"></i>
