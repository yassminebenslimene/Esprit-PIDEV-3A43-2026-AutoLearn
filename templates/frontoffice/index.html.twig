                                        <li>
                                            <span class="category" style="background: 
                                                {% if challenge.niveau == 'Facile' %}#7fb77e;
                                                {% elseif challenge.niveau == 'Intermédiaire' %}#f3b562;
                                                {% else %}#f17b7b;
