<div class="section events" id="events">
    <div class="container">
        <div class="row">
            <div class="col-lg-12 text-center">
                <div class="section-heading">
                    <h6>Événements</h6>
                    <h2>Nos Événements</h2>
                </div>
            </div>
            
            {% if evenements is not defined or evenements is empty %}
                <div class="col-lg-12">
                    <div class="item" style="text-align: center; padding: 40px;">
                        <p style="color: #7a7a7a; font-size: 16px;">Aucun événement pour le moment</p>
                    </div>
                </div>
            {% else %}
                {% for evenement in evenements %}
                    <div class="col-lg-12 col-md-6">
                        <div class="item">
                            <div class="row">
                                <div class="col-lg-3">
                                    <div class="image">
                                        {% if loop.index0 % 3 == 0 %}
                                            <img src="{{ asset('frontoffice/images/event-01.jpg') }}" alt="{{ evenement.titre }}">
                                        {% elseif loop.index0 % 3 == 1 %}
                                            <img src="{{ asset('frontoffice/images/event-02.jpg') }}" alt="{{ evenement.titre }}">
                                        {% else %}
                                            <img src="{{ asset('frontoffice/images/event-03.jpg') }}" alt="{{ evenement.titre }}">
                                        {% endif %}
                                    </div>
                                </div>
                                <div class="col-lg-9">
                                    <ul>
                                        <li>
                                            <span class="category">{{ evenement.type.value }}</span>
                                            <h4>{{ evenement.titre }}</h4>
                                        </li>
                                        <li>
                                            <span>Date:</span>
                                            <h6>{{ evenement.dateDebut|date('d M Y') }}</h6>
                                        </li>
                                        <li>
                                            <span>Durée:</span>
                                            <h6>{{ evenement.dateDebut.diff(evenement.dateFin).days }} jours</h6>
                                        </li>
                                        <li>
                                            <span>Places:</span>
                                            <h6>
                                                {% set acceptedCount = 0 %}
                                                {% for participation in evenement.participations %}
                                                    {% if participation.statut.value == 'Accepté' %}
                                                        {% set acceptedCount = acceptedCount + 1 %}
                                                    {% endif %}
                                                {% endfor %}
                                                {{ evenement.nbMax - acceptedCount }} / {{ evenement.nbMax }} disponibles
                                            </h6>
                                        </li>
                                    </ul>
                                    <a href="#"><i class="fa fa-angle-right"></i></a>
                                </div>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            {% endif %}
        </div>
    </div>
</div>
