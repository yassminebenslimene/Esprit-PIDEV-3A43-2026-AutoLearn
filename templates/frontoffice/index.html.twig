                                            </span>
                                            <h4>{{ challenge.titre }}</h4>
                                            <p style="margin-top: 8px; color: #7a7a7a;">
                                                {{ challenge.description|length > 100 ? challenge.description|slice(0, 100) ~ '...' : challenge.description }}
                                            </p>
                                        </li>
                                        <li>
                                            <span>Début:</span>
                                            <h6>{{ challenge.dateDebut|date('d M Y') }}</h6>
                                        </li>
                                        <li>
                                            <span>Fin:</span>
                                            <h6>{{ challenge.dateFin|date('d M Y') }}</h6>
                                        </li>
                                        <li>
                                            <span>Niveau:</span>
                                            <h6 style="color: 
                                                {% if challenge.niveau == 'Facile' %}#7fb77e;
                                                {% elseif challenge.niveau == 'Intermédiaire' %}#f3b562;
                                                {% else %}#f17b7b;
                                                {% endif %}; font-weight: 700;">
                                                {{ challenge.niveau }}
                                            </h6>
                                        </li>
                                    </ul>
                                    <a href="{{ path('frontchallenge', {'id': challenge.id}) }}">
                                        <i class="fa fa-angle-right"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</section>
