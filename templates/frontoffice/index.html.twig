    <!-- Profile Dropdown Toggle Script -->
    <script>
        function toggleProfileDropdown(event) {
            event.preventDefault();
            event.stopPropagation();
            
            var dropdown = document.getElementById('profileDropdown');
            var languageDropdown = document.getElementById('languageDropdown');
            
            // Fermer le dropdown de langue
            if (languageDropdown) {
                languageDropdown.classList.remove('show');
            }
            
            if (dropdown) {
                dropdown.classList.toggle('show');
            }
        }
        
        function toggleLanguageDropdown(event) {
            event.preventDefault();
            event.stopPropagation();
            
            var dropdown = document.getElementById('languageDropdown');
            var profileDropdown = document.getElementById('profileDropdown');
            
            // Fermer le dropdown de profil
            if (profileDropdown) {
                profileDropdown.classList.remove('show');
            }
            
            dropdown.classList.toggle('show');
        }
        
        document.addEventListener('click', function(event) {
            var dropdown = document.getElementById('profileDropdown');
            var languageDropdown = document.getElementById('languageDropdown');
            var isClickInside = event.target.closest('.profile-dropdown-container');
            
            if (!isClickInside) {
                if (dropdown) {
                    dropdown.classList.remove('show');
                }
                if (languageDropdown) {
                    languageDropdown.classList.remove('show');
                }
            }
        });
        
        document.addEventListener('DOMContentLoaded', function() {
            console.log('Profile and language dropdowns initialized');
            
            // Force search form submission
            var searchForm = document.getElementById('search');
            if (searchForm) {
                searchForm.addEventListener('submit', function(e) {
                    // Ne pas empêcher la soumission du formulaire
                    console.log('Search form submitted');
                    return true;
                });
            }
            
            // Charger le nombre de notifications non lues
            {% if app.user %}
            updateNotificationBadge();
            // Actualiser toutes les 30 secondes
            setInterval(updateNotificationBadge, 30000);
            {% endif %}
            
            // Auto-dismiss flash messages after 5 seconds
            setTimeout(function() {
                var alerts = document.querySelectorAll('.alert');
                alerts.forEach(function(alert) {
                    var bsAlert = new bootstrap.Alert(alert);
                    bsAlert.close();
                });
            }, 5000);
            
            // Scroll to contact section if there's a hash
            if (window.location.hash === '#contact') {
                setTimeout(function() {
                    document.getElementById('contact').scrollIntoView({ behavior: 'smooth' });
                }, 100);
            }
        });
        
        {% if app.user %}
        function updateNotificationBadge() {
            fetch('{{ path('app_notifications_unread_count') }}')
                .then(response => response.json())
                .then(data => {
                    var badge = document.getElementById('notification-badge');
                    if (badge) {
                        if (data.count > 0) {
                            badge.textContent = data.count > 9 ? '9+' : data.count;
                            badge.style.display = 'inline-block';
                        } else {
                            badge.style.display = 'none';
                        }
                    }
                })
                .catch(error => console.error('Erreur lors du chargement des notifications:', error));
        }
        {% endif %}
    </script>
{% endblock %}

