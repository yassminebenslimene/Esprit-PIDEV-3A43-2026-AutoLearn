<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@100;200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">

    <title>Scholar - Online School HTML5 Template</title>

    {% block stylesheets %}
        <!-- Bootstrap -->
        <link rel="stylesheet" href="{{ asset('frontoffice/vendor/bootstrap/css/bootstrap.min.css') }}">

        <!-- FrontOffice CSS -->
        <link rel="stylesheet" href="{{ asset('frontoffice/css/animate.css') }}">
        <link rel="stylesheet" href="{{ asset('frontoffice/css/flex-slider.css') }}">
        <link rel="stylesheet" href="{{ asset('frontoffice/css/fontawesome.css') }}">
        <link rel="stylesheet" href="{{ asset('frontoffice/css/owl.css') }}">
        <link rel="stylesheet" href="{{ asset('frontoffice/css/templatemo-scholar.css') }}">

        <!-- Swiper -->
        <link rel="stylesheet" href="https://unpkg.com/swiper@7/swiper-bundle.min.css"/>
    {% endblock %}
    
    <style>
        /* Reset any conflicting styles - AVEC CENTRAGE VERTICAL */
        .main-nav {
            display: flex !important;
            align-items: center !important;
            height: 80px !important;  /* Ajuste si nécessaire */
        }
        
        .main-nav .nav {
            display: flex !important;
            align-items: center !important;
            height: 100% !important;
            margin-bottom: 0 !important;
        }
        
        .main-nav .nav li {
            display: flex !important;
            align-items: center !important;
            height: 100% !important;
            margin: 0 !important;
        }
        
        .main-nav .nav li a {
            display: flex !important;
            align-items: center !important;
            height: 100% !important;
            line-height: 1 !important;
            padding-top: 0 !important;
            padding-bottom: 0 !important;
        }
        
        .main-nav .nav li.profile-dropdown-container {
            position: relative !important;
            display: flex !important;
            align-items: center !important;
            height: 100% !important;
        }
        
        .main-nav .nav .profile-dropdown-btn {
            background: none !important;
            border: none !important;
            padding: 0 15px !important;
            color: #1e1e1e !important;
            font-weight: 500 !important;
            text-decoration: none !important;
            cursor: pointer !important;
            display: flex !important;
            align-items: center !important;
            height: 100% !important;
            line-height: 1 !important;
            gap: 5px !important;
        }
        
        .main-nav .nav .profile-dropdown-btn i {
            display: flex !important;
            align-items: center !important;
        }
        
        .main-nav .nav .profile-dropdown-menu {
            display: none;
            position: absolute !important;
            top: 100% !important;
            right: 0 !important;
            z-index: 999999 !important;
            min-width: 220px !important;
            background: white !important;
            border-radius: 8px !important;
            box-shadow: 0 5px 25px rgba(0,0,0,0.15) !important;
            padding: 10px 0 !important;
            margin-top: 0 !important;
            list-style: none !important;
        }
        
        .main-nav .nav .profile-dropdown-menu.show {
            display: block !important;
        }
        
        .main-nav .nav .profile-dropdown-menu li {
            width: 100% !important;
            margin: 0 !important;
            padding: 0 !important;
            display: block !important;
            height: auto !important;
        }
        
        .main-nav .nav .profile-dropdown-menu a {
            display: block !important;
            padding: 12px 20px !important;
            color: #333 !important;
            text-decoration: none !important;
            font-size: 15px !important;
            transition: all 0.2s !important;
            line-height: normal !important;
            height: auto !important;
        }
        
        .main-nav .nav .profile-dropdown-menu a:hover {
            background: linear-gradient(105deg, #7a6ad8 0%, #4e3b9c 100%) !important;
            color: white !important;
        }
        
        .main-nav .nav .profile-dropdown-menu i {
            margin-right: 10px !important;
            width: 18px !important;
            text-align: center !important;
        }
        
        .main-nav .nav .profile-dropdown-divider {
            height: 1px !important;
            background: #eeeeee !important;
            margin: 8px 0 !important;
        }
        
        /* Fix pour les autres liens de la navbar */
        .main-nav .nav .scroll-to-section {
            display: flex !important;
            align-items: center !important;
            height: 100% !important;
        }
        
        .main-nav .nav .scroll-to-section a {
            display: flex !important;
            align-items: center !important;
            height: 100% !important;
            padding: 0 15px !important;
            line-height: 1 !important;
        }
        
        @media (max-width: 992px) {
            .main-nav,
            .main-nav .nav,
            .main-nav .nav li,
            .main-nav .nav li a,
            .main-nav .nav li.profile-dropdown-container,
            .main-nav .nav .profile-dropdown-btn {
                height: auto !important;
                min-height: 50px !important;
            }
            
            .main-nav .nav .profile-dropdown-menu {
                position: static !important;
                width: 100% !important;
                box-shadow: none !important;
                background: transparent !important;
            }
            
            .main-nav .nav .profile-dropdown-menu a {
                color: white !important;
                padding-left: 30px !important;
            }
            
            .main-nav .nav .profile-dropdown-divider {
                background: rgba(255,255,255,0.2) !important;
            }
        }
    </style>
</head>
<body>

<!-- ***** Preloader Start ***** -->
<div id="js-preloader" class="js-preloader">
    <div class="preloader-inner">
        <span class="dot"></span>
        <div class="dots">
            <span></span>
            <span></span>
            <span></span>
        </div>
    </div>
</div>
<!-- ***** Preloader End ***** -->

<!-- ***** Header Area Start ***** -->
<header class="header-area header-sticky">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <nav class="main-nav">
                    <!-- ***** Logo Start ***** -->
                    <a href="{{ path('app_frontoffice') }}" class="logo">
                        <h1>AutoLearn</h1>
                    </a>
                    <!-- ***** Logo End ***** -->
                    
                    <!-- ***** Search Start ***** -->
                    <div class="search-input">
                        <form id="search" action="#">
                            <input type="text" placeholder="Type Something" id='searchText' name="searchKeyword" />
                            <i class="fa fa-search"></i>
                        </form>
                    </div>
                    <!-- ***** Search End ***** -->
                    
                    <!-- ***** Menu Start ***** -->
                    <ul class="nav">

                        <li class="scroll-to-section"><a href="#top" class="active">Home</a></li>
                        <li class="scroll-to-section"><a href="#cours">Cours</a></li>
                        <li><a href="{{ path('app_events') }}">Events</a></li>
                        <li class="scroll-to-section"><a href="#challenge">Challenge</a></li>
                        <li class="scroll-to-section"><a href="#contact">Contact</a></li>
                        <li><a href="{{ path('front_communaute') }}">Communauté</a></li>
                        {% if app.user %}
                            <!-- User Logged In - Profile Dropdown -->
                            <li><a href="{{ path('app_mes_participations') }}">My Participations</a></li>

                            <li class="profile-dropdown-container">
                                <a href="javascript:void(0);" onclick="toggleProfileDropdown(event)" class="profile-dropdown-btn">
                                    <i class="fa fa-user-circle"></i>
                                    {{ app.user.prenom }} {{ app.user.nom }}
                                    <i class="fa fa-chevron-down" style="font-size: 12px; margin-left: 5px;"></i>
                                </a>
                                <ul class="profile-dropdown-menu" id="profileDropdown">
                                    <li>
                                        <a href="{{ path('app_profile') }}">
                                            <i class="fa fa-id-card"></i> Mon Profil
                                        </a>
                                    </li>
                                    <li class="profile-dropdown-divider"></li>
                                    <li>
                                        <a href="{{ path('backoffice_logout') }}">
                                            <i class="fa fa-sign-out"></i> Déconnexion
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        {% else %}
                            <!-- User Not Logged In -->
                            <li><a href="{{ path('backoffice_login') }}">Login</a></li>
                            <li><a href="{{ path('backoffice_register') }}">Register</a></li>
                        {% endif %}
                    </ul> 
                    <!-- ***** Menu End ***** -->
                    
                    <form id="logout-form-nav" action="{{ path('backoffice_logout') }}" method="POST" style="display: none;">
                        <input type="hidden" name="_token" value="{{ csrf_token('logout') }}">
                    </form>
                    <a class='menu-trigger'>
                        <span>Menu</span>
                    </a>
                </nav>
            </div>
        </div>
    </div>
</header>
<!-- ***** Header Area End ***** -->

<!-- Flash Messages -->
{% for label, messages in app.flashes %}
    {% for message in messages %}
        <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert" style="position: fixed; top: 100px; right: 20px; z-index: 9999; min-width: 300px; max-width: 500px; box-shadow: 0 5px 25px rgba(0,0,0,0.2);">
            {% if label == 'success' %}
                <i class="fa fa-check-circle" style="margin-right: 10px;"></i>
            {% elseif label == 'error' %}
                <i class="fa fa-exclamation-circle" style="margin-right: 10px;"></i>
            {% else %}
                <i class="fa fa-info-circle" style="margin-right: 10px;"></i>
            {% endif %}
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}
{% endfor %}

<!-- ***** Main Banner Start ***** -->
