{% extends 'base_front.html.twig' %}

{% block title %}Modifier {{ communaute.nom }} | Scholar{% endblock %}

{% block body %}



<style>
.edit-container {
    max-width: 700px;
    margin: 80px auto;
}

.edit-card {
    background: white;
    border-radius: 16px;
    padding: 30px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
}

.edit-card h4 {
    margin-bottom: 20px;
}

/* boutons */
.btn-primary {
    background: linear-gradient(135deg, #7a6ad8, #6c63ff);
    border: none;
    border-radius: 999px;
    padding: 8px 22px;
    color: white;
}

.btn-primary:hover {
    opacity: 0.9;
}

.btn-link {
    display: inline-block;
    margin-top: 15px;
    text-decoration: none;
    color: #6c63ff;
}

.btn-danger {
    margin-top: 25px;
}
</style>

<div class="edit-container">

<!-- ===== MINI BANNER ===== -->
<div class="page-heading header-text">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <h3>Modifier la communauté</h3>
                <span class="breadcrumb">
                    <a href="{{ path('app_frontoffice') }}">Home</a> >
                    <a href="{{ path('app_communaute_show', { id: communaute.id }) }}">
                        {{ communaute.nom }}
                    </a>
                    > Modifier
                </span>
            </div>
        </div>
    </div>
</div>

    <div class="edit-card">

        <h4>✏️ Informations de la communauté</h4>

        {{ include('frontoffice/communaute/_form.html.twig', {
            'button_label': 'Enregistrer les modifications'
        }) }}

        <a href="{{ path('app_communaute_show', { id: communaute.id }) }}"
           class="btn-link">
            ← Retour à la communauté
        </a>

        <hr>

        {{ include('frontoffice/communaute/_delete_form.html.twig') }}

    </div>

</div>

{% endblock %}
