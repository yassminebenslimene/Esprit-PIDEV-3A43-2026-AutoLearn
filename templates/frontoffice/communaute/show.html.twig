{% extends 'base_front.html.twig' %}

{% block title %}{{ communaute.nom }} | Scholar{% endblock %}

{% block body %}

<style>
/* Container principal */
.community-container {
    max-width: 1100px;
    margin: 120px auto 80px;
    padding: 0 20px;
    position: relative;
    z-index: 1;
}

/* Style pour le contenu HTML des posts */
.post-content {
    line-height: 1.8;
    color: #333;
}

.post-content p {
    margin-bottom: 1em;
}

.post-content strong {
    font-weight: 600;
    color: #000;
}

.post-content em {
    font-style: italic;
}

.post-content ul, .post-content ol {
    margin: 1em 0;
    padding-left: 2em;
}

.post-content li {
    margin-bottom: 0.5em;
}

.post-content a {
    color: #667eea;
    text-decoration: underline;
}

.post-content a:hover {
    color: #764ba2;
}

.post-content blockquote {
    border-left: 4px solid #667eea;
    padding-left: 1em;
    margin: 1em 0;
    font-style: italic;
    color: #666;
}

.post-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 1em 0;
}

.post-content table td, .post-content table th {
    border: 1px solid #ddd;
    padding: 8px;
}

.post-content table th {
    background: #f5f5f5;
    font-weight: 600;
}

/* En-tête de la page */
.page-heading {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    padding: 50px 40px;
    border-radius: 20px;
    color: white;
    margin-bottom: 40px;
    box-shadow: 0 10px 40px rgba(102, 126, 234, 0.3);
    text-align: center;
    position: relative;
}

.page-heading h3 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 15px;
    color: white;
}

.breadcrumb {
    display: inline-block;
    background: rgba(255, 255, 255, 0.2);
    padding: 8px 20px;
    border-radius: 20px;
    font-size: 0.9rem;
    backdrop-filter: blur(10px);
}

.breadcrumb a {
    color: white;
    text-decoration: none;
    font-weight: 500;
    transition: opacity 0.3s;
}

.breadcrumb a:hover {
    opacity: 0.8;
}

/* Description de la communauté */
.community-container > p {
    background: #f8f9ff;
    padding: 20px 25px;
    border-radius: 12px;
    border-left: 4px solid #667eea;
    margin-bottom: 30px;
    font-size: 1.05rem;
    line-height: 1.7;
    color: #555;
}

/* Alertes */
.alert-success, .alert-error {
    padding: 15px 20px;
    border-radius: 12px;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 12px;
    font-weight: 500;
    animation: slideIn 0.3s ease;
}

.alert-success {
    background: linear-gradient(135deg, #d4edda 0%, #c3e6cb 100%);
    color: #155724;
    border-left: 4px solid #28a745;
}

.alert-error {
    background: linear-gradient(135deg, #f8d7da 0%, #f5c6cb 100%);
    color: #721c24;
    border-left: 4px solid #dc3545;
}

@keyframes slideIn {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
}

/* Bouton nouveau post */
.btn-new-post {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 28px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
    box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
    transition: all 0.3s ease;
    margin-bottom: 30px;
}

.btn-new-post:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(102, 126, 234, 0.6);
    color: white;
    text-decoration: none;
}

/* Message pour non-membres */
.cannot-post-msg {
    background: #fff3cd;
    color: #856404;
    padding: 15px 20px;
    border-radius: 12px;
    border-left: 4px solid #ffc107;
    margin-bottom: 25px;
    font-style: normal;
}

/* Bloc inviter et membres */
.invite-box, .members-box {
    background: linear-gradient(135deg, #f8f9ff 0%, #f0f2ff 100%);
    border-radius: 16px;
    padding: 25px;
    margin-bottom: 30px;
    border: 1px solid rgba(102, 126, 234, 0.15);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
}

.invite-box strong, .members-box strong {
    display: block;
    color: #667eea;
    font-size: 1.15rem;
    margin-bottom: 15px;
    font-weight: 600;
}

.invite-box form {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    align-items: center;
}

.invite-box input[type="email"] {
    flex: 1;
    min-width: 250px;
    padding: 12px 18px;
    border-radius: 12px;
    border: 2px solid rgba(102, 126, 234, 0.2);
    font-size: 1rem;
    transition: all 0.3s;
}

.invite-box input[type="email"]:focus {
    outline: none;
    border-color: #667eea;
    box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
}

.invite-box button {
    padding: 12px 24px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border: none;
    border-radius: 12px;
    cursor: pointer;
    font-weight: 600;
    transition: all 0.3s;
}

.invite-box button:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
}

/* Liste des membres */
.members-list {
    list-style: none;
    padding: 0;
    margin: 0;
}

.members-list li {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 12px;
    border-bottom: 1px solid rgba(102, 126, 234, 0.1);
    transition: background 0.3s;
}

.members-list li:hover {
    background: rgba(102, 126, 234, 0.05);
}

.members-list li:last-child {
    border-bottom: none;
}

.members-list li span {
    font-weight: 500;
    color: #333;
}

.member-remove-form {
    margin: 0;
}

.member-remove-form button {
    padding: 6px 14px;
    font-size: 0.85rem;
    background: #dc3545;
    color: white;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.3s;
    font-weight: 500;
}

.member-remove-form button:hover {
    background: #c82333;
    transform: scale(1.05);
}

/* Cartes de post */
.post-card {
    position: relative;
    background: white;
    border-radius: 16px;
    padding: 30px;
    margin-bottom: 30px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    transition: all 0.3s ease;
    border: 1px solid rgba(0, 0, 0, 0.05);
}

.post-card:hover {
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12);
    transform: translateY(-2px);
}

.post-card > p {
    font-size: 1.1rem;
    line-height: 1.7;
    color: #333;
    margin-bottom: 20px;
}

.post-card > small {
    display: block;
    color: #999;
    font-size: 0.9rem;
    margin-top: 15px;
    padding-top: 15px;
    border-top: 1px solid #f0f0f0;
}

.post-card hr {
    border: none;
    border-top: 2px solid #f0f0f0;
    margin: 25px 0;
}

/* Média du post */
.post-media {
    margin: 20px 0;
    text-align: center;
    border-radius: 12px;
    overflow: hidden;
}

.post-media img,
.post-media video,
.post-media iframe {
    max-width: 100%;
    max-height: 500px;
    border-radius: 12px;
    object-fit: cover;
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.1);
}

/* Bouton voir le post */
.btn-see-post {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: #667eea;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.3s;
    margin-top: 10px;
}

.btn-see-post:hover {
    color: #764ba2;
    gap: 12px;
    text-decoration: none;
}

/* Menu 3 points */
.post-menu, .comment-menu {
    position: absolute;
    right: 20px;
    top: 20px;
}

.menu-btn {
    background: rgba(0, 0, 0, 0.05);
    border: none;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    font-size: 18px;
    cursor: pointer;
    transition: all 0.3s;
    color: #666;
}

.menu-btn:hover {
    background: rgba(0, 0, 0, 0.1);
}

.post-dropdown, .comment-dropdown {
    display: none;
    position: absolute;
    right: 0;
    top: 40px;
    background: white;
    border-radius: 12px;
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
    overflow: hidden;
    z-index: 10;
    min-width: 150px;
}

.post-menu:focus-within .post-dropdown,
.comment-menu:focus-within .comment-dropdown {
    display: block;
    animation: fadeIn 0.2s ease;
}

@keyframes fadeIn {
    from { opacity: 0; transform: translateY(-5px); }
    to { opacity: 1; transform: translateY(0); }
}

.post-dropdown a,
.post-dropdown button,
.comment-dropdown a,
.comment-dropdown button {
    display: block;
    width: 100%;
    padding: 12px 16px;
    border: none;
    background: white;
    text-align: left;
    cursor: pointer;
    font-size: 0.95rem;
    color: #333;
    transition: all 0.2s;
    text-decoration: none;
}

.post-dropdown a:hover,
.post-dropdown button:hover,
.comment-dropdown a:hover,
.comment-dropdown button:hover {
    background: #f8f9ff;
    color: #667eea;
}

/* Commentaires */
.comment {
    position: relative;
    background: #f8f9ff;
    border-radius: 12px;
    padding: 15px 18px;
    margin-bottom: 12px;
    border-left: 3px solid #667eea;
    transition: all 0.3s;
}

.comment:hover {
    background: #f0f2ff;
}

.comment small {
    color: #999;
    font-size: 0.85rem;
    margin-top: 8px;
    display: block;
}

/* Formulaire de commentaire */
.comment-form {
    margin-top: 20px;
}

.comment-form textarea {
    width: 100%;
    padding: 14px 18px;
    border-radius: 12px;
    border: 2px solid rgba(102, 126, 234, 0.2);
    font-size: 1rem;
    font-family: inherit;
    resize: vertical;
    min-height: 80px;
    transition: all 0.3s;
}

.comment-form textarea:focus {
    outline: none;
    border-color: #667eea;
    box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
}

.comment-form button {
    margin-top: 10px;
    padding: 10px 24px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border: none;
    border-radius: 20px;
    cursor: pointer;
    font-weight: 600;
    transition: all 0.3s;
}

.comment-form button:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
}

/* Message aucun post */
.community-container > p:last-child {
    text-align: center;
    padding: 60px 20px;
    color: #999;
    font-size: 1.1rem;
    background: white;
    border-radius: 16px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
}

/* Responsive */
@media (max-width: 768px) {
    .page-heading h3 {
        font-size: 1.8rem;
    }
    
    .invite-box input[type="email"] {
        min-width: 100%;
    }
    
    .post-card {
        padding: 20px;
    }
}

/* Styles pour les boutons de réaction */
.reaction-btn {
    font-family: inherit;
    font-size: 0.9rem;
}

.reaction-btn:hover {
    background: #f0f0f0 !important;
    transform: scale(1.05);
}

.reaction-btn.active {
    background: #e3f2fd !important;
    color: #1976d2;
    font-weight: 600;
}

.reaction-count {
    font-weight: 600;
    color: #666;
    min-width: 20px;
    text-align: center;
}

.reaction-btn.active .reaction-count {
    color: #1976d2;
}
</style>

<div class="community-container">

    <div class="page-heading header-text" style="text-align:center; margin-bottom:30px;">
        <h3>{{ communaute.nom }}</h3>
        <span class="breadcrumb">
            <a href="{{ path('app_frontoffice') }}">Home</a> > <a href="{{ path('app_communaute_index') }}">Communauté</a> > {{ communaute.nom }}
        </span>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert-success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert-error">{{ message }}</div>
    {% endfor %}

    <p>{{ communaute.description }}</p>

    {# Seul le créateur ou un membre invité peut poster #}
    {% if canPost %}
        <a href="{{ path('app_post_new', { id: communaute.id }) }}" class="btn-new-post">
            ➕ Nouveau post
        </a>
    {% elseif app.user %}
        <p class="cannot-post-msg">Seuls le créateur et les membres invités peuvent poster. Demandez à être invité.</p>
    {% endif %}

    {# Bloc réservé au créateur : inviter des membres + liste des membres #}
    {% if app.user and communaute.owner and communaute.owner.id == app.user.id %}
        <div class="invite-box">
            <strong>Inviter un ami (par email)</strong>
            <form method="post" action="/communaute/{{ communaute.id }}">
                <input type="hidden" name="_invite_token" value="{{ csrf_token('invite_' ~ communaute.id) }}">
                <input type="email" name="email" placeholder="email@exemple.com" required>
                <button type="submit">Inviter</button>
            </form>
        </div>
        <div class="members-box">
            <strong>Membres ({{ (communaute.members|length) + 1 }})</strong>
            <ul class="members-list">
                {# Afficher le propriétaire en premier #}
                {% if communaute.owner %}
                <li>
                    <span>{{ communaute.owner.prenom }} {{ communaute.owner.nom }} <span style="color: #667eea; font-weight: 600;">(Créateur)</span></span>
                </li>
                {% endif %}
                
                {# Afficher les autres membres #}
                {% for member in communaute.members %}
                <li>
                    <span>{{ member.prenom }} {{ member.nom }}</span>
                    <form class="member-remove-form" method="post" action="/communaute/{{ communaute.id }}/remove-member/{{ member.id }}"
                          onsubmit="return confirm('Retirer {{ member.prenom }} de la communauté ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('remove_member_' ~ member.id) }}">
                        <button type="submit">Retirer</button>
                    </form>
                </li>
                {% endfor %}
            </ul>
        </div>

        {# Section des demandes d'adhésion #}
        {% if communaute.pendingMembers|length > 0 %}
        <div class="members-box" style="background: linear-gradient(135deg, #fff3cd 0%, #ffe8a1 100%); border: 1px solid rgba(255, 193, 7, 0.3);">
            <strong style="color: #856404;">📬 Demandes d'adhésion ({{ communaute.pendingMembers|length }})</strong>
            <ul class="members-list">
                {% for pendingUser in communaute.pendingMembers %}
                <li>
                    <span>{{ pendingUser.prenom }} {{ pendingUser.nom }}</span>
                    <div style="display: flex; gap: 8px;">
                        <form method="post" action="{{ path('app_communaute_accept_member', {id: communaute.id, userId: pendingUser.id}) }}" style="display: inline;">
                            <input type="hidden" name="_token" value="{{ csrf_token('accept_member_' ~ pendingUser.id) }}">
                            <button type="submit" style="padding: 6px 14px; font-size: 0.85rem; background: #28a745; color: white; border: none; border-radius: 8px; cursor: pointer; transition: all 0.3s; font-weight: 500;">
                                ✓ Accepter
                            </button>
                        </form>
                        <form method="post" action="{{ path('app_communaute_reject_member', {id: communaute.id, userId: pendingUser.id}) }}" style="display: inline;">
                            <input type="hidden" name="_token" value="{{ csrf_token('reject_member_' ~ pendingUser.id) }}">
                            <button type="submit" style="padding: 6px 14px; font-size: 0.85rem; background: #dc3545; color: white; border: none; border-radius: 8px; cursor: pointer; transition: all 0.3s; font-weight: 500;">
                                ✗ Refuser
                            </button>
                        </form>
                    </div>
                </li>
                {% endfor %}
            </ul>
        </div>
        {% endif %}
    {% endif %}

    {% for post in communaute.posts %}
        <div class="post-card">

            {# Menu 3 points pour le post (comme pour les commentaires) : auteur ou post sans auteur #}
            {% if app.user and (post.user is null or post.user.id == app.user.id) %}
            <div class="post-menu">
                <button type="button" class="menu-btn" aria-label="Options du post">⋮</button>
                <div class="post-dropdown">
                    <a href="/post/{{ post.id }}/edit">Modifier</a>
                    <form method="post"
                          action="/post/{{ post.id }}"
                          onsubmit="return confirm('Supprimer ce post ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ post.id) }}">
                        <button type="submit">Supprimer</button>
                    </form>
                </div>
            </div>
            {% endif %}

            <div style="margin-bottom: 15px; padding-bottom: 10px; border-bottom: 1px solid #f0f0f0;">
                <strong style="color: #667eea; font-size: 1rem; display: block;">
                    {% if post.user %}
                        {{ post.user.prenom }} {{ post.user.nom }}
                    {% else %}
                        Anonyme
                    {% endif %}
                </strong>
                <small style="color: #999; font-size: 0.85rem; display: block; margin-top: 4px;">
                    {{ post.createdAt|time_ago }}
                </small>
            </div>

            {% if post.summary %}
                <div class="post-summary" style="background: linear-gradient(135deg, #f0f4ff 0%, #e8f0ff 100%); padding: 15px 20px; border-radius: 12px; margin-bottom: 15px; border-left: 4px solid #667eea;">
                    <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#667eea" stroke-width="2">
                            <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
                        </svg>
                        <strong style="color: #667eea; font-size: 0.9rem;">Résumé AI</strong>
                    </div>
                    <p style="margin: 0; color: #4a5568; font-size: 0.95rem; line-height: 1.6;">{{ post.summary }}</p>
                </div>
            {% endif %}

            {% if post.titre %}
                <div class="post-title-ai" style="background: linear-gradient(135deg, #fff4e6 0%, #ffe8cc 100%); padding: 15px 20px; border-radius: 12px; margin-bottom: 15px; border-left: 4px solid #ff9800;">
                    <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ff9800" stroke-width="2">
                            <path d="M4 7h16M4 12h16M4 17h10"/>
                        </svg>
                        <strong style="color: #ff9800; font-size: 0.9rem;">Titre AI</strong>
                    </div>
                    <h4 style="margin: 0; color: #2d3748; font-size: 1.1rem; font-weight: 600;">{{ post.titre }}</h4>
                </div>
            {% endif %}

            {% if post.contenu %}
                <div class="post-content">{{ post.contenu|raw }}</div>
            {% endif %}

            {% if post.imageFile %}
    <div class="post-media">
        <img src="{{ asset('uploads/images/' ~ post.imageFile) }}" alt="Image du post">
    </div>
{% endif %}

            {# BOUTONS DE RÉACTION #}
            <div class="post-reactions-bar" style="display: flex; align-items: center; gap: 15px; padding: 15px 0; border-top: 1px solid #e0e0e0; border-bottom: 1px solid #e0e0e0; margin: 15px 0;">
                <button class="reaction-btn" data-post-id="{{ post.id }}" data-type="like" style="background: none; border: none; cursor: pointer; display: flex; align-items: center; gap: 5px; padding: 8px 12px; border-radius: 20px; transition: all 0.2s;">
                    <span style="font-size: 1.3rem;">👍</span>
                    <span class="reaction-label">J'aime</span>
                    <span class="reaction-count" data-type="like">0</span>
                </button>
                <button class="reaction-btn" data-post-id="{{ post.id }}" data-type="love" style="background: none; border: none; cursor: pointer; display: flex; align-items: center; gap: 5px; padding: 8px 12px; border-radius: 20px; transition: all 0.2s;">
                    <span style="font-size: 1.3rem;">❤️</span>
                    <span class="reaction-label">J'adore</span>
                    <span class="reaction-count" data-type="love">0</span>
                </button>
                <button class="reaction-btn" data-post-id="{{ post.id }}" data-type="wow" style="background: none; border: none; cursor: pointer; display: flex; align-items: center; gap: 5px; padding: 8px 12px; border-radius: 20px; transition: all 0.2s;">
                    <span style="font-size: 1.3rem;">😮</span>
                    <span class="reaction-label">Wow</span>
                    <span class="reaction-count" data-type="wow">0</span>
                </button>
                <button class="reaction-btn" data-post-id="{{ post.id }}" data-type="haha" style="background: none; border: none; cursor: pointer; display: flex; align-items: center; gap: 5px; padding: 8px 12px; border-radius: 20px; transition: all 0.2s;">
                    <span style="font-size: 1.3rem;">😄</span>
                    <span class="reaction-label">Haha</span>
                    <span class="reaction-count" data-type="haha">0</span>
                </button>
                <button class="reaction-btn" data-post-id="{{ post.id }}" data-type="sad" style="background: none; border: none; cursor: pointer; display: flex; align-items: center; gap: 5px; padding: 8px 12px; border-radius: 20px; transition: all 0.2s;">
                    <span style="font-size: 1.3rem;">😢</span>
                    <span class="reaction-label">Triste</span>
                    <span class="reaction-count" data-type="sad">0</span>
                </button>
                <button class="reaction-btn" data-post-id="{{ post.id }}" data-type="angry" style="background: none; border: none; cursor: pointer; display: flex; align-items: center; gap: 5px; padding: 8px 12px; border-radius: 20px; transition: all 0.2s;">
                    <span style="font-size: 1.3rem;">😠</span>
                    <span class="reaction-label">Grrr</span>
                    <span class="reaction-count" data-type="angry">0</span>
                </button>
            </div>

            <hr>

            {# COMMENTAIRES #}
            {% for commentaire in post.commentaires %}
                <div class="comment">

                    {% if commentaire.user and app.user and commentaire.user.id == app.user.id %}
                    <div class="comment-menu">
                        <button class="menu-btn">⋮</button>
                        <div class="comment-dropdown">
                            <a href="/commentaire/{{ commentaire.id }}/edit">Modifier</a>
                            <form method="post"
                                  action="/commentaire/{{ commentaire.id }}/delete"
                                  onsubmit="return confirm('Supprimer ce commentaire ?');">
                                <input type="hidden" name="_token"
                                       value="{{ csrf_token('delete' ~ commentaire.id) }}">
                                <button type="submit">Supprimer</button>
                            </form>
                        </div>
                    </div>
                    {% endif %}

                    <strong style="color: #667eea; font-size: 0.95rem;">
                        {% if commentaire.user %}
                            {{ commentaire.user.prenom }} {{ commentaire.user.nom }}
                        {% else %}
                            Anonyme
                        {% endif %}
                    </strong>
                    
                    {% if commentaire.sentiment %}
                        <span style="display: inline-block; margin-left: 10px; padding: 3px 10px; border-radius: 12px; font-size: 0.8rem; font-weight: 600;
                            {% if commentaire.sentiment == 'positive' %}
                                background: #d4edda; color: #155724;
                            {% elseif commentaire.sentiment == 'negative' %}
                                background: #f8d7da; color: #721c24;
                            {% else %}
                                background: #e2e3e5; color: #383d41;
                            {% endif %}
                        ">
                            {% if commentaire.sentiment == 'positive' %}
                                😊 Positif
                            {% elseif commentaire.sentiment == 'negative' %}
                                😞 Négatif
                            {% else %}
                                😐 Neutre
                            {% endif %}
                        </span>
                    {% endif %}
                    
                    <p style="margin: 8px 0 0 0;">{{ commentaire.contenu }}</p>
                    <small>
                        {{ commentaire.createdAt|date('d/m/Y H:i') }}
                    </small>
                </div>
            {% else %}
                <small>Aucun commentaire</small>
            {% endfor %}

            {% if canPost %}
            <form class="comment-form"
                  method="post"
                  action="/commentaire/new/{{ post.id }}">
                <textarea name="commentaire[contenu]"
                          placeholder="Écrire un commentaire..."
                          required></textarea>
                <button type="submit">Commenter</button>
            </form>
            {% endif %}

        </div>
    {% else %}
        <p>Aucun post pour le moment.</p>
    {% endfor %}

</div>

