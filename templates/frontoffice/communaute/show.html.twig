{% extends 'base_front.html.twig' %}

{% block title %}{{ communaute.nom }} | Scholar{% endblock %}

{% block body %}

<style>
.community-container {
    max-width: 900px;
    margin: 80px auto;
}
.post-card {
    position: relative;
    background: white;
    border-radius: 14px;
    padding: 20px;
    margin-bottom: 25px;
    box-shadow: 0 8px 20px rgba(0,0,0,0.08);
}
.post-media {
    margin-top: 15px;
    text-align: center;
}
.post-media img,
.post-media video,
.post-media iframe {
    max-width: 75%;
    max-height: 420px;
    border-radius: 14px;
    object-fit: cover;
    box-shadow: 0 6px 18px rgba(0,0,0,0.08);
}
.comment {
    position: relative;
    margin-left: 20px;
    padding: 10px 14px;
    background: #f4f5ff;
    border-radius: 12px;
    margin-bottom: 8px;
}
.menu-btn {
    background: none;
    border: none;
    font-size: 18px;
    cursor: pointer;
}
.post-menu,
.comment-menu {
    position: absolute;
    right: 14px;
    top: 14px;
}
.post-dropdown,
.comment-dropdown {
    display: none;
    position: absolute;
    right: 0;
    top: 26px;
    background: white;
    border-radius: 8px;
    box-shadow: 0 8px 20px rgba(0,0,0,0.15);
    overflow: hidden;
    z-index: 10;
}
.post-menu:focus-within .post-dropdown,
.comment-menu:focus-within .comment-dropdown {
    display: block;
}
.post-dropdown a,
.post-dropdown button,
.comment-dropdown a,
.comment-dropdown button {
    display: block;
    width: 100%;
    padding: 8px 14px;
    border: none;
    background: white;
    text-align: left;
    cursor: pointer;
    font-size: 14px;
}
.post-dropdown a:hover,
.post-dropdown button:hover,
.comment-dropdown a:hover,
.comment-dropdown button:hover {
    background: #f2f4ff;
}
.comment-form textarea {
    width: 100%;
    border-radius: 10px;
    border: 1px solid #ccc;
    padding: 10px;
}
.comment-form button {
    background: #7a6ad8;
    color: white;
    border: none;
    padding: 6px 16px;
    border-radius: 20px;
    margin-top: 8px;
}
.btn-new-post {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 10px 18px;
    background: linear-gradient(135deg, #7a6ad8, #6c63ff);
    color: white;
    border-radius: 999px;
    text-decoration: none;
    margin-bottom: 25px;
}
.invite-box, .members-box {
    background: #f8f9fa;
    border-radius: 12px;
    padding: 16px;
    margin-bottom: 20px;
}
.invite-box form { display: flex; gap: 10px; flex-wrap: wrap; align-items: center; }
.invite-box input[type="email"] { padding: 8px 12px; border-radius: 8px; border: 1px solid #ddd; min-width: 220px; }
.invite-box button { padding: 8px 16px; background: #7a6ad8; color: white; border: none; border-radius: 8px; cursor: pointer; }
.members-list { list-style: none; padding: 0; margin: 0; }
.members-list li { display: flex; align-items: center; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid #eee; }
.members-list li:last-child { border-bottom: none; }
.member-remove-form { margin: 0; }
.member-remove-form button { padding: 4px 10px; font-size: 12px; background: #f44336; color: white; border: none; border-radius: 6px; cursor: pointer; }
.alert-success { background: #d4edda; color: #155724; padding: 12px; border-radius: 8px; margin-bottom: 16px; }
.alert-error { background: #f8d7da; color: #721c24; padding: 12px; border-radius: 8px; margin-bottom: 16px; }
.cannot-post-msg { color: #666; font-style: italic; margin-bottom: 20px; }
.btn-see-post { display: inline-block; margin-top: 10px; color: #7a6ad8; font-size: 14px; text-decoration: none; }
.btn-see-post:hover { text-decoration: underline; }
</style>

<div class="community-container">

    <div class="page-heading header-text" style="text-align:center; margin-bottom:30px;">
        <h3>{{ communaute.nom }}</h3>
        <span class="breadcrumb">
            <a href="{{ path('app_frontoffice') }}">Home</a> > <a href="{{ path('app_communaute_index') }}">Communauté</a> > {{ communaute.nom }}
        </span>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert-success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert-error">{{ message }}</div>
    {% endfor %}

    <p>{{ communaute.description }}</p>

    {# Seul le créateur ou un membre invité peut poster #}
    {% if canPost %}
        <a href="{{ path('app_post_new', { id: communaute.id }) }}" class="btn-new-post">
            ➕ Nouveau post
        </a>
    {% elseif app.user %}
        <p class="cannot-post-msg">Seuls le créateur et les membres invités peuvent poster. Demandez à être invité.</p>
    {% endif %}

    {# Bloc réservé au créateur : inviter des membres + liste des membres #}
    {% if app.user and communaute.owner.id == app.user.id %}
        <div class="invite-box">
            <strong>Inviter un ami (par email)</strong>
            <form method="post" action="/communaute/{{ communaute.id }}">
                <input type="hidden" name="_invite_token" value="{{ csrf_token('invite_' ~ communaute.id) }}">
                <input type="email" name="email" placeholder="email@exemple.com" required>
                <button type="submit">Inviter</button>
            </form>
        </div>
        {% if communaute.members|length > 0 %}
        <div class="members-box">
            <strong>Membres ({{ communaute.members|length }})</strong>
            <ul class="members-list">
                {% for member in communaute.members %}
                <li>
                    <span>{{ member.prenom }} {{ member.nom }}</span>
                    <form class="member-remove-form" method="post" action="/communaute/{{ communaute.id }}/remove-member/{{ member.id }}"
                          onsubmit="return confirm('Retirer {{ member.prenom }} de la communauté ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('remove_member_' ~ member.id) }}">
                        <button type="submit">Retirer</button>
                    </form>
                </li>
                {% endfor %}
            </ul>
        </div>
        {% endif %}
    {% endif %}

    {% for post in communaute.posts %}
        <div class="post-card">

            {# Menu 3 points pour le post (comme pour les commentaires) : auteur ou post sans auteur #}
            {% if app.user and (post.user is null or post.user.id == app.user.id) %}
            <div class="post-menu">
                <button type="button" class="menu-btn" aria-label="Options du post">⋮</button>
                <div class="post-dropdown">
                    <a href="/post/{{ post.id }}/edit">Modifier</a>
                    <form method="post"
                          action="/post/{{ post.id }}"
                          onsubmit="return confirm('Supprimer ce post ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ post.id) }}">
                        <button type="submit">Supprimer</button>
                    </form>
                </div>
            </div>
            {% endif %}

            {% if post.contenu %}
                <p>{{ post.contenu }}</p>
            {% endif %}

            {% if post.imageFile %}
                <div class="post-media">
                    <img src="{{ asset('uploads/' ~ post.imageFile) }}">
                </div>
            {% endif %}

            <small>
                Posté le {{ post.createdAt|date('d/m/Y H:i') }}
                {% if post.user %}
                    par {{ post.user.prenom }}
                {% endif %}
            </small>

            <a href="/post/{{ post.id }}" class="btn-see-post">Voir le post →</a>

            <hr>

            {# COMMENTAIRES #}
            {% for commentaire in post.commentaires %}
                <div class="comment">

                    {% if commentaire.user == app.user %}
                    <div class="comment-menu">
                        <button class="menu-btn">⋮</button>
                        <div class="comment-dropdown">
                            <a href="/commentaire/{{ commentaire.id }}/edit">Modifier</a>
                            <form method="post"
                                  action="/commentaire/{{ commentaire.id }}/delete"
                                  onsubmit="return confirm('Supprimer ce commentaire ?');">
                                <input type="hidden" name="_token"
                                       value="{{ csrf_token('delete' ~ commentaire.id) }}">
                                <button type="submit">Supprimer</button>
                            </form>
                        </div>
                    </div>
                    {% endif %}

                    {{ commentaire.contenu }}<br>
                    <small>
                        {{ commentaire.createdAt|date('d/m/Y H:i') }}
                        {% if commentaire.user %}
                            par {{ commentaire.user.prenom }}
                        {% endif %}
                    </small>
                </div>
            {% else %}
                <small>Aucun commentaire</small>
            {% endfor %}

            {% if canPost %}
            <form class="comment-form"
                  method="post"
                  action="/commentaire/new/{{ post.id }}">
                <textarea name="commentaire[contenu]"
                          placeholder="Écrire un commentaire..."
                          required></textarea>
                <button type="submit">Commenter</button>
            </form>
            {% endif %}

        </div>
    {% else %}
        <p>Aucun post pour le moment.</p>
    {% endfor %}

</div>

{% endblock %}
