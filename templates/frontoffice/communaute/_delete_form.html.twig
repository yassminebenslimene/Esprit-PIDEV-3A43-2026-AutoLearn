<div class="danger-zone">
    <div class="danger-zone-header">
        <div class="danger-icon">⚠️</div>
        <div>
            <h5 class="danger-title">Zone dangereuse</h5>
            <p class="danger-description">Cette action est irréversible. Tous les posts et commentaires seront supprimés.</p>
        </div>
    </div>
    <form method="post" action="{{ path('app_communaute_delete', {'id': communaute.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer définitivement cette communauté ?');">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ communaute.id) }}">
        <button class="btn btn-danger" type="submit">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="3 6 5 6 21 6"></polyline>
                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
            </svg>
            Supprimer la communauté
        </button>
    </form>
</div>
