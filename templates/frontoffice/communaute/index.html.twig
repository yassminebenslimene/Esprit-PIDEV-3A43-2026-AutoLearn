{% extends 'base_front.html.twig' %}

{% block title %}Communautés | Scholar{% endblock %}

{% block body %}

<div class="page-heading header-text">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <h3>Communautés</h3>
                <span class="breadcrumb">
                    <a href="{{ path('app_frontoffice') }}">Home</a>
                    > Communautés
                </span>
            </div>
        </div>
    </div>
</div>

<style>
.community-container {
    max-width: 900px;
    margin: 140px auto 80px;
    padding-top: 20px;
}

.community-card {
    background: white;
    border-radius: 14px;
    padding: 20px;
    margin-bottom: 20px;
    box-shadow: 0 8px 20px rgba(0,0,0,0.08);
}

.community-title {
    font-size: 20px;
    font-weight: 600;
}

.community-desc {
    color: #666;
    margin-top: 8px;
}

.community-actions {
    margin-top: 15px;
}

.btn-main {
    background: linear-gradient(135deg, #7a6ad8, #6c63ff);
    color: white;
    padding: 10px 20px;
    border-radius: 999px;
    text-decoration: none;
    font-size: 14px;
    display: inline-block;
    position: relative;
    z-index: 10;
    cursor: pointer;
}

.btn-outline {
    background: #f1f3ff;
    color: #333;
    padding: 8px 18px;
    border-radius: 999px;
    text-decoration: none;
    font-size: 14px;
    margin-left: 10px;
}
</style>

<div class="community-container">

    <a href="/communaute/new" class="btn-main">
        ➕ Nouvelle communauté
    </a>

    <br><br>

    {% for communaute in communautes %}
        <div class="community-card">

            <div class="community-title">
                {{ communaute.nom }}
            </div>

            <div class="community-desc">
                {{ communaute.description }}
            </div>

            <div class="community-actions">
                <a href="/communaute/{{ communaute.id }}"
                   class="btn-outline">
                    Voir
                </a>

                {% if app.user and communaute.owner and communaute.owner.id == app.user.id %}
                <a href="/communaute/{{ communaute.id }}/edit"
                   class="btn-outline">
                    Modifier
                </a>
                {% endif %}
            </div>

        </div>
    {% else %}
        <p>Aucune communauté trouvée.</p>
    {% endfor %}

</div>

{% endblock %}
