{% extends 'frontoffice/base.html.twig' %}

{% block title %}{{ 'search.results'|trans }} - {{ query }}{% endblock %}

{% block body %}
<style>
    .search-results-container {
        min-height: 100vh;
        padding: 100px 0 50px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }
    
    .search-header {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        padding: 40px;
        margin-bottom: 40px;
        text-align: center;
        color: white;
    }
    
    .search-header h1 {
        font-size: 2.5rem;
        margin-bottom: 10px;
    }
    
    .search-query {
        font-size: 1.5rem;
        color: #ffd700;
        font-weight: 600;
    }
    
    .search-stats {
        margin-top: 20px;
        font-size: 1.1rem;
        opacity: 0.9;
    }
    
    .result-card {
        background: rgba(255, 255, 255, 0.95);
        border-radius: 15px;
        padding: 25px;
        margin-bottom: 20px;
        transition: all 0.3s;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
    }
    
    .result-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
    }
    
    .result-type {
        display: inline-block;
        padding: 5px 15px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
        margin-bottom: 15px;
        text-transform: uppercase;
    }
    
    .result-type.cours {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: white;
    }
    
    .result-type.chapitre {
        background: linear-gradient(135deg, #f093fb, #f5576c);
        color: white;
    }
    
    .result-type.quiz {
        background: linear-gradient(135deg, #4facfe, #00f2fe);
        color: white;
    }
    
    .result-type.event {
        background: linear-gradient(135deg, #43e97b, #38f9d7);
        color: white;
    }
    
    .result-type.challenge {
        background: linear-gradient(135deg, #fa709a, #fee140);
        color: white;
    }
    
    .result-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #333;
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    
    .result-title i {
        color: #667eea;
    }
    
    .result-description {
        color: #666;
        line-height: 1.6;
        margin-bottom: 15px;
    }
    
    .result-meta {
        display: flex;
        align-items: center;
        gap: 15px;
        font-size: 0.9rem;
        color: #999;
        margin-bottom: 15px;
    }
    
    .result-link {
        display: inline-block;
        padding: 10px 25px;
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: white;
        text-decoration: none;
        border-radius: 25px;
        font-weight: 600;
        transition: all 0.3s;
    }
    
    .result-link:hover {
        transform: scale(1.05);
        box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
        color: white;
    }
    
    .no-results {
        background: rgba(255, 255, 255, 0.95);
        border-radius: 20px;
        padding: 60px;
        text-align: center;
    }
    
    .no-results-icon {
        font-size: 5rem;
        color: #ddd;
        margin-bottom: 20px;
    }
    
    .no-results h2 {
        color: #333;
        margin-bottom: 15px;
    }
    
    .no-results p {
        color: #666;
        font-size: 1.1rem;
    }
    
    .back-button {
        display: inline-block;
        margin-top: 30px;
        padding: 12px 30px;
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: white;
        text-decoration: none;
        border-radius: 25px;
        font-weight: 600;
        transition: all 0.3s;
    }
    
    .back-button:hover {
        transform: scale(1.05);
        color: white;
    }
</style>

<div class="search-results-container">
    <div class="container">
        <div class="search-header">
            <h1><i class="fa fa-search"></i> {{ 'search.results_for'|trans }}</h1>
            <div class="search-query">"{{ query }}"</div>
            <div class="search-stats">
                {{ total }} {{ total > 1 ? 'search.results_found'|trans : 'search.result_found'|trans }}
            </div>
        </div>

        {% if results is empty %}
            <div class="no-results">
                <div class="no-results-icon">
                    <i class="fa fa-search"></i>
                </div>
                <h2>{{ 'search.no_results'|trans }}</h2>
                <p>{{ 'search.try_different'|trans }}</p>
                <a href="{{ path('app_frontoffice') }}" class="back-button">
                    <i class="fa fa-arrow-left"></i> {{ 'actions.back'|trans }}
                </a>
            </div>
        {% else %}
            {% for result in results %}
                <div class="result-card">
                    <span class="result-type {{ result.type }}">
                        <i class="fa {{ result.icon }}"></i> {{ ('search.type.' ~ result.type)|trans }}
                    </span>
                    
                    <h3 class="result-title">
                        <i class="fa {{ result.icon }}"></i>
                        {{ result.title }}
                    </h3>
                    
                    {% if result.cours is defined and result.cours %}
                        <div class="result-meta">
                            <span><i class="fa fa-book"></i> {{ result.cours }}</span>
                        </div>
                    {% endif %}
                    
                    <p class="result-description">
                        {{ result.description|slice(0, 200) ~ (result.description|length > 200 ? '...' : '') }}
                    </p>
                    
                    <a href="{{ result.url }}" class="result-link">
                        {{ 'search.view_details'|trans }} <i class="fa fa-arrow-right"></i>
                    </a>
                </div>
            {% endfor %}
            
            <div style="text-align: center; margin-top: 40px;">
                <a href="{{ path('app_frontoffice') }}" class="back-button">
                    <i class="fa fa-arrow-left"></i> {{ 'frontoffice.chapter.back_to_courses'|trans }}
                </a>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
