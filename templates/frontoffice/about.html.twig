{% extends 'frontoffice/base.html.twig' %}

{% block title %}À propos - AutoLearn{% endblock %}

{% block body %}
<div class="page-heading">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="header-text">
                    <h2>À propos d'AutoLearn</h2>
                    <div class="div-dec"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<section class="about-us" style="padding: 80px 0;">
    <div class="container">
        <!-- Mission -->
        <div class="row" style="margin-bottom: 60px;">
            <div class="col-lg-6">
                <div class="section-heading">
                    <h6>Notre Mission</h6>
                    <h2>Révolutionner l'apprentissage en ligne</h2>
                    <div class="div-dec"></div>
                </div>
            </div>
            <div class="col-lg-6">
                <p style="font-size: 16px; line-height: 1.8; color: #666;">
                    AutoLearn est une plateforme d'apprentissage en ligne innovante qui combine l'intelligence artificielle 
                    et la pédagogie moderne pour offrir une expérience d'apprentissage personnalisée et efficace. 
                    Notre mission est de rendre l'éducation accessible à tous, partout et à tout moment.
                </p>
            </div>
        </div>

        <!-- Fonctionnalités Principales -->
        <div class="row" style="margin-bottom: 60px;">
            <div class="col-lg-12">
                <div class="section-heading text-center" style="margin-bottom: 50px;">
                    <h6>Nos Fonctionnalités</h6>
                    <h2>Ce qui nous rend uniques</h2>
                    <div class="div-dec" style="margin: 20px auto;"></div>
                </div>
            </div>
        </div>

        <div class="row">
            <!-- Feature 1 -->
            <div class="col-lg-4 col-md-6" style="margin-bottom: 30px;">
                <div class="service-item" style="background: white; padding: 40px 30px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); height: 100%; transition: transform 0.3s;">
                    <div class="icon" style="font-size: 48px; color: #7a6ad8; margin-bottom: 20px;">
                        <i class="fa fa-robot"></i>
                    </div>
                    <h4 style="margin-bottom: 15px; color: #1e1e1e;">Intelligence Artificielle</h4>
                    <p style="color: #666; line-height: 1.6;">
                        Correction automatique et analyse sémantique des réponses grâce à l'IA Groq. 
                        Génération intelligente d'exercices adaptés à votre niveau.
                    </p>
                </div>
            </div>

            <!-- Feature 2 -->
            <div class="col-lg-4 col-md-6" style="margin-bottom: 30px;">
                <div class="service-item" style="background: white; padding: 40px 30px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); height: 100%; transition: transform 0.3s;">
                    <div class="icon" style="font-size: 48px; color: #7a6ad8; margin-bottom: 20px;">
                        <i class="fa fa-trophy"></i>
                    </div>
                    <h4 style="margin-bottom: 15px; color: #1e1e1e;">Challenges Interactifs</h4>
                    <p style="color: #666; line-height: 1.6;">
                        Participez à des challenges stimulants avec feedback détaillé et explications personnalisées. 
                        Suivez votre progression en temps réel.
                    </p>
                </div>
            </div>

            <!-- Feature 3 -->
            <div class="col-lg-4 col-md-6" style="margin-bottom: 30px;">
                <div class="service-item" style="background: white; padding: 40px 30px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); height: 100%; transition: transform 0.3s;">
                    <div class="icon" style="font-size: 48px; color: #7a6ad8; margin-bottom: 20px;">
                        <i class="fa fa-users"></i>
                    </div>
                    <h4 style="margin-bottom: 15px; color: #1e1e1e;">Communauté Active</h4>
                    <p style="color: #666; line-height: 1.6;">
                        Rejoignez une communauté d'apprenants passionnés. Partagez vos connaissances, 
                        posez des questions et collaborez avec d'autres étudiants.
                    </p>
                </div>
            </div>

            <!-- Feature 4 -->
            <div class="col-lg-4 col-md-6" style="margin-bottom: 30px;">
                <div class="service-item" style="background: white; padding: 40px 30px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); height: 100%; transition: transform 0.3s;">
                    <div class="icon" style="font-size: 48px; color: #7a6ad8; margin-bottom: 20px;">
                        <i class="fa fa-book"></i>
                    </div>
                    <h4 style="margin-bottom: 15px; color: #1e1e1e;">Cours Structurés</h4>
                    <p style="color: #666; line-height: 1.6;">
                        Accédez à des cours complets organisés par chapitres et niveaux de difficulté. 
                        Apprenez à votre rythme avec du contenu de qualité.
                    </p>
                </div>
            </div>

            <!-- Feature 5 -->
            <div class="col-lg-4 col-md-6" style="margin-bottom: 30px;">
                <div class="service-item" style="background: white; padding: 40px 30px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); height: 100%; transition: transform 0.3s;">
                    <div class="icon" style="font-size: 48px; color: #7a6ad8; margin-bottom: 20px;">
                        <i class="fa fa-calendar"></i>
                    </div>
                    <h4 style="margin-bottom: 15px; color: #1e1e1e;">Événements en Direct</h4>
                    <p style="color: #666; line-height: 1.6;">
                        Participez à des événements en ligne, webinaires et sessions de formation en direct. 
                        Interagissez avec des experts et des formateurs qualifiés.
                    </p>
                </div>
            </div>

            <!-- Feature 6 -->
            <div class="col-lg-4 col-md-6" style="margin-bottom: 30px;">
                <div class="service-item" style="background: white; padding: 40px 30px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); height: 100%; transition: transform 0.3s;">
                    <div class="icon" style="font-size: 48px; color: #7a6ad8; margin-bottom: 20px;">
                        <i class="fa fa-chart-line"></i>
                    </div>
                    <h4 style="margin-bottom: 15px; color: #1e1e1e;">Suivi de Progression</h4>
                    <p style="color: #666; line-height: 1.6;">
                        Visualisez votre progression avec des statistiques détaillées et des rapports personnalisés. 
                        Identifiez vos points forts et axes d'amélioration.
                    </p>
                </div>
            </div>
        </div>

        <!-- Technologies -->
        <div class="row" style="margin-top: 80px; margin-bottom: 60px;">
            <div class="col-lg-12">
                <div class="section-heading text-center" style="margin-bottom: 50px;">
                    <h6>Technologies</h6>
                    <h2>Propulsé par les meilleures technologies</h2>
                    <div class="div-dec" style="margin: 20px auto;"></div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-3 col-md-6 text-center" style="margin-bottom: 30px;">
                <div style="background: white; padding: 30px; border-radius: 15px; box-shadow: 0 5px 20px rgba(0,0,0,0.08);">
                    <i class="fa fa-code" style="font-size: 40px; color: #7a6ad8; margin-bottom: 15px;"></i>
                    <h5 style="color: #1e1e1e;">Symfony 7</h5>
                    <p style="color: #999; font-size: 14px;">Framework PHP moderne</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 text-center" style="margin-bottom: 30px;">
                <div style="background: white; padding: 30px; border-radius: 15px; box-shadow: 0 5px 20px rgba(0,0,0,0.08);">
                    <i class="fa fa-brain" style="font-size: 40px; color: #7a6ad8; margin-bottom: 15px;"></i>
                    <h5 style="color: #1e1e1e;">Groq AI</h5>
                    <p style="color: #999; font-size: 14px;">Intelligence artificielle ultra-rapide</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 text-center" style="margin-bottom: 30px;">
                <div style="background: white; padding: 30px; border-radius: 15px; box-shadow: 0 5px 20px rgba(0,0,0,0.08);">
                    <i class="fa fa-database" style="font-size: 40px; color: #7a6ad8; margin-bottom: 15px;"></i>
                    <h5 style="color: #1e1e1e;">MySQL</h5>
                    <p style="color: #999; font-size: 14px;">Base de données robuste</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 text-center" style="margin-bottom: 30px;">
                <div style="background: white; padding: 30px; border-radius: 15px; box-shadow: 0 5px 20px rgba(0,0,0,0.08);">
                    <i class="fa fa-shield-alt" style="font-size: 40px; color: #7a6ad8; margin-bottom: 15px;"></i>
                    <h5 style="color: #1e1e1e;">Sécurité</h5>
                    <p style="color: #999; font-size: 14px;">Protection des données</p>
                </div>
            </div>
        </div>

        <!-- Statistiques -->
        <div class="row" style="margin-top: 80px; background: linear-gradient(105deg, #7a6ad8 0%, #4e3b9c 100%); padding: 60px 40px; border-radius: 20px;">
            <div class="col-lg-3 col-md-6 text-center" style="margin-bottom: 30px;">
                <h2 style="color: white; font-size: 48px; font-weight: 700; margin-bottom: 10px;">1000+</h2>
                <p style="color: rgba(255,255,255,0.9); font-size: 16px;">Étudiants actifs</p>
            </div>
            <div class="col-lg-3 col-md-6 text-center" style="margin-bottom: 30px;">
                <h2 style="color: white; font-size: 48px; font-weight: 700; margin-bottom: 10px;">50+</h2>
                <p style="color: rgba(255,255,255,0.9); font-size: 16px;">Cours disponibles</p>
            </div>
            <div class="col-lg-3 col-md-6 text-center" style="margin-bottom: 30px;">
                <h2 style="color: white; font-size: 48px; font-weight: 700; margin-bottom: 10px;">500+</h2>
                <p style="color: rgba(255,255,255,0.9); font-size: 16px;">Exercices IA</p>
            </div>
            <div class="col-lg-3 col-md-6 text-center" style="margin-bottom: 30px;">
                <h2 style="color: white; font-size: 48px; font-weight: 700; margin-bottom: 10px;">24/7</h2>
                <p style="color: rgba(255,255,255,0.9); font-size: 16px;">Support disponible</p>
            </div>
        </div>

        <!-- Testimonials -->
        <div class="row" style="margin-top: 80px; margin-bottom: 60px;">
            <div class="col-lg-12">
                <div class="section-heading text-center" style="margin-bottom: 50px;">
                    <h6>Témoignages</h6>
                    <h2>Ce qu'ils disent de nous</h2>
                    <div class="div-dec" style="margin: 20px auto;"></div>
                </div>
            </div>
        </div>

        <div class="row">
            <!-- Testimonial 1 -->
            <div class="col-lg-4 col-md-6" style="margin-bottom: 30px;">
                <div style="background: linear-gradient(135deg, #7a6ad8 0%, #6a5ac8 100%); padding: 40px 30px; border-radius: 20px; box-shadow: 0 10px 30px rgba(122, 106, 216, 0.3); height: 100%; position: relative;">
                    <div style="color: rgba(255,255,255,0.3); font-size: 48px; line-height: 1; margin-bottom: 20px;">"</div>
                    <p style="color: white; font-size: 16px; line-height: 1.8; margin-bottom: 30px; font-style: italic;">
                        AutoLearn a transformé ma façon d'apprendre. Les exercices générés par l'IA sont incroyablement pertinents et m'aident à progresser rapidement. La correction intelligente me donne des feedbacks précis qui m'aident vraiment à comprendre mes erreurs.
                    </p>
                    <div style="display: flex; align-items: center; gap: 15px;">
                        <div style="width: 60px; height: 60px; border-radius: 50%; background: white; display: flex; align-items: center; justify-content: center; font-size: 24px; font-weight: 700; color: #7a6ad8;">
                            SM
                        </div>
                        <div>
                            <h5 style="color: white; margin: 0; font-size: 18px;">Sarah Martin</h5>
                            <p style="color: rgba(255,255,255,0.8); margin: 0; font-size: 14px;">Développeuse Full Stack</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Testimonial 2 -->
            <div class="col-lg-4 col-md-6" style="margin-bottom: 30px;">
                <div style="background: linear-gradient(135deg, #6a5ac8 0%, #5a4ab8 100%); padding: 40px 30px; border-radius: 20px; box-shadow: 0 10px 30px rgba(122, 106, 216, 0.3); height: 100%; position: relative;">
                    <div style="color: rgba(255,255,255,0.3); font-size: 48px; line-height: 1; margin-bottom: 20px;">"</div>
                    <p style="color: white; font-size: 16px; line-height: 1.8; margin-bottom: 30px; font-style: italic;">
                        La plateforme est intuitive et les cours sont très bien structurés. J'apprécie particulièrement les challenges qui me permettent de mettre en pratique ce que j'apprends. Le système de progression me motive à continuer chaque jour.
                    </p>
                    <div style="display: flex; align-items: center; gap: 15px;">
                        <div style="width: 60px; height: 60px; border-radius: 50%; background: white; display: flex; align-items: center; justify-content: center; font-size: 24px; font-weight: 700; color: #7a6ad8;">
                            AB
                        </div>
                        <div>
                            <h5 style="color: white; margin: 0; font-size: 18px;">Ahmed Benali</h5>
                            <p style="color: rgba(255,255,255,0.8); margin: 0; font-size: 14px;">Étudiant en Informatique</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Testimonial 3 -->
            <div class="col-lg-4 col-md-6" style="margin-bottom: 30px;">
                <div style="background: linear-gradient(135deg, #5a4ab8 0%, #4e3b9c 100%); padding: 40px 30px; border-radius: 20px; box-shadow: 0 10px 30px rgba(122, 106, 216, 0.3); height: 100%; position: relative;">
                    <div style="color: rgba(255,255,255,0.3); font-size: 48px; line-height: 1; margin-bottom: 20px;">"</div>
                    <p style="color: white; font-size: 16px; line-height: 1.8; margin-bottom: 30px; font-style: italic;">
                        Excellente plateforme pour apprendre à son rythme. Les explications sont claires, les exercices variés et la communauté est très active. Le support est réactif et toujours prêt à aider. Je recommande vivement AutoLearn!
                    </p>
                    <div style="display: flex; align-items: center; gap: 15px;">
                        <div style="width: 60px; height: 60px; border-radius: 50%; background: white; display: flex; align-items: center; justify-content: center; font-size: 24px; font-weight: 700; color: #7a6ad8;">
                            ML
                        </div>
                        <div>
                            <h5 style="color: white; margin: 0; font-size: 18px;">Marie Lefebvre</h5>
                            <p style="color: rgba(255,255,255,0.8); margin: 0; font-size: 14px;">Data Scientist</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Call to Action -->
        <div class="row" style="margin-top: 80px;">
            <div class="col-lg-12 text-center">
                <h2 style="margin-bottom: 20px; color: #1e1e1e;">Prêt à commencer votre parcours d'apprentissage ?</h2>
                <p style="font-size: 18px; color: #666; margin-bottom: 30px;">
                    Rejoignez des milliers d'étudiants qui transforment leur avenir avec AutoLearn
                </p>
                {% if not app.user %}
                    <a href="{{ path('backoffice_register') }}" class="main-button" style="display: inline-block; padding: 15px 40px; background: linear-gradient(105deg, #7a6ad8 0%, #4e3b9c 100%); color: white; text-decoration: none; border-radius: 25px; font-weight: 600; font-size: 16px; transition: transform 0.3s;">
                        Inscrivez-vous gratuitement
                    </a>
                {% else %}
                    <a href="{{ path('app_frontoffice') }}#cours" class="main-button" style="display: inline-block; padding: 15px 40px; background: linear-gradient(105deg, #7a6ad8 0%, #4e3b9c 100%); color: white; text-decoration: none; border-radius: 25px; font-weight: 600; font-size: 16px; transition: transform 0.3s;">
                        Explorer les cours
                    </a>
                {% endif %}
            </div>
        </div>
    </div>
</section>

<style>
    .service-item:hover {
        transform: translateY(-10px);
        box-shadow: 0 15px 40px rgba(122, 106, 216, 0.2) !important;
    }
    
    .main-button:hover {
        transform: scale(1.05);
    }
</style>
{% endblock %}
