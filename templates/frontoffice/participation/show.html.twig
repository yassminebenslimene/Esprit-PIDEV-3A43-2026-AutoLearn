{% extends 'frontoffice/base.html.twig' %}

{% block title %}Participation Details{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .detail-section {
            padding: 120px 0 80px;
            background: linear-gradient(135deg, #48bb78 0%, #38a169 100%);
            min-height: 100vh;
        }
        
        .detail-container {
            background: white;
            border-radius: 20px;
            padding: 50px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.2);
            max-width: 900px;
            margin: 0 auto;
        }
        
        .detail-header {
            text-align: center;
            margin-bottom: 40px;
            padding-bottom: 30px;
            border-bottom: 2px solid #e2e8f0;
        }
        
        .detail-header h1 {
            font-size: 36px;
            font-weight: 700;
            color: #2d3748;
            margin-bottom: 15px;
        }
        
        .status-badge {
            display: inline-block;
            padding: 12px 30px;
            border-radius: 25px;
            font-size: 16px;
            font-weight: 600;
        }
        
        .status-accepted {
            background: #c6f6d5;
            color: #22543d;
        }
        
        .status-pending {
            background: #feebc8;
            color: #7c2d12;
        }
        
        .status-refused {
            background: #fed7d7;
            color: #742a2a;
        }
        
        .info-section {
            margin-bottom: 40px;
        }
        
        .info-section h3 {
            font-size: 20px;
            font-weight: 700;
            color: #48bb78;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
        }
        
        .info-card {
            background: #f7fafc;
            padding: 20px;
            border-radius: 10px;
            border-left: 4px solid #48bb78;
        }
        
        .info-card strong {
            display: block;
            color: #2d3748;
            margin-bottom: 5px;
            font-size: 14px;
        }
        
        .info-card span {
            color: #4a5568;
            font-size: 16px;
        }
        
        .status-explanation {
            background: #f7fafc;
            padding: 25px;
            border-radius: 10px;
            border-left: 4px solid #48bb78;
        }
        
        .status-explanation h4 {
            color: #2d3748;
            margin-bottom: 15px;
            font-size: 18px;
        }
        
        .status-explanation p {
            color: #4a5568;
            margin-bottom: 10px;
            line-height: 1.6;
        }
        
        .status-explanation ul {
            margin: 10px 0;
            padding-left: 20px;
        }
        
        .status-explanation li {
            color: #4a5568;
            margin-bottom: 5px;
        }
        
        .members-list {
            display: grid;
            gap: 15px;
        }
        
        .member-card {
            background: #f7fafc;
            padding: 20px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            gap: 15px;
        }
        
        .member-avatar {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: linear-gradient(135deg, #48bb78 0%, #38a169 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 700;
            font-size: 18px;
        }
        
        .member-info {
            flex: 1;
        }
        
        .member-name {
            font-weight: 600;
            color: #2d3748;
            font-size: 16px;
            margin-bottom: 3px;
        }
        
        .member-details {
            color: #718096;
            font-size: 14px;
        }
        
        .action-buttons {
            display: flex;
            gap: 15px;
            justify-content: center;
            margin-top: 40px;
            padding-top: 30px;
            border-top: 2px solid #e2e8f0;
        }
        
        .btn {
            padding: 12px 30px;
            border-radius: 10px;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }
        
        .btn-primary {
            background: linear-gradient(135deg, #48bb78 0%, #38a169 100%);
            color: white;
        }
        
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(72, 187, 120, 0.4);
        }
        
        .btn-secondary {
            background: #f7fafc;
            color: #4a5568;
            border: 2px solid #e2e8f0;
        }
        
        .btn-secondary:hover {
            background: #edf2f7;
        }
    </style>
{% endblock %}

{% block body %}
<div class="detail-section">
    <div class="container">
        <div class="detail-container">
            <div class="detail-header">
                <h1>Participation Details</h1>
                {% if participation.statut.value == 'ACCEPTE' %}
                    <span class="status-badge status-accepted">✓ Accepted</span>
                {% elseif participation.statut.value == 'EN_ATTENTE' %}
                    <span class="status-badge status-pending">⏳ Pending</span>
                {% else %}
                    <span class="status-badge status-refused">✗ Refused</span>
                {% endif %}
            </div>

            <div class="info-section">
                <h3>
                    <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                    Event Information
                </h3>
                <div class="info-grid">
                    <div class="info-card">
                        <strong>Event Name</strong>
                        <span>{{ participation.evenement.titre }}</span>
                    </div>
                    <div class="info-card">
                        <strong>Location</strong>
                        <span>{{ participation.evenement.lieu }}</span>
                    </div>
                    <div class="info-card">
                        <strong>Type</strong>
                        <span>{{ participation.evenement.type.value }}</span>
                    </div>
                    <div class="info-card">
                        <strong>Start Date</strong>
                        <span>{{ participation.evenement.dateDebut|date('d/m/Y H:i') }}</span>
                    </div>
                    <div class="info-card">
                        <strong>End Date</strong>
                        <span>{{ participation.evenement.dateFin|date('d/m/Y H:i') }}</span>
                    </div>
                    <div class="info-card">
                        <strong>Max Teams</strong>
                        <span>{{ participation.evenement.nbMax }}</span>
                    </div>
                </div>
            </div>

            <div class="info-section">
                <h3>
                    <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                    </svg>
                    Team: {{ participation.equipe.nom }}
                </h3>
                <div class="members-list">
                    {% for etudiant in participation.equipe.etudiants %}
                        <div class="member-card">
                            <div class="member-avatar">
                                {{ etudiant.prenom|slice(0, 1)|upper }}{{ etudiant.nom|slice(0, 1)|upper }}
                            </div>
                            <div class="member-info">
                                <div class="member-name">{{ etudiant.prenom }} {{ etudiant.nom }}</div>
                                <div class="member-details">{{ etudiant.email }}</div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>

            <div class="info-section">
                <h3>
                    <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    Participation Status
                </h3>
                <div class="status-explanation">
                    {% if participation.statut.value == 'ACCEPTE' %}
                        <h4 style="color: #22543d;">✓ Your participation has been accepted!</h4>
                        <p>Your team is registered for this event. See you there!</p>
                    {% elseif participation.statut.value == 'EN_ATTENTE' %}
                        <h4 style="color: #7c2d12;">⏳ Your participation is pending validation</h4>
                        <p>Your participation is being processed. You will be notified once validated.</p>
                    {% else %}
                        <h4 style="color: #742a2a;">✗ Your participation has been refused</h4>
                        <p>Your participation could not be accepted. Possible reasons:</p>
                        <ul>
                            <li>The event has reached its maximum capacity</li>
                            <li>One or more team members are already participating with another team</li>
                        </ul>
                    {% endif %}
                </div>
            </div>

            <div class="action-buttons">
                <a href="{{ path('app_mes_participations') }}" class="btn btn-secondary">
                    ← Back to My Participations
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
