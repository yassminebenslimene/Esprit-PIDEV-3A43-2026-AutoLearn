{% extends 'frontoffice/base.html.twig' %}

{% block title %}Mes participations{% endblock %}

{% block body %}
<div class="container" style="margin-top: 120px; margin-bottom: 80px;">
    <div class="row">
        <div class="col-lg-12">
            <div class="section-heading text-center">
                <h2>Mes participations</h2>
                <p>Suivez vos participations aux événements</p>
            </div>

            <div style="text-align: right; margin-bottom: 20px;">
                <a href="{{ path('app_participation_new') }}" class="btn btn-primary" style="background-color: #7a6ad8; border: none; padding: 12px 30px; border-radius: 5px; color: white; font-weight: 600; text-decoration: none;">
                    + Participer à un événement
                </a>
            </div>

            {% for message in app.flashes('success') %}
                <div class="alert alert-success" style="padding: 15px; background-color: #d4edda; border: 1px solid #c3e6cb; border-radius: 5px; margin-bottom: 20px;">
                    {{ message }}
                </div>
            {% endfor %}

            {% for message in app.flashes('warning') %}
                <div class="alert alert-warning" style="padding: 15px; background-color: #fff3cd; border: 1px solid #ffeaa7; border-radius: 5px; margin-bottom: 20px;">
                    {{ message }}
                </div>
            {% endfor %}

            {% for message in app.flashes('error') %}
                <div class="alert alert-danger" style="padding: 15px; background-color: #f8d7da; border: 1px solid #f5c6cb; border-radius: 5px; margin-bottom: 20px;">
                    {{ message }}
                </div>
            {% endfor %}

            {% if participations is empty %}
                <div style="text-align: center; padding: 60px; background: white; border-radius: 10px; box-shadow: 0 0 20px rgba(0,0,0,0.1);">
                    <h4>Vous n'avez pas encore de participation</h4>
                    <p>Inscrivez votre équipe à un événement !</p>
                    <a href="{{ path('app_participation_new') }}" class="btn btn-primary" style="background-color: #7a6ad8; border: none; padding: 12px 30px; border-radius: 5px; color: white; font-weight: 600; text-decoration: none; display: inline-block; margin-top: 20px;">
                        Participer à un événement
                    </a>
                </div>
            {% else %}
                <div class="row">
                    {% for participation in participations %}
                        <div class="col-lg-6" style="margin-bottom: 30px;">
                            <div style="background: white; padding: 30px; border-radius: 10px; box-shadow: 0 0 20px rgba(0,0,0,0.1); height: 100%;">
                                <h4 style="color: #7a6ad8; margin-bottom: 15px;">{{ participation.evenement.titre }}</h4>
                                
                                <p style="color: #666; margin-bottom: 8px;">
                                    <strong>Équipe:</strong> {{ participation.equipe.nom }}
                                </p>
                                <p style="color: #666; margin-bottom: 8px;">
                                    <strong>Lieu:</strong> {{ participation.evenement.lieu }}
                                </p>
                                <p style="color: #666; margin-bottom: 8px;">
                                    <strong>Date:</strong> {{ participation.evenement.dateDebut|date('d/m/Y H:i') }}
                                </p>
                                <p style="margin-bottom: 15px;">
                                    <strong>Statut:</strong> 
                                    {% if participation.statut.value == 'ACCEPTE' %}
                                        <span style="background-color: #d4edda; color: #155724; padding: 5px 15px; border-radius: 20px; font-size: 13px;">✓ Acceptée</span>
                                    {% elseif participation.statut.value == 'EN_ATTENTE' %}
                                        <span style="background-color: #fff3cd; color: #856404; padding: 5px 15px; border-radius: 20px; font-size: 13px;">⏳ En attente</span>
                                    {% else %}
                                        <span style="background-color: #f8d7da; color: #721c24; padding: 5px 15px; border-radius: 20px; font-size: 13px;">✗ Refusée</span>
                                    {% endif %}
                                </p>
                                
                                <div style="margin-top: 20px;">
                                    <a href="{{ path('app_participation_show', {'id': participation.id}) }}" class="btn btn-sm" style="background-color: #7a6ad8; padding: 8px 15px; border-radius: 5px; text-decoration: none; color: white;">
                                        Voir détails
                                    </a>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
