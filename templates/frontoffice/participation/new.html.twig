{% extends 'frontoffice/base.html.twig' %}

{% block title %}Participate in Event{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .form-section {
            padding: 120px 0 80px;
            background: linear-gradient(135deg, #48bb78 0%, #38a169 100%);
            min-height: 100vh;
        }
        
        .form-container {
            background: white;
            border-radius: 20px;
            padding: 50px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.2);
            max-width: 700px;
            margin: 0 auto;
        }
        
        .form-header {
            text-align: center;
            margin-bottom: 40px;
        }
        
        .form-header h1 {
            font-size: 36px;
            font-weight: 700;
            color: #2d3748;
            margin-bottom: 10px;
        }
        
        .form-header p {
            font-size: 16px;
            color: #718096;
        }
        
        .form-group {
            margin-bottom: 30px;
        }
        
        .form-label {
            display: block;
            font-weight: 600;
            color: #2d3748;
            margin-bottom: 10px;
            font-size: 15px;
        }
        
        .form-control {
            width: 100%;
            padding: 15px 20px;
            border: 2px solid #e2e8f0;
            border-radius: 10px;
            font-size: 15px;
            transition: all 0.3s ease;
            font-family: 'Poppins', sans-serif;
        }
        
        .form-control:focus {
            outline: none;
            border-color: #48bb78;
            box-shadow: 0 0 0 3px rgba(72, 187, 120, 0.1);
        }
        
        .form-help {
            margin-top: 8px;
            font-size: 14px;
            color: #718096;
            display: flex;
            align-items: start;
            gap: 8px;
        }
        
        .help-icon {
            color: #48bb78;
            font-weight: bold;
            flex-shrink: 0;
        }
        
        .info-box {
            background: #ebf8ff;
            border-left: 4px solid #48bb78;
            padding: 20px;
            border-radius: 8px;
            margin-bottom: 30px;
        }
        
        .info-box strong {
            color: #48bb78;
            display: block;
            margin-bottom: 10px;
            font-size: 16px;
        }
        
        .info-box ul {
            margin: 0;
            padding-left: 20px;
        }
        
        .info-box li {
            color: #4a5568;
            margin-bottom: 5px;
        }
        
        .form-actions {
            display: flex;
            gap: 15px;
            margin-top: 40px;
            justify-content: center;
        }
        
        .btn {
            padding: 15px 40px;
            border-radius: 10px;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s ease;
            border: none;
            cursor: pointer;
            font-size: 16px;
        }
        
        .btn-primary {
            background: linear-gradient(135deg, #48bb78 0%, #38a169 100%);
            color: white;
        }
        
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(72, 187, 120, 0.4);
        }
        
        .btn-secondary {
            background: #f7fafc;
            color: #4a5568;
            border: 2px solid #e2e8f0;
        }
        
        .btn-secondary:hover {
            background: #edf2f7;
        }
    </style>
{% endblock %}

{% block body %}
<div class="form-section">
    <div class="container">
        <div class="form-container">
            <div class="form-header">
                <h1>Participate in Event</h1>
                <p>Register your team for an event</p>
            </div>

            {% for message in app.flashes('success') %}
                <div style="background: #c6f6d5; color: #22543d; padding: 15px 20px; border-radius: 10px; margin-bottom: 20px; border-left: 4px solid #48bb78;">
                    ✓ {{ message }}
                </div>
            {% endfor %}

            {% for message in app.flashes('error') %}
                <div style="background: #fed7d7; color: #742a2a; padding: 15px 20px; border-radius: 10px; margin-bottom: 20px; border-left: 4px solid #fc8181;">
                    ✗ {{ message }}
                </div>
            {% endfor %}

            <div class="info-box">
                <strong>📋 Automatic Validation</strong>
                <ul>
                    <li>Your participation will be automatically validated if:</li>
                    <li>✓ The event has not reached its maximum capacity</li>
                    <li>✓ No team member is already participating with another team</li>
                </ul>
            </div>

            {{ form_start(form) }}
            
            <div class="form-group">
                {{ form_label(form.evenement, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.evenement) }}
                {{ form_errors(form.evenement) }}
                <div class="form-help">
                    <span class="help-icon">ℹ️</span>
                    <span>{{ form_help(form.evenement) }}</span>
                </div>
            </div>

            <div class="form-group">
                {{ form_label(form.equipe, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.equipe) }}
                {{ form_errors(form.equipe) }}
                <div class="form-help">
                    <span class="help-icon">ℹ️</span>
                    <span>{{ form_help(form.equipe) }}</span>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    🎯 Participate
                </button>
                <a href="{{ path('app_mes_participations') }}" class="btn btn-secondary">
                    ✗ Cancel
                </a>
            </div>

            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
