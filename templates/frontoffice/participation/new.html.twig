{% extends 'frontoffice/base.html.twig' %}

{% block title %}Participer à un événement{% endblock %}

{% block body %}
<div class="container" style="margin-top: 120px; margin-bottom: 80px;">
    <div class="row">
        <div class="col-lg-8 offset-lg-2">
            <div class="section-heading text-center">
                <h2>Participer à un événement</h2>
                <p>Inscrivez votre équipe à un événement</p>
            </div>

            <div class="contact-us" style="background: white; padding: 40px; border-radius: 10px; box-shadow: 0 0 20px rgba(0,0,0,0.1);">
                {{ form_start(form) }}
                
                <div class="row">
                    <div class="col-lg-12">
                        <fieldset>
                            {{ form_label(form.evenement) }}
                            {{ form_widget(form.evenement, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.evenement) }}
                            <small class="form-text text-muted">{{ form_help(form.evenement) }}</small>
                        </fieldset>
                    </div>

                    <div class="col-lg-12">
                        <fieldset>
                            {{ form_label(form.equipe) }}
                            {{ form_widget(form.equipe, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.equipe) }}
                            <small class="form-text text-muted">{{ form_help(form.equipe) }}</small>
                        </fieldset>
                    </div>

                    <div class="col-lg-12">
                        <div style="background: #fff3cd; padding: 15px; border-radius: 5px; margin-bottom: 20px;">
                            <strong>Note:</strong> Votre participation sera automatiquement validée si :
                            <ul style="margin-top: 10px; margin-bottom: 0;">
                                <li>L'événement n'a pas atteint sa capacité maximale</li>
                                <li>Aucun membre de votre équipe ne participe déjà avec une autre équipe</li>
                            </ul>
                        </div>
                    </div>

                    <div class="col-lg-12">
                        <fieldset>
                            <button type="submit" class="btn btn-primary" style="background-color: #7a6ad8; border: none; padding: 12px 30px; border-radius: 5px; color: white; font-weight: 600;">
                                Participer
                            </button>
                            <a href="{{ path('app_mes_participations') }}" class="btn btn-secondary" style="margin-left: 10px; padding: 12px 30px; border-radius: 5px;">
                                Annuler
                            </a>
                        </fieldset>
                    </div>
                </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>

<style>
    .form-control {
        width: 100%;
        padding: 12px 20px;
        margin: 8px 0;
        border: 1px solid #ddd;
        border-radius: 5px;
        font-size: 14px;
    }
    
    fieldset {
        margin-bottom: 20px;
    }
    
    label {
        font-weight: 600;
        color: #2a2a2a;
        margin-bottom: 8px;
        display: block;
    }
    
    .form-text {
        color: #666;
        font-size: 13px;
        margin-top: 5px;
    }
</style>
{% endblock %}
