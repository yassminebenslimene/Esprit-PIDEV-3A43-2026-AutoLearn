{% extends 'frontoffice/base.html.twig' %}

{% block title %}Edit Participation{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .form-section {
            padding: 120px 0 80px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
        }
        
        .form-container {
            background: white;
            border-radius: 20px;
            padding: 50px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.2);
            max-width: 800px;
            margin: 0 auto;
        }
        
        .form-header {
            text-align: center;
            margin-bottom: 40px;
        }
        
        .form-header h1 {
            font-size: 36px;
            font-weight: 700;
            color: #2d3748;
            margin-bottom: 10px;
        }
        
        .form-header p {
            font-size: 16px;
            color: #718096;
        }
        
        .form-group {
            margin-bottom: 30px;
        }
        
        .form-label {
            display: block;
            font-weight: 600;
            color: #2d3748;
            margin-bottom: 10px;
            font-size: 15px;
        }
        
        .form-control, .form-select {
            width: 100%;
            padding: 15px 20px;
            border: 2px solid #e2e8f0;
            border-radius: 10px;
            font-size: 15px;
            transition: all 0.3s ease;
            font-family: 'Poppins', sans-serif;
        }
        
        .form-control:focus, .form-select:focus {
            outline: none;
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }
        
        .form-help {
            margin-top: 8px;
            font-size: 14px;
            color: #718096;
        }
        
        .form-actions {
            display: flex;
            gap: 15px;
            margin-top: 40px;
            justify-content: center;
        }
        
        .btn {
            padding: 15px 40px;
            border-radius: 10px;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s ease;
            border: none;
            cursor: pointer;
            font-size: 16px;
        }
        
        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }
        
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(102, 126, 234, 0.4);
        }
        
        .btn-secondary {
            background: #f7fafc;
            color: #4a5568;
            border: 2px solid #e2e8f0;
        }
        
        .btn-secondary:hover {
            background: #edf2f7;
        }
        
        .form-error {
            color: #e53e3e;
            font-size: 14px;
            margin-top: 5px;
        }
        
        .info-box {
            background: #ebf4ff;
            border-left: 4px solid #667eea;
            padding: 15px 20px;
            border-radius: 8px;
            margin-bottom: 25px;
        }
        
        .info-box p {
            margin: 0;
            color: #4a5568;
            font-size: 14px;
        }
    </style>
{% endblock %}

{% block body %}
<div class="form-section">
    <div class="container">
        <div class="form-container">
            <div class="form-header">
                <h1>Edit Participation</h1>
                <p>Update your team's participation details</p>
            </div>

            <div class="info-box">
                <p><strong>Note:</strong> Changing the team or event will re-validate the participation according to event capacity and student availability rules.</p>
            </div>

            {{ form_start(form) }}
            
            <div class="form-group">
                {{ form_label(form.equipe, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.equipe, {'attr': {'class': 'form-select'}}) }}
                {{ form_errors(form.equipe) }}
                <div class="form-help">
                    Select the team participating in this event
                </div>
            </div>

            <div class="form-group">
                {{ form_label(form.evenement, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.evenement, {'attr': {'class': 'form-select'}}) }}
                {{ form_errors(form.evenement) }}
                <div class="form-help">
                    Select the event to participate in
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    ✓ Update Participation
                </button>
                <a href="{{ path('app_mes_participations') }}" class="btn btn-secondary">
                    ✗ Cancel
                </a>
            </div>

            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
