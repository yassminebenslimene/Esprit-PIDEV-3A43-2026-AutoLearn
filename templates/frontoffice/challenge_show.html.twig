{% extends 'frontoffice/base.html.twig' %}

{% block title %}{{ challenge.titre }} - Scholar{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .challenge-detail {
            margin-top: 120px;
            margin-bottom: 80px;
        }
        
        .challenge-card {
            background: white;
            border-radius: 20px;
            padding: 40px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            max-width: 600px;
            margin: 0 auto;
        }
        
        .challenge-title {
            font-size: 32px;
            font-weight: 700;
            color: #2a2a2a;
            margin-bottom: 30px;
            text-align: center;
        }
        
        .info-item {
            margin-bottom: 20px;
            padding: 15px;
            background: #f9f9f9;
            border-radius: 10px;
        }
        
        .info-label {
            font-size: 14px;
            color: #7a7a7a;
            margin-bottom: 5px;
        }
        
        .info-value {
            font-size: 18px;
            font-weight: 600;
            color: #2a2a2a;
        }
        
        .info-value i {
            margin-right: 10px;
            color: #7fb77e;
        }
        
        .niveau-badge {
            display: inline-block;
            padding: 5px 15px;
            border-radius: 20px;
            font-size: 14px;
            font-weight: 600;
        }
        
        .niveau-facile {
            background: #7fb77e;
            color: white;
        }
        
        .niveau-intermediaire {
            background: #f3b562;
            color: white;
        }
        
        .niveau-difficile {
            background: #f17b7b;
            color: white;
        }
        
        .btn-start, .btn-results {
            display: inline-block;
            padding: 12px 40px;
            border-radius: 25px;
            font-size: 16px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.3s;
            border: none;
            cursor: pointer;
            width: 100%;
            text-align: center;
            margin-top: 20px;
        }
        
        .btn-start {
            background: #7fb77e;
            color: white;
        }
        
        .btn-start:hover {
            background: #6da06c;
            color: white;
            transform: translateY(-2px);
        }
        
        .btn-results {
            background: #f3b562;
            color: white;
        }
        
        .btn-results:hover {
            background: #e0a451;
            color: white;
            transform: translateY(-2px);
        }
        
        .btn-start i, .btn-results i {
            margin-left: 10px;
        }
        
        .result-card {
            background: #f9f9f9;
            border-radius: 15px;
            padding: 20px;
            margin-top: 20px;
            border-left: 4px solid #7fb77e;
        }
        
        .result-score {
            font-size: 28px;
            font-weight: 700;
            color: #7fb77e;
            margin: 10px 0;
        }
        
        .back-button {
            display: inline-block;
            margin-top: 20px;
            padding: 10px 20px;
            background: #6c5ce7;
            color: white;
            text-decoration: none;
            border-radius: 25px;
            font-weight: 500;
            transition: all 0.3s;
        }
        
        .back-button:hover {
            background: #5a4ad1;
            transform: translateY(-2px);
            color: white;
        }
    </style>
{% endblock %}

{% block body %}
<div class="challenge-detail">
    <div class="container">
        <div class="challenge-card">
            <h1 class="challenge-title">{{ challenge.titre }}</h1>
            
            <!-- Date de début -->
            <div class="info-item">
                <div class="info-label">Date de début</div>
                <div class="info-value">
                    <i class="fa fa-calendar"></i>
                    {{ challenge.dateDebut|date('d/m/Y') }}
                </div>
            </div>
            
            <!-- Date de fin -->
            <div class="info-item">
                <div class="info-label">Date de fin</div>
                <div class="info-value">
                    <i class="fa fa-calendar-check-o"></i>
                    {{ challenge.dateFin|date('d/m/Y') }}
                </div>
            </div>
            
            <!-- Durée -->
            <div class="info-item">
                <div class="info-label">Durée</div>
                <div class="info-value">
                    <i class="fa fa-clock-o"></i>
                    {{ challenge.duree }} minutes
                </div>
            </div>
            
            <!-- Niveau -->
            <div class="info-item">
                <div class="info-label">Niveau</div>
                <div class="info-value">
                    <i class="fa fa-signal"></i>
                    <span class="niveau-badge 
                        {% if challenge.niveau == 'Facile' %}niveau-facile
                        {% elseif challenge.niveau == 'Intermédiaire' %}niveau-intermediaire
                        {% else %}niveau-difficile
                        {% endif %}">
                        {{ challenge.niveau }}
                    </span>
                </div>
            </div>
            
            {% if userChallenge and userChallenge.completed %}
                <!-- Résultat du challenge déjà complété -->
                <div class="result-card">
                    <h3 style="text-align: center; margin-bottom: 15px;">Votre résultat</h3>
                    <div style="text-align: center;">
                        <div class="result-score">{{ userChallenge.score }}/{{ userChallenge.totalPoints }}</div>
                        <p style="color: #7a7a7a;">Terminé le {{ userChallenge.completedAt|date('d/m/Y à H:i') }}</p>
                        
                        {% set percentage = (userChallenge.score / userChallenge.totalPoints * 100)|round %}
                        <p style="font-size: 16px;">
                            Pourcentage de réussite: 
                            <strong style="color: 
                                {% if percentage >= 80 %}#7fb77e
                                {% elseif percentage >= 50 %}#f3b562
                                {% else %}#f17b7b
                                {% endif %};">
                                {{ percentage }}%
                            </strong>
                        </p>
                    </div>
                    
                    <!-- Bouton Retour uniquement -->
                    <a href="{{ path('app_frontoffice') }}#challenge" class="btn-results">
                        Retour aux challenges <i class="fa fa-arrow-right"></i>
                    </a>
                </div>
            {% else %}
                <!-- Bouton commencer pour les nouveaux challenges -->
                <a href="{{ path('frontchallenge_play', {'id': challenge.id}) }}" class="btn-start">
                    Commencer le challenge <i class="fa fa-arrow-right"></i>
                </a>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
{% endblock %}