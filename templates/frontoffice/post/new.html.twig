{% extends 'base_front.html.twig' %}

{% block title %}Nouveau post | Scholar{% endblock %}

{% block body %}

<div class="page-heading header-text">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <h3>Nouveau post</h3>
                <span class="breadcrumb">
                    <a href="{{ path('app_frontoffice') }}">Home</a>
                    > Nouveau post
                </span>
            </div>
        </div>
    </div>
</div>

<style>
.post-form-container {
    max-width: 720px;
    margin: 80px auto;
}

.post-form-card {
    background: white;
    border-radius: 18px;
    padding: 30px;
    box-shadow: 0 12px 32px rgba(0,0,0,0.08);
}

.post-form-card textarea {
    width: 100%;
    min-height: 140px;
    border-radius: 12px;
    border: 1px solid #ddd;
    padding: 14px;
    resize: none;
    font-size: 15px;
}

.media-field {
    margin-top: 20px;
}

.media-field input[type="file"] {
    width: 100%;
    padding: 10px;
    border-radius: 12px;
    border: 1px dashed #7a6ad8;
    background: #f8f7ff;
    cursor: pointer;
}

.post-actions {
    display: flex;
    gap: 12px;
    margin-top: 30px;
}

.btn-publish {
    background: linear-gradient(135deg, #7a6ad8, #6c63ff);
    color: white;
    border: none;
    padding: 10px 26px;
    border-radius: 999px;
    font-weight: 500;
    cursor: pointer;
}

.btn-back {
    background: #f1f3ff;
    color: #333;
    padding: 10px 26px;
    border-radius: 999px;
    text-decoration: none;
    display: inline-block;
}
</style>

<div class="post-form-container">

    <div class="post-form-card">

        <h4>Créer un post</h4>

        {{ form_start(form) }}

        {# ===== TEXTE ===== #}
        {{ form_widget(form.contenu, {
            attr: { placeholder: 'Écris ton post ici...' }
        }) }}

        {# ================= IMAGE ================= #}
        <div class="media-field">
            {{ form_label(form.imageFileUpload, 'Uploader une image') }}
            {{ form_widget(form.imageFileUpload) }}
        </div>

        {# ================= VIDEO ================= #}
        <div class="media-field">
            {{ form_label(form.videoFileUpload, 'Uploader une vidéo') }}
            {{ form_widget(form.videoFileUpload) }}
        </div>

        {# ================= ACTIONS ================= #}
        <div class="post-actions">
            <button type="submit" class="btn-publish">
                Publier
            </button>

            <a href="{{ path('app_communaute_show', { id: communaute.id }) }}"
               class="btn-back">
                ← Retour à la communauté
            </a>
        </div>

        {{ form_end(form) }}

    </div>

</div>

{% endblock %}