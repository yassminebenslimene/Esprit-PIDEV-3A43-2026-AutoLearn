{% extends 'base_front.html.twig' %}

{% block title %}Modifier le post | Scholar{% endblock %}

{% block body %}

<!-- ===== PAGE HEADING ===== -->
<div class="page-heading header-text">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <h3>Modifier le post</h3>
                <span class="breadcrumb">
                    <a href="{{ path('app_frontoffice') }}">Home</a>
                    > Modifier le post
                </span>
            </div>
        </div>
    </div>
</div>

<style>
.post-form-container {
    max-width: 720px;
    margin: 80px auto;
}

.post-form-card {
    background: white;
    border-radius: 18px;
    padding: 30px;
    box-shadow: 0 12px 32px rgba(0,0,0,0.08);
}

.post-form-card h4 {
    margin-bottom: 22px;
}

/* textarea */
.post-form-card textarea {
    width: 100%;
    min-height: 140px;
    border-radius: 12px;
    border: 1px solid #ddd;
    padding: 14px;
    resize: none;
    font-size: 15px;
}

/* media fields */
.media-field {
    margin-top: 20px;
}

.media-field label {
    font-size: 14px;
    font-weight: 500;
    margin-bottom: 8px;
    display: block;
}

/* text inputs */
.media-field input[type="text"],
.media-field input[type="url"] {
    width: 100%;
    border-radius: 12px;
    border: 1px solid #ddd;
    padding: 10px 14px;
    font-size: 14px;
}

/* file upload */
.media-field input[type="file"] {
    width: 100%;
    padding: 10px;
    border-radius: 12px;
    border: 1px dashed #7a6ad8;
    background: #f8f7ff;
    cursor: pointer;
}

/* separator */
.media-separator {
    text-align: center;
    font-size: 13px;
    color: #999;
    margin: 14px 0;
}

/* actions */
.post-actions {
    display: flex;
    gap: 12px;
    margin-top: 30px;
    position: relative;
    z-index: 10;
}

.btn-publish {
    background: linear-gradient(135deg, #7a6ad8, #6c63ff);
    color: white;
    border: none;
    padding: 10px 26px;
    border-radius: 999px;
    font-weight: 500;
    cursor: pointer;
    position: relative;
    z-index: 10;
}

.btn-publish:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(122, 106, 216, 0.4);
}

.btn-back {
    background: #f1f3ff;
    color: #333;
    padding: 10px 26px;
    border-radius: 999px;
    text-decoration: none;
    display: inline-block;
    position: relative;
    z-index: 10;
}

.btn-back:hover {
    background: #e5e7ff;
    color: #333;
}
</style>

<div class="post-form-container">

    <div class="post-form-card">

        <h4>Modifier le post</h4>

        {{ form_start(form, {'attr': {'enctype': 'multipart/form-data'}}) }}

            {{ form_widget(form) }}

            <div class="post-actions">
                <button type="submit" class="btn-publish">
                    Mettre à jour
                </button>

                <a href="{{ path('app_communaute_show', { id: post.getCommunaute().getId() }) }}"
                   class="btn-back">
                    ← Retour à la communauté
                </a>
            </div>

        {{ form_end(form) }}

    </div>

</div>

<footer>
    <div class="container">
        <div class="col-lg-12">
            <p>Copyright © 2036 Scholar Organization. All rights reserved. &nbsp;&nbsp;&nbsp; Design: <a href="https://templatemo.com" rel="nofollow" target="_blank">TemplateMo</a></p>
        </div>
    </div>
</footer>

{% endblock %}
