{% extends 'frontoffice/base.html.twig' %}

{% block title %}{{ challenge.titre }} - Scholar{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .play-challenge {
            margin-top: 40px;
            margin-bottom: 80px;
        }
        
        .progress-container {
            background: white;
            padding: 20px;
            border-radius: 15px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            margin-bottom: 30px;
        }
        
        .progress-info {
            display: flex;
            justify-content: space-between;
            margin-bottom: 10px;
            color: #2a2a2a;
            font-weight: 500;
        }
        
        .progress-bar-container {
            width: 100%;
            height: 10px;
            background: #f0f0f0;
            border-radius: 10px;
            overflow: hidden;
        }
        
        .progress-bar-fill {
            height: 100%;
            background: linear-gradient(105deg, #7fb77e 0%, #4a9b4a 100%);
            border-radius: 10px;
            transition: width 0.3s ease;
        }
        
        .content-card {
            background: white;
            padding: 40px;
            border-radius: 20px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            margin-bottom: 30px;
        }
        
        .content-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            padding-bottom: 20px;
            border-bottom: 1px solid #f0f0f0;
        }
        
        .content-type {
            display: inline-block;
            padding: 8px 20px;
            border-radius: 25px;
            font-weight: 500;
        }
        
        .content-type.exercice {
            background: rgba(127, 183, 126, 0.1);
            color: #7fb77e;
        }
        
        .content-type.quiz {
            background: rgba(243, 181, 98, 0.1);
            color: #f3b562;
        }
        
        .content-index {
            font-size: 16px;
            color: #7a7a7a;
        }
        
        .content-index span {
            color: #7fb77e;
            font-weight: 600;
        }
        
        .content-body {
            margin-bottom: 30px;
        }
        
        .content-title {
            font-size: 24px;
            font-weight: 600;
            margin-bottom: 20px;
            color: #2a2a2a;
        }
        
        .content-text {
            font-size: 18px;
            color: #7a7a7a;
            margin-bottom: 30px;
        }
        
        .answer-area {
            margin: 30px 0;
        }
        
        .form-control {
            width: 100%;
            padding: 15px;
            border: 2px solid #f0f0f0;
            border-radius: 10px;
            font-size: 16px;
            transition: all 0.3s;
        }
        
        .form-control:focus {
            border-color: #7fb77e;
            outline: none;
            box-shadow: 0 0 0 3px rgba(127, 183, 126, 0.1);
        }
        
        .navigation-buttons {
            display: flex;
            justify-content: space-between;
            gap: 20px;
            margin-top: 30px;
        }
        
        .nav-btn {
            padding: 12px 30px;
            border-radius: 25px;
            font-weight: 500;
            text-decoration: none;
            transition: all 0.3s;
            border: none;
            cursor: pointer;
            font-size: 16px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }
        
        .nav-btn.prev {
            background: #f0f0f0;
            color: #2a2a2a;
        }
        
        .nav-btn.prev:hover {
            background: #e0e0e0;
            color: #2a2a2a;
        }
        
        .nav-btn.next {
            background: linear-gradient(105deg, #7fb77e 0%, #4a9b4a 100%);
            color: white;
        }
        
        .nav-btn.next:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(127, 183, 126, 0.3);
            color: white;
        }
        
        .nav-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }
        
        .quiz-options {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }
        
        .quiz-option {
            padding: 15px 20px;
            border: 2px solid #f0f0f0;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.3s;
        }
        
        .quiz-option:hover {
            border-color: #7fb77e;
            background: rgba(127, 183, 126, 0.05);
        }
        
        .quiz-option.selected {
            border-color: #7fb77e;
            background: rgba(127, 183, 126, 0.1);
        }
        
        .quiz-option input[type="radio"] {
            margin-right: 10px;
        }
        
        .question-points {
            font-size: 14px;
            color: #7fb77e;
            font-weight: 600;
            margin-top: 10px;
        }
        
        .question-block {
            margin-bottom: 30px;
            padding: 20px;
            background: #f9f9f9;
            border-radius: 10px;
        }
        
        .question-text {
            font-size: 18px;
            font-weight: 600;
            color: #2a2a2a;
            margin-bottom: 15px;
        }
        
        .quiz-questions {
            margin-top: 20px;
        }
        
        .save-indicator {
            font-size: 12px;
            color: #7a7a7a;
            margin-top: 10px;
            text-align: right;
            font-style: italic;
        }
        
        .header-buttons {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }
        
        .quit-btn {
            background: #f17b7b;
            color: white;
            padding: 8px 20px;
            border-radius: 25px;
            text-decoration: none;
            font-weight: 500;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }
        
        .quit-btn:hover {
            background: #e05a5a;
            transform: translateY(-2px);
            color: white;
        }
        
        .challenge-title-header {
            font-size: 24px;
            font-weight: 600;
            color: #2a2a2a;
        }
    </style>
{% endblock %}

{% block body %}
<div class="play-challenge">
    <div class="container">
        <div class="header-buttons">
            <a href="{{ path('frontchallenge', {'id': challenge.id}) }}" class="quit-btn">
                <i class="fa fa-arrow-left"></i> Retour
            </a>
            <div class="challenge-title-header">{{ challenge.titre }}</div>
            <div></div>
        </div>
        
        {% if currentItem %}
            <div class="progress-container">
                <div class="progress-info">
                    <span>Question {{ currentIndex + 1 }}/{{ totalItems }}</span>
                    <span>{{ ((currentIndex + 1) / totalItems * 100)|round }}% complété</span>
                </div>
                <div class="progress-bar-container">
                    <div class="progress-bar-fill" style="width: {{ ((currentIndex + 1) / totalItems * 100)|round }}%"></div>
                </div>
            </div>
            
            <div class="content-card">
                <div class="content-header">
                    <span class="content-type {{ currentType }}">
                        {% if currentType == 'exercice' %}
                            Exercice
                        {% else %}
                            Quiz
                        {% endif %}
                    </span>
                    <span class="content-index"><span>{{ currentIndex + 1 }}</span>/{{ totalItems }}</span>
                </div>
                
                <div class="content-body">
                    {% if currentType == 'exercice' %}
                        <h2 class="content-title">{{ currentItem.question }}</h2>
                        <div class="answer-area">
                            <input type="text" 
                                   class="form-control" 
                                   placeholder="Votre réponse..." 
                                   id="answer_{{ currentItem.id }}" 
                                   value="{% if sessionAnswers[currentItem.id] is defined %}{% if sessionAnswers[currentItem.id] is iterable and sessionAnswers[currentItem.id]['answer'] is defined %}{{ sessionAnswers[currentItem.id]['answer'] }}{% else %}{{ sessionAnswers[currentItem.id] }}{% endif %}{% endif %}"
                                   onchange="saveAnswer('{{ currentItem.id }}', this.value, 'exercice', {{ currentIndex }})">
                        </div>
                        <div class="question-points">Points: {{ currentItem.points }}</div>
                    {% else %}
                        <h2 class="content-title">{{ currentItem.titre }}</h2>
                        <p class="content-text">{{ currentItem.description }}</p>
                        <div class="quiz-questions">
                            {% if currentItem.questions is defined and currentItem.questions|length > 0 %}
                                {% for question in currentItem.questions %}
                                    <div class="question-block">
                                        <h3 class="question-text">{{ question.texteQuestion }}</h3>
                                        <div class="quiz-options" id="quizOptions_{{ question.id }}">
                                            {% for option in question.options %}
                                                {% set isSelected = false %}
                                                {% if sessionAnswers[question.id] is defined %}
                                                    {% if sessionAnswers[question.id] is iterable and sessionAnswers[question.id]['answer'] is defined %}
                                                        {% set isSelected = (sessionAnswers[question.id]['answer'] == option.id) %}
                                                    {% else %}
                                                        {% set isSelected = (sessionAnswers[question.id] == option.id) %}
                                                    {% endif %}
                                                {% endif %}
                                                <div class="quiz-option {% if isSelected %}selected{% endif %}" 
                                                     onclick="selectOption(this, 'opt{{ option.id }}', '{{ question.id }}', '{{ option.id }}', {{ currentIndex }})">
                                                    <input type="radio" 
                                                           name="question_{{ question.id }}" 
                                                           id="opt{{ option.id }}" 
                                                           value="{{ option.id }}" 
                                                           {% if isSelected %}checked{% endif %}>
                                                    <label for="opt{{ option.id }}">{{ option.texteOption }}</label>
                                                </div>
                                            {% endfor %}
                                        </div>
                                        <div class="question-points">Points: {{ question.point }}</div>
                                    </div>
                                {% endfor %}
                            {% else %}
                                <p>Aucune question disponible pour ce quiz</p>
                            {% endif %}
                        </div>
                    {% endif %}
                </div>
                
                <div class="save-indicator" id="saveIndicator">
                    <i class="fa fa-info-circle"></i> Les réponses sont automatiquement sauvegardées
                </div>
                
                <div class="navigation-buttons">
                    {% if currentIndex > 0 %}
                        <a href="javascript:void(0);" 
                           class="nav-btn prev" 
                           onclick="saveAndNavigate({{ currentIndex - 1 }}, '{{ path('frontchallenge_play', {'id': challenge.id, 'index': currentIndex - 1}) }}')">
                            <i class="fa fa-arrow-left"></i> Précédent
                        </a>
                    {% else %}
                        <button class="nav-btn prev" disabled>
                            <i class="fa fa-arrow-left"></i> Précédent
                        </button>
                    {% endif %}
                    
                    {% if currentIndex < totalItems - 1 %}
                        <a href="javascript:void(0);" 
                           class="nav-btn next" 
                           onclick="saveAndNavigate({{ currentIndex + 1 }}, '{{ path('frontchallenge_play', {'id': challenge.id, 'index': currentIndex + 1}) }}')">
                            Suivant <i class="fa fa-arrow-right"></i>
                        </a>
                    {% else %}
                        <a href="javascript:void(0);" 
                           class="nav-btn next" 
                           onclick="saveAndNavigate({{ totalItems }}, '{{ path('frontchallenge_complete', {'id': challenge.id}) }}')">
                            Terminer <i class="fa fa-check"></i>
                        </a>
                    {% endif %}
                </div>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    
    <script>
        let answers = {{ sessionAnswers|json_encode|raw }};
        let saveTimeout;
        let currentChallengeId = {{ challenge.id }};
        let currentIndex = {{ currentIndex }};
        
        function selectOption(element, inputId, questionId, answer, index) {
            const parentOptions = element.parentElement;
            parentOptions.querySelectorAll('.quiz-option').forEach(opt => {
                opt.classList.remove('selected');
            });
            
            element.classList.add('selected');
            document.getElementById(inputId).checked = true;
            saveAnswer(questionId, answer, 'quiz', index);
        }
        
        function saveAnswer(itemId, answer, type, index) {
            const indicator = document.getElementById('saveIndicator');
            indicator.innerHTML = '<i class="fa fa-spinner fa-spin"></i> Sauvegarde en cours...';
            indicator.style.color = '#7a7a7a';
            
            if (saveTimeout) {
                clearTimeout(saveTimeout);
            }
            
            currentIndex = index;
            
            fetch('{{ path('frontchallenge_save_answer') }}', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({
                    itemId: itemId,
                    answer: answer,
                    type: type,
                    challengeId: currentChallengeId,
                    currentIndex: index
                })
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error('Erreur HTTP: ' + response.status);
                }
                return response.json();
            })
            .then(data => {
                if (data.success) {
                    indicator.innerHTML = '<i class="fa fa-check-circle" style="color: #7fb77e;"></i> Réponse sauvegardée';
                    indicator.style.color = '#7fb77e';
                } else {
                    throw new Error(data.error || 'Erreur inconnue');
                }
                
                saveTimeout = setTimeout(() => {
                    indicator.innerHTML = '<i class="fa fa-info-circle"></i> Les réponses sont automatiquement sauvegardées';
                    indicator.style.color = '#7a7a7a';
                }, 3000);
            })
            .catch(error => {
                console.error('Erreur:', error);
                indicator.innerHTML = '<i class="fa fa-exclamation-circle" style="color: #f17b7b;"></i> Erreur: ' + error.message;
                indicator.style.color = '#f17b7b';
                
                saveTimeout = setTimeout(() => {
                    indicator.innerHTML = '<i class="fa fa-info-circle"></i> Les réponses sont automatiquement sauvegardées';
                    indicator.style.color = '#7a7a7a';
                }, 5000);
            });
        }
        
        function saveAndNavigate(index, url) {
            const indicator = document.getElementById('saveIndicator');
            indicator.innerHTML = '<i class="fa fa-spinner fa-spin"></i> Navigation...';
            indicator.style.color = '#7a7a7a';
            
            fetch('{{ path('frontchallenge_save_index') }}', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({
                    challengeId: currentChallengeId,
                    currentIndex: index
                })
            })
            .then(response => response.json())
            .then(data => {
                console.log('Index sauvegardé:', data);
                window.location.href = url;
            })
            .catch(error => {
                console.error('Erreur lors de la sauvegarde:', error);
                window.location.href = url;
            });
        }
    </script>
{% endblock %}
