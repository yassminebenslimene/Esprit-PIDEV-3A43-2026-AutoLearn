<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@100;200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">

    <title>{{ challenge.titre }} - Scholar</title>

    {% block stylesheets %}
        <!-- Bootstrap -->
        <link rel="stylesheet" href="{{ asset('frontoffice/vendor/bootstrap/css/bootstrap.min.css') }}">

        <!-- FrontOffice CSS -->
        <link rel="stylesheet" href="{{ asset('frontoffice/css/animate.css') }}">
        <link rel="stylesheet" href="{{ asset('frontoffice/css/flex-slider.css') }}">
        <link rel="stylesheet" href="{{ asset('frontoffice/css/fontawesome.css') }}">
        <link rel="stylesheet" href="{{ asset('frontoffice/css/owl.css') }}">
        <link rel="stylesheet" href="{{ asset('frontoffice/css/templatemo-scholar.css') }}">

        <!-- Swiper -->
        <link rel="stylesheet" href="https://unpkg.com/swiper@7/swiper-bundle.min.css"/>
        
        <style>
            .play-challenge {
                margin-top: 120px;
                margin-bottom: 80px;
            }
            
            /* Barre de progression */
            .progress-container {
                background: white;
                padding: 20px;
                border-radius: 15px;
                box-shadow: 0 5px 20px rgba(0,0,0,0.05);
                margin-bottom: 30px;
            }
            
            .progress-info {
                display: flex;
                justify-content: space-between;
                margin-bottom: 10px;
                color: #2a2a2a;
                font-weight: 500;
            }
            
            .progress-bar-container {
                width: 100%;
                height: 10px;
                background: #f0f0f0;
                border-radius: 10px;
                overflow: hidden;
            }
            
            .progress-bar-fill {
                height: 100%;
                background: linear-gradient(105deg, #7fb77e 0%, #4a9b4a 100%);
                border-radius: 10px;
                transition: width 0.3s ease;
            }
            
            /* Carte de contenu */
            .content-card {
                background: white;
                padding: 40px;
                border-radius: 20px;
                box-shadow: 0 5px 20px rgba(0,0,0,0.05);
                margin-bottom: 30px;
            }
            
            .content-header {
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-bottom: 30px;
                padding-bottom: 20px;
                border-bottom: 1px solid #f0f0f0;
            }
            
            .content-type {
                display: inline-block;
                padding: 8px 20px;
                border-radius: 25px;
                font-weight: 500;
            }
            
            .content-type.exercice {
                background: rgba(127, 183, 126, 0.1);
                color: #7fb77e;
            }
            
            .content-type.quiz {
                background: rgba(243, 181, 98, 0.1);
                color: #f3b562;
            }
            
            .content-index {
                font-size: 16px;
                color: #7a7a7a;
            }
            
            .content-index span {
                color: #7fb77e;
                font-weight: 600;
            }
            
            .content-body {
                margin-bottom: 30px;
            }
            
            .content-title {
                font-size: 24px;
                font-weight: 600;
                margin-bottom: 20px;
                color: #2a2a2a;
            }
            
            .content-text {
                font-size: 18px;
                color: #7a7a7a;
                margin-bottom: 30px;
            }
            
            /* Zone de réponse */
            .answer-area {
                margin: 30px 0;
            }
            
            .form-control {
                width: 100%;
                padding: 15px;
                border: 2px solid #f0f0f0;
                border-radius: 10px;
                font-size: 16px;
                transition: all 0.3s;
            }
            
            .form-control:focus {
                border-color: #7fb77e;
                outline: none;
                box-shadow: 0 0 0 3px rgba(127, 183, 126, 0.1);
            }
            
            /* Boutons de navigation */
            .navigation-buttons {
                display: flex;
                justify-content: space-between;
                gap: 20px;
                margin-top: 30px;
            }
            
            .nav-btn {
                padding: 12px 30px;
                border-radius: 25px;
                font-weight: 500;
                text-decoration: none;
                transition: all 0.3s;
                border: none;
                cursor: pointer;
                font-size: 16px;
                display: inline-flex;
                align-items: center;
                gap: 8px;
            }
            
            .nav-btn.prev {
                background: #f0f0f0;
                color: #2a2a2a;
            }
            
            .nav-btn.prev:hover {
                background: #e0e0e0;
                color: #2a2a2a;
            }
            
            .nav-btn.next {
                background: linear-gradient(105deg, #7fb77e 0%, #4a9b4a 100%);
                color: white;
            }
            
            .nav-btn.next:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(127, 183, 126, 0.3);
                color: white;
            }
            
            .nav-btn.quit {
                background: #f17b7b;
                color: white;
            }
            
            .nav-btn.quit:hover {
                background: #e05a5a;
                transform: translateY(-2px);
            }
            
            .nav-btn:disabled {
                opacity: 0.5;
                cursor: not-allowed;
            }
            
            /* Options pour les quiz */
            .quiz-options {
                display: flex;
                flex-direction: column;
                gap: 15px;
            }
            
            .quiz-option {
                padding: 15px 20px;
                border: 2px solid #f0f0f0;
                border-radius: 10px;
                cursor: pointer;
                transition: all 0.3s;
            }
            
            .quiz-option:hover {
                border-color: #7fb77e;
                background: rgba(127, 183, 126, 0.05);
            }
            
            .quiz-option.selected {
                border-color: #7fb77e;
                background: rgba(127, 183, 126, 0.1);
            }
            
            .quiz-option input[type="radio"] {
                margin-right: 10px;
            }
            
            .question-points {
                font-size: 14px;
                color: #7fb77e;
                font-weight: 600;
                margin-top: 10px;
            }
            
            .save-indicator {
                font-size: 12px;
                color: #7a7a7a;
                margin-top: 10px;
                text-align: right;
                font-style: italic;
            }
            
            .header-buttons {
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-bottom: 20px;
            }
            
            .quit-btn {
                background: #f17b7b;
                color: white;
                padding: 8px 20px;
                border-radius: 25px;
                text-decoration: none;
                font-weight: 500;
                transition: all 0.3s;
                display: inline-flex;
                align-items: center;
                gap: 8px;
            }
            
            .quit-btn:hover {
                background: #e05a5a;
                transform: translateY(-2px);
                color: white;
            }
        </style>
    {% endblock %}
</head>
<body>

<!-- ***** Header Area Start ***** -->
<header class="header-area header-sticky">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <nav class="main-nav">
                    <!-- ***** Logo Start ***** -->
                    <a href="{{ path('app_frontoffice') }}" class="logo">
                        <h1>Scholar</h1>
                    </a>
                    <!-- ***** Logo End ***** -->
                    <!-- ***** Menu Start ***** -->
                    <ul class="nav">
                        <li class="scroll-to-section"><a href="{{ path('app_frontoffice') }}">Home</a></li>
                        <li class="scroll-to-section"><a href="{{ path('frontchallenge', {'id': challenge.id}) }}">Retour au challenge</a></li>
                    </ul>   
                    <a class='menu-trigger'>
                        <span>Menu</span>
                    </a>
                    <!-- ***** Menu End ***** -->
                </nav>
            </div>
        </div>
    </div>
</header>
<!-- ***** Header Area End ***** -->

<div class="play-challenge">
    <div class="container">
        <div class="header-buttons">
            <a href="{{ path('app_frontoffice') }}" class="quit-btn">
                <i class="fa fa-sign-out"></i> Quitter
            </a>
            <div class="challenge-title">{{ challenge.titre }}</div>
        </div>
        
        {% if currentItem %}
            <!-- Barre de progression -->
            <div class="progress-container">
                <div class="progress-info">
                    <span>{{ currentIndex + 1 }}/{{ totalItems }}</span>
                    <span>{{ ((currentIndex + 1) / totalItems * 100)|round }}% complété</span>
                </div>
                <div class="progress-bar-container">
                    <div class="progress-bar-fill" style="width: {{ ((currentIndex + 1) / totalItems * 100)|round }}%"></div>
                </div>
            </div>
            
            <!-- Carte de contenu -->
            <div class="content-card">
                <div class="content-header">
                    <span class="content-type {{ currentType }}">{{ currentType == 'exercice' ? 'Exercice' : 'Quiz' }}</span>
                    <span class="content-index"><span>{{ currentIndex + 1 }}</span>/{{ totalItems }}</span>
                </div>
                
                <div class="content-body">
                    {% if currentType == 'exercice' %}
                        <h2 class="content-title">{{ currentItem.question }}</h2>
                        <div class="answer-area">
                            <input type="text" class="form-control" placeholder="Votre réponse..." id="answer_{{ currentItem.id }}" 
                                   value="{{ sessionAnswers[currentItem.id]['answer'] is defined ? sessionAnswers[currentItem.id]['answer'] : '' }}"
                                   onchange="saveAnswer('{{ currentItem.id }}', this.value, 'exercice', {{ currentIndex }})">
                        </div>
                        <div class="question-points">Points: {{ currentItem.points }}</div>
                    {% else %}
                        <h2 class="content-title">{{ currentItem.titre }}</h2>
                        <p class="content-text">{{ currentItem.description }}</p>
                        <div class="quiz-options" id="quizOptions">
                            {% if currentItem.questions is defined and currentItem.questions|length > 0 %}
                                {% for question in currentItem.questions %}
                                    <div class="quiz-option {% if sessionAnswers[question.id] is defined %}selected{% endif %}" 
                                         onclick="selectOption(this, 'q{{ question.id }}', '{{ question.id }}', '{{ question.reponse }}', {{ currentIndex }})">
                                        <input type="radio" name="question_{{ currentItem.id }}" id="q{{ question.id }}" 
                                               value="{{ question.reponse }}" 
                                               {% if sessionAnswers[question.id] is defined %}checked{% endif %}>
                                        <label for="q{{ question.id }}">{{ question.question }}</label>
                                    </div>
                                {% endfor %}
                            {% else %}
                                <p>Aucune question disponible pour ce quiz</p>
                            {% endif %}
                        </div>
                    {% endif %}
                </div>
                
                <!-- Indicateur de sauvegarde -->
                <div class="save-indicator" id="saveIndicator">
                    <i class="fa fa-info-circle"></i> Les réponses sont automatiquement sauvegardées
                </div>
                
                <!-- Boutons de navigation -->
                <div class="navigation-buttons">
                    {% if currentIndex > 0 %}
                        <a href="javascript:void(0);" 
                           class="nav-btn prev" 
                           onclick="saveAndNavigate({{ currentIndex - 1 }}, '{{ path('frontchallenge_play', {'id': challenge.id, 'index': currentIndex - 1}) }}')">
                            <i class="fa fa-arrow-left"></i> Précédent
                        </a>
                    {% else %}
                        <button class="nav-btn prev" disabled>
                            <i class="fa fa-arrow-left"></i> Précédent
                        </button>
                    {% endif %}
                    
                    {% if currentIndex < totalItems - 1 %}
                        <a href="javascript:void(0);" 
                           class="nav-btn next" 
                           onclick="saveAndNavigate({{ currentIndex + 1 }}, '{{ path('frontchallenge_play', {'id': challenge.id, 'index': currentIndex + 1}) }}')">
                            Suivant <i class="fa fa-arrow-right"></i>
                        </a>
                    {% else %}
                        <a href="javascript:void(0);" 
                           class="nav-btn next" 
                           onclick="saveAndNavigate({{ totalItems }}, '{{ path('frontchallenge_complete', {'id': challenge.id}) }}')">
                            Terminer <i class="fa fa-check"></i>
                        </a>
                    {% endif %}
                </div>
            </div>
        {% endif %}
    </div>
</div>

<footer>
    <div class="container">
        <div class="col-lg-12">
            <p>Copyright © 2036 Scholar Organization. All rights reserved.</p>
        </div>
    </div>
</footer>

{% block javascripts %}
    <!-- jQuery -->
    <script src="{{ asset('frontoffice/vendor/jquery/jquery.min.js') }}"></script>
    
    <!-- Bootstrap -->
    <script src="{{ asset('frontoffice/vendor/bootstrap/js/bootstrap.bundle.min.js') }}"></script>
    
    <!-- Custom JS -->
    <script src="{{ asset('frontoffice/js/custom.js') }}"></script>
    
    <script>
        let answers = {{ sessionAnswers|json_encode|raw }};
        let saveTimeout;
        let currentChallengeId = {{ challenge.id }};
        let currentIndex = {{ currentIndex }};
        
        function selectOption(element, inputId, questionId, answer, index) {
            // Désélectionner toutes les options
            document.querySelectorAll('.quiz-option').forEach(opt => {
                opt.classList.remove('selected');
            });
            
            // Sélectionner l'option cliquée
            element.classList.add('selected');
            
            // Cocher le radio button
            document.getElementById(inputId).checked = true;
            
            // Sauvegarder la réponse
            saveAnswer(questionId, answer, 'quiz', index);
        }
        
        function saveAnswer(itemId, answer, type, index) {
            // Afficher l'indicateur de sauvegarde
            const indicator = document.getElementById('saveIndicator');
            indicator.innerHTML = '<i class="fa fa-spinner fa-spin"></i> Sauvegarde en cours...';
            indicator.style.color = '#7a7a7a';
            
            // Annuler le timeout précédent
            if (saveTimeout) {
                clearTimeout(saveTimeout);
            }
            
            // Mettre à jour l'index courant
            currentIndex = index;
            
            // Envoyer la réponse au serveur via AJAX
            fetch('{{ path('frontchallenge_save_answer') }}', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({
                    itemId: itemId,
                    answer: answer,
                    type: type,
                    challengeId: currentChallengeId,
                    currentIndex: index
                })
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error('Erreur HTTP: ' + response.status);
                }
                return response.json();
            })
            .then(data => {
                if (data.success) {
                    // Mettre à jour l'indicateur
                    indicator.innerHTML = '<i class="fa fa-check-circle" style="color: #7fb77e;"></i> Réponse sauvegardée';
                    indicator.style.color = '#7fb77e';
                } else {
                    throw new Error(data.error || 'Erreur inconnue');
                }
                
                // Cache l'indicateur après 3 secondes
                saveTimeout = setTimeout(() => {
                    indicator.innerHTML = '<i class="fa fa-info-circle"></i> Les réponses sont automatiquement sauvegardées';
                    indicator.style.color = '#7a7a7a';
                }, 3000);
            })
            .catch(error => {
                console.error('Erreur:', error);
                indicator.innerHTML = '<i class="fa fa-exclamation-circle" style="color: #f17b7b;"></i> Erreur: ' + error.message;
                indicator.style.color = '#f17b7b';
                
                // Cache l'erreur après 5 secondes
                saveTimeout = setTimeout(() => {
                    indicator.innerHTML = '<i class="fa fa-info-circle"></i> Les réponses sont automatiquement sauvegardées';
                    indicator.style.color = '#7a7a7a';
                }, 5000);
            });
        }
        
        function saveAndNavigate(index, url) {
            // Afficher un indicateur de chargement
            const indicator = document.getElementById('saveIndicator');
            indicator.innerHTML = '<i class="fa fa-spinner fa-spin"></i> Navigation...';
            indicator.style.color = '#7a7a7a';
            
            // Sauvegarder l'index
            fetch('{{ path('frontchallenge_save_index') }}', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({
                    challengeId: currentChallengeId,
                    currentIndex: index
                })
            })
            .then(response => response.json())
            .then(data => {
                console.log('Index sauvegardé:', data);
                // Rediriger vers la nouvelle page
                window.location.href = url;
            })
            .catch(error => {
                console.error('Erreur lors de la sauvegarde:', error);
                // Rediriger quand même en cas d'erreur
                window.location.href = url;
            });
        }
    </script>
{% endblock %}

</body>
</html>