{% extends 'frontoffice/base.html.twig' %}

{% block title %}Calendrier des Événements{% endblock %}

{% block body %}
<div class="page-heading" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 80px 0 40px; margin-top: 80px;">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div style="text-align: center; color: white;">
                    <h2 style="font-size: 48px; font-weight: 700; margin-bottom: 15px; text-shadow: 2px 2px 4px rgba(0,0,0,0.2);">
                        📅 Calendrier des Événements
                    </h2>
                    <p style="font-size: 18px; opacity: 0.95;">
                        Vue d'ensemble de tous les événements à venir
                    </p>
                    <div style="margin-top: 25px;">
                        <a href="{{ path('app_events') }}" class="btn" style="background: white; color: #667eea; padding: 14px 32px; border-radius: 25px; text-decoration: none; font-weight: 600; box-shadow: 0 5px 15px rgba(0,0,0,0.2); transition: all 0.3s; display: inline-block;">
                            📋 Retour à la Vue Liste
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container" style="margin-top: 40px; margin-bottom: 50px;">

    {# Légende des couleurs #}
    <div style="background: white; padding: 25px; border-radius: 15px; margin-bottom: 25px; box-shadow: 0 5px 20px rgba(0,0,0,0.08);">
        <h3 style="margin: 0 0 20px 0; color: #667eea; font-size: 18px; font-weight: 700; font-family: 'Poppins', sans-serif;">
            🎨 Légende des Types d'Événements
        </h3>
        <div style="display: flex; flex-wrap: wrap; gap: 20px;">
            <div style="display: flex; align-items: center; gap: 10px;">
                <div style="width: 24px; height: 24px; background: #667eea; border-radius: 6px; box-shadow: 0 2px 4px rgba(102, 126, 234, 0.3);"></div>
                <span style="font-size: 15px; font-weight: 500; color: #333;">Workshop</span>
            </div>
            <div style="display: flex; align-items: center; gap: 10px;">
                <div style="width: 24px; height: 24px; background: #f093fb; border-radius: 6px; box-shadow: 0 2px 4px rgba(240, 147, 251, 0.3);"></div>
                <span style="font-size: 15px; font-weight: 500; color: #333;">Conference</span>
            </div>
            <div style="display: flex; align-items: center; gap: 10px;">
                <div style="width: 24px; height: 24px; background: #4facfe; border-radius: 6px; box-shadow: 0 2px 4px rgba(79, 172, 254, 0.3);"></div>
                <span style="font-size: 15px; font-weight: 500; color: #333;">Hackathon</span>
            </div>
            <div style="display: flex; align-items: center; gap: 10px;">
                <div style="width: 24px; height: 24px; background: #43e97b; border-radius: 6px; box-shadow: 0 2px 4px rgba(67, 233, 123, 0.3);"></div>
                <span style="font-size: 15px; font-weight: 500; color: #333;">Seminar</span>
            </div>
            <div style="display: flex; align-items: center; gap: 10px;">
                <div style="width: 24px; height: 24px; background: #95a5a6; border-radius: 6px; box-shadow: 0 2px 4px rgba(149, 165, 166, 0.3);"></div>
                <span style="font-size: 15px; font-weight: 500; color: #333;">Annulé</span>
            </div>
            <div style="display: flex; align-items: center; gap: 10px;">
                <div style="width: 24px; height: 24px; background: #7fb77e; border-radius: 6px; box-shadow: 0 2px 4px rgba(127, 183, 126, 0.3);"></div>
                <span style="font-size: 15px; font-weight: 500; color: #333;">Passé</span>
            </div>
        </div>
    </div>

    {# Calendrier #}
    <div style="background: white; padding: 35px; border-radius: 15px; box-shadow: 0 5px 20px rgba(0,0,0,0.08);">
        <div id="calendar-loading" style="text-align: center; padding: 60px;">
            <div style="display: inline-block; width: 60px; height: 60px; border: 6px solid rgba(102, 126, 234, 0.2); border-top-color: #667eea; border-radius: 50%; animation: spin 1s linear infinite;"></div>
            <p style="margin-top: 20px; color: #666; font-size: 16px; font-weight: 500;">Chargement du calendrier...</p>
        </div>
        
        <div id="calendar" style="display: none;"></div>
    </div>
</div>

{# Styles CSS #}
<style>
@keyframes spin {
    to { transform: rotate(360deg); }
}

/* Personnalisation du calendrier */
#calendar {
    font-family: 'Poppins', sans-serif;
}

/* Toolbar du calendrier */
.fc-toolbar {
    margin-bottom: 25px !important;
    padding: 15px !important;
    background: #f8f9fa !important;
    border-radius: 12px !important;
}

/* Boutons du calendrier - Espacement amélioré */
.fc-button {
    background: linear-gradient(135deg, #667eea, #764ba2) !important;
    border: none !important;
    padding: 10px 18px !important;
    border-radius: 8px !important;
    text-transform: capitalize !important;
    margin: 0 4px !important;
    font-weight: 500 !important;
    font-size: 14px !important;
}

.fc-button:hover {
    opacity: 0.9 !important;
    transform: translateY(-1px) !important;
    box-shadow: 0 4px 8px rgba(102, 126, 234, 0.3) !important;
}

.fc-button-active {
    background: linear-gradient(135deg, #764ba2, #667eea) !important;
    box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4) !important;
}

/* Groupe de boutons - Espacement */
.fc-button-group {
    gap: 5px !important;
}

.fc-button-group .fc-button {
    margin: 0 2px !important;
}

/* Titre du calendrier */
.fc-toolbar-title {
    font-size: 26px !important;
    color: #333 !important;
    font-weight: 700 !important;
    font-family: 'Poppins', sans-serif !important;
}

/* Événements */
.fc-event {
    cursor: pointer !important;
    border-radius: 6px !important;
    padding: 4px 6px !important;
    font-size: 13px !important;
    font-weight: 500 !important;
    border: none !important;
}

.fc-event:hover {
    opacity: 0.85 !important;
    transform: translateY(-2px) !important;
    transition: all 0.2s !important;
    box-shadow: 0 4px 8px rgba(0,0,0,0.15) !important;
}

/* En-têtes des jours */
.fc-col-header-cell {
    background: linear-gradient(135deg, #f8f9fa, #e9ecef) !important;
    font-weight: 600 !important;
    color: #667eea !important;
    padding: 12px 8px !important;
    border: none !important;
}

/* Aujourd'hui */
.fc-day-today {
    background: rgba(102, 126, 234, 0.08) !important;
}

.fc-day-today .fc-daygrid-day-number {
    background: #667eea !important;
    color: white !important;
    border-radius: 50% !important;
    width: 32px !important;
    height: 32px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    margin: 4px auto !important;
}

/* Cellules du calendrier */
.fc-daygrid-day {
    transition: background 0.2s !important;
}

.fc-daygrid-day:hover {
    background: rgba(102, 126, 234, 0.03) !important;
}

/* Responsive */
@media (max-width: 768px) {
    .fc-toolbar {
        flex-direction: column !important;
        gap: 15px !important;
    }
    
    .fc-toolbar-chunk {
        display: flex !important;
        justify-content: center !important;
        width: 100% !important;
    }
    
    .fc-button {
        padding: 8px 12px !important;
        font-size: 12px !important;
    }
    
    .fc-toolbar-title {
        font-size: 20px !important;
    }
}

/* Modal de détails */
.event-modal {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0,0,0,0.75);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10000;
    animation: fadeIn 0.3s;
    padding: 20px;
}

@keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
}

.event-modal-content {
    background: white;
    border-radius: 20px;
    max-width: 650px;
    width: 100%;
    max-height: 85vh;
    overflow-y: auto;
    animation: slideUp 0.3s;
    box-shadow: 0 20px 60px rgba(0,0,0,0.3);
}

@keyframes slideUp {
    from { transform: translateY(50px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
}

.event-modal-header {
    padding: 30px;
    border-bottom: 2px solid #f0f0f0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border-radius: 20px 20px 0 0;
}

.event-modal-header h2 {
    margin: 0;
    color: white;
    font-size: 26px;
    font-weight: 700;
    font-family: 'Poppins', sans-serif;
}

.close-btn {
    background: rgba(255,255,255,0.2);
    border: none;
    font-size: 28px;
    cursor: pointer;
    color: white;
    line-height: 1;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
}

.close-btn:hover {
    background: rgba(255,255,255,0.3);
    transform: rotate(90deg);
}

.event-modal-body {
    padding: 30px;
}

.event-detail {
    margin: 20px 0;
    display: flex;
    align-items: start;
    gap: 15px;
    padding: 15px;
    background: #f8f9fa;
    border-radius: 12px;
    transition: all 0.2s;
}

.event-detail:hover {
    background: #e9ecef;
    transform: translateX(5px);
}

.event-detail-icon {
    font-size: 24px;
    min-width: 35px;
    text-align: center;
}

.event-detail-content {
    flex: 1;
}

.event-detail-label {
    font-weight: 700;
    color: #667eea;
    margin-bottom: 6px;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.event-detail-value {
    color: #333;
    font-size: 15px;
    line-height: 1.6;
}

.status-badge {
    display: inline-block;
    padding: 8px 16px;
    border-radius: 25px;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.status-planifie {
    background: linear-gradient(135deg, rgba(102, 126, 234, 0.2), rgba(102, 126, 234, 0.3));
    color: #667eea;
}

.status-en-cours {
    background: linear-gradient(135deg, rgba(67, 233, 123, 0.2), rgba(67, 233, 123, 0.3));
    color: #43e97b;
}

.status-passe {
    background: linear-gradient(135deg, rgba(127, 183, 126, 0.2), rgba(127, 183, 126, 0.3));
    color: #7fb77e;
}

.status-annule {
    background: linear-gradient(135deg, rgba(149, 165, 166, 0.2), rgba(149, 165, 166, 0.3));
    color: #95a5a6;
}

.event-modal-footer {
    padding: 25px 30px;
    border-top: 2px solid #f0f0f0;
    display: flex;
    gap: 12px;
    justify-content: flex-end;
    background: #f8f9fa;
    border-radius: 0 0 20px 20px;
}

.btn-modal {
    padding: 12px 28px;
    border-radius: 25px;
    text-decoration: none;
    border: none;
    cursor: pointer;
    font-size: 15px;
    font-weight: 600;
    transition: all 0.3s;
    font-family: 'Poppins', sans-serif;
}

.btn-primary-modal {
    background: linear-gradient(135deg, #667eea, #764ba2);
    color: white;
    box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);
}

.btn-primary-modal:hover {
    transform: translateY(-3px);
    box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
}

.btn-secondary-modal {
    background: white;
    color: #666;
    border: 2px solid #e0e0e0;
}

.btn-secondary-modal:hover {
    background: #f0f0f0;
    border-color: #d0d0d0;
}

/* Responsive Modal */
@media (max-width: 768px) {
    .event-modal {
        padding: 10px;
    }
    
    .event-modal-content {
        max-height: 90vh;
    }
    
    .event-modal-header {
        padding: 20px;
    }
    
    .event-modal-header h2 {
        font-size: 20px;
    }
    
    .event-modal-body {
        padding: 20px;
    }
    
    .event-detail {
        padding: 12px;
        margin: 15px 0;
    }
    
    .event-modal-footer {
        padding: 20px;
        flex-direction: column;
    }
    
    .btn-modal {
        width: 100%;
        text-align: center;
    }
}
</style>

{# JavaScript pour le calendrier #}
{% block javascripts %}
    {{ parent() }}
    
    {# Charger FullCalendar depuis CDN #}
    <link href='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.css' rel='stylesheet' />
    <script src='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.js'></script>
    <script src='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/locales/fr.global.min.js'></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var calendarEl = document.getElementById('calendar');
            
            var calendar = new FullCalendar.Calendar(calendarEl, {
                // Configuration de base
                locale: 'fr',
                initialView: 'dayGridMonth',
                headerToolbar: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'dayGridMonth,timeGridWeek,timeGridDay,listMonth'
                },
                buttonText: {
                    today: "Aujourd'hui",
                    month: 'Mois',
                    week: 'Semaine',
                    day: 'Jour',
                    list: 'Liste'
                },
                
                // Hauteur
                height: 'auto',
                
                // Premier jour = Lundi
                firstDay: 1,
                
                // Charger les événements depuis le CalendarBundle
                events: '{{ path('fc_load_events') }}',
                
                // Clic sur un événement
                eventClick: function(info) {
                    info.jsEvent.preventDefault();
                    showEventModal(info.event);
                },
                
                // Loading
                loading: function(isLoading) {
                    document.getElementById('calendar-loading').style.display = isLoading ? 'block' : 'none';
                    document.getElementById('calendar').style.display = isLoading ? 'none' : 'block';
                },
                
                // Format de l'heure
                eventTimeFormat: {
                    hour: '2-digit',
                    minute: '2-digit',
                    hour12: false
                }
            });
            
            calendar.render();
        });
        
        // Fonction pour afficher la modal de détails
        function showEventModal(event) {
            const props = event.extendedProps;
            
            // Déterminer la classe CSS du statut
            let statusClass = 'status-planifie';
            if (props.status === 'En cours') statusClass = 'status-en-cours';
            else if (props.status === 'Passé') statusClass = 'status-passe';
            else if (props.status === 'Annulé') statusClass = 'status-annule';
            
            const modal = `
                <div class="event-modal" id="event-modal" onclick="closeModalOnBackdrop(event)">
                    <div class="event-modal-content" onclick="event.stopPropagation()">
                        <div class="event-modal-header">
                            <h2>${event.title}</h2>
                            <button onclick="closeModal()" class="close-btn">×</button>
                        </div>
                        <div class="event-modal-body">
                            <div class="event-detail">
                                <div class="event-detail-icon">🏷️</div>
                                <div class="event-detail-content">
                                    <div class="event-detail-label">Type</div>
                                    <div class="event-detail-value">${props.type || 'N/A'}</div>
                                </div>
                            </div>
                            
                            <div class="event-detail">
                                <div class="event-detail-icon">📍</div>
                                <div class="event-detail-content">
                                    <div class="event-detail-label">Lieu</div>
                                    <div class="event-detail-value">${props.lieu || 'N/A'}</div>
                                </div>
                            </div>
                            
                            <div class="event-detail">
                                <div class="event-detail-icon">📅</div>
                                <div class="event-detail-content">
                                    <div class="event-detail-label">Début</div>
                                    <div class="event-detail-value">${event.start.toLocaleString('fr-FR')}</div>
                                </div>
                            </div>
                            
                            <div class="event-detail">
                                <div class="event-detail-icon">🏁</div>
                                <div class="event-detail-content">
                                    <div class="event-detail-label">Fin</div>
                                    <div class="event-detail-value">${event.end ? event.end.toLocaleString('fr-FR') : 'N/A'}</div>
                                </div>
                            </div>
                            
                            <div class="event-detail">
                                <div class="event-detail-icon">📊</div>
                                <div class="event-detail-content">
                                    <div class="event-detail-label">Statut</div>
                                    <div class="event-detail-value">
                                        <span class="status-badge ${statusClass}">${props.status || 'N/A'}</span>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="event-detail">
                                <div class="event-detail-icon">👥</div>
                                <div class="event-detail-content">
                                    <div class="event-detail-label">Participations</div>
                                    <div class="event-detail-value">${props.nbParticipations || 0} / ${props.nbMax || 0} équipes</div>
                                </div>
                            </div>
                            
                            <div class="event-detail">
                                <div class="event-detail-icon">📝</div>
                                <div class="event-detail-content">
                                    <div class="event-detail-label">Description</div>
                                    <div class="event-detail-value">${props.description || 'Aucune description'}</div>
                                </div>
                            </div>
                        </div>
                        <div class="event-modal-footer">
                            <button onclick="closeModal()" class="btn-modal btn-secondary-modal">Fermer</button>
                            ${props.url ? `<a href="${props.url}" class="btn-modal btn-primary-modal">Voir les détails</a>` : ''}
                        </div>
                    </div>
                </div>
            `;
            
            document.body.insertAdjacentHTML('beforeend', modal);
        }
        
        // Fermer la modal
        function closeModal() {
            const modal = document.getElementById('event-modal');
            if (modal) {
                modal.style.animation = 'fadeOut 0.3s';
                setTimeout(() => modal.remove(), 300);
            }
        }
        
        // Fermer en cliquant sur le fond
        function closeModalOnBackdrop(event) {
            if (event.target.id === 'event-modal') {
                closeModal();
            }
        }
        
        // Fermer avec Escape
        document.addEventListener('keydown', function(event) {
            if (event.key === 'Escape') {
                closeModal();
            }
        });
    </script>
{% endblock %}
{% endblock %}
