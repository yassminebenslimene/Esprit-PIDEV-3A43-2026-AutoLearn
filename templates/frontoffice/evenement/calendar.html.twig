{% extends 'frontoffice/base.html.twig' %}

{% block title %}Calendrier des Événements{% endblock %}

{% block body %}
<div class="container" style="margin-top: 100px; margin-bottom: 50px;">
    {# En-tête avec titre et boutons #}
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
        <div>
            <h1 style="color: #667eea; margin: 0; font-size: 32px;">
                📅 Calendrier des Événements
            </h1>
            <p style="color: #666; margin-top: 10px;">
                Vue d'ensemble de tous les événements à venir
            </p>
        </div>
        <div style="display: flex; gap: 10px;">
            <a href="{{ path('app_events') }}" class="btn" style="background: linear-gradient(135deg, #667eea, #764ba2); color: white; padding: 12px 24px; border-radius: 8px; text-decoration: none;">
                📋 Vue Liste
            </a>
        </div>
    </div>

    {# Légende des couleurs #}
    <div style="background: white; padding: 20px; border-radius: 12px; margin-bottom: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
        <h3 style="margin: 0 0 15px 0; color: #333; font-size: 16px;">🎨 Légende des couleurs</h3>
        <div style="display: flex; flex-wrap: wrap; gap: 15px;">
            <div style="display: flex; align-items: center; gap: 8px;">
                <div style="width: 20px; height: 20px; background: #667eea; border-radius: 4px;"></div>
                <span style="font-size: 14px;">Workshop</span>
            </div>
            <div style="display: flex; align-items: center; gap: 8px;">
                <div style="width: 20px; height: 20px; background: #f093fb; border-radius: 4px;"></div>
                <span style="font-size: 14px;">Conference</span>
            </div>
            <div style="display: flex; align-items: center; gap: 8px;">
                <div style="width: 20px; height: 20px; background: #4facfe; border-radius: 4px;"></div>
                <span style="font-size: 14px;">Hackathon</span>
            </div>
            <div style="display: flex; align-items: center; gap: 8px;">
                <div style="width: 20px; height: 20px; background: #43e97b; border-radius: 4px;"></div>
                <span style="font-size: 14px;">Seminar</span>
            </div>
            <div style="display: flex; align-items: center; gap: 8px;">
                <div style="width: 20px; height: 20px; background: #95a5a6; border-radius: 4px;"></div>
                <span style="font-size: 14px;">Annulé</span>
            </div>
            <div style="display: flex; align-items: center; gap: 8px;">
                <div style="width: 20px; height: 20px; background: #7fb77e; border-radius: 4px;"></div>
                <span style="font-size: 14px;">Passé</span>
            </div>
        </div>
    </div>

    {# Calendrier #}
    <div style="background: white; padding: 30px; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
        <div id="calendar-loading" style="text-align: center; padding: 40px;">
            <div style="display: inline-block; width: 50px; height: 50px; border: 5px solid rgba(102, 126, 234, 0.2); border-top-color: #667eea; border-radius: 50%; animation: spin 1s linear infinite;"></div>
            <p style="margin-top: 15px; color: #666;">Chargement du calendrier...</p>
        </div>
        
        <div id="calendar"></div>
    </div>
</div>

{# Styles CSS #}
<style>
@keyframes spin {
    to { transform: rotate(360deg); }
}

/* Personnalisation du calendrier */
#calendar {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
}

/* Boutons du calendrier */
.fc-button {
    background: linear-gradient(135deg, #667eea, #764ba2) !important;
    border: none !important;
    padding: 8px 16px !important;
    border-radius: 8px !important;
    text-transform: capitalize !important;
}

.fc-button:hover {
    opacity: 0.9 !important;
}

.fc-button-active {
    background: linear-gradient(135deg, #764ba2, #667eea) !important;
}

/* Titre du calendrier */
.fc-toolbar-title {
    font-size: 24px !important;
    color: #333 !important;
    font-weight: 600 !important;
}

/* Événements */
.fc-event {
    cursor: pointer !important;
    border-radius: 4px !important;
    padding: 2px 4px !important;
    font-size: 13px !important;
}

.fc-event:hover {
    opacity: 0.85 !important;
    transform: translateY(-1px);
    transition: all 0.2s;
}

/* En-têtes des jours */
.fc-col-header-cell {
    background: #f8f9fa !important;
    font-weight: 600 !important;
    color: #667eea !important;
}

/* Aujourd'hui */
.fc-day-today {
    background: rgba(102, 126, 234, 0.1) !important;
}

/* Modal de détails */
.event-modal {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0,0,0,0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10000;
    animation: fadeIn 0.3s;
}

@keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
}

.event-modal-content {
    background: white;
    border-radius: 16px;
    max-width: 600px;
    width: 90%;
    max-height: 80vh;
    overflow-y: auto;
    animation: slideUp 0.3s;
}

@keyframes slideUp {
    from { transform: translateY(50px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
}

.event-modal-header {
    padding: 25px;
    border-bottom: 1px solid #eee;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.event-modal-header h2 {
    margin: 0;
    color: #667eea;
    font-size: 24px;
}

.close-btn {
    background: none;
    border: none;
    font-size: 32px;
    cursor: pointer;
    color: #999;
    line-height: 1;
}

.close-btn:hover {
    color: #333;
}

.event-modal-body {
    padding: 25px;
}

.event-detail {
    margin: 15px 0;
    display: flex;
    align-items: start;
    gap: 10px;
}

.event-detail-icon {
    font-size: 20px;
    min-width: 30px;
}

.event-detail-content {
    flex: 1;
}

.event-detail-label {
    font-weight: 600;
    color: #333;
    margin-bottom: 5px;
}

.event-detail-value {
    color: #666;
}

.status-badge {
    display: inline-block;
    padding: 6px 12px;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 600;
}

.status-planifie {
    background: rgba(102, 126, 234, 0.2);
    color: #667eea;
}

.status-en-cours {
    background: rgba(67, 233, 123, 0.2);
    color: #43e97b;
}

.status-passe {
    background: rgba(127, 183, 126, 0.2);
    color: #7fb77e;
}

.status-annule {
    background: rgba(149, 165, 166, 0.2);
    color: #95a5a6;
}

.event-modal-footer {
    padding: 20px 25px;
    border-top: 1px solid #eee;
    display: flex;
    gap: 10px;
    justify-content: flex-end;
}

.btn-modal {
    padding: 10px 20px;
    border-radius: 8px;
    text-decoration: none;
    border: none;
    cursor: pointer;
    font-size: 14px;
    font-weight: 600;
    transition: all 0.2s;
}

.btn-primary-modal {
    background: linear-gradient(135deg, #667eea, #764ba2);
    color: white;
}

.btn-primary-modal:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
}

.btn-secondary-modal {
    background: #f8f9fa;
    color: #666;
}

.btn-secondary-modal:hover {
    background: #e9ecef;
}
</style>

{# JavaScript pour le calendrier #}
{% block javascripts %}
    {{ parent() }}
    
    {# Charger FullCalendar depuis CDN #}
    <link href='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.css' rel='stylesheet' />
    <script src='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.js'></script>
    <script src='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/locales/fr.global.min.js'></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var calendarEl = document.getElementById('calendar');
            
            var calendar = new FullCalendar.Calendar(calendarEl, {
                // Configuration de base
                locale: 'fr',
                initialView: 'dayGridMonth',
                headerToolbar: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'dayGridMonth,timeGridWeek,timeGridDay,listMonth'
                },
                buttonText: {
                    today: "Aujourd'hui",
                    month: 'Mois',
                    week: 'Semaine',
                    day: 'Jour',
                    list: 'Liste'
                },
                
                // Hauteur
                height: 'auto',
                
                // Premier jour = Lundi
                firstDay: 1,
                
                // Charger les événements depuis le CalendarBundle
                events: '{{ path('fc_load_events') }}',
                
                // Clic sur un événement
                eventClick: function(info) {
                    info.jsEvent.preventDefault();
                    showEventModal(info.event);
                },
                
                // Loading
                loading: function(isLoading) {
                    document.getElementById('calendar-loading').style.display = isLoading ? 'block' : 'none';
                    document.getElementById('calendar').style.display = isLoading ? 'none' : 'block';
                },
                
                // Format de l'heure
                eventTimeFormat: {
                    hour: '2-digit',
                    minute: '2-digit',
                    hour12: false
                }
            });
            
            calendar.render();
        });
        
        // Fonction pour afficher la modal de détails
        function showEventModal(event) {
            const props = event.extendedProps;
            
            // Déterminer la classe CSS du statut
            let statusClass = 'status-planifie';
            if (props.status === 'En cours') statusClass = 'status-en-cours';
            else if (props.status === 'Passé') statusClass = 'status-passe';
            else if (props.status === 'Annulé') statusClass = 'status-annule';
            
            const modal = `
                <div class="event-modal" id="event-modal" onclick="closeModalOnBackdrop(event)">
                    <div class="event-modal-content" onclick="event.stopPropagation()">
                        <div class="event-modal-header">
                            <h2>${event.title}</h2>
                            <button onclick="closeModal()" class="close-btn">×</button>
                        </div>
                        <div class="event-modal-body">
                            <div class="event-detail">
                                <div class="event-detail-icon">🏷️</div>
                                <div class="event-detail-content">
                                    <div class="event-detail-label">Type</div>
                                    <div class="event-detail-value">${props.type || 'N/A'}</div>
                                </div>
                            </div>
                            
                            <div class="event-detail">
                                <div class="event-detail-icon">📍</div>
                                <div class="event-detail-content">
                                    <div class="event-detail-label">Lieu</div>
                                    <div class="event-detail-value">${props.lieu || 'N/A'}</div>
                                </div>
                            </div>
                            
                            <div class="event-detail">
                                <div class="event-detail-icon">📅</div>
                                <div class="event-detail-content">
                                    <div class="event-detail-label">Début</div>
                                    <div class="event-detail-value">${event.start.toLocaleString('fr-FR')}</div>
                                </div>
                            </div>
                            
                            <div class="event-detail">
                                <div class="event-detail-icon">🏁</div>
                                <div class="event-detail-content">
                                    <div class="event-detail-label">Fin</div>
                                    <div class="event-detail-value">${event.end ? event.end.toLocaleString('fr-FR') : 'N/A'}</div>
                                </div>
                            </div>
                            
                            <div class="event-detail">
                                <div class="event-detail-icon">📊</div>
                                <div class="event-detail-content">
                                    <div class="event-detail-label">Statut</div>
                                    <div class="event-detail-value">
                                        <span class="status-badge ${statusClass}">${props.status || 'N/A'}</span>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="event-detail">
                                <div class="event-detail-icon">👥</div>
                                <div class="event-detail-content">
                                    <div class="event-detail-label">Participations</div>
                                    <div class="event-detail-value">${props.nbParticipations || 0} / ${props.nbMax || 0} équipes</div>
                                </div>
                            </div>
                            
                            <div class="event-detail">
                                <div class="event-detail-icon">📝</div>
                                <div class="event-detail-content">
                                    <div class="event-detail-label">Description</div>
                                    <div class="event-detail-value">${props.description || 'Aucune description'}</div>
                                </div>
                            </div>
                        </div>
                        <div class="event-modal-footer">
                            <button onclick="closeModal()" class="btn-modal btn-secondary-modal">Fermer</button>
                            ${props.url ? `<a href="${props.url}" class="btn-modal btn-primary-modal">Voir les détails</a>` : ''}
                        </div>
                    </div>
                </div>
            `;
            
            document.body.insertAdjacentHTML('beforeend', modal);
        }
        
        // Fermer la modal
        function closeModal() {
            const modal = document.getElementById('event-modal');
            if (modal) {
                modal.style.animation = 'fadeOut 0.3s';
                setTimeout(() => modal.remove(), 300);
            }
        }
        
        // Fermer en cliquant sur le fond
        function closeModalOnBackdrop(event) {
            if (event.target.id === 'event-modal') {
                closeModal();
            }
        }
        
        // Fermer avec Escape
        document.addEventListener('keydown', function(event) {
            if (event.key === 'Escape') {
                closeModal();
            }
        });
    </script>
{% endblock %}
{% endblock %}
