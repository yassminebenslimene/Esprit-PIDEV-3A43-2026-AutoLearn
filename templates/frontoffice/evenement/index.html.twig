{% extends 'frontoffice/base.html.twig' %}

{% block title %}Our Events{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .events-section {
            padding: 120px 0 80px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
        }
        
        .section-header {
            text-align: center;
            margin-bottom: 40px;
            color: white;
        }
        
        .section-header h1 {
            font-size: 48px;
            font-weight: 700;
            margin-bottom: 15px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
        }
        
        .section-intro {
            background: rgba(255,255,255,0.95);
            padding: 30px;
            border-radius: 15px;
            margin-bottom: 40px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }
        
        .section-intro p {
            color: #4a5568;
            font-size: 16px;
            line-height: 1.8;
            margin: 0;
            text-align: center;
        }
        
        .event-card {
            background: white;
            border-radius: 20px;
            margin-bottom: 30px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.15);
            overflow: hidden;
            transition: all 0.3s ease;
        }
        
        .event-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 50px rgba(0,0,0,0.2);
        }
        
        .event-header {
            display: flex;
            align-items: center;
            padding: 30px;
            cursor: pointer;
            position: relative;
        }
        
        .event-image {
            width: 120px;
            height: 120px;
            border-radius: 15px;
            object-fit: cover;
            margin-right: 25px;
        }
        
        .event-info {
            flex: 1;
        }
        
        .event-type {
            display: inline-block;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 5px 15px;
            border-radius: 15px;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            margin-bottom: 10px;
        }
        
        .event-title {
            font-size: 24px;
            font-weight: 700;
            color: #2d3748;
            margin-bottom: 10px;
        }
        
        .event-meta {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
        }
        
        .meta-item {
            display: flex;
            align-items: center;
            gap: 8px;
            color: #718096;
            font-size: 14px;
        }
        
        .meta-icon {
            width: 18px;
            height: 18px;
            color: #667eea;
        }
        
        .countdown {
            background: #fef5e7;
            border: 2px solid #f39c12;
            padding: 15px 20px;
            border-radius: 10px;
            text-align: center;
            min-width: 150px;
        }
        
        .countdown-label {
            font-size: 12px;
            color: #856404;
            font-weight: 600;
            margin-bottom: 5px;
        }
        
        .countdown-value {
            font-size: 24px;
            font-weight: 700;
            color: #f39c12;
        }
        
        .expand-arrow {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: #f7fafc;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
            margin-left: 20px;
        }
        
        .expand-arrow svg {
            width: 20px;
            height: 20px;
            color: #667eea;
            transition: transform 0.3s ease;
        }
        
        .event-card.expanded .expand-arrow svg {
            transform: rotate(180deg);
        }
        
        .event-details {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.5s ease;
        }
        
        .event-card.expanded .event-details {
            max-height: 2000px;
        }
        
        .event-details-content {
            padding: 0 30px 30px;
            border-top: 2px solid #e2e8f0;
        }
        
        .details-section {
            margin-top: 25px;
        }
        
        .details-section h4 {
            font-size: 18px;
            font-weight: 700;
            color: #667eea;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .places-info {
            background: #ebf8ff;
            border-left: 4px solid #667eea;
            padding: 20px;
            border-radius: 10px;
            margin-bottom: 20px;
        }
        
        .places-info strong {
            font-size: 24px;
            color: #667eea;
        }
        
        .teams-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 30px;
            margin-top: 15px;
        }
        
        .team-card-mini {
            background: white;
            padding: 25px;
            border-radius: 15px;
            text-align: center;
            transition: all 0.3s ease;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }
        
        .team-card-mini:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.15);
        }
        
        .team-image {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            object-fit: cover;
            margin: 0 auto 15px;
            border: 4px solid #667eea;
        }
        
        .team-name {
            font-weight: 700;
            color: #2d3748;
            font-size: 18px;
            margin-bottom: 8px;
        }
        
        .team-event-badge {
            display: inline-block;
            background: #667eea;
            color: white;
            padding: 4px 12px;
            border-radius: 12px;
            font-size: 12px;
            margin-bottom: 10px;
        }
        
        .team-members-count {
            color: #718096;
            font-size: 14px;
        }
        
        .participate-btn {
            display: inline-block;
            background: linear-gradient(135deg, #48bb78 0%, #38a169 100%);
            color: white;
            padding: 15px 40px;
            border-radius: 12px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.3s ease;
            margin-top: 20px;
            box-shadow: 0 5px 15px rgba(72, 187, 120, 0.3);
        }
        
        .participate-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(72, 187, 120, 0.4);
            color: white;
        }
        
        .empty-teams {
            text-align: center;
            padding: 40px;
            color: #718096;
        }
        
        @keyframes pulse {
            0%, 100% {
                opacity: 1;
                transform: scale(1);
            }
            50% {
                opacity: 0.8;
                transform: scale(1.05);
            }
        }
    </style>
{% endblock %}

{% block body %}
<div class="events-section">
    <div class="container">
        <div class="section-header">
            <h1>Our Events</h1>
            <div style="margin-top: 20px;">
                <a href="{{ path('app_events_calendar') }}" style="display: inline-block; background: rgba(255,255,255,0.95); color: #667eea; padding: 12px 30px; border-radius: 12px; text-decoration: none; font-weight: 600; box-shadow: 0 5px 15px rgba(0,0,0,0.2); transition: all 0.3s ease;">
                    📅 View Calendar
                </a>
            </div>
        </div>

        <div class="section-intro">
            <p>
                <strong>🎯 Enhance Your Skills Through Practical Experience</strong><br>
                Our events are designed to help students develop essential technical and soft skills through hands-on projects. 
                Participate in hackathons and workshops to strengthen your teamwork, communication, and networking abilities 
                while applying what you've learned in real-world scenarios. Join us to grow professionally and connect with peers!
            </p>
        </div>

        {% if evenementsData is empty %}
            <div style="text-align: center; padding: 80px; background: white; border-radius: 20px;">
                <h3 style="color: #2d3748;">No events available at the moment</h3>
                <p style="color: #718096;">Check back soon for upcoming events!</p>
            </div>
        {% else %}
            {% for data in evenementsData %}
                {% set evenement = data.evenement %}
                {% set now = date() %}
                {% set diff = date(evenement.dateDebut).diff(now) %}
                {% set daysLeft = diff.days %}
                
                <div class="event-card" id="event-{{ evenement.id }}" {% if evenement.isCanceled %}style="opacity: 0.85; border: 3px solid #e53e3e;"{% endif %}>
                    <div class="event-header" onclick="toggleEvent({{ evenement.id }})">
                        <img src="{{ asset('frontoffice/images/event-0' ~ ((loop.index0 % 3) + 1) ~ '.jpg') }}" alt="{{ evenement.titre }}" class="event-image" {% if evenement.isCanceled %}style="filter: grayscale(50%);"{% endif %}>
                        
                        <div class="event-info">
                            <div style="display: flex; align-items: center; gap: 10px; flex-wrap: wrap;">
                                <span class="event-type">{{ evenement.type.value }}</span>
                                {% if evenement.isCanceled %}
                                    <span style="background: linear-gradient(135deg, #e53e3e 0%, #c53030 100%); color: white; padding: 5px 15px; border-radius: 15px; font-size: 12px; font-weight: 700; text-transform: uppercase; animation: pulse 2s infinite;">
                                        ❌ CANCELLED
                                    </span>
                                {% endif %}
                            </div>
                            <h3 class="event-title" {% if evenement.isCanceled %}style="text-decoration: line-through; color: #718096;"{% endif %}>{{ evenement.titre }}</h3>
                            
                            <div class="event-meta">
                                <div class="meta-item">
                                    <svg class="meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                    </svg>
                                    {{ evenement.dateDebut|date('d M Y') }}
                                </div>
                                <div class="meta-item">
                                    <svg class="meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                    </svg>
                                    {{ evenement.dateDebut|date('H:i') }}
                                </div>
                                <div class="meta-item">
                                    <svg class="meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                                    </svg>
                                    {{ evenement.lieu }}
                                </div>
                                <div class="meta-item">
                                    <svg class="meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                                    </svg>
                                    {{ data.placesOccupees }} / {{ evenement.nbMax }} teams
                                </div>
                            </div>
                        </div>
                        
                        {% if daysLeft >= 0 %}
                            <div class="countdown">
                                <div class="countdown-label">TIME LEFT</div>
                                <div class="countdown-value">{{ daysLeft }} days</div>
                            </div>
                        {% endif %}
                        
                        <div class="expand-arrow">
                            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                            </svg>
                        </div>
                    </div>
                    
                    <div class="event-details">
                        <div class="event-details-content">
                            <div class="details-section">
                                <h4>
                                    <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                    </svg>
                                    About This Event
                                </h4>
                                <p style="color: #4a5568; line-height: 1.6;">{{ evenement.description }}</p>
                            </div>
                            
                            {# Weather Forecast Section #}
                            {% if data.weather is not null %}
                                <div class="details-section">
                                    <h4>
                                        <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/>
                                        </svg>
                                        Weather {% if data.weather.is_forecast is defined and data.weather.is_forecast %}Forecast{% else %}Information{% endif %}
                                    </h4>
                                    
                                    {% if data.weather.available is defined and data.weather.available %}
                                        <div style="background: linear-gradient(135deg, #e0f2fe 0%, #bae6fd 100%); border-radius: 15px; padding: 25px; border-left: 5px solid #0ea5e9;">
                                            {% if data.weather.is_forecast is defined and not data.weather.is_forecast %}
                                                <div style="background: rgba(251, 191, 36, 0.2); border-radius: 10px; padding: 10px; margin-bottom: 15px; text-align: center;">
                                                    <small style="color: #92400e; font-weight: 600;">
                                                        ℹ️ Current weather in Tunis (event is too far for accurate forecast)
                                                    </small>
                                                </div>
                                            {% else %}
                                                <div style="background: rgba(34, 197, 94, 0.2); border-radius: 10px; padding: 10px; margin-bottom: 15px; text-align: center;">
                                                    <small style="color: #166534; font-weight: 600;">
                                                        📍 Weather forecast for event day in Tunis, Tunisia
                                                    </small>
                                                </div>
                                            {% endif %}
                                            
                                            <div style="display: flex; align-items: center; gap: 20px; flex-wrap: wrap;">
                                                <div style="font-size: 64px;">
                                                    {{ weatherService.getWeatherEmoji(data.weather.icon) }}
                                                </div>
                                                <div style="flex: 1;">
                                                    <div style="font-size: 36px; font-weight: 700; color: #0c4a6e; margin-bottom: 5px;">
                                                        {{ data.weather.temperature }}°C
                                                    </div>
                                                    <div style="font-size: 18px; color: #075985; font-weight: 600; margin-bottom: 10px;">
                                                        {{ data.weather.description }}
                                                    </div>
                                                    <div style="display: flex; gap: 20px; flex-wrap: wrap; font-size: 14px; color: #0c4a6e;">
                                                        <span>🌡️ Feels like: {{ data.weather.feels_like }}°C</span>
                                                        <span>💨 Wind: {{ data.weather.wind_speed }} km/h</span>
                                                        <span>💧 Humidity: {{ data.weather.humidity }}%</span>
                                                    </div>
                                                </div>
                                            </div>
                                            
                                            {# Personalized message based on weather #}
                                            <div style="margin-top: 20px; padding: 15px; background: rgba(255,255,255,0.7); border-radius: 10px;">
                                                {% if data.weather.is_forecast is defined and not data.weather.is_forecast %}
                                                    <p style="margin: 0; color: #0c4a6e; font-weight: 600;">
                                                        ℹ️ This shows today's weather as reference. Actual forecast will be available 5 days before the event.
                                                    </p>
                                                {% elseif data.weather.temperature > 25 %}
                                                    <p style="margin: 0; color: #0c4a6e; font-weight: 600;">
                                                        ☀️ It will be hot! Remember to bring water and wear light clothing.
                                                    </p>
                                                {% elseif data.weather.temperature < 10 %}
                                                    <p style="margin: 0; color: #0c4a6e; font-weight: 600;">
                                                        🧥 It will be cold! Dress warmly for the event.
                                                    </p>
                                                {% elseif 'rain' in data.weather.description|lower %}
                                                    <p style="margin: 0; color: #0c4a6e; font-weight: 600;">
                                                        🌧️ Rain expected! Don't forget your umbrella.
                                                    </p>
                                                {% else %}
                                                    <p style="margin: 0; color: #0c4a6e; font-weight: 600;">
                                                        🌤️ Perfect weather for the event! See you there!
                                                    </p>
                                                {% endif %}
                                            </div>
                                        </div>
                                    {% elseif data.weather.error is defined and data.weather.error %}
                                        <div style="background: #fee2e2; border-radius: 10px; padding: 20px; border-left: 5px solid #ef4444;">
                                            <p style="margin: 0; color: #991b1b; font-weight: 600;">
                                                ⚠️ {{ data.weather.message }}
                                            </p>
                                        </div>
                                    {% else %}
                                        <div style="background: #fef3c7; border-radius: 10px; padding: 20px; border-left: 5px solid #f59e0b;">
                                            <p style="margin: 0; color: #92400e; font-weight: 600;">
                                                ℹ️ Weather information not available for this location
                                            </p>
                                        </div>
                                    {% endif %}
                                </div>
                            {% endif %}
                            
                            <div class="details-section">
                                <h4>
                                    <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                    </svg>
                                    Available Spots
                                </h4>
                                <div class="places-info">
                                    <strong>{{ data.placesDisponibles }}</strong> spots remaining out of {{ evenement.nbMax }} total
                                </div>
                            </div>
                            
                            <div class="details-section">
                                <h4>
                                    <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                                    </svg>
                                    Participating Teams ({{ data.equipes|length }})
                                </h4>
                                
                                {% if data.equipes is empty %}
                                    <div class="empty-teams">
                                        <p>No teams registered yet. Be the first to participate!</p>
                                    </div>
                                {% else %}
                                    <div class="teams-grid">
                                        {% for equipe in data.equipes %}
                                            <div class="team-card-mini">
                                                <img src="{{ asset('frontoffice/images/member-0' ~ ((loop.index0 % 4) + 1) ~ '.jpg') }}" alt="{{ equipe.nom }}" class="team-image">
                                                <span class="team-event-badge">{{ evenement.type.value }}</span>
                                                <div class="team-name">{{ equipe.nom }}</div>
                                                <div class="team-members-count">
                                                    👥 {{ equipe.etudiants|length }} members
                                                </div>
                                            </div>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            </div>
                            
                            {% if evenement.isCanceled %}
                                <div style="text-align: center; padding: 30px; background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%); border-radius: 15px; border: 2px solid #e53e3e;">
                                    <div style="font-size: 48px; margin-bottom: 15px;">❌</div>
                                    <h3 style="color: #991b1b; margin-bottom: 10px; font-size: 24px;">Event Cancelled</h3>
                                    <p style="color: #7f1d1d; margin: 0; font-size: 16px;">
                                        This event has been cancelled. No registrations are accepted.
                                    </p>
                                </div>
                            {% elseif evenement.workflowStatus == 'termine' or evenement.status.value == 'Passé' %}
                                <div style="text-align: center; padding: 30px; background: linear-gradient(135deg, #e2e8f0 0%, #cbd5e0 100%); border-radius: 15px; border: 2px solid #718096;">
                                    <div style="font-size: 48px; margin-bottom: 15px;">🏁</div>
                                    <h3 style="color: #2d3748; margin-bottom: 10px; font-size: 24px;">Event Completed</h3>
                                    <p style="color: #4a5568; margin: 0; font-size: 16px;">
                                        This event has ended. Registrations are now closed.
                                    </p>
                                </div>
                            {% elseif data.placesDisponibles > 0 and (evenement.workflowStatus == 'planifie' or evenement.workflowStatus == 'en_cours') %}
                                <div style="text-align: center;">
                                    {% if evenement.workflowStatus == 'en_cours' %}
                                        <div style="background: #fef3c7; padding: 15px; border-radius: 10px; margin-bottom: 15px; border: 2px solid #f59e0b;">
                                            <p style="margin: 0; color: #92400e; font-weight: 600;">
                                                ⏰ Event in progress! You can still join now.
                                            </p>
                                        </div>
                                    {% endif %}
                                    <a href="{{ path('app_event_participate', {'id': evenement.id}) }}" class="participate-btn">
                                        🎯 Participate in This Event
                                    </a>
                                </div>
                            {% else %}
                                <div style="text-align: center; padding: 20px;">
                                    <p style="color: #e53e3e; font-weight: 600;">❌ Event is full - No spots available</p>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% endfor %}
        {% endif %}
    </div>
</div>

<script>
function toggleEvent(id) {
    const card = document.getElementById('event-' + id);
    card.classList.toggle('expanded');
}
</script>
{% endblock %}
