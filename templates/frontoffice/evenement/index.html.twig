{% extends 'frontoffice/base.html.twig' %}

{% block title %}Our Events{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .events-section {
            padding: 120px 0 80px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
        }
        
        .section-header {
            text-align: center;
            margin-bottom: 40px;
            color: white;
        }
        
        .section-header h1 {
            font-size: 48px;
            font-weight: 700;
            margin-bottom: 15px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
        }
        
        .section-intro {
            background: rgba(255,255,255,0.95);
            padding: 30px;
            border-radius: 15px;
            margin-bottom: 40px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }
        
        .section-intro p {
            color: #4a5568;
            font-size: 16px;
            line-height: 1.8;
            margin: 0;
            text-align: center;
        }
        
        .event-card {
            background: white;
            border-radius: 20px;
            margin-bottom: 30px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.15);
            overflow: hidden;
            transition: all 0.3s ease;
        }
        
        .event-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 50px rgba(0,0,0,0.2);
        }
        
        .event-header {
            display: flex;
            align-items: center;
            padding: 30px;
            cursor: pointer;
            position: relative;
        }
        
        .event-image {
            width: 120px;
            height: 120px;
            border-radius: 15px;
            object-fit: cover;
            margin-right: 25px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }
        
        .event-info {
            flex: 1;
        }
        
        .event-type {
            display: inline-block;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 5px 15px;
            border-radius: 15px;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            margin-bottom: 10px;
        }
        
        .event-title {
            font-size: 24px;
            font-weight: 700;
            color: #2d3748;
            margin-bottom: 10px;
        }
        
        .event-meta {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
        }
        
        .meta-item {
            display: flex;
            align-items: center;
            gap: 8px;
            color: #718096;
            font-size: 14px;
        }
        
        .meta-icon {
            width: 18px;
            height: 18px;
            color: #667eea;
        }
        
        .countdown {
            background: #fef5e7;
            border: 2px solid #f39c12;
            padding: 15px 20px;
            border-radius: 10px;
            text-align: center;
            min-width: 150px;
        }
        
        .countdown-label {
            font-size: 12px;
            color: #856404;
            font-weight: 600;
            margin-bottom: 5px;
        }
        
        .countdown-value {
            font-size: 24px;
            font-weight: 700;
            color: #f39c12;
        }
        
        .expand-arrow {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: #f7fafc;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
            margin-left: 20px;
        }
        
        .expand-arrow svg {
            width: 20px;
            height: 20px;
            color: #667eea;
            transition: transform 0.3s ease;
        }
        
        .event-card.expanded .expand-arrow svg {
            transform: rotate(180deg);
        }
        
        .event-details {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.5s ease;
        }
        
        .event-card.expanded .event-details {
            max-height: 2000px;
        }
        
        .event-details-content {
            padding: 0 30px 30px;
            border-top: 2px solid #e2e8f0;
        }
        
        .details-section {
            margin-top: 25px;
        }
        
        .details-section h4 {
            font-size: 18px;
            font-weight: 700;
            color: #667eea;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .places-info {
            background: #ebf8ff;
            border-left: 4px solid #667eea;
            padding: 20px;
            border-radius: 10px;
            margin-bottom: 20px;
        }
        
        .places-info strong {
            font-size: 24px;
            color: #667eea;
        }
        
        .teams-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 20px;
            margin-top: 15px;
        }
        
        .team-card-mini {
            background: #f7fafc;
            padding: 20px;
            border-radius: 12px;
            border-left: 4px solid #667eea;
            transition: all 0.3s ease;
        }
        
        .team-card-mini:hover {
            background: #edf2f7;
            transform: translateX(5px);
        }
        
        .team-name {
            font-weight: 700;
            color: #2d3748;
            font-size: 16px;
            margin-bottom: 8px;
        }
        
        .team-members-count {
            color: #718096;
            font-size: 14px;
        }
        
        .participate-btn {
            display: inline-block;
            background: linear-gradient(135deg, #48bb78 0%, #38a169 100%);
            color: white;
            padding: 15px 40px;
            border-radius: 12px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.3s ease;
            margin-top: 20px;
            box-shadow: 0 5px 15px rgba(72, 187, 120, 0.3);
        }
        
        .participate-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(72, 187, 120, 0.4);
            color: white;
        }
        
        .empty-teams {
            text-align: center;
            padding: 40px;
            color: #718096;
        }
    </style>
{% endblock %}

{% block body %}
<div class="events-section">
    <div class="container">
        <div class="section-header">
            <h1>Our Events</h1>
        </div>

        <div class="section-intro">
            <p>
                <strong>🎯 Enhance Your Skills Through Practical Experience</strong><br>
                Our events are designed to help students develop essential technical and soft skills through hands-on projects. 
                Participate in hackathons and workshops to strengthen your teamwork, communication, and networking abilities 
                while applying what you've learned in real-world scenarios. Join us to grow professionally and connect with peers!
            </p>
        </div>

        {% if evenementsData is empty %}
            <div style="text-align: center; padding: 80px; background: white; border-radius: 20px;">
                <h3 style="color: #2d3748;">No events available at the moment</h3>
                <p style="color: #718096;">Check back soon for upcoming events!</p>
            </div>
        {% else %}
            {% for data in evenementsData %}
                {% set evenement = data.evenement %}
                {% set now = date() %}
                {% set diff = date(evenement.dateDebut).diff(now) %}
                {% set daysLeft = diff.days %}
                
                <div class="event-card" id="event-{{ evenement.id }}">
                    <div class="event-header" onclick="toggleEvent({{ evenement.id }})">
                        <div class="event-image"></div>
                        
                        <div class="event-info">
                            <span class="event-type">{{ evenement.type.value }}</span>
                            <h3 class="event-title">{{ evenement.titre }}</h3>
                            
                            <div class="event-meta">
                                <div class="meta-item">
                                    <svg class="meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                    </svg>
                                    {{ evenement.dateDebut|date('d M Y') }}
                                </div>
                                <div class="meta-item">
                                    <svg class="meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                    </svg>
                                    {{ evenement.dateDebut|date('H:i') }}
                                </div>
                                <div class="meta-item">
                                    <svg class="meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                                    </svg>
                                    {{ evenement.lieu }}
                                </div>
                                <div class="meta-item">
                                    <svg class="meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                                    </svg>
                                    {{ data.placesOccupees }} / {{ evenement.nbMax }} teams
                                </div>
                            </div>
                        </div>
                        
                        {% if daysLeft >= 0 %}
                            <div class="countdown">
                                <div class="countdown-label">TIME LEFT</div>
                                <div class="countdown-value">{{ daysLeft }} days</div>
                            </div>
                        {% endif %}
                        
                        <div class="expand-arrow">
                            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                            </svg>
                        </div>
                    </div>
                    
                    <div class="event-details">
                        <div class="event-details-content">
                            <div class="details-section">
                                <h4>
                                    <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                    </svg>
                                    About This Event
                                </h4>
                                <p style="color: #4a5568; line-height: 1.6;">{{ evenement.description }}</p>
                            </div>
                            
                            <div class="details-section">
                                <h4>
                                    <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                    </svg>
                                    Available Spots
                                </h4>
                                <div class="places-info">
                                    <strong>{{ data.placesDisponibles }}</strong> spots remaining out of {{ evenement.nbMax }} total
                                </div>
                            </div>
                            
                            <div class="details-section">
                                <h4>
                                    <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                                    </svg>
                                    Participating Teams ({{ data.equipes|length }})
                                </h4>
                                
                                {% if data.equipes is empty %}
                                    <div class="empty-teams">
                                        <p>No teams registered yet. Be the first to participate!</p>
                                    </div>
                                {% else %}
                                    <div class="teams-grid">
                                        {% for equipe in data.equipes %}
                                            <div class="team-card-mini">
                                                <div class="team-name">{{ equipe.nom }}</div>
                                                <div class="team-members-count">
                                                    👥 {{ equipe.etudiants|length }} members
                                                </div>
                                            </div>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            </div>
                            
                            {% if data.placesDisponibles > 0 %}
                                <div style="text-align: center;">
                                    <a href="{{ path('app_event_participate', {'id': evenement.id}) }}" class="participate-btn">
                                        🎯 Participate in This Event
                                    </a>
                                </div>
                            {% else %}
                                <div style="text-align: center; padding: 20px;">
                                    <p style="color: #e53e3e; font-weight: 600;">❌ Event is full - No spots available</p>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% endfor %}
        {% endif %}
    </div>
</div>

<script>
function toggleEvent(id) {
    const card = document.getElementById('event-' + id);
    card.classList.toggle('expanded');
}
</script>
{% endblock %}
